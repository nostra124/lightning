#!/bin/bash

############################################################################
# Configuration section
############################################################################

# This should always be the first line of code to facilitate debugging.
[ -n "$SELF_DEBUG" ] && set -vx

# Per FEAT-194: VERSION read at runtime from .rpk/version (dev tree)
# or $PREFIX/share/lightning/version (installed). The hardcoded fallback
# is used only if both files are missing.
__d="$(cd "$(dirname "$0")" && pwd)"; __s="$(basename "$0")"
# FEAT-170: when invoked as `lightning.sh` (symlink), present as `lightning`.
__s="${__s%.sh}"
VERSION=$(cat "$__d/../.rpk/version" 2>/dev/null || cat "$__d/../share/$__s/version" 2>/dev/null || echo '0.2.0')
unset __d
SELF=$__s
unset __s

# Resolve $SELF_LIBEXEC (FEAT-001 libexec convention).
if [ -z "$SELF_LIBEXEC" ]; then
	for _d in \
		"$(cd "$(dirname "$0")/../libexec" 2>/dev/null && pwd)" \
		"$HOME/.local/libexec" \
		"/usr/local/libexec" \
		"/usr/libexec"; do
		[ -d "$_d/$SELF" ] && SELF_LIBEXEC="$_d" && break
	done
	unset _d
fi

die() {
	echo "$1" >&2
	exit "${2:-1}"
}

fatal() {
	echo "$SELF: fatal - $1" >&2
	exit "${2:-1}"
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $@" >&2
}

info() {
	if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$@\033[0m" >&2; fi
}

warn() {
	echo -e "$SELF: warn - \033[31;1;m$@\033[0m" >&2
}

# Checks if a certain function exists.
has() {
	local KIND=$1
	local NAME=$2
	type -t $KIND:$NAME | grep -q function
}

############################################################################
# Commands
############################################################################

command:help() {
	cat >&2 <<ENDHELP
usage: $SELF <options> <command> <args>

   options:
   -d                       enable debug mode
   -q                       enable quiet mode

   $SELF is the educational Lightning Network frontend on
   clightning (Core Lightning). Verbs shell out to
   lightning-cli; help text cites the BOLT each verb
   implements.

   Vendored standards: BOLT specs (BOLT 1..12) plus LNURL LUDs
   and the Lightning Address spec, under share/doc/lightning/
   standards/ (FEAT-178; pending full implementation).

   The four design principles (educational, functional,
   decentralized, simple) apply: each verb is a thin
   wrapper over lightning-cli that cites the BOLT it
   implements.

generic commands:
   help                     print this help message
   version                  print the version of $SELF

clightning node:
   info                     summary of \`lightning-cli getinfo\`
   node-id                  this node's pubkey
   peers                    connected peers (TSV)
   channels                 channels (TSV)
   balance                  on-chain + LN balance (TSV)

daemon control:
   daemon start             start lightningd
   daemon stop              graceful shutdown
   daemon restart           stop + start
   daemon status            health check
   daemon logs              tail the daemon log
   daemon install [--system] generate a systemd unit

wallet unlock:
   unlock                   release the HSM (interactive)
   unlock --stored          non-interactive (from \`secret\`)
   unlock rotate            change password
   unlock forget            drop the stored secret

environment:
   LIGHTNING_DIR            path to lightningd's data dir
                            (default: \$HOME/.lightning)
   LIGHTNING_NETWORK        bitcoin / testnet / regtest / signet
                            (default: bitcoin)

(Verb surface beyond the above lands per FEAT-172..196 —
see issues/ for the milestone plan.)
ENDHELP
}

command:version() {
	echo "$VERSION"
}

############################################################################
# Command-line processing
############################################################################

# FEAT-170: source-mode guard. When sourced (via `. lightning.sh`),
# define functions but do not execute the dispatcher.
[[ "${BASH_SOURCE[0]}" != "$0" ]] && return 0

while getopts "dq" flag; do
	if [ x"$1" = x'-q' ]; then SELF_QUIET=1; fi
	if [ x"$1" = x'-d' ]; then SELF_DEBUG=1; fi
	shift 1
done

if [[ $# == 0 ]]; then
	command:help
	exit
fi

if has command $1; then
	debug "executing command:$1 ${@:2}"
	command:$1 "${@:2}"
	exit $?
elif test -x "$SELF_LIBEXEC/$SELF/$1"; then
	exec "$SELF_LIBEXEC/$SELF/$1" "${@:2}"
fi

fatal "unknown command $1 ${@:2}" 1
