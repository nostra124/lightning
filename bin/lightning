#!/bin/bash

############################################################################
# Configuration section
############################################################################

# This should always be the first line of code to facilitate debugging.
[ -n "$SELF_DEBUG" ] && set -vx

# Per FEAT-194: VERSION read at runtime from .rpk/version (dev tree)
# or $PREFIX/share/lightning/version (installed). The hardcoded fallback
# is used only if both files are missing.
__d="$(cd "$(dirname "$0")" && pwd)"; __s="$(basename "$0")"
# FEAT-170: when invoked as `lightning.sh` (symlink), present as `lightning`.
__s="${__s%.sh}"
VERSION=$(cat "$__d/../.rpk/version" 2>/dev/null || cat "$__d/../share/$__s/version" 2>/dev/null || echo '1.3.0')
unset __d
SELF=$__s
export SELF
unset __s

# Resolve $SELF_LIBEXEC (FEAT-001 libexec convention).
if [ -z "$SELF_LIBEXEC" ]; then
	for _d in \
		"$(cd "$(dirname "$0")/../libexec" 2>/dev/null && pwd)" \
		"$HOME/.local/libexec" \
		"/usr/local/libexec" \
		"/usr/libexec"; do
		[ -d "$_d/$SELF" ] && SELF_LIBEXEC="$_d" && break
	done
	unset _d
fi
# Export so sub-verbs can chain into sibling verbs (e.g. `channel list`
# delegating to `channels`, `invoice --qr` reaching `qr`).
export SELF_LIBEXEC

# Logging — rpk convention: "$SELF - <level>: <msg>" with ANSI colors.
# Levels (see also rpk's skills/logging.md):
#   fatal  red    — unrecoverable, exits 1
#   error  red    — recoverable failure, doesn't exit
#   warn   yellow — degraded but continuing (honours -q unless -v)
#   info   green  — normal outcomes (honours -q unless -v)
#   debug  grey   — internal diagnostics (only under -d or -v)
fatal() {
	# Always exits 1 (rpk convention). For other exit codes, use
	# `error "..."; exit N` — keeps fatal's signature unambiguous.
	echo -e "$SELF - fatal: \033[31;m$*\033[0m" >&2
	exit 1
}

error() {
	echo -e "$SELF - error: \033[31;m$*\033[0m" >&2
}

debug() {
	# Activates under both -d (which also flips bash xtrace) and -v.
	if [ -n "$SELF_DEBUG" ] || [ -n "$SELF_VERBOSE" ]; then
		echo -e "$SELF - debug: \033[90;m$*\033[0m" >&2
	fi
}

info() {
	# -q suppresses, -v overrides -q.
	if [ -n "$SELF_VERBOSE" ] || [ -z "$SELF_QUIET" ]; then
		echo -e "$SELF - info:  \033[32;m$*\033[0m" >&2
	fi
}

warn() {
	if [ -n "$SELF_VERBOSE" ] || [ -z "$SELF_QUIET" ]; then
		echo -e "$SELF - warn:  \033[33;1;m$*\033[0m" >&2
	fi
}

# Kept for back-compat with old call sites — equivalent to bare echo+exit.
die() {
	echo "$1" >&2
	exit "${2:-1}"
}

fatal() {
	echo "$SELF: fatal - $1" >&2
	exit "${2:-1}"
}

# Checks if a certain function exists.
has() {
	local KIND=$1
	local NAME=$2
	type -t $KIND:$NAME | grep -q function
}

# Export the helpers so libexec verbs inherit them across exec. Bash
# encodes exported functions via BASH_FUNC_* env entries; the child
# shell re-evaluates them on startup. Means each libexec script can
# call info/warn/fatal/etc. without sourcing this file.
export -f fatal error debug info warn die has

############################################################################
# Commands
############################################################################

# shellcheck disable=SC2120  # callers may pass a verb name; the no-arg form prints global help.
command:help() {
	# `lightning help <verb>` routes to help:<verb> (rpk convention).
	if [[ $# -gt 0 ]]; then
		local verb=$1
		if has command "$verb"; then
			if has help "$verb"; then
				help:$verb
			else
				echo "No help found for '$verb' — try '$SELF $verb --help'." >&2
				return 3
			fi
		elif [ -x "$SELF_LIBEXEC/$SELF/$verb" ]; then
			# Delegate to the object dispatcher's own --help.
			exec "$SELF_LIBEXEC/$SELF/$verb" --help
		else
			echo "'$verb' is not a $SELF command. Run '$SELF help'." >&2
			return 2
		fi
		return 0
	fi

	cat >&2 <<ENDHELP
usage: $SELF <options> <command> [<args>]

   options:
   -d                      debug mode — bash xtrace + everything -v shows
   -v                      verbose mode — show debug lines, override -q for warn/info
   -q                      quiet mode — suppress info and warn (errors still print)
   -f                      force mode — overwrite / bypass safety checks

   $SELF is the educational Lightning Network frontend on
   clightning (Core Lightning). Each command is an object —
   run \`$SELF <command>\` for its sub-commands, or
   \`$SELF help <command>\` for a richer description. The four
   design principles (educational, functional, decentralized,
   simple) apply: each verb is a thin wrapper over
   lightning-cli that cites the BOLT it implements.

   Vendored standards (BOLT 1..12, LNURL LUDs, Lightning
   Address) live under share/doc/lightning/standards/.

generic:
   help [<command>]        print this help (or help for <command>)
   version                 print the version of $SELF

objects:
   wallet                  your Lightning identity (info, balance, seed,
                           unlock, push/pull, backup/restore)
   peer                    network peering (list, connect, bootstrap)
   account                 logical accounts and api keys
   channel                 Lightning channels (open, close, balance, scb)
   fee                     per-channel fees (get, set, policy)
   fee-policy              operator-fee revenue + rates (FEAT-213/214)
   alert                   threshold-driven webhooks (create, list, run)
   daemon                  lightningd lifecycle (start, stop, logs, install)
   plugin                  CLN plugins via reckless (list, install, remove)
   invoice                 BOLT-11 invoices (create, pay)
   offer                   BOLT-12 offers (create, pay)
   address                 Lightning Addresses (resolve, pay, create)
   lnurl                   LNURL (decode, pay; LSPS1)
   liquidity               inbound / outbound (totals, loop, boltz, lsp)
   ledger                  derived ledger (list, sum, balance, export)

clightning node (0.2.0):
   info                     summary of \`lightning-cli getinfo\`
   node-id                  this node's pubkey
   peers                    connected peers (TSV)
   channels                 channels (TSV)
   balance                  on-chain + LN balance (recfile)

channels (0.3.0 — BOLT-2 / BOLT-5):
   channel list             TSV of all channels
   channel open <uri> <sats> open a channel
   channel close <id>       cooperative close
   channel force-close <id> --confirm   unilateral close
   channel balance [<id>]   local / remote msat
   channel info <id>
   channel pending          opening / closing channels

payments (0.3.0 — BOLT-11 / BOLT-12 / LNURL):
   invoice <sat> <label>    mint a BOLT-11; --qr renders one
   pay <bolt11>             pay a BOLT-11 invoice
   send <node-id> <sat>     keysend (BOLT-4 TLV)
   offer <sat>|any <desc>   create a BOLT-12 offer
   offer-pay <bolt12>       fetch + pay a BOLT-12 offer
   lnurl decode <lnurl>
   lnurl pay <addr> <sat>   LNURL-pay (LUD-06 + LUD-12)
   decode <string>          detect + decode any of the above

qr codes (0.3.0):
   qr <text>                ANSI / PNG / SVG; honours \`--png\` / \`--svg\`

wallet & accounts (0.4.0 — git-backed SQLite store):
   wallet new <name>        initialise a wallet repo
   wallet use <name>        set active wallet
   wallet list              list wallets
   wallet push/pull/sync    git round-trip + state.db rebuild
   account list             accounts in the active wallet
   account create <name>    --limit <sat> --overdraft <policy>
   account show <name>      balance + recent ledger
   ledger list              TSV rows from the ledger
   ledger sum --by month    aggregate
   ledger annotate <hash> <note>
   history                  alias for \`ledger list\`

seed & backups (0.4.0):
   seed export              print mnemonic (read once)
   seed import              initialise hsm_secret from mnemonic
   scb emit                 write a Static Channel Backup
   scb restore <file>       force-close recovery
   backup [--seed]          SCB + state.sql + git push
   restore <url> [<name>]   clone wallet + seed import + scb restore

ecosystem (0.5.0 — addresses, liquidity, bank mode):
   address create <addr>    register a LUD-16 endpoint
                            (Apache + Python CGI)
   address pay <addr> <sat> [--comment <text>]
   address resolve <addr>
   address list / remove
   liquidity status         per-channel inbound/outbound (TSV)
   liquidity in <sat>       LSPS1 channel purchase (default)
   liquidity out <sat>      Loop / Boltz outbound
   account create <n> --host <domain>
                            auto-issues <n>@<domain>
   account apikey create <n> --scope read|write
                            issue a key for the well-known API
   ledger statement --account <n> --period <YYYY-MM|YYYY-Q1..Q4|YYYY>

daemon control (0.2.0):
   daemon start             start lightningd
   daemon stop              graceful shutdown
   daemon restart           stop + start
   daemon status            health check
   daemon logs              tail the daemon log
   daemon install [--system] generate a systemd unit

wallet unlock (0.2.0):
   unlock                   release the HSM (interactive)
   unlock --stored          non-interactive (from \`secret\`)
   unlock rotate            change password
   unlock forget            drop the stored secret

tor (0.6.0):
   tor on                   enable v3 hidden service
   tor off                  disable
   tor status               tor running? onion advertised? leak?

routing node (1.1.0):
   tower client-add <pk@host:port>   register a watchtower
   tower client-list / -stats        sessions / backups
   tower server-on / -off / -status  run a watchtower
   fee get [<channel-id>]            base + ppm per channel
   fee set <channel-id> <base> <ppm>
   fee policy <name>                 flat | lsp-style | match-peer
   forward list [--since D] [--status S]
   forward stats                     totals + success rate

environment:
   LIGHTNING_DIR           path to lightningd's data dir
                           (default: \$HOME/.lightning)
   LIGHTNING_NETWORK       bitcoin / testnet / regtest / signet
                           (default: bitcoin)
ENDHELP
}

help:help() {
	cat >&2 <<ENDHELP
usage: $SELF help [<command>]

Print the top-level help, or, when <command> is given, print the
detailed help for that command. For object dispatchers this is
equivalent to '$SELF <command> --help'.
ENDHELP
}

command:version() {
	echo "$VERSION"
}

help:version() {
	cat >&2 <<ENDHELP
usage: $SELF version

Print the $SELF version string. Source of truth: .rpk/version
in the dev tree, or share/$SELF/version in an installed bundle.
ENDHELP
}

############################################################################
# Command-line processing
############################################################################

# FEAT-170: source-mode guard. When sourced (via `. lightning.sh`),
# define functions but do not execute the dispatcher.
[[ "${BASH_SOURCE[0]}" != "$0" ]] && return 0

while getopts "dqvf" _flag; do
	case "$_flag" in
		d) SELF_DEBUG=1; SELF_VERBOSE=1 ;;
		q) SELF_QUIET=1 ;;
		v) SELF_VERBOSE=1 ;;
		f) SELF_FORCE=1 ;;
		*) command:help; exit 1 ;;
	esac
done
export SELF_DEBUG SELF_VERBOSE SELF_QUIET SELF_FORCE
shift $((OPTIND - 1))
unset _flag

if [[ $# == 0 ]]; then
	command:help
	exit
fi

if has command "$1"; then
	debug "executing command:$1 ${*:2}"
	command:"$1" "${@:2}"
	exit $?
elif test -x "$SELF_LIBEXEC/$SELF/$1"; then
	verb=$1; shift
	debug "executing libexec/$SELF/$verb $*"
	exec "$SELF_LIBEXEC/$SELF/$verb" "$@"
fi

fatal "unknown command $1 ${*:2}" 1
