#!/bin/bash
# lightning wallet-balance-sat   (FEAT-1768)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
total_msat = sum(o.get('amount_msat', 0) for o in outputs if o.get('status') == 'confirmed')
print(json.dumps({'balance_sat': total_msat // 1000, 'balance_msat': total_msat}))
" "$result"
