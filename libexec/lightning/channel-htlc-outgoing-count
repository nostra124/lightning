#!/bin/bash
# lightning channel-htlc-outgoing-count   (FEAT-2302)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
count = 0
for ch in channels:
    for h in ch.get('htlcs', []):
        if h.get('direction') == 'out':
            count += 1
print(json.dumps({'outgoing_htlc_count': count}))
" "$result"
