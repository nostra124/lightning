#!/bin/bash
# lightning node-routing-fee-earned   (FEAT-599)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
settled = [f for f in fwds if f.get('status') == 'settled']
fee_msat = sum(f.get('fee_msat', 0) for f in settled)
print(json.dumps({'settled_forwards': len(settled), 'total_fee_msat': fee_msat, 'total_fee_sat': fee_msat // 1000}))
" "$result"
