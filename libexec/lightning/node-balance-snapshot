#!/bin/bash
# lightning node-balance-snapshot   (FEAT-425)
result_funds=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
result_info=$(lightning-cli getinfo 2>/dev/null) || result_info='{}'
python3 -c "
import sys, json, time
funds = json.loads(sys.argv[1])
info = json.loads(sys.argv[2])
outputs = funds.get('outputs', [])
channels = funds.get('channels', [])
onchain_msat = sum(o.get('amount_msat', 0) for o in outputs if o.get('status') == 'confirmed')
offchain_msat = sum(c.get('our_amount_msat', 0) for c in channels)
print(json.dumps({'timestamp': int(time.time()), 'node_id': info.get('id',''),
    'onchain_msat': onchain_msat, 'offchain_msat': offchain_msat,
    'total_msat': onchain_msat + offchain_msat}, separators=(',', ':')))
" "$result_funds" "$result_info"
