#!/bin/bash
# lightning channel-csv-delay-total   (FEAT-1995)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('our_to_self_delay', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_csv_delay': total}))
" "$result"
