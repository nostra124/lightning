#!/bin/bash
# lightning channel-peer-capacity <peer_id>   (FEAT-852)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-peer-capacity <peer_id>"}'
    exit 0
fi
peer_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
chs = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
total = sum(c.get('total_msat', 0) for c in chs)
print(json.dumps({'peer_id': pid, 'channel_count': len(chs), 'total_capacity_msat': total}))
" "$result" "$peer_id"
