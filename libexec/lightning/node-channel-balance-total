#!/bin/bash
# lightning node-channel-balance-total   (FEAT-1179)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
our_total = sum(c.get('our_amount_msat', 0) for c in channels if isinstance(c.get('our_amount_msat'), int))
print(json.dumps({'our_total_msat': our_total, 'channel_count': len(channels)}))
" "$result"
