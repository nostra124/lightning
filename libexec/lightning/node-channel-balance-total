#!/bin/bash
# lightning node-channel-balance-total   (FEAT-531)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
local = sum(c.get('to_us_msat', 0) for c in channels)
total = sum(c.get('total_msat', 0) for c in channels)
remote = total - local
print(json.dumps({'local_msat': local, 'remote_msat': remote, 'total_msat': total}))
" "$result"
