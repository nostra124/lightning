#!/bin/bash
# lightning node-watchtower-status   (FEAT-651)
if ! result=$(lightning-cli plugin list 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
plugins = data.get('plugins', [])
watchtower = next((p for p in plugins if 'watchtower' in p.get('name', '').lower()), None)
print(json.dumps({'watchtower_active': watchtower is not None, 'plugin': watchtower.get('name') if watchtower else None}))
" "$result"
