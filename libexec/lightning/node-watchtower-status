#!/bin/bash
# lightning node-watchtower-status   (FEAT-412)
result=$(lightning-cli listconfigs 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
cfg = json.loads(sys.argv[1])
configs = cfg.get('configs', cfg)
wt = configs.get('watchtower', {})
print(json.dumps({'watchtower_enabled': bool(wt), 'config': wt}, separators=(',', ':')))
" "$result"
