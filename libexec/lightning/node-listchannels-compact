#!/bin/bash
# lightning node-listchannels-compact   (FEAT-601)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
compact = [{'short_channel_id': c.get('short_channel_id'), 'source': c.get('source'), 'destination': c.get('destination'), 'base_fee_millisatoshi': c.get('base_fee_millisatoshi')} for c in channels[:100]]
print(json.dumps({'total': len(channels), 'sample': compact}))
" "$result"
