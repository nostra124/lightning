#!/bin/bash
# lightning node-channel-graph [--limit N]   (FEAT-389)
set -e
limit=100
while [ $# -gt 0 ]; do
    case "$1" in
        --limit) limit="$2"; shift 2 ;;
        *) shift ;;
    esac
done
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
limit = int(sys.argv[2])
channels = data.get('channels', [])[:limit]
out = [{'source': c.get('source',''), 'destination': c.get('destination',''),
        'short_channel_id': c.get('short_channel_id',''),
        'satoshis': c.get('satoshis', 0), 'active': c.get('active', False)} for c in channels]
print(json.dumps(out, separators=(',', ':')))
" "$result" "$limit"
