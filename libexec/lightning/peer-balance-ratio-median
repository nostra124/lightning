#!/bin/bash
# lightning peer-balance-ratio-median   (FEAT-3008)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ratios = []
for ch in channels:
    total = ch.get('total_msat', 0)
    spendable = ch.get('spendable_msat', 0)
    if isinstance(total, str): total = int(total.replace('msat',''))
    if isinstance(spendable, str): spendable = int(spendable.replace('msat',''))
    if total > 0:
        ratios.append(spendable / total)
if ratios:
    ratios.sort()
    n = len(ratios)
    mid = n // 2
    median = ratios[mid] if n % 2 == 1 else (ratios[mid-1] + ratios[mid]) / 2
    print(json.dumps({'balance_ratio_median_peer': median}))
else:
    print(json.dumps({'balance_ratio_median_peer': None}))
" "$result"
