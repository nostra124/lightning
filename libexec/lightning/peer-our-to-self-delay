#!/bin/bash
# lightning peer-our-to-self-delay <peer_id>   (FEAT-1677)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-our-to-self-delay <peer_id>"}'; exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels for peer'}))
    sys.exit(0)
ch = channels[0]
print(json.dumps({'peer_id': sys.argv[2], 'our_to_self_delay': ch.get('our_to_self_delay')}))
" "$result" "$peer_id"
