#!/bin/bash
# lightning node-invoice-amount-stats   (FEAT-2117)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
amounts = [i.get('amount_received_msat', i.get('amount_msat', 0)) for i in invoices if i.get('status') == 'paid']
if amounts:
    out = {'min_msat': min(amounts), 'max_msat': max(amounts), 'avg_msat': int(sum(amounts)/len(amounts)), 'count': len(amounts)}
else:
    out = {'min_msat': None, 'max_msat': None, 'avg_msat': None, 'count': 0}
print(json.dumps(out))
" "$result"
