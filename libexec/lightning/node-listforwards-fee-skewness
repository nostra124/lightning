#!/bin/bash
# lightning node-listforwards-fee-skewness   (FEAT-2801)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
vals = [f.get('fee_msat', 0) for f in fwds if 'fee_msat' in f]
n = len(vals)
if n >= 3:
    mean = sum(vals) / n
    std = math.sqrt(sum((v - mean)**2 for v in vals) / n)
    skewness = (sum((v - mean)**3 for v in vals) / n) / (std**3) if std > 0 else 0.0
else:
    skewness = 0.0
print(json.dumps({'fee_skewness': round(skewness, 6), 'count': n}))
" "$result"
