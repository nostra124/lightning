#!/bin/bash
# lightning node-listforwards-settled-rate   (FEAT-2331)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total = len(forwards)
settled = sum(1 for f in forwards if f.get('status') == 'settled')
rate = round(settled / total, 6) if total > 0 else 0.0
print(json.dumps({'settled_forwards': settled, 'total_forwards': total, 'settled_rate': rate}))
" "$result"
