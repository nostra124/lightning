#!/bin/bash
# lightning node-pay-amount-kurtosis-weekly   (FEAT-2844)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
from datetime import datetime, timezone, timedelta
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
now = datetime.now(timezone.utc)
week_ago = now - timedelta(weeks=1)
amounts = []
for p in pays:
    ts = p.get('created_at', 0)
    if datetime.fromtimestamp(ts, tz=timezone.utc) >= week_ago:
        amt = p.get('amount_sent_msat', p.get('amount_msat', 0))
        if isinstance(amt, str):
            amt = int(amt.rstrip('msat'))
        amounts.append(float(amt))
n = len(amounts)
if n < 4:
    print(json.dumps({'amount_kurtosis_weekly': None, 'n': n}))
    sys.exit(0)
mean = sum(amounts) / n
var = sum((x - mean)**2 for x in amounts) / n
if var == 0:
    print(json.dumps({'amount_kurtosis_weekly': None, 'n': n}))
    sys.exit(0)
std = math.sqrt(var)
kurt = (sum((x - mean)**4 for x in amounts) / n) / (var**2) - 3
print(json.dumps({'amount_kurtosis_weekly': round(kurt, 6), 'n': n}))
" "$result"
