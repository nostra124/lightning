#!/bin/bash
# lightning peer-fee-base-max   (FEAT-2478)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'peer_id': None, 'fee_base_msat': None}))
else:
    best = max(channels, key=lambda c: int(c.get('fee_base_msat', 0)))
    print(json.dumps({'peer_id': best.get('peer_id'), 'fee_base_msat': int(best.get('fee_base_msat', 0))}))
" "$result"
