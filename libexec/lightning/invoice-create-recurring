#!/bin/bash
# lightning invoice-create-recurring <amount_msat> <label_prefix> <count>   (FEAT-381)
set -e
if [ $# -lt 3 ]; then
    echo '{"error":"usage: invoice-create-recurring <amount_msat> <label_prefix> <count>"}'
    exit 0
fi
amount_msat="$1"
prefix="$2"
count="$3"
results="["
sep=""
for i in $(seq 1 "$count"); do
    label="${prefix}-$(date +%s)-${i}"
    r=$(lightning-cli invoice "$amount_msat" "$label" "recurring payment $i" 2>/dev/null) || { results="${results}${sep}{\"error\":\"failed\"}"; sep=","; continue; }
    bolt11=$(python3 -c "import sys,json; print(json.loads(sys.argv[1]).get('bolt11',''))" "$r" 2>/dev/null)
    results="${results}${sep}{\"label\":\"${label}\",\"bolt11\":\"${bolt11}\"}"
    sep=","
done
echo "${results}]"
