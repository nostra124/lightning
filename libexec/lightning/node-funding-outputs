#!/bin/bash
# lightning node-funding-outputs   (FEAT-604)
if ! result=$(lightning-cli listfunds 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
print(json.dumps({'outputs': outputs, 'count': len(outputs)}))
" "$result"
