#!/bin/bash
# lightning wallet-id <wallet_name>   (FEAT-588)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-id <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
wid=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='wallet_id';" 2>/dev/null) || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"wallet_id\":\"$wid\"}"
