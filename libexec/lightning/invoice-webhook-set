#!/bin/bash
# lightning invoice-webhook-set <url>   (FEAT-795)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-webhook-set <url>"}'; exit 0; fi
url="$1"
result=$(lightning-cli setpaymentwebhook "$url" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps(d))" "$result"
