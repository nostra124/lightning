#!/bin/bash
# lightning node-pay-fee-skewness   (FEAT-2814)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
vals = []
for p in pays:
    sent = p.get('amount_sent_msat', 0)
    amt = p.get('amount_msat', 0)
    if sent and amt:
        vals.append(sent - amt)
if len(vals) < 3:
    print(json.dumps({'fee_skewness_pay': None, 'count': len(vals)}))
    sys.exit(0)
n = len(vals)
mean = sum(vals) / n
var = sum((x - mean)**2 for x in vals) / n
std = var**0.5
if std == 0:
    print(json.dumps({'fee_skewness_pay': None, 'count': n}))
    sys.exit(0)
skew = (sum(((x - mean)/std)**3 for x in vals) / n)
print(json.dumps({'fee_skewness_pay': skew, 'count': n}))
" "$result"
