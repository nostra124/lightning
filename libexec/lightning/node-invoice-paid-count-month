#!/bin/bash
# lightning node-invoice-paid-count-month   (FEAT-2786)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
now = time.time()
cutoff = now - 30 * 24 * 3600
count = sum(1 for inv in invoices if inv.get('status') == 'paid' and inv.get('paid_at', 0) >= cutoff)
print(json.dumps({'paid_count_month': count}))
" "$result"
