#!/bin/bash
# lightning node-listforwards-fee-max   (FEAT-2311)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
settled = [f for f in forwards if f.get('status') == 'settled' and 'fee_msat' in f]
if not settled:
    print(json.dumps({'max_fee_msat': 0, 'count_settled': 0}))
else:
    max_fee = max(f['fee_msat'] for f in settled)
    print(json.dumps({'max_fee_msat': max_fee, 'count_settled': len(settled)}))
" "$result"
