#!/bin/bash
# lightning peer-connected-pct   (FEAT-2338)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
total = len(peers)
connected = sum(1 for p in peers if p.get('connected', False))
pct = round(connected / total * 100, 2) if total > 0 else 0.0
print(json.dumps({'connected_peers': connected, 'total_peers': total, 'connected_pct': pct}))
" "$result"
