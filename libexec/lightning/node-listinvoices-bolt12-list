#!/bin/bash
# lightning node-listinvoices-bolt12-list   (FEAT-2389)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
bolt12 = [i for i in invoices if 'local_offer_id' in i]
print(json.dumps({'bolt12_invoice_count': len(bolt12), 'bolt12_invoices': bolt12}))
" "$result"
