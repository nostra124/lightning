#!/bin/bash
# lightning channel-state-counts   (FEAT-1935)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
states = {}
for ch in channels:
    s = ch.get('state', 'unknown')
    states[s] = states.get(s, 0) + 1
print(json.dumps({'states': states, 'total': len(channels)}))
" "$result"
