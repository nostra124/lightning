#!/bin/bash
# lightning node-pay-avg-msat   (FEAT-2039)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
if complete:
    total = 0
    for p in complete:
        amt = p.get('amount_sent_msat', 0)
        if isinstance(amt, str) and amt.endswith('msat'):
            amt = int(amt[:-4])
        total += int(amt)
    avg = total // len(complete)
else:
    avg = 0
print(json.dumps({'avg_msat': avg, 'count': len(complete)}))
" "$result"
