#!/bin/bash
# lightning node-pay-avg-msat   (FEAT-1311)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete' and p.get('amount_sent_msat')]
total = sum(int(str(p['amount_sent_msat']).replace('msat','')) for p in pays)
avg = total // len(pays) if pays else 0
print(json.dumps({'count': len(pays), 'avg_msat': avg}))
" "$result"
