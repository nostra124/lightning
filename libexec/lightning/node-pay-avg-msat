#!/bin/bash
# lightning node-pay-avg-msat   (FEAT-1031)
if ! result=$(lightning-cli listpays 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
total = sum(p.get('amount_sent_msat', 0) for p in pays)
avg = total // len(pays) if pays else 0
print(json.dumps({'count': len(pays), 'avg_msat': avg}))
" "$result"
