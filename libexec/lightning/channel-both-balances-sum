#!/bin/bash
# lightning channel-both-balances-sum   (FEAT-2652)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum((c.get('to_us_msat', 0) or 0) + (c.get('total_msat', 0) or 0) for c in channels)
print(json.dumps({'both_balances_sum_msat': total}))
" "$result"
