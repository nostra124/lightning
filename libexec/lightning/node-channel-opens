#!/bin/bash
# lightning node-channel-opens [--pending]   (FEAT-506)
pending_only=0
[ "$1" = "--pending" ] && pending_only=1
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
pending_only = sys.argv[2] == '1'
if pending_only:
    channels = [c for c in channels if c.get('state') not in ('CHANNELD_NORMAL', 'CLOSED')]
out = [{'channel_id': c.get('channel_id',''), 'state': c.get('state',''),
    'peer_id': c.get('peer_id','')} for c in channels]
print(json.dumps(out, separators=(',', ':')))
" "$result" "$pending_only"
