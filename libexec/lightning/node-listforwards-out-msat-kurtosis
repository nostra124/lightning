#!/bin/bash
# lightning node-listforwards-out-msat-kurtosis   (FEAT-2811)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
vals = [f['out_msat'] for f in forwards if 'out_msat' in f]
if len(vals) < 4:
    print(json.dumps({'out_msat_kurtosis': None, 'count': len(vals)}))
    sys.exit(0)
n = len(vals)
mean = sum(vals) / n
var = sum((x - mean)**2 for x in vals) / n
std = var**0.5
if std == 0:
    print(json.dumps({'out_msat_kurtosis': None, 'count': n}))
    sys.exit(0)
kurt = (sum(((x - mean)/std)**4 for x in vals) / n) - 3
print(json.dumps({'out_msat_kurtosis': kurt, 'count': n}))
" "$result"
