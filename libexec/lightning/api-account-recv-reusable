#!/bin/bash
# lightning api-account-recv-reusable <address> <sat|any> [--desc <text>]
#                                                            (FEAT-212 PR-2)
#
# Mints a BOLT-12 offer tied to the account.  Reusable (the payer
# can fetch an invoice and pay many times against the same offer).
#   {"bolt12":"lno1...","offer_id":"...","amount_sat":<int|null>}

set -e
[ $# -ge 2 ] || exit 1
address="$1"; sat="$2"; shift 2
desc="receive"
while [ $# -gt 0 ]; do
	case "$1" in
		--desc) desc="$2"; shift 2 ;;
		*) exit 2 ;;
	esac
done

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
case "$sat" in any) ;; ''|*[!0-9]*) exit 2 ;; esac

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }
name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

# FEAT-243 — capability gate.
"$(cd "$(dirname "$0")" && pwd)/account" capability "$address" recv 2>/dev/null \
	|| { echo '{"error":"capability_disabled","capability":"recv"}'; exit 6; }

now=$(date -u +%s)
sqlite3 "$db" "UPDATE accounts SET last_api_call_at = $now WHERE address = $(sql_quote "$address");" 2>/dev/null || true

command -v lightning-cli >/dev/null || { echo '{"error":"lightning-cli not installed"}'; exit 127; }

if [ "$sat" = "any" ]; then
	amount_arg="any"
	amount_json=null
else
	amount_arg="${sat}sat"
	amount_json="$sat"
fi
offer_json=$(lightning-cli \
	--lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
	--network="${LIGHTNING_NETWORK:-bitcoin}" \
	offer "$amount_arg" "$desc" 2>/dev/null) || {
		echo '{"error":"offer_failed"}'
		exit 5
	}

bolt12=$(jq -r '.bolt12 // empty' <<<"$offer_json")
offer_id=$(jq -r '.offer_id // empty' <<<"$offer_json")
jq -nc \
	--arg b12 "$bolt12" \
	--arg id "$offer_id" \
	--argjson amount "$amount_json" \
	'{bolt12: $b12, offer_id: $id, amount_sat: $amount}'
