#!/bin/bash
# lightning channel-local-disabled   (FEAT-1616)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
disabled = [c.get('channel_id') for c in channels if c.get('updates', {}).get('local', {}).get('channel_flags', 0) & 2]
print(json.dumps({'count': len(disabled), 'channels': disabled}))
" "$result"
