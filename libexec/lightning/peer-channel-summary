#!/bin/bash
# lightning peer-channel-summary   (FEAT-2116)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
summary = []
for p in peers:
    channels = p.get('channels', [])
    summary.append({'peer_id': p.get('id', ''), 'connected': p.get('connected', False), 'channel_count': len(channels)})
print(json.dumps({'peers': summary, 'total': len(summary)}))
" "$result"
