#!/bin/bash
# lightning node-listforwards-total-msat   (FEAT-1549)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
total_in = sum(f.get('in_msat', 0) for f in fwds)
total_out = sum(f.get('out_msat', 0) for f in fwds)
print(json.dumps({'settled_count': len(fwds), 'total_in_msat': total_in, 'total_out_msat': total_out}))
" "$result"
