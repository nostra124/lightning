#!/bin/bash
# lightning node-listpeers-alias   (FEAT-1001)
if ! result=$(lightning-cli listpeers 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
out = [{'id': p.get('id'), 'alias': p.get('alias', '')} for p in peers]
print(json.dumps({'count': len(out), 'peers': out}))
" "$result"
