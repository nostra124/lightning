#!/bin/bash
# lightning node-listpeers-alias   (FEAT-1614)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = [{'id': p.get('id'), 'alias': p.get('alias')} for p in data.get('peers', []) if p.get('alias')]
print(json.dumps({'count': len(peers), 'peers': peers}))
" "$result"
