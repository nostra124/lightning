#!/bin/bash
# lightning channel-local-pct-max   (FEAT-2335)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_pct = -1.0
for ch in channels:
    local = ch.get('local_msat', 0)
    remote = ch.get('remote_msat', 0)
    total = local + remote
    if total > 0:
        pct = local / total
        if pct > best_pct:
            best_pct = pct
            best = {'peer_id': ch.get('peer_id',''), 'local_msat': local, 'remote_msat': remote, 'local_pct': round(pct, 6)}
if best is None:
    best = {'peer_id': None, 'local_msat': 0, 'remote_msat': 0, 'local_pct': 0.0}
print(json.dumps(best))
" "$result"
