#!/bin/bash
# lightning channel-both-reserves-min   (FEAT-2923)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    lr = ch.get('our_reserve_msat', 0)
    rr = ch.get('their_reserve_msat', 0)
    if isinstance(lr, str): lr = int(lr)
    if isinstance(rr, str): rr = int(rr)
    vals.append(lr + rr)
result = min(vals) if vals else 0
print(json.dumps({'both_reserves_min_msat': result}))
" "$result"
