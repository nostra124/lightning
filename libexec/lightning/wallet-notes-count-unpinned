#!/bin/bash
# lightning wallet-notes-count-unpinned <wallet>   (FEAT-1528)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-count-unpinned <wallet>"}'; exit 0; fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE pinned=0 OR pinned IS NULL;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"unpinned_count\":$count}"
