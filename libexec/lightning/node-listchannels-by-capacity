#!/bin/bash
# lightning node-listchannels-by-capacity <min_msat>   (FEAT-1794)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listchannels-by-capacity <min_msat>"}'; exit 0; fi
min_msat="$1"
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
min_m = int(sys.argv[2])
channels = [c for c in data.get('channels', []) if c.get('amount_msat', 0) >= min_m]
print(json.dumps({'count': len(channels), 'channels': [c.get('short_channel_id') for c in channels]}))
" "$result" "$min_msat"
