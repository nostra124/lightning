#!/bin/bash
# lightning node-listchannels-by-capacity <min_msat>   (FEAT-1274)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listchannels-by-capacity <min_msat>"}'; exit 0; fi
min_msat="$1"
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
min_m = int(sys.argv[2])
matched = [c for c in data.get('channels', []) if isinstance(c.get('amount_msat'), int) and c.get('amount_msat') >= min_m]
print(json.dumps({'min_msat': min_m, 'count': len(matched), 'channels': [c.get('short_channel_id') for c in matched]}))
" "$result" "$min_msat"
