#!/bin/bash
# lightning node-invoice-paid-count-by-month   (FEAT-2294)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from datetime import datetime, timezone
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
counts = {}
for inv in invoices:
    if inv.get('status') == 'paid' and 'paid_at' in inv:
        dt = datetime.fromtimestamp(inv['paid_at'], tz=timezone.utc)
        key = dt.strftime('%Y-%m')
        counts[key] = counts.get(key, 0) + 1
print(json.dumps({'paid_by_month': counts}))
" "$result"
