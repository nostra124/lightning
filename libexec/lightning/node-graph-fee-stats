#!/bin/bash
# lightning node-graph-fee-stats   (FEAT-2074)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = [int(c.get('fee_per_millionth', 0)) for c in channels]
if not fees:
    print(json.dumps({'min_fee_ppm': None, 'max_fee_ppm': None, 'avg_fee_ppm': None, 'channel_count': 0}))
else:
    print(json.dumps({'min_fee_ppm': min(fees), 'max_fee_ppm': max(fees), 'avg_fee_ppm': sum(fees)//len(fees), 'channel_count': len(fees)}))
" "$result"
