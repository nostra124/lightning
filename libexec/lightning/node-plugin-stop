#!/bin/bash
# lightning node-plugin-stop <plugin_name>   (FEAT-379)
set -e
[ $# -ge 1 ] || { echo '{"error":"usage: node-plugin-stop <plugin_name>"}'; exit 0; }
plugin="$1"
result=$(lightning-cli plugin stop "$plugin" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
echo '{"ok":true}'
