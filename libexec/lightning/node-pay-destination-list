#!/bin/bash
# lightning node-pay-destination-list   (FEAT-1941)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
seen = []
for p in pays:
    d = p.get('destination')
    if d and d not in seen:
        seen.append(d)
print(json.dumps({'count': len(seen), 'destinations': seen}))
" "$result"
