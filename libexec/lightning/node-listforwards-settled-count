#!/bin/bash
# lightning node-listforwards-settled-count   (FEAT-2241)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
count = sum(1 for f in forwards if f.get('status') == 'settled')
print(json.dumps({'settled_count': count}))
" "$result"
