#!/bin/bash
# lightning node-invoice-paid-last-90d   (FEAT-2414)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
cutoff = time.time() - 90 * 86400
count = 0
for inv in invoices:
    if inv.get('status') == 'paid' and inv.get('paid_at', 0) >= cutoff:
        count += 1
print(json.dumps({'invoice_paid_count_90d': count}))
" "$result"
