#!/bin/bash
# lightning node-connect-auto   (FEAT-392)
set -e
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
peers = json.loads(sys.argv[1]).get('peers', [])
disconnected = [p for p in peers if not p.get('connected', False)]
reconnected = []
for p in disconnected:
    addrs = p.get('netaddr', [])
    if addrs:
        reconnected.append({'peer_id': p.get('id',''), 'addr': addrs[0], 'status': 'reconnect_scheduled'})
print(json.dumps({'reconnect_scheduled': len(reconnected), 'peers': reconnected}, separators=(',', ':')))
" "$result"
