#!/bin/bash
# lightning peer-node-info <node_id>   (FEAT-687)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-node-info <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listnodes "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
if nodes:
    n = nodes[0]
    print(json.dumps({'nodeid': n.get('nodeid'), 'alias': n.get('alias'), 'color': n.get('color'), 'last_timestamp': n.get('last_timestamp')}))
else:
    print(json.dumps({'error': 'node not found'}))
" "$result"
