#!/bin/bash
# lightning channel-close-mutual <channel_id> [<dest_addr>]   (FEAT-650)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-close-mutual <channel_id> [<dest_addr>]"}'
    exit 0
fi
channel_id="$1"; dest="${2:-}"
if [ -n "$dest" ]; then
    result=$(lightning-cli close "$channel_id" 0 "$dest" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
else
    result=$(lightning-cli close "$channel_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
fi
echo "$result"
