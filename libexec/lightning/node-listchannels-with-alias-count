#!/bin/bash
# lightning node-listchannels-with-alias-count   (FEAT-1469)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
with_alias = [c for c in channels if c.get('alias')]
print(json.dumps({'total': len(channels), 'with_alias': len(with_alias)}))
" "$result"
