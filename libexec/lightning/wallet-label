#!/bin/bash
# lightning wallet-label <wallet_name> <label>   (FEAT-553)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-label <wallet_name> <label>"}'
    exit 0
fi
wname="$1"; label="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('label','$label');" 2>/dev/null || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"ok\":true,\"wallet\":\"$wname\",\"label\":\"$label\"}"
