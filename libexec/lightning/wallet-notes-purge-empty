#!/bin/bash
# lightning wallet-notes-purge-empty   (FEAT-1838)
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "DELETE FROM notes WHERE value IS NULL OR value='';" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo '{"purged":true}'
