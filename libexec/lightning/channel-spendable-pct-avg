#!/bin/bash
# lightning channel-spendable-pct-avg   (FEAT-2760)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pcts = []
for c in channels:
    total = c.get('total_msat', 0)
    spendable = c.get('spendable_msat', 0)
    if total:
        pcts.append(100.0 * spendable / total)
avg = sum(pcts) / len(pcts) if pcts else 0
print(json.dumps({'spendable_pct_avg': avg}))
" "$result"
