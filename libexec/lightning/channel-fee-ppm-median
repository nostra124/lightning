#!/bin/bash
# lightning channel-fee-ppm-median   (FEAT-2238)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ppms = sorted(c.get('fee_proportional_millionths', 0) for c in channels if isinstance(c.get('fee_proportional_millionths'), int))
if not ppms:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
n = len(ppms)
if n % 2 == 1:
    median = ppms[n // 2]
else:
    median = (ppms[n // 2 - 1] + ppms[n // 2]) / 2
print(json.dumps({'median_ppm': median, 'channel_count': n}))
" "$result"
