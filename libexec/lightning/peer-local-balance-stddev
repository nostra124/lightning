#!/bin/bash
# lightning peer-local-balance-stddev   (FEAT-2713)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
balances = [c.get('to_us_msat', 0) for c in channels]
if len(balances) < 2:
    stddev = 0
else:
    mean = sum(balances) / len(balances)
    stddev = math.sqrt(sum((x - mean) ** 2 for x in balances) / len(balances))
print(json.dumps({'local_balance_stddev_msat': int(stddev)}))
" "$result"
