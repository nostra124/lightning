#!/bin/bash
# lightning wallet-history <wallet_name>   (FEAT-1178)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-history <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "SELECT * FROM history ORDER BY rowid DESC LIMIT 50;" 2>/dev/null | python3 -c "
import sys, json
rows = [line.rstrip('\n') for line in sys.stdin if line.strip()]
print(json.dumps({'wallet': sys.argv[1], 'history': rows}))
" "$wname"
