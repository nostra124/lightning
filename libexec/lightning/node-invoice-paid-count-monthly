#!/bin/bash
# lightning node-invoice-paid-count-monthly   (FEAT-2894)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
month_ago = time.time() - 30 * 86400
count = sum(1 for i in invoices if i.get('status') == 'paid' and i.get('paid_at', 0) >= month_ago)
print(json.dumps({'paid_count_monthly': count}))
" "$result"
