#!/bin/bash
# lightning wallet-meta-keys <wallet>   (FEAT-1678)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-meta-keys <wallet>"}'; exit 0
fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
keys=$(sqlite3 "$db" "SELECT key FROM meta;" 2>/dev/null | tr '\n' ',' | sed 's/,$//')
echo "{\"wallet\":\"$wname\",\"keys\":\"$keys\"}"
