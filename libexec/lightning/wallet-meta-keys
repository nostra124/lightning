#!/bin/bash
# lightning wallet-meta-keys <wallet_name>   (FEAT-988)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-meta-keys <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
meta_dir="$root/$wname/meta"
if [ ! -d "$meta_dir" ]; then echo "{\"wallet\":\"$wname\",\"keys\":[]}"; exit 0; fi
keys=$(ls "$meta_dir" 2>/dev/null | python3 -c "import sys,json; print(json.dumps(sys.stdin.read().strip().split('\n') if sys.stdin.read().strip() else []))" 2>/dev/null || echo '[]')
echo "{\"wallet\":\"$wname\",\"keys\":$keys}"
