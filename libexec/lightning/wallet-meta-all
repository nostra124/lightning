#!/bin/bash
# lightning wallet-meta-all <wallet_name>   (FEAT-1108)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-meta-all <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
meta=$(sqlite3 "$db" "SELECT key,value FROM meta;" 2>/dev/null | python3 -c "import sys,json; rows=[l.strip().split('|',1) for l in sys.stdin if '|' in l]; print(json.dumps({r[0]:r[1] for r in rows}))" 2>/dev/null || echo '{}')
echo "{\"wallet\":\"$wname\",\"meta\":$meta}"
