#!/bin/bash
# lightning node-listinvoices-amount-total   (FEAT-2235)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid']
total = sum(i.get('amount_received_msat', i.get('amount_msat', 0)) for i in paid if isinstance(i.get('amount_received_msat', i.get('amount_msat')), int))
print(json.dumps({'paid_count': len(paid), 'total_msat': total}))
" "$result"
