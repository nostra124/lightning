#!/bin/bash
# lightning node-listforwards-pending-count   (FEAT-2301)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
count = sum(1 for f in forwards if f.get('status') in ('offered', 'pending'))
print(json.dumps({'pending_forwards_count': count}))
" "$result"
