#!/bin/bash
# lightning node-graph-ppm-stats   (FEAT-2084)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ppms = [ch.get('fee_per_millionth', 0) for ch in channels if 'fee_per_millionth' in ch]
if ppms:
    avg = sum(ppms) / len(ppms)
    result = {'ppm_min': min(ppms), 'ppm_max': max(ppms), 'ppm_avg': round(avg, 2), 'channel_count': len(ppms)}
else:
    result = {'ppm_min': 0, 'ppm_max': 0, 'ppm_avg': 0, 'channel_count': 0}
print(json.dumps(result))
" "$result"
