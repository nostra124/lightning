#!/bin/bash
# lightning peer-last-pay <peer_id>   (FEAT-1077)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-last-pay <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
pays = [p for p in data.get('pays', []) if p.get('destination') == pid]
pays.sort(key=lambda x: x.get('created_at', 0), reverse=True)
last = pays[0] if pays else None
print(json.dumps({'peer_id': pid, 'last_pay': last}))
" "$result" "$peer_id"
