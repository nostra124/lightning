#!/bin/bash
# lightning invoice-list-all   (FEAT-1905)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
by_status = {}
for i in invoices:
    s = i.get('status', 'unknown')
    by_status[s] = by_status.get(s, 0) + 1
print(json.dumps({'total': len(invoices), 'by_status': by_status}))
" "$result"
