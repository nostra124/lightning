#!/bin/bash
# lightning peer-remote-reserve-avg   (FEAT-2683)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
reserves = [c.get('remote_reserve_msat', 0) for c in channels if 'remote_reserve_msat' in c]
avg = sum(reserves) / len(reserves) if reserves else 0
print(json.dumps({'avg_remote_reserve_msat': avg}))
" "$result"
