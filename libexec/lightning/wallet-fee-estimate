#!/bin/bash
# lightning wallet-fee-estimate   (FEAT-957)
if ! result=$(lightning-cli feerates perkb 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
rates = data.get('perkb', {})
print(json.dumps({'opening': rates.get('opening'), 'mutual_close': rates.get('mutual_close'), 'urgent': rates.get('urgent'), 'normal': rates.get('normal')}))
" "$result"
