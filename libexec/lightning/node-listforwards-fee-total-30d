#!/bin/bash
# lightning node-listforwards-fee-total-30d   (FEAT-2411)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
cutoff = time.time() - 30 * 86400
total = 0
count = 0
for f in forwards:
    if f.get('status') == 'settled' and f.get('received_time', 0) >= cutoff:
        total += f.get('fee_msat', 0)
        count += 1
print(json.dumps({'fee_total_msat_30d': total, 'settled_count_30d': count}))
" "$result"
