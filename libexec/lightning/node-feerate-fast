#!/bin/bash
# lightning node-feerate-fast   (FEAT-1379)
result=$(lightning-cli feerates perkw 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
perkw = data.get('perkw', {})
print(json.dumps({'feerate_fast_perkw': perkw.get('urgent')}))
" "$result"
