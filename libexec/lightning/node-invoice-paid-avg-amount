#!/bin/bash
# lightning node-invoice-paid-avg-amount   (FEAT-2554)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
if not invoices:
    print(json.dumps({'paid_avg_amount_msat': 0}))
else:
    total = sum(i.get('amount_received_msat', 0) for i in invoices)
    avg = total // len(invoices)
    print(json.dumps({'paid_avg_amount_msat': avg}))
" "$result"
