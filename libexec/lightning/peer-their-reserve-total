#!/bin/bash
# lightning peer-their-reserve-total   (FEAT-2578)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
totals = {}
for c in channels:
    peer = c.get('peer_id', 'unknown')
    totals[peer] = totals.get(peer, 0) + c.get('their_reserve_msat', 0)
print(json.dumps({'peer_their_reserve_totals': totals}))
" "$result"
