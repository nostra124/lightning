#!/bin/bash
# lightning node-onchain-pending   (FEAT-1539)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
pending = [o for o in outputs if o.get('status') in ('unconfirmed', 'immature')]
total = sum(o.get('amount_msat', 0) for o in pending)
print(json.dumps({'pending_count': len(pending), 'pending_msat': total}))
" "$result"
