#!/bin/bash
# lightning channel-remote-reserve-bottom5   (FEAT-2702)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
enriched = []
for ch in channels:
    reserve = ch.get('remote_reserve_msat', 0)
    if isinstance(reserve, str):
        reserve = int(reserve)
    enriched.append({'channel_id': ch.get('channel_id', ''), 'peer_id': ch.get('peer_id', ''), 'remote_reserve_msat': reserve})
bottom5 = sorted(enriched, key=lambda c: c['remote_reserve_msat'])[:5]
print(json.dumps({'bottom5_by_remote_reserve': bottom5}))
" "$result"
