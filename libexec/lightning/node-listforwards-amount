#!/bin/bash
# lightning node-listforwards-amount   (FEAT-1234)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = [f for f in data.get('forwards', []) if f.get('status') == 'settled']
total_in = sum(f.get('in_msat', 0) for f in fwds if isinstance(f.get('in_msat'), int))
total_out = sum(f.get('out_msat', 0) for f in fwds if isinstance(f.get('out_msat'), int))
print(json.dumps({'settled_count': len(fwds), 'total_in_msat': total_in, 'total_out_msat': total_out}))
" "$result"
