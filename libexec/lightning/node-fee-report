#!/bin/bash
# lightning node-fee-report   (FEAT-521)
if ! result=$(lightning-cli listforwards 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
settled = [f for f in fwds if f.get('status') == 'settled']
total_fee = sum(f.get('fee_msat', 0) for f in settled)
print(json.dumps({'total_forwards': len(settled), 'total_fee_msat': total_fee, 'total_fee_sat': total_fee // 1000}))
" "$result"
