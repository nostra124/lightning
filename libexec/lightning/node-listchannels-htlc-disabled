#!/bin/bash
# lightning node-listchannels-htlc-disabled   (FEAT-1844)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
disabled = [c for c in channels if not c.get('active', True)]
print(json.dumps({'total': len(channels), 'disabled_count': len(disabled)}))
" "$result"
