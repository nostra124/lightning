#!/bin/bash
# lightning wallet-notes-restore <wallet> <key>   (FEAT-1733)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-notes-restore <wallet> <key>"}'; exit 0
fi
wname="$1"; key="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "UPDATE notes SET tag=NULL WHERE key='$key' AND tag='archived';" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"restored\":true}"
