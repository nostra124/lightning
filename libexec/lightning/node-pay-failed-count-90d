#!/bin/bash
# lightning node-pay-failed-count-90d   (FEAT-2644)
result=$(lightning-cli listpays status=failed 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
cutoff = int(time.time()) - 90 * 86400
count = sum(1 for p in pays if p.get('created_at', 0) >= cutoff)
print(json.dumps({'failed_pay_count_90d': count}))
" "$result"
