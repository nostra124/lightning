#!/bin/bash
# lightning node-pay-oldest   (FEAT-1911)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'created_at': None, 'pay': None}))
else:
    oldest = min(pays, key=lambda p: p.get('created_at', 0))
    print(json.dumps({'pay': oldest.get('payment_hash'), 'created_at': oldest.get('created_at'), 'amount_msat': oldest.get('amount_sent_msat')}))
" "$result"
