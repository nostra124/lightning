#!/bin/bash
# lightning channel-capacity-variance   (FEAT-2420)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    local = ch.get('local_msat', 0)
    remote = ch.get('remote_msat', 0)
    if local or remote:
        vals.append(local + remote)
mean = sum(vals) / len(vals) if vals else 0
variance = sum((x - mean) ** 2 for x in vals) / len(vals) if vals else 0
print(json.dumps({'capacity_variance': variance, 'capacity_mean_msat': mean, 'channel_count': len(vals)}))
" "$result"
