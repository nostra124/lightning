#!/bin/bash
# lightning node-channel-policy-list   (FEAT-434)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
out = [{'channel_id': c.get('channel_id',''), 'peer_id': c.get('peer_id',''),
        'fee_base_msat': c.get('fee_base_msat', 0), 'fee_proportional_millionths': c.get('fee_proportional_millionths', 0),
        'htlc_minimum_msat': c.get('htlc_minimum_msat', 0), 'htlc_maximum_msat': c.get('htlc_maximum_msat', 0)}
       for c in channels]
print(json.dumps(out, separators=(',', ':')))
" "$result"
