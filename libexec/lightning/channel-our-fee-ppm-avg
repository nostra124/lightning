#!/bin/bash
# lightning channel-our-fee-ppm-avg   (FEAT-1696)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = []
for ch in channels:
    local = ch.get('updates', {}).get('local', {})
    f = local.get('fee_proportional_millionths')
    if f is not None:
        fees.append(f)
if not fees:
    print(json.dumps({'count': 0, 'avg_fee_ppm': None}))
    sys.exit(0)
print(json.dumps({'count': len(fees), 'avg_fee_ppm': sum(fees) / len(fees)}))
" "$result"
