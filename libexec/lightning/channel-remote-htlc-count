#!/bin/bash
# lightning channel-remote-htlc-count   (FEAT-1892)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(len([h for h in c.get('htlcs', []) if h.get('direction') == 'in']) for c in data.get('channels', []))
print(json.dumps({'total_remote_htlcs': total}))
" "$result"
