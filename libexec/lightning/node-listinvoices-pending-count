#!/bin/bash
# lightning node-listinvoices-pending-count   (FEAT-2419)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
now = time.time()
count = 0
for inv in invoices:
    if inv.get('status') == 'unpaid':
        exp = inv.get('expires_at', 0)
        if exp == 0 or exp > now:
            count += 1
print(json.dumps({'pending_invoice_count': count}))
" "$result"
