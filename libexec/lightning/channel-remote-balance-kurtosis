#!/bin/bash
# lightning channel-remote-balance-kurtosis   (FEAT-2812)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c['to_us_msat'] for c in channels if 'to_us_msat' in c and 'total_msat' in c]
vals = [c['total_msat'] - c['to_us_msat'] for c in channels if 'to_us_msat' in c and 'total_msat' in c]
if len(vals) < 4:
    print(json.dumps({'remote_balance_kurtosis': None, 'count': len(vals)}))
    sys.exit(0)
n = len(vals)
mean = sum(vals) / n
var = sum((x - mean)**2 for x in vals) / n
std = var**0.5
if std == 0:
    print(json.dumps({'remote_balance_kurtosis': None, 'count': n}))
    sys.exit(0)
kurt = (sum(((x - mean)/std)**4 for x in vals) / n) - 3
print(json.dumps({'remote_balance_kurtosis': kurt, 'count': n}))
" "$result"
