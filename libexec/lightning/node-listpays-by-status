#!/bin/bash
# lightning node-listpays-by-status <status>   (FEAT-1461)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listpays-by-status <status>"}'; exit 0; fi
status="$1"
result=$(lightning-cli listpays status="$status" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'status': sys.argv[2], 'count': len(pays), 'pays': pays}))
" "$result" "$status"
