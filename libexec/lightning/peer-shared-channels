#!/bin/bash
# lightning peer-shared-channels <node_id>   (FEAT-817)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-shared-channels <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nid = sys.argv[2]
channels = [{'channel_id': c.get('channel_id'), 'state': c.get('state'), 'total_msat': c.get('total_msat')} for c in data.get('channels', []) if c.get('peer_id') == nid]
print(json.dumps({'node_id': nid, 'shared_channels': channels, 'count': len(channels)}))
" "$result" "$node_id"
