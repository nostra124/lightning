#!/bin/bash
# lightning channel-close-coop <channel_id>   (FEAT-600)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-close-coop <channel_id>"}'
    exit 0
fi
channel_id="$1"
result=$(lightning-cli close "$channel_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
