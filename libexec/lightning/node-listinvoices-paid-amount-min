#!/bin/bash
# lightning node-listinvoices-paid-amount-min   (FEAT-2519)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i.get('amount_msat', 0) or 0 for i in invoices if i.get('status') == 'paid']
if not paid:
    print(json.dumps({'paid_invoice_amount_min_msat': None, 'paid_count': 0}))
else:
    print(json.dumps({'paid_invoice_amount_min_msat': min(paid), 'paid_count': len(paid)}))
" "$result"
