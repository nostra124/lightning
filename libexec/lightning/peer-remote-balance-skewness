#!/bin/bash
# lightning peer-remote-balance-skewness   (FEAT-2818)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
from collections import defaultdict
peer_bal = defaultdict(int)
for c in channels:
    pid = c.get('peer_id', '')
    total = c.get('total_msat', 0)
    local = c.get('to_us_msat', 0)
    peer_bal[pid] += total - local
vals = list(peer_bal.values())
if len(vals) < 3:
    print(json.dumps({'remote_balance_skewness_peer': None, 'count': len(vals)}))
    sys.exit(0)
n = len(vals)
mean = sum(vals) / n
var = sum((x - mean)**2 for x in vals) / n
std = var**0.5
if std == 0:
    print(json.dumps({'remote_balance_skewness_peer': None, 'count': n}))
    sys.exit(0)
skew = (sum(((x - mean)/std)**3 for x in vals) / n)
print(json.dumps({'remote_balance_skewness_peer': skew, 'count': n}))
" "$result"
