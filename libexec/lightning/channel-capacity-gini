#!/bin/bash
# lightning channel-capacity-gini   (FEAT-2245)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
def to_msat(v):
    if isinstance(v, int):
        return v
    if isinstance(v, str) and v.endswith('msat'):
        return int(v[:-4])
    return 0
caps = []
for c in channels:
    local = to_msat(c.get('local_msat', 0))
    remote = to_msat(c.get('remote_msat', 0))
    caps.append(local + remote)
caps = [v for v in caps if v > 0]
if len(caps) < 2:
    print(json.dumps({'gini': None}))
else:
    caps_sorted = sorted(caps)
    n = len(caps_sorted)
    cumsum = 0
    for i, v in enumerate(caps_sorted):
        cumsum += (2 * (i + 1) - n - 1) * v
    gini = round(cumsum / (n * sum(caps_sorted)), 4)
    print(json.dumps({'gini': gini}))
" "$result"
