#!/bin/bash
# lightning node-pay-fee-max   (FEAT-1691)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
fees = [(p.get('amount_sent_msat', 0) - p.get('amount_msat', 0)) for p in pays if p.get('amount_sent_msat') and p.get('amount_msat')]
if not fees:
    print(json.dumps({'count': 0, 'max_fee_msat': None}))
    sys.exit(0)
print(json.dumps({'count': len(fees), 'max_fee_msat': max(fees)}))
" "$result"
