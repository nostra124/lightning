#!/bin/bash
# lightning node-graph-channel-age-stats   (FEAT-2184)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
now = int(time.time())
ages = []
for c in channels:
    lu = c.get('last_update')
    if lu is not None:
        ages.append(now - int(lu))
if ages:
    result = {'count': len(ages), 'min_age_seconds': min(ages), 'max_age_seconds': max(ages), 'avg_age_seconds': int(sum(ages)/len(ages))}
else:
    result = {'count': 0, 'min_age_seconds': None, 'max_age_seconds': None, 'avg_age_seconds': None}
print(json.dumps(result))
" "$result"
