#!/bin/bash
# lightning node-pay-complete-newest   (FEAT-2189)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
if complete:
    newest = max(complete, key=lambda p: p.get('created_at', 0))
    print(json.dumps({'payment_hash': newest.get('payment_hash'), 'created_at': newest.get('created_at'), 'amount_msat': newest.get('amount_msat'), 'destination': newest.get('destination')}))
else:
    print(json.dumps({'payment_hash': None, 'created_at': None, 'amount_msat': None, 'destination': None}))
" "$result"
