#!/bin/bash
# lightning channel-local-pct-stddev   (FEAT-2670)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pcts = []
for ch in channels:
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if isinstance(total, str): total = int(total.replace('msat',''))
    if isinstance(local, str): local = int(local.replace('msat',''))
    if total > 0:
        pcts.append(100.0 * local / total)
if len(pcts) >= 2:
    mean = sum(pcts) / len(pcts)
    variance = sum((x - mean) ** 2 for x in pcts) / len(pcts)
    print(json.dumps({'local_pct_stddev': round(math.sqrt(variance), 4)}))
else:
    print(json.dumps({'local_pct_stddev': None}))
" "$result"
