#!/bin/bash
# lightning node-listchannels-zero-reserve   (FEAT-1409)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c.get('channel_id') for c in data.get('channels', []) if c.get('our_reserve_msat', 1) == 0]
print(json.dumps({'count': len(channels), 'channel_ids': channels}))
" "$result"
