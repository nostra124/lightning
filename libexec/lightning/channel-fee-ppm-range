#!/bin/bash
# lightning channel-fee-ppm-range   (FEAT-2242)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ppms = [c.get('fee_proportional_millionths', 0) for c in channels if 'fee_proportional_millionths' in c]
if ppms:
    print(json.dumps({'fee_ppm_min': min(ppms), 'fee_ppm_max': max(ppms)}))
else:
    print(json.dumps({'fee_ppm_min': None, 'fee_ppm_max': None}))
" "$result"
