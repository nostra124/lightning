#!/bin/bash
# lightning channel-fee-revenue-total   (FEAT-2221)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    capacity = (ch.get('total_msat', 0) or 0)
    ppm = ch.get('fee_proportional_millionths', 0) or 0
    total += int(capacity) * int(ppm) // 1_000_000
print(json.dumps({'fee_revenue_potential_msat': total, 'channel_count': len(channels)}))
" "\$result"
