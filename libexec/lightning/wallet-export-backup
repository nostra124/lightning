#!/bin/bash
# lightning wallet-export-backup <wallet_name> [<dest_dir>]   (FEAT-408)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-export-backup <wallet_name> [<dest_dir>]"}'
    exit 0
fi
wname="$1"
dest="${2:-.}"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
ts=$(date -u +%Y%m%d_%H%M%S)
dest_file="$dest/${wname}_backup_${ts}.db"
cp "$db" "$dest_file"
echo '{"status":"exported","path":"'"$dest_file"'","wallet":"'"$wname"'"}'
