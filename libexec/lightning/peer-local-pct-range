#!/bin/bash
# lightning peer-local-pct-range   (FEAT-2788)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_vals = {}
for c in channels:
    peer = c.get('peer_id', '')
    local = c.get('to_us_msat')
    total = c.get('total_msat')
    if peer and local is not None and total and total > 0:
        pct = local / total * 100.0
        peer_vals.setdefault(peer, []).append(pct)
averages = [sum(v)/len(v) for v in peer_vals.values() if v]
if averages:
    local_pct_range = max(averages) - min(averages)
else:
    local_pct_range = None
print(json.dumps({'local_pct_range': local_pct_range, 'peer_count': len(averages)}))
" "$result"
