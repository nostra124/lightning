#!/bin/bash
# lightning node-htlc-in-flight   (FEAT-849)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(len(c.get('htlcs', [])) for c in data.get('channels', []))
print(json.dumps({'in_flight_htlcs': total}))
" "$result"
