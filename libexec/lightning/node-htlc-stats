#!/bin/bash
# lightning node-htlc-stats   (FEAT-354)
set -e
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_htlcs = 0
offered = 0
received = 0
for c in channels:
    htlcs = c.get('htlcs', [])
    total_htlcs += len(htlcs)
    offered += sum(1 for h in htlcs if h.get('direction') == 'out')
    received += sum(1 for h in htlcs if h.get('direction') == 'in')
print(json.dumps({'total_htlcs': total_htlcs, 'offered': offered, 'received': received, 'channels_with_htlcs': sum(1 for c in channels if c.get('htlcs'))}, separators=(',', ':')))
" "$result"
