#!/bin/bash
# lightning channel-local-balance-stats   (FEAT-2115)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
balances = [ch.get('to_us_msat', 0) for ch in channels if 'to_us_msat' in ch]
if balances:
    out = {'min_msat': min(balances), 'max_msat': max(balances), 'avg_msat': int(sum(balances)/len(balances)), 'count': len(balances)}
else:
    out = {'min_msat': None, 'max_msat': None, 'avg_msat': None, 'count': 0}
print(json.dumps(out))
" "$result"
