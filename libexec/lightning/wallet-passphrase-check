#!/bin/bash
# lightning wallet-passphrase-check <wallet_name>   (FEAT-858)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-passphrase-check <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$wname" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
has_pass=false
[ -f "$root/$wname/.encrypted" ] && has_pass=true
echo "{\"wallet\":\"$wname\",\"has_passphrase\":$has_pass}"
