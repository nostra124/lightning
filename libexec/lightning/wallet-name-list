#!/bin/bash
# lightning wallet-name-list   (FEAT-643)
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root" ]; then
    echo '[]'
    exit 0
fi
python3 -c "
import sys, json, os
root = sys.argv[1]
try:
    names = sorted(n for n in os.listdir(root) if os.path.isdir(os.path.join(root, n)))
    print(json.dumps(names))
except Exception:
    print('[]')
" "$root"
