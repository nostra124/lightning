#!/bin/bash
# lightning node-listpeers-compact   (FEAT-587)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
compact = [{'id': p.get('id'), 'connected': p.get('connected'), 'num_channels': len(p.get('channels', []))} for p in peers]
print(json.dumps(compact))
" "$result"
