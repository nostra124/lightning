#!/bin/bash
# lightning channel-remote-balance-bottom10   (FEAT-2607)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
for c in channels:
    c['_remote_msat'] = c.get('total_msat', 0) - c.get('to_us_msat', 0)
sorted_ch = sorted(channels, key=lambda c: c['_remote_msat'])
bottom10 = sorted_ch[:10]
out = [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id'), 'remote_balance_msat': c['_remote_msat']} for c in bottom10]
print(json.dumps({'bottom10_channels_by_remote': out}))
" "$result"
