#!/bin/bash
# lightning wallet-notes-pinned <wallet_name>   (FEAT-1278)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-pinned <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "SELECT key, value FROM notes WHERE pinned=1;" 2>/dev/null | python3 -c "
import sys, json
rows = []
for line in sys.stdin:
    parts = line.rstrip('\n').split('|', 1)
    if len(parts) == 2:
        rows.append({'key': parts[0], 'value': parts[1]})
print(json.dumps({'pinned': rows, 'count': len(rows)}))
"
