#!/bin/bash
# lightning channel-remote-pct <channel_id>   (FEAT-976)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-remote-pct <channel_id>"}'; exit 0; fi
channel_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        total = ch.get('total_msat', 0); local = ch.get('to_us_msat', 0)
        remote_pct = round((total - local) / total * 100, 1) if total > 0 else 0
        print(json.dumps({'channel_id': ch.get('channel_id'), 'remote_pct': remote_pct})); sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
