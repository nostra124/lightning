#!/bin/bash
# lightning peer-remote-balance-max   (FEAT-2373)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_totals = {}
for ch in channels:
    pid = ch.get('peer_id', '')
    remote = ch.get('remote_msat', 0)
    peer_totals[pid] = peer_totals.get(pid, 0) + remote
if not peer_totals:
    print(json.dumps({'peer_id': None, 'total_remote_msat': 0}))
else:
    best = max(peer_totals, key=lambda p: peer_totals[p])
    print(json.dumps({'peer_id': best, 'total_remote_msat': peer_totals[best]}))
" "$result"
