#!/bin/bash
# lightning node-listforwards-by-out-channel <short_channel_id>   (FEAT-1219)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listforwards-by-out-channel <short_channel_id>"}'; exit 0; fi
scid="$1"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
scid = sys.argv[2]
matched = [f for f in data.get('forwards', []) if f.get('out_channel') == scid]
print(json.dumps({'channel': scid, 'count': len(matched), 'forwards': matched}))
" "$result" "$scid"
