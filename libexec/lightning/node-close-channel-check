#!/bin/bash
# lightning node-close-channel-check <channel_id>   (FEAT-869)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-close-channel-check <channel_id>"}'; exit 0; fi
channel_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        state = ch.get('state', '')
        closeable = state in ('CHANNELD_NORMAL', 'CHANNELD_AWAITING_LOCKIN')
        print(json.dumps({'channel_id': ch.get('channel_id'), 'state': state, 'closeable': closeable})); sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
