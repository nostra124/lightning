#!/bin/bash
# lightning channel-local-pct-min   (FEAT-2529)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel_id': None, 'local_pct': 0.0}))
    sys.exit(0)
best = None
best_pct = float('inf')
for c in channels:
    local = c.get('to_us_msat', 0)
    total = c.get('total_msat', 0)
    if isinstance(local, str):
        local = int(local.replace('msat',''))
    if isinstance(total, str):
        total = int(total.replace('msat',''))
    pct = round(local / total * 100, 2) if total > 0 else 0.0
    if pct < best_pct:
        best_pct = pct
        best = c.get('channel_id', '')
print(json.dumps({'channel_id': best, 'local_pct': best_pct}))
" "$result"
