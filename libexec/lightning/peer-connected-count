#!/bin/bash
# lightning peer-connected-count   (FEAT-1936)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
connected = sum(1 for p in peers if p.get('connected') == True)
print(json.dumps({'connected': connected, 'total': len(peers)}))
" "$result"
