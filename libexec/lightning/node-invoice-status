#!/bin/bash
# lightning node-invoice-status <label>   (FEAT-854)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-invoice-status <label>"}'
    exit 0
fi
label="$1"
if ! result=$(lightning-cli listinvoices "$label" 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
if invs:
    print(json.dumps({'label': sys.argv[2], 'status': invs[0].get('status'), 'amount_msat': invs[0].get('amount_msat')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result" "$label"
