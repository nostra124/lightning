#!/bin/bash
# lightning peer-max-channel <peer_id>   (FEAT-927)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-max-channel <peer_id>"}'; exit 0; fi
peer_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); pid = sys.argv[2]
chs = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
if chs:
    biggest = max(chs, key=lambda c: c.get('total_msat', 0))
    print(json.dumps({'peer_id': pid, 'max_channel_id': biggest.get('channel_id'), 'total_msat': biggest.get('total_msat')}))
else:
    print(json.dumps({'error': 'no channels for peer'}))
" "$result" "$peer_id"
