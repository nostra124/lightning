#!/bin/bash
# lightning node-short-channel-id <channel_id>   (FEAT-442)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-short-channel-id <channel_id>"}'
    exit 0
fi
cid="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
cid = sys.argv[2]
match = next((c for c in channels if c.get('channel_id') == cid), None)
if match:
    print(json.dumps({'channel_id': cid, 'short_channel_id': match.get('short_channel_id','')}, separators=(',', ':')))
else:
    print(json.dumps({'error': 'channel_not_found'}))
" "$result" "$cid"
