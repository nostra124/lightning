#!/bin/bash
# lightning invoice-amount-total   (FEAT-1895)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
total = sum(i.get('amount_received_msat', 0) or 0 for i in invoices if i.get('status') == 'paid')
print(json.dumps({'paid_count': sum(1 for i in invoices if i.get('status') == 'paid'), 'total_received_msat': total}))
" "$result"
