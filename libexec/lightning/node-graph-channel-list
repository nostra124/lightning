#!/bin/bash
# lightning node-graph-channel-list   (FEAT-2094)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
out = [{'short_channel_id': c.get('short_channel_id'), 'source': c.get('source'), 'destination': c.get('destination'), 'satoshis': c.get('satoshis')} for c in channels]
print(json.dumps({'channels': out, 'count': len(out)}))
" "$result"
