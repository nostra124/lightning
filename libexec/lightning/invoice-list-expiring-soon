#!/bin/bash
# lightning invoice-list-expiring-soon <seconds>   (FEAT-1635)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-expiring-soon <seconds>"}'; exit 0
fi
secs="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
secs = int(sys.argv[2])
now = int(time.time())
invs = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid' and i.get('expires_at') and i['expires_at'] - now <= secs and i['expires_at'] > now]
print(json.dumps({'count': len(invs), 'invoices': [i.get('label') for i in invs]}))
" "$result" "$secs"
