#!/bin/bash
# lightning api-account-withdraw <address> <sat> <onchain-addr>
#                                                            (FEAT-212 PR-2)
#
# Submarine swap out (reverse): debit the account's Lightning
# balance, settle on-chain at <onchain-addr>.  Returns the swap-id.
#
#   {"swap_id":"...","status":"created","amount_sat":<int>,
#    "destination":"bc1q..."}

set -e
[ $# -eq 3 ] || exit 1
address="$1"; sat="$2"; dest="$3"

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
case "$sat" in ''|*[!0-9]*) exit 2 ;; esac
# Loose shape check on the destination (full bech32 + base58check
# validation lives in boltzcli, which we'll error-through if the
# input is bogus).  Just guard against obvious mishaps.
[ "${#dest}" -ge 26 ] || { echo '{"error":"destination_too_short"}'; exit 2; }
case "$dest" in bc1*|tb1*|bcrt1*|1*|3*|m*|n*|2*) ;;
	*) echo '{"error":"destination_shape_unrecognised"}'; exit 2 ;;
esac

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }
name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

now=$(date -u +%s)
sqlite3 "$db" "UPDATE accounts SET last_api_call_at = $now WHERE address = $(sql_quote "$address");" 2>/dev/null || true

# FEAT-233 — compliance pre-hook (fast no-op unless opted in; may deny).
cc_self=$(cd "$(dirname "$0")" && pwd)
compliance_hook() {
	[ -s "$WALLETS_ROOT/$wname/compliance.recfile" ] || return 0
	local out rc
	out=$("$cc_self/_compliance" hook "$1" "$2" "$3" 2>/dev/null); rc=$?
	[ "$rc" -eq 0 ] || { [ -n "$out" ] && echo "$out"; }
	return "$rc"
}
cc_ctx="{\"account\":\"$name\",\"op\":\"withdraw\",\"amount_sat\":$sat}"
compliance_hook pre withdraw "$cc_ctx" || exit 6

# FEAT-243 — capability gate (on-chain pay-out is a banking op).
"$cc_self/account" capability "$address" withdraw 2>/dev/null \
	|| { echo '{"error":"capability_disabled","capability":"withdraw"}'; exit 6; }

if ! command -v boltzcli >/dev/null 2>&1; then
	echo '{"error":"boltzcli_not_installed","hint":"submarine-swap dependency"}'
	exit 127
fi

swap_json=$(boltzcli createreverseswap --amount "$sat" --address "$dest" 2>/dev/null) || {
	echo '{"error":"boltz_failed"}'
	exit 5
}

swap_id=$(jq -r '.id // .swap_id // empty' <<<"$swap_json")
[ -n "$swap_id" ] || swap_id="unknown"

# FEAT-213 — operator-fee skim atop the boltz swap.
amount_msat=$(( sat * 1000 ))
fees_file="$WALLETS_ROOT/$wname/fees.recfile"
operator_fee_msat=0
if [ -f "$fees_file" ]; then
	read -r fee_base_sat fee_rate_ppm < <(awk -v op="withdraw" '
		BEGIN { RS=""; FS="\n"; b=0; r=0 }
		{
			in_op=0; bb=0; rr=0
			for (i=1; i<=NF; i++) {
				if ($i == "operation: " op) in_op=1
				if ($i ~ /^base_sat: *[0-9-]/) { bb=$i; sub(/^base_sat: */, "", bb) }
				if ($i ~ /^rate_ppm: *[0-9-]/) { rr=$i; sub(/^rate_ppm: */, "", rr) }
			}
			if (in_op) { b=bb; r=rr }
		}
		END { printf "%d %d\n", b+0, r+0 }
	' "$fees_file")
	operator_fee_msat=$(( fee_base_sat * 1000 + amount_msat * fee_rate_ppm / 1000000 ))
fi
operator_fee_sat=$(( operator_fee_msat / 1000 ))

if [ "$operator_fee_msat" -gt 0 ]; then
	sqlite3 "$db" "INSERT OR IGNORE INTO accounts(name, description, overdraft) \
		VALUES('house', 'operator fee revenue', 'allow');" 2>/dev/null || true
fi

# FEAT-219 — referral split.  Same logic as api-account-pay; see
# that verb's comments for the sybil-defence reasoning.
referral_msat=0
referrer=""
direct_pct="${LIGHTNING_REFERRAL_DIRECT_PCT:-0}"
case "$direct_pct" in ''|*[!0-9]*) direct_pct=0 ;; esac
[ "$direct_pct" -gt 100 ] && direct_pct=100
if [ "$operator_fee_msat" -gt 0 ] && [ "$direct_pct" -gt 0 ]; then
	referrer=$(sqlite3 "$db" "SELECT COALESCE(referrer, 'house') FROM accounts WHERE name = $(sql_quote "$name");" 2>/dev/null)
	case "$referrer" in
		""|"house"|"-") referrer="" ;;
		*)
			min_msat=$(( ${LIGHTNING_REFERRAL_MIN_ACTIVITY_SAT:-10000} * 1000 ))
			act_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(ABS(amount_msat)), 0) FROM ledger \
				WHERE account = $(sql_quote "$name") AND message NOT LIKE 'fee:%';" 2>/dev/null)
			[ "${act_msat:-0}" -lt "$min_msat" ] && referrer=""
			;;
	esac
	if [ -n "$referrer" ]; then
		cap_msat=$(( ${LIGHTNING_REFERRAL_MAX_PER_DAY_SAT:-10000} * 1000 ))
		today_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(amount_msat), 0) FROM ledger \
			WHERE account = $(sql_quote "$referrer") \
			  AND direction = 'in' \
			  AND message LIKE 'fee:referral%' \
			  AND date(ts) = date('now');" 2>/dev/null)
		[ "${today_msat:-0}" -ge "$cap_msat" ] && referrer=""
	fi
	if [ -n "$referrer" ]; then
		referral_msat=$(( operator_fee_msat * direct_pct / 100 ))
	fi
fi
house_share_msat=$(( operator_fee_msat - referral_msat ))
referral_sat=$(( referral_msat / 1000 ))

# Provisional debit; the swap watcher (PR-4) will reconcile on settle
# (or refund on timeout).  Tag with the swap id for traceability.
# Plus the operator-fee skim → house + (optionally) referrer.
sql="BEGIN;"
sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, message)"
sql+=" VALUES(datetime('now'), $(sql_quote "$name"), 'out', -$amount_msat, $(sql_quote "$dest"), $(sql_quote "swap $swap_id"));"
if [ "$operator_fee_msat" -gt 0 ]; then
	sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, message)"
	sql+=" VALUES(datetime('now'), $(sql_quote "$name"), 'out', -$operator_fee_msat, $(sql_quote "$dest"), $(sql_quote "fee:withdraw (swap $swap_id)"));"
	if [ "$house_share_msat" -gt 0 ]; then
		sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, message)"
		sql+=" VALUES(datetime('now'), 'house', 'in', $house_share_msat, $(sql_quote "$dest"), $(sql_quote "fee:withdraw from $name (swap $swap_id)"));"
	fi
	if [ "$referral_msat" -gt 0 ] && [ -n "$referrer" ]; then
		sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, message)"
		sql+=" VALUES(datetime('now'), $(sql_quote "$referrer"), 'in', $referral_msat, $(sql_quote "referee:$name"), $(sql_quote "fee:referral from $name (swap $swap_id)"));"
	fi
fi
sql+=" COMMIT;"
sqlite3 "$db" "$sql" 2>/dev/null || true

# FEAT-233 — post-hook: observe + record (never blocks).
compliance_hook post withdraw "$cc_ctx" || true

jq -nc \
	--arg id "$swap_id" \
	--argjson amount "$sat" \
	--argjson ofee "$operator_fee_sat" \
	--argjson rfee "$referral_sat" \
	--arg dest "$dest" \
	'{swap_id: $id, status: "created", amount_sat: $amount,
	  operator_fee_sat: $ofee, referral_fee_sat: $rfee, destination: $dest}'
