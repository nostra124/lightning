#!/bin/bash
# lightning peer-features-count <peer_id>   (FEAT-1667)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-features-count <peer_id>"}'; exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeers "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
if not peers:
    print(json.dumps({'error': 'peer not found'}))
    sys.exit(0)
p = peers[0]
features = p.get('features', '')
count = bin(int(features, 16)).count('1') if features else 0
print(json.dumps({'peer_id': p.get('id'), 'feature_bit_count': count}))
" "$result"
