#!/bin/bash
# lightning node-onchain-total   (FEAT-1434)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
total = sum(o.get('amount_msat', 0) for o in outputs)
print(json.dumps({'output_count': len(outputs), 'total_msat': total}))
" "$result"
