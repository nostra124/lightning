#!/bin/bash
# lightning wallet-seed-words <wallet_name>   (FEAT-648)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-seed-words <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
words=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='seed_words';" 2>/dev/null) || { echo '{"error":"sqlite3 not found"}'; exit 0; }
if [ -z "$words" ]; then
    echo '{"error":"no seed words stored"}'
else
    python3 -c "import sys,json; print(json.dumps({'wallet': sys.argv[1], 'seed_words': sys.argv[2]}))" "$wname" "$words"
fi
