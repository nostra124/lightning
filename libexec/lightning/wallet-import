#!/bin/bash
# lightning wallet-import <wallet_name> <src_path>   (FEAT-1053)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-import <wallet_name> <src_path>"}'
    exit 0
fi
wname="$1"; src="$2"
if [ ! -f "$src" ]; then
    echo '{"error":"source_not_found"}'
    exit 0
fi
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
mkdir -p "$root/$wname"
if cp "$src" "$root/$wname/state.db" 2>/dev/null; then
    echo "{\"ok\":true,\"wallet\":\"$wname\",\"imported_from\":\"$src\"}"
else
    echo '{"error":"import_failed"}'
fi
