#!/bin/bash
# lightning node-listfunds-channels   (FEAT-931)
if ! result=$(lightning-cli listfunds 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('our_amount_msat', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_our_msat': total}))
" "$result"
