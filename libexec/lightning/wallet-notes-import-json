#!/bin/bash
# lightning wallet-notes-import-json <wallet> <json_file>   (FEAT-1483)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-import-json <wallet> <json_file>"}'; exit 0; fi
wname="$1"; jfile="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
if [ ! -f "$jfile" ]; then echo '{"error":"json file not found"}'; exit 0; fi
count=$(python3 -c "
import sys, json, sqlite3
with open(sys.argv[1]) as f:
    notes = json.load(f)
conn = sqlite3.connect(sys.argv[2])
c = conn.cursor()
n = 0
for k, v in (notes.items() if isinstance(notes, dict) else []):
    c.execute('INSERT OR REPLACE INTO notes (key, value) VALUES (?, ?)', (k, str(v)))
    n += 1
conn.commit()
conn.close()
print(n)
" "$jfile" "$db" 2>/dev/null) || { echo '{"error":"import failed"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"imported\":$count}"
