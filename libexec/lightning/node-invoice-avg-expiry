#!/bin/bash
# lightning node-invoice-avg-expiry   (FEAT-2354)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
pending = [i for i in invoices if i.get('status') == 'unpaid']
if pending:
    avg = sum(i.get('expiry', 0) for i in pending) / len(pending)
else:
    avg = 0
print(json.dumps({'avg_expiry_seconds': round(avg, 2), 'pending_count': len(pending)}))
" "$result"
