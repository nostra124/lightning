#!/bin/bash
# lightning channel-onchain-state   (FEAT-1666)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
onchain = [c for c in channels if c.get('state') in ('ONCHAIN', 'FUNDING_SPEND_SEEN')]
print(json.dumps({'count': len(onchain), 'channels': [c.get('channel_id') for c in onchain]}))
" "$result"
