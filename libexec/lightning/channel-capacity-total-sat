#!/bin/bash
# lightning channel-capacity-total-sat   (FEAT-2090)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    cap = ch.get('total_msat', 0)
    if isinstance(cap, str):
        cap = int(cap.replace('msat',''))
    total += cap
total_sat = total // 1000
print(json.dumps({'capacity_total_sat': total_sat, 'channel_count': len(channels)}))
" "$result"
