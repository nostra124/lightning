#!/bin/bash
# lightning peer-channel-spendable <peer_id>   (FEAT-1367)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-channel-spendable <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
total = sum(ch.get('spendable_msat', 0) for ch in data.get('channels', []) if ch.get('peer_id') == pid)
print(json.dumps({'peer_id': pid, 'spendable_msat': total}))
" "$result" "$peer_id"
