#!/bin/bash
# lightning node-pay-180d-total   (FEAT-2356)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
cutoff = time.time() - 180 * 86400
total = sum(p.get('amount_sent_msat', 0) for p in pays
            if p.get('status') == 'complete' and p.get('created_at', 0) >= cutoff)
print(json.dumps({'amount_sent_msat_180d': total}))
" "$result"
