#!/bin/bash
# lightning peer-channel-spendable-total   (FEAT-2548)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
totals = {}
for c in channels:
    peer = c.get('peer_id', 'unknown')
    v = c.get('spendable_msat', 0)
    val = int(str(v).rstrip('msat')) if isinstance(v, str) else int(v)
    totals[peer] = totals.get(peer, 0) + val
print(json.dumps({'peer_spendable_totals': totals}))
" "$result"
