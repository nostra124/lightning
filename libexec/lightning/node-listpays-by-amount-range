#!/bin/bash
# lightning node-listpays-by-amount-range <min_msat> <max_msat>   (FEAT-1821)
if [ $# -lt 2 ]; then echo '{"error":"usage: node-listpays-by-amount-range <min_msat> <max_msat>"}'; exit 0; fi
min_msat="$1"
max_msat="$2"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
mn, mx = int(sys.argv[2]), int(sys.argv[3])
pays = [p for p in data.get('pays', []) if mn <= p.get('amount_sent_msat', 0) <= mx]
print(json.dumps({'count': len(pays), 'pays': pays}))
" "$result" "$min_msat" "$max_msat"
