#!/bin/bash
# lightning wallet-label-count <wallet_name>   (FEAT-1253)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-label-count <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM labels;" 2>/dev/null) || count=0
echo "{\"wallet\":\"$wname\",\"label_count\":$count}"
