#!/bin/bash
# lightning peer-invoice-requests <node_id>   (FEAT-797)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-invoice-requests <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listinvoicerequests 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
requests = data.get('invoicerequests', [])
print(json.dumps({'node_id': sys.argv[2], 'requests': requests[:10]}))
" "$result" "$node_id"
