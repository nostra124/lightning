#!/bin/bash
# lightning peer-connected-ratio   (FEAT-2728)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
total = len(peers)
connected = sum(1 for p in peers if p.get('connected', False))
ratio = (connected / total) if total else 0
print(json.dumps({'connected_ratio': ratio, 'connected': connected, 'total': total}))
" "$result"
