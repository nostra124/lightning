#!/bin/bash
# lightning node-listforwards-count-local-failed   (FEAT-2906)
result=$(lightning-cli listforwards status=local_failed 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
print(json.dumps({'local_failed_count': len(forwards)}))
" "$result"
