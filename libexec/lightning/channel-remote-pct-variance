#!/bin/bash
# lightning channel-remote-pct-variance   (FEAT-2955)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pcts = []
for c in channels:
    total = c.get('total_msat', 0)
    local = c.get('to_us_msat', 0)
    if total > 0:
        remote = total - local
        pcts.append(remote / total * 100)
if not pcts:
    print(json.dumps({'remote_pct_variance': 0, 'channel_count': 0}))
else:
    mean = sum(pcts) / len(pcts)
    variance = sum((p - mean) ** 2 for p in pcts) / len(pcts)
    print(json.dumps({'remote_pct_variance': variance, 'channel_count': len(pcts)}))
" "$result"
