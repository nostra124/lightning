#!/bin/bash
# lightning invoice-bolt11-expiry <bolt11>   (FEAT-1295)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-bolt11-expiry <bolt11>"}'; exit 0; fi
bolt11="$1"
if ! result=$(lightning-cli decodepay "$bolt11" 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'expiry': data.get('expiry'), 'created_at': data.get('created_at')}))
" "$result"
