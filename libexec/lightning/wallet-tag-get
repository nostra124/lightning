#!/bin/bash
# lightning wallet-tag-get <wallet_name>   (FEAT-1083)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-tag-get <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
tag=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='tag';" 2>/dev/null || echo "")
echo "{\"wallet\":\"$wname\",\"tag\":\"$tag\"}"
