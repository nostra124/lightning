#!/bin/bash
# lightning peer-newest-channel-age   (FEAT-2036)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
now = int(time.time())
min_age = None
newest_id = None
for ch in channels:
    opened = ch.get('opened_at', ch.get('funding_txid', None))
    if isinstance(opened, int):
        age = now - opened
        if min_age is None or age < min_age:
            min_age = age
            newest_id = ch.get('channel_id', ch.get('short_channel_id', ''))
if min_age is None:
    print(json.dumps({'newest_channel_age_seconds': None, 'channel_id': None}))
else:
    print(json.dumps({'newest_channel_age_seconds': min_age, 'channel_id': newest_id}))
" "$result"
