#!/bin/bash
# lightning channel-local-balance-largest   (FEAT-2188)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_local = -1
for c in channels:
    local = c.get('to_us_msat', 0)
    if isinstance(local, str): local = int(local.replace('msat',''))
    if local > best_local:
        best_local = local
        best = c
if best:
    print(json.dumps({'peer_id': best.get('peer_id'), 'channel_id': best.get('channel_id'), 'local_msat': best_local}))
else:
    print(json.dumps({'peer_id': None, 'channel_id': None, 'local_msat': None}))
" "$result"
