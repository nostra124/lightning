#!/bin/bash
# lightning invoice — BOLT-11 invoices (create + pay).
#
# Implements: BOLT-11 per FEAT-173.
#   share/doc/lightning/standards/bolts/11-payment-encoding.md
#
# Subcommands:
#   create <sat> <label> [--description <text>] [--expiry <sec>]
#                                              [--qr] [--account <name>]
#   pay <bolt11> [--max-fee-sat N] [--timeout S]
#                [--account <name>] [--note <text>]

set -e

usage() {
	cat >&2 <<EOF
usage: lightning invoice <subcommand> [args]

   BOLT-11 invoices — single-use, addressed payment requests.
   Mint one to receive a payment; pay one to send. Each invoice
   has a unique payment_hash and amount. See
   share/doc/lightning/standards/bolts/11-payment-encoding.md
   for the encoding spec. Each sub-command also accepts --help.

subcommands:
   create <sat> <label> [--description <text>] [--expiry <sec>]
                        [--qr] [--account <name>]
   pay <bolt11> [--max-fee-sat N] [--timeout S]
                [--account <name>] [--note <text>]
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }
require_cli() {
	command -v lightning-cli >/dev/null || {
		error "lightning-cli not found — install Core Lightning"; exit 127; }
}

# Resolve the active wallet's DB the same way wallet/ledger/account do
# (the active pointer lives at $WALLETS_ROOT-parent/active, NOT inside
# the wallet dir).  Must match those verbs or ledger writes land in a
# different DB than `ledger`/`account` read.
WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wallet_db() {
	local active="default"
	[ -f "$ACTIVE_LINK" ] && active=$(cat "$ACTIVE_LINK")
	echo "$WALLETS_ROOT/$active/state.db"
}

cmd_create() {
	[ $# -lt 2 ] && { echo "usage: lightning invoice create <sat> <label> [--description <text>] [--expiry <sec>] [--qr] [--account <name>]" >&2; exit 1; }

	local sat="$1" label="$2"; shift 2
	local desc="$label"
	local expiry=3600
	local want_qr=0
	local account=""

	while [ $# -gt 0 ]; do
		case "$1" in
			--description) desc="$2"; shift 2 ;;
			--expiry)      expiry="$2"; shift 2 ;;
			--qr)          want_qr=1; shift ;;
			--account)     account="$2"; shift 2 ;;
			*) error "invoice create: unknown flag '$1'"; exit 1 ;;
		esac
	done

	local msat=$(( sat * 1000 ))
	local json; json=$(cli invoice "$msat" "$label" "$desc" "$expiry")

	local bolt11; bolt11=$(jq -r .bolt11 <<<"$json")
	local hash;   hash=$(jq -r .payment_hash <<<"$json")

	echo "$bolt11"
	echo "# payment_hash: $hash" >&2

	local DB; DB=$(wallet_db)
	if [ -f "$DB" ] && command -v sqlite3 >/dev/null; then
		local acct="${account:--}"
		local expiry_ts
		expiry_ts=$(date -u -d "+$expiry seconds" +%Y-%m-%dT%H:%M:%S 2>/dev/null || date -u -v+"$expiry"S +%Y-%m-%dT%H:%M:%S 2>/dev/null || echo "")
		[ -n "$expiry_ts" ] && \
			sqlite3 "$DB" "INSERT INTO invoices (bolt11, payment_hash, account, amount_msat, expiry, message, state) VALUES ('$(echo "$bolt11" | sed "s/'/''/g")', '$(echo "$hash" | sed "s/'/''/g")', '$(echo "$acct" | sed "s/'/''/g")', $msat, '$expiry_ts', '$(echo "$desc" | sed "s/'/''/g")', 'pending')" 2>/dev/null || true
	fi

	if [ "$want_qr" -eq 1 ] && [ -x "$SELF_LIBEXEC/lightning/qr" ]; then
		echo
		"$SELF_LIBEXEC/lightning/qr" "lightning:$bolt11"
	fi
}

cmd_pay() {
	[ $# -lt 1 ] && { echo "usage: lightning invoice pay <bolt11> [--max-fee-sat N] [--timeout S] [--account <name>] [--note <text>]" >&2; exit 1; }

	local bolt11="$1"; shift
	local maxfee_sat=""
	local timeout=60
	local account=""
	local note=""

	while [ $# -gt 0 ]; do
		case "$1" in
			--max-fee-sat) maxfee_sat="$2"; shift 2 ;;
			--timeout)     timeout="$2"; shift 2 ;;
			--account)     account="$2"; shift 2 ;;
			--note)        note="$2"; shift 2 ;;
			*) error "invoice pay: unknown flag '$1'"; exit 1 ;;
		esac
	done

	# Overdraft check (FEAT-195).
	if [ -n "$account" ]; then
		local DB; DB=$(wallet_db)
		if [ -f "$DB" ] && command -v sqlite3 >/dev/null; then
			local esc_acct; esc_acct=$(echo "$account" | sed "s/'/''/g")
			local policy; policy=$(sqlite3 -readonly "$DB" "SELECT overdraft FROM accounts WHERE name = '$esc_acct'")

			if [ -n "$policy" ]; then
				local decoded; decoded=$(cli decodepay "$bolt11" 2>/dev/null)
				local pay_msat; pay_msat=$(jq -r '.amount_msat // 0' <<<"$decoded")
				local pay_sat=$(( pay_msat / 1000 ))

				if [ "$pay_sat" -gt 0 ] 2>/dev/null; then
					local balance_msat; balance_msat=$(sqlite3 -readonly "$DB" "SELECT COALESCE(SUM(amount_msat), 0) FROM ledger WHERE account = '$esc_acct'")
					local balance_sat=$(( balance_msat / 1000 ))

					if [ "$policy" = "deny" ] && [ "$balance_sat" -lt "$pay_sat" ] 2>/dev/null; then
						local shortfall=$(( pay_sat - balance_sat ))
						error "would overdraw account '$account' by ${shortfall} sat (balance: ${balance_sat} sat, policy: deny)"
						exit 3
					fi
					if [ "$policy" = "warn" ] && [ "$balance_sat" -lt "$pay_sat" ] 2>/dev/null; then
						local shortfall=$(( pay_sat - balance_sat ))
						warn "warning — payment of $pay_sat sat would overdraw '$account' by ${shortfall} sat"
					fi
				fi
			fi
		fi
	fi

	local args=("$bolt11")
	[ -n "$maxfee_sat" ] && args+=("null" "null" "$timeout" "null" "${maxfee_sat}sat") \
	                    || args+=("null" "null" "$timeout")

	local result; result=$(cli pay "${args[@]}")
	local status; status=$(jq -r .status <<<"$result")
	local hash;   hash=$(jq -r .payment_hash <<<"$result")
	local amount_msat; amount_msat=$(jq -r '.amount_msat // 0' <<<"$result")
	amount_msat=${amount_msat%msat}
	local fee_msat; fee_msat=$(jq -r '.amount_sent_msat - .amount_msat // 0' <<<"$result" 2>/dev/null || echo 0)
	fee_msat=${fee_msat%msat}
	local fee_sat=$(( fee_msat / 1000 ))

	if [ "$status" = "complete" ]; then
		echo "ok"
		echo "payment_hash: $hash"
		echo "fee_sat:      $fee_sat"

		local DB; DB=$(wallet_db)
		if [ -f "$DB" ] && command -v sqlite3 >/dev/null; then
			local note_esc; note_esc=$(echo "$note" | sed "s/'/''/g")
			local acct="${account:--}"
			sqlite3 "$DB" "INSERT INTO ledger (ts, account, direction, amount_msat, peer, payment_hash, message, note) VALUES (datetime('now'), '$(echo "$acct" | sed "s/'/''/g")', 'out', -$amount_msat, '-', '$(echo "$hash" | sed "s/'/''/g")', '', '$note_esc')" 2>/dev/null || true
			[ "$fee_msat" -gt 0 ] 2>/dev/null && \
				sqlite3 "$DB" "INSERT INTO ledger (ts, account, direction, amount_msat, peer, payment_hash, message, note) VALUES (datetime('now'), '$(echo "$acct" | sed "s/'/''/g")', 'fee', -$fee_msat, '-', '$(echo "$hash" | sed "s/'/''/g")', '', '')" 2>/dev/null || true
		fi
		exit 0
	else
		echo "failed: $status" >&2
		echo "$result" >&2
		exit 4
	fi
}

# -----------------------------------------------------------------------------
# New operational subcommands (consolidated from invoice-* micro-verbs)
# -----------------------------------------------------------------------------

cmd_status() {
	[ $# -lt 1 ] && { error "invoice status needs <label>"; exit 1; }
	local label="$1"
	local result; result=$(cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invoices = data.get('invoices', [])
if not invoices: print(json.dumps({'error': 'invoice not found'})); sys.exit(0)
i = invoices[0]
print(json.dumps({'label': i.get('label'), 'status': i.get('status'),
    'amount_msat': i.get('amount_msat'), 'expires_at': i.get('expires_at')}))
" "$result"
}

cmd_cancel() {
	[ $# -lt 1 ] && { error "invoice cancel needs <label>"; exit 1; }
	local label="$1"
	local result; result=$(cli delinvoice "$label" unpaid 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
try:
    data = json.loads(sys.argv[1])
    print(json.dumps({'ok': True, 'label': sys.argv[2], 'result': data.get('status')}))
except Exception:
    print(json.dumps({'error': 'cancel failed'}))
" "$result" "$label"
}

cmd_expire() {
	[ $# -lt 1 ] && { error "invoice expire needs <label>"; exit 1; }
	local label="$1"
	cli delinvoice "$label" unpaid >/dev/null 2>/dev/null || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	echo '{"ok":true}'
}

cmd_delete() {
	[ $# -lt 2 ] && { error "invoice delete needs <label> <status>"; exit 1; }
	local label="$1" status="$2"
	local result; result=$(cli delinvoice "$label" "$status" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	echo "$result"
}

cmd_lookup() {
	[ $# -lt 1 ] && { error "invoice lookup needs <label>"; exit 1; }
	local label="$1"
	local result; result=$(cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invs = data.get('invoices', [])
if not invs: print(json.dumps({'error': 'invoice not found'})); sys.exit(0)
print(json.dumps(invs[0]))
" "$result"
}

cmd_wait_invoice() {
	[ $# -lt 1 ] && { error "invoice wait needs <label>"; exit 1; }
	local label="$1" timeout=60; shift
	while [ $# -gt 0 ]; do
		case "$1" in --timeout) timeout="$2"; shift 2 ;; *) shift ;; esac
	done
	local result; result=$(cli waitinvoice "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'label': data.get('label'), 'status': data.get('status'), 'paid_at': data.get('paid_at')}))
" "$result"
}

cmd_settle() {
	[ $# -lt 1 ] && { error "invoice settle needs <label>"; exit 1; }
	local label="$1"
	local result; result=$(cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invoices = data.get('invoices', [])
if invoices:
    inv = invoices[0]
    print(json.dumps({'label': inv.get('label'), 'status': inv.get('status'), 'settled': inv.get('status') == 'paid'}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
}

cmd_list_all() {
	local result; result=$(cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invoices = data.get('invoices', [])
by_status = {}
for i in invoices:
    s = i.get('status', 'unknown'); by_status[s] = by_status.get(s, 0) + 1
print(json.dumps({'total': len(invoices), 'by_status': by_status, 'invoices': invoices}))
" "$result"
}

cmd_list_paid() {
	local result; result=$(cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
paid = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
print(json.dumps({'count': len(paid), 'invoices': paid}))
" "$result"
}

cmd_list_pending() {
	local result; result=$(cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pending = [{'label': i.get('label'), 'amount_msat': i.get('amount_msat'), 'expires_at': i.get('expires_at')} for i in data.get('invoices', []) if i.get('status') == 'unpaid']
print(json.dumps({'count': len(pending), 'invoices': pending}))
" "$result"
}

cmd_list_expired() {
	local result; result=$(cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
expired = [i for i in data.get('invoices', []) if i.get('status') == 'expired']
print(json.dumps({'count': len(expired), 'invoices': expired}))
" "$result"
}

cmd_list_active() {
	local result; result=$(cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
	python3 -c "
import sys, json, time
data = json.loads(sys.argv[1]); now = int(time.time())
active = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid' and i.get('expires_at', 0) > now]
print(json.dumps(active))
" "$result"
}

cmd_list_by_status() {
	[ $# -lt 1 ] && { error "invoice list-by-status needs <status>"; exit 1; }
	local status="$1"
	local result; result=$(cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = [{'label': i.get('label'), 'amount_msat': i.get('amount_msat')} for i in data.get('invoices', []) if i.get('status') == sys.argv[2]]
print(json.dumps({'status': sys.argv[2], 'count': len(invs), 'invoices': invs}))
" "$result" "$status"
}

cmd_bolt11_decode() {
	[ $# -lt 1 ] && { error "invoice bolt11-decode needs <bolt11>"; exit 1; }
	local bolt11="$1"
	local result; result=$(cli decodepay "$bolt11" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
if 'error' in data: print(json.dumps({'error': data['error']})); sys.exit(0)
print(json.dumps({'payment_hash': data.get('payment_hash'), 'amount_msat': data.get('amount_msat'),
    'description': data.get('description'), 'expiry': data.get('expiry'), 'payee': data.get('payee')}))
" "$result"
}

cmd_bolt11_check() {
	[ $# -lt 1 ] && { error "invoice bolt11-check needs <bolt11>"; exit 1; }
	local bolt11="$1"
	local result; result=$(cli decodepay "$bolt11" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json, time
d = json.loads(sys.argv[1])
if 'error' in d:
    print(json.dumps({'valid': False, 'error': d.get('error')}))
else:
    expires = d.get('created_at', 0) + d.get('expiry', 3600)
    print(json.dumps({'valid': True, 'payee': d.get('payee'), 'amount_msat': d.get('amount_msat'), 'expired': time.time() > expires}))
" "$result"
}

cmd_payment_hash() {
	[ $# -lt 1 ] && { error "invoice payment-hash needs <label>"; exit 1; }
	local label="$1"
	local result; result=$(cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invs = data.get('invoices', [])
if not invs: print(json.dumps({'error': 'invoice not found'})); sys.exit(0)
i = invs[0]
print(json.dumps({'label': i.get('label'), 'payment_hash': i.get('payment_hash')}))
" "$result"
}

cmd_description() {
	[ $# -lt 1 ] && { error "invoice description needs <label>"; exit 1; }
	local label="$1"
	local result; result=$(cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invoices = data.get('invoices', [])
if not invoices: print(json.dumps({'error': 'invoice not found'})); sys.exit(0)
i = invoices[0]
print(json.dumps({'label': i.get('label'), 'description': i.get('description')}))
" "$result"
}

cmd_qr_data() {
	[ $# -lt 1 ] && { error "invoice qr-data needs <bolt11>"; exit 1; }
	local bolt11="$1"
	local upper; upper=$(echo "$bolt11" | tr '[:lower:]' '[:upper:]')
	echo "{\"bolt11\":\"$bolt11\",\"qr_data\":\"LIGHTNING:$upper\"}"
}

cmd_keysend() {
	[ $# -lt 2 ] && { error "invoice keysend needs <node_id> <amount_msat>"; exit 1; }
	local node_id="$1" amount_msat="$2"
	local result; result=$(cli keysend "$node_id" "$amount_msat" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'payment_hash': data.get('payment_hash', ''), 'status': data.get('status', '')}))
" "$result"
}

cmd_summary_invoice() {
	local result; result=$(cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invoices = data.get('invoices', [])
paid = sum(1 for i in invoices if i.get('status') == 'paid')
unpaid = sum(1 for i in invoices if i.get('status') == 'unpaid')
expired = sum(1 for i in invoices if i.get('status') == 'expired')
total_recv = sum(i.get('amount_received_msat', 0) for i in invoices if i.get('status') == 'paid')
print(json.dumps({'total': len(invoices), 'paid': paid, 'unpaid': unpaid, 'expired': expired,
    'total_received_msat': total_recv}))
" "$result"
}

# -----------------------------------------------------------------------------
# cmd_stats — single Python pass over all invoices
# -----------------------------------------------------------------------------
cmd_invoice_stats() {
	local field=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--field) field="$2"; shift 2 ;;
			--field=*) field="${1#--field=}"; shift ;;
			*) error "invoice stats: unknown option '$1'"; exit 1 ;;
		esac
	done

	local raw; raw=$(cli listinvoices 2>/dev/null) || raw='{"invoices":[]}'
	export _STAT_FIELD="$field"
	python3 - "$raw" <<'PYEOF'
import sys, json, os, time

invoices = json.loads(sys.argv[1]).get('invoices', [])
now = int(time.time())

paid    = [i for i in invoices if i.get('status') == 'paid']
unpaid  = [i for i in invoices if i.get('status') == 'unpaid']
expired = [i for i in invoices if i.get('status') == 'expired']
active  = [i for i in unpaid if i.get('expires_at', 0) > now]

amounts       = [i.get('amount_msat', 0) or 0 for i in invoices]
paid_amounts  = [i.get('amount_received_msat', 0) or 0 for i in paid]
total_received= sum(paid_amounts)
max_amount    = max(amounts) if amounts else 0
min_amount    = min(a for a in amounts if a > 0) if any(a > 0 for a in amounts) else 0

result = {
    "total_count":          len(invoices),
    "paid_count":           len(paid),
    "unpaid_count":         len(unpaid),
    "expired_count":        len(expired),
    "active_count":         len(active),
    "total_received_msat":  total_received,
    "max_amount_msat":      max_amount,
    "min_amount_msat":      min_amount,
    "avg_amount_msat":      int(sum(amounts)/len(amounts)) if amounts else 0,
    "avg_received_msat":    int(total_received/len(paid)) if paid else 0,
}

field = os.environ.get("_STAT_FIELD", "")
if field:
    print(json.dumps(result.get(field)))
else:
    print(json.dumps(result))
PYEOF
}

subhelp() {
	case "$1" in
		create)
			cat <<'EOF'
usage: lightning invoice create <sat> <label>
            [--description <text>] [--expiry <sec>]
            [--qr] [--account <name>]

Mint a BOLT-11 invoice for <sat> sats. <label> is a daemon-side
unique identifier; --description sets the human-readable memo (or
reuses label). --expiry defaults to 3600s. --qr also renders the
invoice as a QR code. --account tags it in the wallet's invoices
table for the ledger.
EOF
			;;
		pay)
			cat <<'EOF'
usage: lightning invoice pay <bolt11>
            [--max-fee-sat N] [--timeout S]
            [--account <name>] [--note <text>]

Pay a BOLT-11 invoice. --max-fee-sat caps routing fees; --timeout
gives up after S seconds (default 60). --account writes the payment
to the ledger and enforces overdraft policy (deny/warn/allow);
--note attaches a local-only annotation.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="$1"; shift || true
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac
case "$SUB" in
	help) subhelp "${1:-}" || usage; exit ;;
esac

require_cli

case "$SUB" in
	create)          cmd_create "$@" ;;
	pay)             cmd_pay "$@" ;;
	stats)           cmd_invoice_stats "$@" ;;
	status)          cmd_status "$@" ;;
	cancel)          cmd_cancel "$@" ;;
	expire)          cmd_expire "$@" ;;
	delete)          cmd_delete "$@" ;;
	lookup)          cmd_lookup "$@" ;;
	wait)            cmd_wait_invoice "$@" ;;
	settle)          cmd_settle "$@" ;;
	summary)         cmd_summary_invoice "$@" ;;
	list-all)        cmd_list_all "$@" ;;
	list-paid)       cmd_list_paid "$@" ;;
	list-pending)    cmd_list_pending "$@" ;;
	list-expired)    cmd_list_expired "$@" ;;
	list-active)     cmd_list_active "$@" ;;
	list-by-status)  cmd_list_by_status "$@" ;;
	bolt11-decode)   cmd_bolt11_decode "$@" ;;
	bolt11-check)    cmd_bolt11_check "$@" ;;
	payment-hash)    cmd_payment_hash "$@" ;;
	description)     cmd_description "$@" ;;
	qr-data)         cmd_qr_data "$@" ;;
	keysend)         cmd_keysend "$@" ;;
	*) usage; exit 1 ;;
esac
