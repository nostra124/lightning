#!/bin/bash
# lightning channel-pending   (FEAT-322)
set -e
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pending = [
    {
        'channel_id': c.get('channel_id', ''),
        'peer_id': c.get('peer_id', ''),
        'state': c.get('state', ''),
        'to_us_msat': c.get('to_us_msat', 0),
        'total_msat': c.get('total_msat', 0),
    }
    for c in channels
    if c.get('state', '') not in ('CHANNELD_NORMAL', 'CLOSED')
]
print(json.dumps(pending, separators=(',', ':')))
" "$result"
