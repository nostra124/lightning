#!/bin/bash
# lightning wallet-tag-count <wallet_name>   (FEAT-1333)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-tag-count <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, sqlite3, json
db = sys.argv[1]; wname = sys.argv[2]
conn = sqlite3.connect(db)
row = conn.execute('SELECT COUNT(DISTINCT tag) FROM tags').fetchone()
conn.close()
print(json.dumps({'wallet': wname, 'count': row[0]}))
" "$db" "$wname" 2>/dev/null || echo '{"error":"db_error"}'
