#!/bin/bash
# lightning node-graph-node-count   (FEAT-1344)
result=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
print(json.dumps({'node_count': len(nodes)}))
" "$result"
