#!/bin/bash
# lightning node-graph-node-count   (FEAT-1029)
if ! result=$(lightning-cli listnodes 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
print(json.dumps({'node_count': len(nodes)}))
" "$result"
