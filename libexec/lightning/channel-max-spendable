#!/bin/bash
# lightning channel-max-spendable   (FEAT-2018)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
max_spendable = 0
best_channel = None
for ch in channels:
    val = ch.get('spendable_msat', 0)
    if isinstance(val, str):
        val = int(val.replace('msat',''))
    if val > max_spendable:
        max_spendable = val
        best_channel = ch.get('channel_id', ch.get('short_channel_id'))
print(json.dumps({'max_spendable_msat': max_spendable, 'channel_id': best_channel}))
" "$result"
