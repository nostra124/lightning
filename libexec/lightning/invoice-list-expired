#!/bin/bash
# lightning invoice-list-expired   (FEAT-1015)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
expired = [i for i in data.get('invoices', []) if i.get('status') == 'expired']
print(json.dumps(expired))
" "$result"
