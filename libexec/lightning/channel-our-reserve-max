#!/bin/bash
# lightning channel-our-reserve-max   (FEAT-2340)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_val = -1
for ch in channels:
    val = ch.get('our_reserve_msat', 0)
    if val > best_val:
        best_val = val
        best = {'peer_id': ch.get('peer_id',''), 'our_reserve_msat': val}
if best is None:
    best = {'peer_id': None, 'our_reserve_msat': 0}
print(json.dumps(best))
" "$result"
