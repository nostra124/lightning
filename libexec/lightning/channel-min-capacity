#!/bin/bash
# lightning channel-min-capacity <min_msat>   (FEAT-1060)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-min-capacity <min_msat>"}'
    exit 0
fi
min_msat="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
min_m = int(sys.argv[2])
channels = [ch for ch in data.get('channels', []) if ch.get('total_msat', 0) >= min_m]
print(json.dumps({'count': len(channels), 'channels': [ch.get('channel_id') for ch in channels]}))
" "$result" "$min_msat"
