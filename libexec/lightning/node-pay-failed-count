#!/bin/bash
# lightning node-pay-failed-count   (FEAT-1171)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
failed = [p for p in pays if p.get('status') == 'failed']
print(json.dumps({'failed_count': len(failed), 'total': len(pays)}))
" "$result"
