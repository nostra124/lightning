#!/bin/bash
# lightning node-listchannels-with-alias   (FEAT-1374)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [{'channel_id': c.get('channel_id'), 'alias': c.get('alias', {})} for c in data.get('channels', []) if c.get('alias')]
print(json.dumps({'count': len(channels), 'channels': channels}))
" "$result"
