#!/bin/bash
# lightning peer-balance-ratio-stddev   (FEAT-3004)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ratios = []
for ch in channels:
    total = ch.get('total_msat', 0)
    spendable = ch.get('spendable_msat', 0)
    if isinstance(total, str): total = int(total.replace('msat',''))
    if isinstance(spendable, str): spendable = int(spendable.replace('msat',''))
    if total > 0:
        ratios.append(spendable / total)
if len(ratios) > 1:
    mean = sum(ratios) / len(ratios)
    stddev = math.sqrt(sum((r - mean)**2 for r in ratios) / len(ratios))
    print(json.dumps({'balance_ratio_stddev_peer': stddev}))
else:
    print(json.dumps({'balance_ratio_stddev_peer': None}))
" "$result"
