#!/bin/bash
# lightning node-listforwards-in-msat-kurtosis   (FEAT-2809)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
vals = [f.get('in_msat', 0) for f in fwds if 'in_msat' in f]
n = len(vals)
if n >= 4:
    mean = sum(vals) / n
    std = math.sqrt(sum((v - mean)**2 for v in vals) / n)
    kurtosis = (sum((v - mean)**4 for v in vals) / n) / (std**4) - 3 if std > 0 else 0.0
else:
    kurtosis = 0.0
print(json.dumps({'in_msat_kurtosis': round(kurtosis, 6), 'count': n}))
" "$result"
