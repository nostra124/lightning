#!/bin/bash
# lightning channel-balance-available   (FEAT-1050)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [ch for ch in data.get('channels', []) if ch.get('state') == 'CHANNELD_NORMAL']
spendable = sum(ch.get('spendable_msat', 0) for ch in channels)
receivable = sum(ch.get('receivable_msat', 0) for ch in channels)
print(json.dumps({'spendable_msat': spendable, 'receivable_msat': receivable, 'channel_count': len(channels)}))
" "$result"
