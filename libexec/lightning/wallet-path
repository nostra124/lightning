#!/bin/bash
# lightning wallet-path <wallet_name>   (FEAT-523)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-path <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
wpath="$root/$wname"
if [ -d "$wpath" ]; then
    echo "{\"wallet\":\"$wname\",\"path\":\"$wpath\",\"exists\":true}"
else
    echo "{\"wallet\":\"$wname\",\"path\":\"$wpath\",\"exists\":false}"
fi
