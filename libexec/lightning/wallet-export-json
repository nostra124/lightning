#!/bin/bash
# lightning wallet-export-json <wallet_name>   (FEAT-608)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-export-json <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
meta=$(sqlite3 "$db" "SELECT json_group_object(key,value) FROM meta;" 2>/dev/null) || { echo '{"error":"sqlite3 not found"}'; exit 0; }
python3 -c "import sys,json; print(json.dumps({'wallet': sys.argv[1], 'meta': json.loads(sys.argv[2] or '{}')}))" "$wname" "$meta"
