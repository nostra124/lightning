#!/bin/bash
# lightning channel-local-balance-top10   (FEAT-2582)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
sorted_ch = sorted(channels, key=lambda c: int(c.get('to_us_msat', 0)), reverse=True)[:10]
out = [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id'), 'to_us_msat': c.get('to_us_msat')} for c in sorted_ch]
print(json.dumps({'top10_channels_by_local': out}))
" "$result"
