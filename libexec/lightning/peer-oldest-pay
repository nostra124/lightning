#!/bin/bash
# lightning peer-oldest-pay   (FEAT-2328)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'error': 'no complete pays'}))
else:
    oldest = min(pays, key=lambda p: p.get('created_at', 0))
    print(json.dumps({'destination': oldest.get('destination', ''), 'payment_hash': oldest.get('payment_hash', ''), 'amount_msat': oldest.get('amount_msat', 0), 'created_at': oldest.get('created_at', 0)}))
" "$result"
