#!/bin/bash
# lightning invoice-local-offer-id <label>   (FEAT-1255)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-local-offer-id <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if invoices:
    inv = invoices[0]
    print(json.dumps({'label': inv.get('label'), 'local_offer_id': inv.get('local_offer_id')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
