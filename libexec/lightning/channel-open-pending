#!/bin/bash
# lightning channel-open-pending   (FEAT-596)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pending = [c for c in data.get('channels', []) if c.get('state') not in ('CHANNELD_NORMAL', 'CLOSED')]
print(json.dumps(pending))
" "$result"
