#!/bin/bash
# lightning channel-capacity-median   (FEAT-2320)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = sorted(
    (ch.get('local_msat', 0) + ch.get('remote_msat', 0))
    for ch in channels
    if 'local_msat' in ch and 'remote_msat' in ch
)
if not vals:
    print(json.dumps({'median_capacity_msat': None, 'channel_count': 0}))
else:
    n = len(vals)
    if n % 2 == 1:
        median = vals[n // 2]
    else:
        median = (vals[n // 2 - 1] + vals[n // 2]) / 2
    print(json.dumps({'median_capacity_msat': median, 'channel_count': n}))
" "$result"
