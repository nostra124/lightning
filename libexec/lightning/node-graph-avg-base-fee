#!/bin/bash
# lightning node-graph-avg-base-fee   (FEAT-1939)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
n = len(channels)
if n == 0:
    avg = None
else:
    avg = round(sum(ch.get('base_fee_millisatoshi', 0) for ch in channels) / n, 2)
print(json.dumps({'channel_count': n, 'avg_base_fee_msat': avg}))
" "$result"
