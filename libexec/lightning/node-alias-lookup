#!/bin/bash
# lightning node-alias-lookup <node_id>   (FEAT-529)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-alias-lookup <node_id>"}'
    exit 0
fi
node_id="$1"
result=$(lightning-cli listnodes "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
if nodes:
    n = nodes[0]
    print(json.dumps({'node_id': n.get('nodeid'), 'alias': n.get('alias', ''), 'color': n.get('color', '')}))
else:
    print(json.dumps({'node_id': sys.argv[2], 'alias': None}))
" "$result" "$node_id"
