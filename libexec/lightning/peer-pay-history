#!/bin/bash
# lightning peer-pay-history <peer_id>   (FEAT-1167)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-pay-history <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
pays = [p for p in data.get('pays', []) if p.get('destination') == pid]
print(json.dumps({'peer_id': pid, 'count': len(pays), 'pays': pays}))
" "$result" "$peer_id"
