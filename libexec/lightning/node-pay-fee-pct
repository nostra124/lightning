#!/bin/bash
# lightning node-pay-fee-pct   (FEAT-1961)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
fees = []
for p in complete:
    sent = p.get('amount_sent_msat', 0)
    amt = p.get('amount_msat', 0)
    if isinstance(sent, str): sent = int(sent.replace('msat',''))
    if isinstance(amt, str): amt = int(amt.replace('msat',''))
    if amt and amt > 0:
        fees.append((sent - amt) / amt * 100)
avg = round(sum(fees)/len(fees), 4) if fees else None
print(json.dumps({'count': len(complete), 'avg_fee_pct': avg}))
" "$result"
