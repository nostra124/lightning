#!/bin/bash
# lightning node-invoice-paid-streak   (FEAT-2217)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
invoices.sort(key=lambda x: x.get('paid_at', x.get('expires_at', 0)), reverse=True)
streak = 0
for inv in invoices:
    if inv.get('status') == 'paid':
        streak += 1
    else:
        break
print(json.dumps({'streak': streak, 'total_invoices': len(invoices)}))
" "$result"
