#!/bin/bash
# lightning peer-htlc-count-total   (FEAT-2888)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
count = sum(len(ch.get('htlcs', [])) for ch in channels)
print(json.dumps({'htlc_count_total': count}))
" "$result"
