#!/bin/bash
# lightning wallet-notes-count-by-value <wallet> <value>   (FEAT-1583)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-count-by-value <wallet> <value>"}'; exit 0; fi
wname="$1"; value="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE value='$value';" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"value\":\"$value\",\"count\":$count}"
