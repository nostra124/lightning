#!/bin/bash
# lightning node-invoice-last   (FEAT-1241)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = sorted(data.get('invoices', []), key=lambda i: i.get('expires_at', 0), reverse=True)
if invoices:
    print(json.dumps({'last_invoice': invoices[0]}))
else:
    print(json.dumps({'last_invoice': None}))
" "$result"
