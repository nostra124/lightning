#!/bin/bash
# lightning node-listforwards-in-msat-max   (FEAT-2591)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
if not forwards:
    print(json.dumps({'max_in_msat': 0}))
else:
    mx = max(int(f.get('in_msat', 0)) for f in forwards)
    print(json.dumps({'max_in_msat': mx}))
" "$result"
