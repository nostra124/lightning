#!/bin/bash
# lightning node-pay-amount-avg   (FEAT-1651)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete' and p.get('amount_sent_msat') is not None]
if not pays:
    print(json.dumps({'avg_amount_msat': None, 'count': 0}))
    sys.exit(0)
amounts = [p['amount_sent_msat'] for p in pays]
print(json.dumps({'avg_amount_msat': sum(amounts) / len(amounts), 'count': len(amounts)}))
" "$result"
