#!/bin/bash
# lightning node-invoice-expiry-min   (FEAT-2374)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
unpaid = [i for i in invoices if i.get('status') == 'unpaid']
if not unpaid:
    print(json.dumps({'label': None, 'expiry': None, 'unpaid_count': 0}))
else:
    soonest = min(unpaid, key=lambda i: i.get('expiry', float('inf')))
    print(json.dumps({'label': soonest.get('label'), 'expiry': soonest.get('expiry'), 'expires_at': soonest.get('expires_at'), 'unpaid_count': len(unpaid)}))
" "$result"
