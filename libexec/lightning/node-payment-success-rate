#!/bin/bash
# lightning node-payment-success-rate   (FEAT-729)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
total = len(pays)
complete = len([p for p in pays if p.get('status') == 'complete'])
rate = round(complete / total * 100, 2) if total > 0 else 0
print(json.dumps({'total': total, 'complete': complete, 'success_rate_pct': rate}))
" "$result"
