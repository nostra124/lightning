#!/bin/bash
# lightning peer-local-balance-total   (FEAT-2076)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
totals = {}
for c in channels:
    peer = c.get('peer_id', '')
    msat = int(str(c.get('to_us_msat', 0)).replace('msat',''))
    totals[peer] = totals.get(peer, 0) + msat
print(json.dumps({'peer_local_balance': totals}))
" "$result"
