#!/bin/bash
# lightning node-check-config   (FEAT-395)
set -e
result=$(lightning-cli listconfigs 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
cfg = json.loads(sys.argv[1])
configs = cfg.get('configs', cfg)
important = {k: v for k, v in configs.items() if k in [
    'network', 'log-level', 'alias', 'rgb', 'fee-base', 'fee-per-satoshi',
    'min-capacity-sat', 'max-concurrent-htlcs', 'cltv-delta'
]}
print(json.dumps({'config_count': len(configs), 'key_settings': important}, separators=(',', ':')))
" "$result"
