#!/bin/bash
# lightning node-pay-median-msat   (FEAT-1339)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
amounts = sorted(int(str(p.get('amount_sent_msat',0)).replace('msat','')) for p in data.get('pays', []) if p.get('status') == 'complete')
if not amounts:
    print(json.dumps({'count': 0, 'median_msat': 0}))
else:
    n = len(amounts)
    med = amounts[n//2] if n % 2 else (amounts[n//2-1] + amounts[n//2]) // 2
    print(json.dumps({'count': n, 'median_msat': med}))
" "$result"
