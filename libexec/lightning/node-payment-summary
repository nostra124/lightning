#!/bin/bash
# lightning node-payment-summary   (FEAT-342)
set -e
pays=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
invs=$(lightning-cli listinvoices 2>/dev/null) || invs='{"invoices":[]}'
python3 -c "
import sys, json
pays = json.loads(sys.argv[1]).get('pays', [])
invs = json.loads(sys.argv[2]).get('invoices', [])
sent = [p for p in pays if p.get('status') == 'complete']
received = [i for i in invs if i.get('status') == 'paid']
total_sent = sum(p.get('amount_sent_msat', 0) for p in sent)
total_recv = sum(i.get('amount_received_msat', 0) for i in received)
print(json.dumps({
    'payments_sent': len(sent),
    'total_sent_msat': total_sent,
    'invoices_paid': len(received),
    'total_received_msat': total_recv,
    'net_msat': total_recv - total_sent,
}, separators=(',', ':')))
" "$pays" "$invs"
