#!/bin/bash
# lightning node-rebalance-status   (FEAT-564)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
imbalanced = []
for ch in channels:
    local = ch.get('to_us_msat', 0)
    total = ch.get('total_msat', 1)
    if total > 0:
        ratio = local / total
        if ratio < 0.2 or ratio > 0.8:
            imbalanced.append({'channel_id': ch.get('channel_id'), 'local_ratio': round(ratio, 3)})
print(json.dumps({'imbalanced_channels': imbalanced, 'count': len(imbalanced)}))
" "$result"
