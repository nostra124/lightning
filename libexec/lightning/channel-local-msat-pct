#!/bin/bash
# lightning channel-local-msat-pct <channel_id>   (FEAT-1076)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-local-msat-pct <channel_id>"}'
    exit 0
fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        local = ch.get('to_us_msat', 0)
        total = ch.get('total_msat', 1)
        pct = round(local / total * 100, 2) if total else 0
        print(json.dumps({'channel_id': ch.get('channel_id'), 'local_msat': local, 'total_msat': total, 'local_pct': pct}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
