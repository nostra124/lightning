#!/bin/bash
# lightning node-listforwards-fee-range   (FEAT-2759)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
fees = [f.get('fee_msat', 0) for f in forwards]
fee_range = max(fees) - min(fees) if len(fees) > 1 else 0
print(json.dumps({'fee_range_msat': fee_range}))
" "$result"
