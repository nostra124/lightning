#!/bin/bash
# lightning peer-bandwidth <peer_id>   (FEAT-977)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-bandwidth <peer_id>"}'; exit 0; fi
peer_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); pid = sys.argv[2]
chs = [c for c in data.get('channels', []) if c.get('peer_id') == pid and c.get('state') == 'CHANNELD_NORMAL']
spendable = sum(c.get('spendable_msat', 0) for c in chs)
receivable = sum(c.get('receivable_msat', 0) for c in chs)
print(json.dumps({'peer_id': pid, 'spendable_msat': spendable, 'receivable_msat': receivable}))
" "$result" "$peer_id"
