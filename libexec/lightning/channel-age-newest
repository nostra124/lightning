#!/bin/bash
# lightning channel-age-newest   (FEAT-2150)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
by_time = [c for c in channels if c.get('opened_at')]
if not by_time:
    if channels:
        c = channels[-1]
        print(json.dumps({'newest': {'peer_id': c.get('peer_id',''), 'short_channel_id': c.get('short_channel_id','')}}))
    else:
        print(json.dumps({'newest': None}))
    sys.exit(0)
newest = max(by_time, key=lambda c: c['opened_at'])
print(json.dumps({'newest': {'peer_id': newest.get('peer_id',''), 'opened_at': newest.get('opened_at'), 'short_channel_id': newest.get('short_channel_id','')}}))
" "$result"
