#!/bin/bash
# lightning node-rebalance-needed <threshold_pct>   (FEAT-739)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-rebalance-needed <threshold_pct>"}'; exit 0; fi
threshold="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
threshold = float(sys.argv[2]) / 100
channels = data.get('channels', [])
imbalanced = []
for c in channels:
    total = c.get('total_msat', 0)
    to_us = c.get('to_us_msat', 0)
    if isinstance(total, int) and isinstance(to_us, int) and total > 0:
        ratio = to_us / total
        if ratio < threshold or ratio > (1 - threshold):
            imbalanced.append({'channel_id': c.get('channel_id'), 'ratio': round(ratio, 3)})
print(json.dumps({'imbalanced': imbalanced, 'count': len(imbalanced)}))
" "$result" "$threshold"
