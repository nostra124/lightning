#!/bin/bash
# lightning channel-opener-remote   (FEAT-1810)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
remote_opened = [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id')} for c in channels if c.get('opener') == 'remote']
print(json.dumps({'count': len(remote_opened), 'channels': remote_opened}))
" "$result"
