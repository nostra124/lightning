#!/bin/bash
# lightning wallet-meta-delete <wallet_name> <key>   (FEAT-1273)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-meta-delete <wallet_name> <key>"}'; exit 0; fi
wname="$1"; key="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "DELETE FROM meta WHERE key='$key';" 2>/dev/null
echo "{\"ok\":true,\"wallet\":\"$wname\",\"deleted\":\"$key\"}"
