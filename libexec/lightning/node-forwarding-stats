#!/bin/bash
# lightning node-forwarding-stats [--days N]   (FEAT-356)
set -e
days=30
while [ $# -gt 0 ]; do
    case "$1" in
        --days) days="$2"; shift 2 ;;
        *) shift ;;
    esac
done
cutoff=$(( $(date +%s) - days * 86400 ))
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cutoff = int(sys.argv[2])
fwds = [f for f in data.get('forwards', []) if f.get('resolved_time', 0) >= cutoff]
total_in = sum(f.get('in_msat', 0) for f in fwds)
total_fee = sum(f.get('fee_msat', 0) for f in fwds)
print(json.dumps({
    'period_days': int(sys.argv[3]),
    'count': len(fwds),
    'total_in_msat': total_in,
    'total_fee_msat': total_fee,
}, separators=(',', ':')))
" "$result" "$cutoff" "$days"
