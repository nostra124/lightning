#!/bin/bash
# lightning wallet-notes-batch-get <wallet> <key1> [key2...]   (FEAT-1593)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-batch-get <wallet> <key1> [key2...]"}'; exit 0; fi
wname="$1"; shift
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
result="{\"wallet\":\"$wname\",\"notes\":{"
first=1
for key in "$@"; do
    val=$(sqlite3 "$db" "SELECT value FROM notes WHERE key='$key';" 2>/dev/null)
    if [ $first -eq 0 ]; then result="$result,"; fi
    result="${result}\"$key\":$([ -n "$val" ] && echo "\"$val\"" || echo 'null')"
    first=0
done
echo "${result}}}"
