#!/bin/bash
# lightning node-listpays-by-hash <payment_hash>   (FEAT-1521)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listpays-by-hash <payment_hash>"}'; exit 0; fi
phash="$1"
result=$(lightning-cli listpays payment_hash="$phash" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'payment_hash': sys.argv[2], 'count': len(pays), 'pays': pays}))
" "$result" "$phash"
