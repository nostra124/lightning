#!/bin/bash
# lightning backup — one-shot backup/restore umbrella (FEAT-187).
#
# Usage:
#   lightning backup [--seed]
#   lightning restore <wallet-remote>
#   lightning backup verify

set -e

usage() {
	cat >&2 <<EOF
usage: lightning backup [--seed]
       lightning restore <wallet-remote>
       lightning backup verify
EOF
}

# Default to 'backup' when called directly (no subcommand arg).
[ $# -lt 1 ] && set -- backup

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
# Resolve sibling-verb directory: SELF_LIBEXEC/lightning/ when called
# from the bin/lightning dispatcher (SELF_LIBEXEC = libexec/ parent).
_LIB="${SELF_LIBEXEC:+"$SELF_LIBEXEC/lightning"}"
_LIB="${_LIB:-$(cd "$(dirname "$0")" && pwd)}"

cmd_backup() {
	local include_seed=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--seed) include_seed=1; shift ;;
			*) echo "lightning backup: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	# 1. Emit SCB.
	"$_LIB/scb" emit

	# 2. Optional seed export into wallet.
	if [ "$include_seed" -eq 1 ]; then
		cat >&2 <<'BANNER'
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!   WARNING: storing your seed in the wallet repo       !
!   makes it available to anyone who can read the git   !
!   history. Only use --seed if you understand this.    !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
BANNER
		local active; active=$(cat "$LIGHTNING_DIR/wallet/.active" 2>/dev/null || echo "default")
		local seed_path="$LIGHTNING_DIR/wallet/$active/seed.enc"
		"$_LIB/seed" export --out "$seed_path"
		echo "lightning: seed exported to $seed_path" >&2

		local wdir="$LIGHTNING_DIR/wallet/$active"
		if [ -d "$wdir/.git" ]; then
			git -C "$wdir" add "$seed_path" 2>/dev/null || true
			git -C "$wdir" commit -m "backup: seed export" --quiet 2>/dev/null || true
		fi
	fi

	# 3. Git push.
	"$_LIB/wallet" push

	echo "lightning: backup complete" >&2
}

cmd_restore() {
	[ $# -lt 1 ] && { echo "usage: lightning restore <wallet-remote>" >&2; exit 1; }
	local remote="$1"
	local name; name=$(basename "$remote" .git)

	# Clone the wallet repo.
	git clone "$remote" "$LIGHTNING_DIR/wallet/$name" 2>/dev/null || {
		echo "lightning: failed to clone $remote" >&2; exit 4; }

	# Set as active.
	echo "$name" > "$LIGHTNING_DIR/wallet/.active"

	# Rebuild state.db from state.sql.
	local wdir="$LIGHTNING_DIR/wallet/$name"
	if [ -f "$wdir/state.sql" ] && ! [ -f "$wdir/state.db" ]; then
		sqlite3 "$wdir/state.db" < "$wdir/state.sql"
	fi

	# Collect latest SCB.
	local latest_scb; latest_scb=$(ls -t "$wdir/scb/"*.json 2>/dev/null | head -1)

	echo "lightning: wallet restored from $remote" >&2
	echo "lightning: now run 'lightning seed import' to restore your seed,"
	echo "          then 'lightning unlock' to unlock the daemon." >&2

	if [ -n "$latest_scb" ]; then
		echo "lightning: latest SCB: $latest_scb" >&2
		echo "          run 'lightning scb restore $latest_scb' after unlock" >&2
	fi
}

cmd_verify() {
	# Check SCB present.
	local active; active=$(cat "$LIGHTNING_DIR/wallet/.active" 2>/dev/null || echo "default")
	local wdir="$LIGHTNING_DIR/wallet/$active"
	local scb_count; scb_count=$(ls "$wdir/scb/"*.json 2>/dev/null | wc -l)

	[ "$scb_count" -gt 0 ] || {
		echo "lightning: WARNING — no SCB snapshots found in wallet" >&2
	}

	# Check wallet remote reachable.
	local remote
	remote=$(git -C "$wdir" remote get-url origin 2>/dev/null) || remote="(none)"
	echo "wallet:      $active"
	echo "remote:      $remote"
	echo "scb_count:   $scb_count"

	# Check seed export (if present).
	if [ -f "$wdir/seed.enc" ]; then
		echo "seed:        present at $wdir/seed.enc"
	else
		echo "seed:        not stored in wallet (expected — use --seed at backup time)"
	fi
	echo "lightning: backup structure looks intact" >&2
}

case "$1" in
	backup)  shift; cmd_backup "$@" ;;
	restore) shift; cmd_restore "$@" ;;
	verify)  shift; cmd_verify "$@" ;;
	*) usage; exit 1 ;;
esac
