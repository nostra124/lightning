#!/bin/bash
# lightning node-listforwards-count-failed   (FEAT-2671)
result=$(lightning-cli listforwards status=failed 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
print(json.dumps({'failed_count': len(forwards)}))
" "$result"
