#!/bin/bash
# lightning channel-peer-summary   (FEAT-446)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
by_peer = {}
for c in channels:
    pid = c.get('peer_id', '')
    if pid not in by_peer:
        by_peer[pid] = {'peer_id': pid, 'channels': 0, 'total_msat': 0, 'local_msat': 0}
    by_peer[pid]['channels'] += 1
    by_peer[pid]['total_msat'] += c.get('total_msat', 0)
    by_peer[pid]['local_msat'] += c.get('to_us_msat', 0)
print(json.dumps(list(by_peer.values()), separators=(',', ':')))
" "$result"
