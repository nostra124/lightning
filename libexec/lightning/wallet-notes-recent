#!/bin/bash
# lightning wallet-notes-recent   (FEAT-2053)
N=${1:-10}
result=$(sqlite3 wallet.db "SELECT id, note, created_at FROM notes ORDER BY created_at DESC LIMIT $N;" 2>/dev/null) || { echo '{"error":"sqlite3 not available or no wallet.db"}'; exit 0; }
python3 -c "
import sys, json
lines = sys.argv[1].strip().split('\n') if sys.argv[1].strip() else []
notes = []
for line in lines:
    parts = line.split('|', 2)
    if len(parts) == 3:
        notes.append({'id': parts[0], 'note': parts[1], 'created_at': parts[2]})
print(json.dumps({'recent_notes': notes}))
" "$result"
