#!/bin/bash
# lightning node-listpays-count-by-dest <dest>   (FEAT-1881)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listpays-count-by-dest <dest>"}'; exit 0; fi
dest="$1"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
d = sys.argv[2]
pays = [p for p in data.get('pays', []) if p.get('destination') == d]
print(json.dumps({'destination': d, 'count': len(pays)}))
" "$result" "$dest"
