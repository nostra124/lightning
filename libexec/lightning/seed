#!/bin/bash
# lightning seed — seed backup & recovery (FEAT-185).
#
# Usage:
#   lightning seed export [--out <file>]
#   lightning seed import
#   lightning seed verify

set -e

usage() {
	cat >&2 <<EOF
usage: lightning seed <subcommand> [args]

subcommands:
   export [--out <file>]
   import
   verify
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"

command -v lightning-cli >/dev/null || {
	echo "lightning: lightning-cli not found — install Core Lightning" >&2; exit 127; }

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

hsm_secret_path() {
	local p="$LIGHTNING_DIR/$LIGHTNING_NETWORK/hsm_secret"
	[ -f "$p" ] || p="$LIGHTNING_DIR/hsm_secret"
	echo "$p"
}

cmd_export() {
	local outfile=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--out) outfile="$2"; shift 2 ;;
			*) echo "lightning seed export: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	hs=$(hsm_secret_path)
	[ -f "$hs" ] || { echo "lightning: no hsm_secret found at $hs" >&2; exit 4; }

	local mnemonic
	mnemonic=$(cli hsmtool gethsmsecret "$hs" 2>/dev/null | tr -d '"\n' || true)
	if [ -z "$mnemonic" ]; then
		# Fallback: show the raw hex as a hexdump.
		mnemonic=$(xxd -p "$hs" 2>/dev/null | tr -d '\n')
	fi

	if [ -n "$outfile" ]; then
		echo "$mnemonic" > "$outfile"
		chmod 600 "$outfile"
		echo "lightning: seed written to $outfile (keep this safe!)" >&2
	else
		cat >&2 <<'BANNER'
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                    WARNING                            !
!    This seed controls ALL your Lightning funds.       !
!    Anyone with this phrase can steal your money.      !
!    Read it once, then store it OFFLINE.               !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
BANNER
		echo >&2
		echo "$mnemonic"
	fi
}

cmd_import() {
	echo -n "lightning: paste your seed phrase (12/24 words) and press Enter: " >&2
	read -r phrase

	hs=$(hsm_secret_path)
	if [ -f "$hs" ] && [ ! -s "$hs" ]; then
		rm -f "$hs"
	fi
	[ -f "$hs" ] && {
		echo "lightning: hsm_secret already exists; refusing to overwrite" >&2
		exit 3
	}

	if ! cli hsmtool generatehsm "$hs" 2>/dev/null <<<"$phrase"; then
		echo "lightning: seed import failed (wrong phrase length?)" >&2
		exit 4
	fi
	echo "ok"
	echo "lightning: seed imported; daemon ready for unlock" >&2
}

cmd_verify() {
	hs=$(hsm_secret_path)
	[ -f "$hs" ] || { echo "lightning: no hsm_secret found" >&2; exit 4; }

	local mnemonic
	mnemonic=$(cli hsmtool gethsmsecret "$hs" 2>/dev/null | tr -d '"\n' || true)
	[ -z "$mnemonic" ] && {
		echo "lightning: could not read seed from daemon" >&2
		exit 4
	}

	# Extract two random words and ask user to re-type them.
	IFS=' ' read -ra words <<<"$mnemonic"
	local n=${#words[@]}
	[ "$n" -lt 12 ] && { echo "lightning: seed phrase too short ($n words)" >&2; exit 4; }

	# Use /dev/random to pick indices.
	local i1 i2
	i1=$(( ($(od -An -N2 -i /dev/random) % n) ))
	i2=$(( ($(od -An -N2 -i /dev/random 2>/dev/null || echo 42) % n) ))
	while [ "$i2" = "$i1" ]; do
		i2=$(( (i2 + 1) % n ))
	done

	echo -n "lightning: verify seed — word $((i1+1)): " >&2
	read -r w1
	echo -n "lightning: verify seed — word $((i2+1)): " >&2
	read -r w2

	if [ "${words[$i1]}" = "$w1" ] && [ "${words[$i2]}" = "$w2" ]; then
		echo "ok"
		echo "lightning: seed verified" >&2
	else
		echo "lightning: seed verification FAILED — phrases do not match" >&2
		exit 2
	fi
}

case "$1" in
	export) shift; cmd_export "$@" ;;
	import) shift; cmd_import "$@" ;;
	verify) shift; cmd_verify "$@" ;;
	*) usage; exit 1 ;;
esac
