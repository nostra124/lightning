#!/bin/bash
# lightning channel-fee-base-range   (FEAT-2495)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
bases = [c.get('fee_base_msat', 0) for c in channels if 'fee_base_msat' in c]
if bases:
    print(json.dumps({'fee_base_range_msat': max(bases) - min(bases), 'fee_base_min': min(bases), 'fee_base_max': max(bases)}))
else:
    print(json.dumps({'fee_base_range_msat': None, 'fee_base_min': None, 'fee_base_max': None}))
" "$result"
