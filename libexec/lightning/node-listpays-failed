#!/bin/bash
# lightning node-listpays-failed   (FEAT-1594)
result=$(lightning-cli listpays status=failed 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'count': len(pays), 'pays': pays}))
" "$result"
