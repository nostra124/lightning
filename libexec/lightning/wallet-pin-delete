#!/bin/bash
# lightning wallet-pin-delete <wallet_name>   (FEAT-1028)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-pin-delete <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
echo "{\"ok\":true,\"wallet\":\"$wname\",\"pin_deleted\":true}"
