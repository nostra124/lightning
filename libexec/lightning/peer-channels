#!/bin/bash
# lightning peer-channels <peer_id>   (FEAT-385)
set -e
[ $# -ge 1 ] || { echo '{"error":"usage: peer-channels <peer_id>"}'; exit 0; }
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [
    {'channel_id': c.get('channel_id', ''), 'state': c.get('state', ''),
     'to_us_msat': c.get('to_us_msat', 0), 'total_msat': c.get('total_msat', 0)}
    for c in data.get('channels', [])
]
print(json.dumps(channels, separators=(',', ':')))
" "$result"
