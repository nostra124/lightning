#!/bin/bash
# lightning node-graph-max-capacity   (FEAT-2034)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
max_sat = 0
for ch in channels:
    sat = ch.get('satoshis', 0)
    if sat > max_sat:
        max_sat = sat
print(json.dumps({'max_capacity_sat': max_sat}))
" "$result"
