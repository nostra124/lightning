#!/bin/bash
# lightning node-graph-max-capacity   (FEAT-1949)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
max_cap = None
for c in channels:
    s = c.get('satoshis')
    if s is not None:
        if max_cap is None or s > max_cap:
            max_cap = s
print(json.dumps({'channel_count': len(channels), 'max_capacity_sat': max_cap}))
" "$result"
