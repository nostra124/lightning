#!/bin/bash
# lightning channel-remote-balance-top5   (FEAT-2550)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
def get_remote(c):
    def to_int(v):
        return int(str(v).rstrip('msat')) if isinstance(v, str) else int(v)
    total = to_int(c.get('total_msat', 0))
    local = to_int(c.get('to_us_msat', 0))
    return total - local
sorted_ch = sorted(channels, key=get_remote, reverse=True)[:5]
result = [{'channel_id': c.get('channel_id'), 'remote_balance_msat': get_remote(c)} for c in sorted_ch]
print(json.dumps({'top5_channels_by_remote_balance': result}))
" "$result"
