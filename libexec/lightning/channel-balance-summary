#!/bin/bash
# lightning channel-balance-summary   (FEAT-2058)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_local = 0
total_remote = 0
total_capacity = 0
for c in channels:
    local = int(c.get('to_us_msat', 0))
    total_val = int(c.get('total_msat', 0))
    remote = total_val - local
    total_local += local
    total_remote += remote
    total_capacity += total_val
print(json.dumps({'total_local_msat': total_local, 'total_remote_msat': total_remote, 'total_capacity_msat': total_capacity, 'channel_count': len(channels)}))
" "$result"
