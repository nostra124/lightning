#!/bin/bash
# lightning node-listinvoices-expired-list   (FEAT-2289)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
expired = [
    {'label': i.get('label'), 'amount_msat': i.get('amount_msat')}
    for i in invoices if i.get('status') == 'expired'
]
print(json.dumps({'expired_invoices': expired}))
" "$result"
