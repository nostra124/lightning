#!/bin/bash
# lightning node-listchannels-inactive   (FEAT-1209)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
inactive = [c for c in data.get('channels', []) if not c.get('active')]
print(json.dumps({'count': len(inactive), 'channels': [c.get('short_channel_id') for c in inactive]}))
" "$result"
