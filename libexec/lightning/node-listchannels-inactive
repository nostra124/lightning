#!/bin/bash
# lightning node-listchannels-inactive   (FEAT-1491)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
inactive = [c for c in channels if not c.get('active')]
print(json.dumps({'total': len(channels), 'inactive': len(inactive)}))
" "$result"
