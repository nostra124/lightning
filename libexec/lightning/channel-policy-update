#!/bin/bash
# lightning channel-policy-update <channel_id> <fee_base> <fee_ppm>   (FEAT-1082)
if [ $# -lt 3 ]; then
    echo '{"error":"usage: channel-policy-update <channel_id> <fee_base> <fee_ppm>"}'
    exit 0
fi
channel_id="$1"; fee_base="$2"; fee_ppm="$3"
result=$(lightning-cli setchannelfee "$channel_id" "$fee_base" "$fee_ppm" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
try:
    data = json.loads(sys.argv[1])
    print(json.dumps({'ok': True, 'channel_id': sys.argv[2], 'result': data}))
except Exception:
    print(json.dumps({'ok': True, 'channel_id': sys.argv[2]}))
" "$result" "$channel_id"
