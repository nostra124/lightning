#!/bin/bash
# lightning node-listchannels-private   (FEAT-1314)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
priv = [ch for ch in data.get('channels', []) if ch.get('private')]
print(json.dumps({'count': len(priv)}))
" "$result"
