#!/bin/bash
# lightning node-listchannels-private   (FEAT-911)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
priv = [c for c in data.get('channels', []) if c.get('private')]
print(json.dumps({'count': len(priv), 'channels': [c.get('channel_id') for c in priv]}))
" "$result"
