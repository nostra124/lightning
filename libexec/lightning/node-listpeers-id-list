#!/bin/bash
# lightning node-listpeers-id-list   (FEAT-1464)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
ids = [p.get('id') for p in data.get('peers', [])]
print(json.dumps({'count': len(ids), 'peer_ids': ids}))
" "$result"
