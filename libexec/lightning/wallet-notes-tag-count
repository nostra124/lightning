#!/bin/bash
# lightning wallet-notes-tag-count   (FEAT-2033)
DB="${LIGHTNING_WALLET_DB:-$HOME/.lightning/wallet.db}"
if [ ! -f "$DB" ]; then
    echo '{"error":"wallet db not found"}'
    exit 0
fi
result=$(sqlite3 "$DB" "SELECT tag, COUNT(*) as cnt FROM notes GROUP BY tag;" 2>/dev/null) || { echo '{"error":"sqlite3 query failed"}'; exit 0; }
python3 -c "
import sys, json
lines = sys.argv[1].strip().splitlines() if sys.argv[1].strip() else []
counts = {}
for line in lines:
    parts = line.split('|')
    if len(parts) == 2:
        counts[parts[0]] = int(parts[1])
print(json.dumps({'tag_counts': counts}))
" "$result"
