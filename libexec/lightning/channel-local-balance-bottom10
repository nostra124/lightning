#!/bin/bash
# lightning channel-local-balance-bottom10   (FEAT-2597)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
channels.sort(key=lambda c: int(c.get('to_us_msat', 0)))
bottom10 = [{'channel_id': c.get('channel_id',''), 'peer_id': c.get('peer_id',''), 'to_us_msat': int(c.get('to_us_msat', 0))} for c in channels[:10]]
print(json.dumps({'bottom10_channels_by_local': bottom10}))
" "$result"
