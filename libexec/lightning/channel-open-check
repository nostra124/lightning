#!/bin/bash
# lightning channel-open-check   (FEAT-522)
if ! result=$(lightning-cli listfunds 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
spendable = sum(o.get('amount_msat', 0) for o in outputs if o.get('status') == 'confirmed')
print(json.dumps({'spendable_msat': spendable, 'spendable_sat': spendable // 1000, 'can_open': spendable > 0}))
" "$result"
