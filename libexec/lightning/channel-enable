#!/bin/bash
# lightning channel-enable <channel_id> [<base_msat> <ppm>]   (FEAT-426)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-enable <channel_id> [<base_msat> <ppm>]"}'
    exit 0
fi
channel_id="$1"; base="${2:-1000}"; ppm="${3:-1}"
result=$(lightning-cli setchannel "$channel_id" "${base}msat" "$ppm" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo '{"status":"enabled","channel_id":"'"$channel_id"'"}'
