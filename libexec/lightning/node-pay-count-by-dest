#!/bin/bash
# lightning node-pay-count-by-dest <destination>   (FEAT-1631)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-pay-count-by-dest <destination>"}'; exit 0
fi
dest="$1"
result=$(lightning-cli listpays "bolt11=" 2>/dev/null) || result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
dest = sys.argv[2]
pays = [p for p in data.get('pays', []) if p.get('destination') == dest]
print(json.dumps({'destination': dest, 'count': len(pays), 'complete': sum(1 for p in pays if p.get('status') == 'complete')}))
" "$result" "$dest"
