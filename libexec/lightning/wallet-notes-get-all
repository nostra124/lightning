#!/bin/bash
# lightning wallet-notes-get-all <wallet_name>   (FEAT-1403)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-get-all <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, sqlite3, json
db = sys.argv[1]; wname = sys.argv[2]
conn = sqlite3.connect(db)
rows = conn.execute('SELECT key, value FROM notes ORDER BY key').fetchall()
conn.close()
notes = {r[0]: r[1] for r in rows}
print(json.dumps({'wallet': wname, 'count': len(notes), 'notes': notes}))
" "$db" "$wname" 2>/dev/null || echo '{"error":"db_error"}'
