#!/bin/bash
# lightning wallet-meta-get-all <wallet>   (FEAT-1718)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-meta-get-all <wallet>"}'; exit 0
fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
data=$(sqlite3 "$db" "SELECT key||'='||value FROM meta;" 2>/dev/null | tr '\n' ',' | sed 's/,$//')
echo "{\"wallet\":\"$wname\",\"entries\":\"$data\"}"
