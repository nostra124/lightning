#!/bin/bash
# lightning channel-peer-list   (FEAT-2102)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peers = {}
for c in channels:
    pid = c.get('peer_id', '')
    peers[pid] = peers.get(pid, 0) + 1
peer_list = [{'peer_id': k, 'channel_count': v} for k, v in peers.items()]
print(json.dumps({'peers': peer_list, 'total_peers': len(peer_list)}))
" "$result"
