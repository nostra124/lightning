#!/bin/bash
# lightning invoice-list-by-date <since_timestamp>   (FEAT-1095)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-by-date <since_timestamp>"}'
    exit 0
fi
since="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
since = int(sys.argv[2])
invs = [i for i in data.get('invoices', []) if (i.get('pay_index') or i.get('paid_at', 0)) >= since or i.get('expires_at', 0) >= since]
print(json.dumps(invs[:20]))
" "$result" "$since"
