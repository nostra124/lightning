#!/bin/bash
# lightning node-fee-rate   (FEAT-571)
if ! result=$(lightning-cli feerates perkb 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
perkb = data.get('perkb', {})
print(json.dumps({
    'opening': perkb.get('opening'),
    'mutual_close': perkb.get('mutual_close'),
    'unilateral_close': perkb.get('unilateral_close'),
    'min_acceptable': perkb.get('min_acceptable'),
    'max_acceptable': perkb.get('max_acceptable')
}))
" "$result"
