#!/bin/bash
# lightning node-pay-amount-skewness   (FEAT-2804)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
vals = [p.get('amount_msat', 0) for p in pays if 'amount_msat' in p]
n = len(vals)
if n >= 3:
    mean = sum(vals) / n
    std = math.sqrt(sum((v - mean)**2 for v in vals) / n)
    skewness = (sum((v - mean)**3 for v in vals) / n) / (std**3) if std > 0 else 0.0
else:
    skewness = 0.0
print(json.dumps({'amount_skewness': round(skewness, 6), 'count': n}))
" "$result"
