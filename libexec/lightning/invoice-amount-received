#!/bin/bash
# lightning invoice-amount-received <label>   (FEAT-1315)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-amount-received <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
if invs:
    i = invs[0]
    print(json.dumps({'label': i.get('label'), 'amount_received_msat': i.get('amount_received_msat')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
