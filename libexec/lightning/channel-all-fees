#!/bin/bash
# lightning channel-all-fees   (FEAT-646)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fees = []
for ch in data.get('channels', []):
    fees.append({
        'channel_id': ch.get('channel_id'),
        'short_channel_id': ch.get('short_channel_id'),
        'fee_base_msat': ch.get('fee_base_msat'),
        'fee_proportional_millionths': ch.get('fee_proportional_millionths')
    })
print(json.dumps(fees))
" "$result"
