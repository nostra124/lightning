#!/bin/bash
# lightning channel-opener-local-count   (FEAT-2010)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
local_count = sum(1 for c in channels if c.get('opener') == 'local')
print(json.dumps({'local_opener_count': local_count, 'total_channels': len(channels)}))
" "$result"
