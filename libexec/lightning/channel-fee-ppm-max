#!/bin/bash
# lightning channel-fee-ppm-max   (FEAT-2455)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel_id': None, 'fee_proportional_millionths': 0}))
else:
    best = max(channels, key=lambda c: c.get('fee_proportional_millionths', 0))
    print(json.dumps({'channel_id': best.get('channel_id'), 'fee_proportional_millionths': best.get('fee_proportional_millionths', 0)}))
" "$result"
