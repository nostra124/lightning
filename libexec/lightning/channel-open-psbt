#!/bin/bash
# lightning channel-open-psbt <peer_id> <amount_sat>   (FEAT-404)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: channel-open-psbt <peer_id> <amount_sat>"}'
    exit 0
fi
peer_id="$1"; amount_sat="$2"
result=$(lightning-cli fundchannel_start "$peer_id" "${amount_sat}sat" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
