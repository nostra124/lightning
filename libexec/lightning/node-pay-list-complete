#!/bin/bash
# lightning node-pay-list-complete   (FEAT-1091)
result=$(lightning-cli listpays 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
print(json.dumps(pays[:20]))
" "$result"
