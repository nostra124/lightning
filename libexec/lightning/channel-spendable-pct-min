#!/bin/bash
# lightning channel-spendable-pct-min   (FEAT-2777)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    total = ch.get('total_msat', 0)
    spendable = ch.get('spendable_msat', 0)
    if isinstance(total, str): total = int(total.rstrip('msat'))
    if isinstance(spendable, str): spendable = int(spendable.rstrip('msat'))
    if total > 0:
        vals.append(spendable / total * 100)
if not vals:
    print(json.dumps({'spendable_pct_min': None}))
else:
    print(json.dumps({'spendable_pct_min': round(min(vals), 4)}))
" "$result"
