#!/bin/bash
# lightning node-graph-betweenness   (FEAT-2204)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from collections import defaultdict
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
degree = defaultdict(int)
for c in channels:
    src = c.get('source', '')
    dst = c.get('destination', '')
    if src:
        degree[src] += 1
    if dst:
        degree[dst] += 1
if not degree:
    print(json.dumps({'error': 'no nodes found'}))
    sys.exit(0)
top_node = max(degree, key=lambda n: degree[n])
print(json.dumps({'top_node': top_node, 'degree': degree[top_node], 'node_count': len(degree)}))
" "$result"
