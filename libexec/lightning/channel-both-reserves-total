#!/bin/bash
# lightning channel-both-reserves-total   (FEAT-2367)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('our_reserve_msat', 0) + c.get('their_reserve_msat', 0) for c in channels)
print(json.dumps({'both_reserves_total_msat': total, 'channel_count': len(channels)}))
" "$result"
