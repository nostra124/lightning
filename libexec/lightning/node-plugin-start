#!/bin/bash
# lightning node-plugin-start <plugin_path>   (FEAT-378)
set -e
[ $# -ge 1 ] || { echo '{"error":"usage: node-plugin-start <plugin_path>"}'; exit 0; }
plugin="$1"
result=$(lightning-cli plugin start "$plugin" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
echo '{"ok":true}'
