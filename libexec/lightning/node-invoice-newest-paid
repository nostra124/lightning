#!/bin/bash
# lightning node-invoice-newest-paid   (FEAT-2244)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid' and i.get('paid_at')]
if paid:
    newest = max(paid, key=lambda i: i['paid_at'])
    print(json.dumps({'label': newest.get('label'), 'payment_hash': newest.get('payment_hash'), 'amount_msat': newest.get('amount_msat'), 'paid_at': newest.get('paid_at')}))
else:
    print(json.dumps({'label': None, 'payment_hash': None, 'amount_msat': None, 'paid_at': None}))
" "$result"
