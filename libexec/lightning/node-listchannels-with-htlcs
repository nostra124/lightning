#!/bin/bash
# lightning node-listchannels-with-htlcs   (FEAT-1604)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('htlcs')]
print(json.dumps({'count': len(channels), 'channels': [c.get('channel_id') for c in channels]}))
" "$result"
