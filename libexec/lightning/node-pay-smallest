#!/bin/bash
# lightning node-pay-smallest   (FEAT-2179)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'error': 'no complete pays found'}))
    sys.exit(0)
smallest = min(pays, key=lambda p: p.get('amount_sent_msat', 0) or 0)
print(json.dumps({'payment_hash': smallest.get('payment_hash', ''), 'amount_sent_msat': smallest.get('amount_sent_msat', 0), 'destination': smallest.get('destination', '')}))
" "$result"
