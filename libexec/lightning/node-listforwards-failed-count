#!/bin/bash
# lightning node-listforwards-failed-count   (FEAT-2251)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
count = sum(1 for f in forwards if f.get('status') == 'failed')
print(json.dumps({'failed_count': count}))
" "$result"
