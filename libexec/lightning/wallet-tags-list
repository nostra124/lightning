#!/bin/bash
# lightning wallet-tags-list <wallet_name>   (FEAT-818)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-tags-list <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
tags=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='tags'" 2>/dev/null) || tags=""
python3 -c "import sys, json; t=sys.argv[1]; print(json.dumps({'wallet': sys.argv[2], 'tags': t.split(',') if t else []}))" "$tags" "$wname"
