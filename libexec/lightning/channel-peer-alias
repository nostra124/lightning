#!/bin/bash
# lightning channel-peer-alias <peer_id>   (FEAT-485)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-peer-alias <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listnodes "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
nodes = json.loads(sys.argv[1]).get('nodes', [])
peer_id = sys.argv[2]
node = next((n for n in nodes if n.get('nodeid') == peer_id), None)
if node:
    print(json.dumps({'peer_id': peer_id, 'alias': node.get('alias', ''), 'color': node.get('color', '')}, separators=(',', ':')))
else:
    print(json.dumps({'error': 'peer_not_found'}))
" "$result" "$peer_id"
