#!/bin/bash
# lightning channel-peer-alias <channel_id>   (FEAT-1992)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-peer-alias <channel_id>"}'; exit 0; fi
arg="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
nodes=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = json.loads(sys.argv[2])
channel_id = sys.argv[3]
channels = data.get('channels', [])
ch = next((c for c in channels if c.get('channel_id') == channel_id), None)
if not ch:
    print(json.dumps({'error': 'channel not found'}))
    sys.exit(0)
peer_id = ch.get('peer_id')
node_map = {n.get('nodeid'): n for n in nodes.get('nodes', [])}
node = node_map.get(peer_id, {})
alias = node.get('alias')
print(json.dumps({'channel_id': channel_id, 'peer_id': peer_id, 'alias': alias}))
" "$result" "$nodes" "$arg"
