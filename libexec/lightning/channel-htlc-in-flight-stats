#!/bin/bash
# lightning channel-htlc-in-flight-stats   (FEAT-2192)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
max_in = 0
for ch in channels:
    htlcs = ch.get('htlcs', [])
    n = len(htlcs)
    total += n
    if n > max_in: max_in = n
count = len(channels)
avg = total / count if count else 0
print(json.dumps({'total_in_flight': total, 'max_per_channel': max_in, 'avg_per_channel': avg, 'channel_count': count}))
" "$result"
