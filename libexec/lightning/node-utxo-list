#!/bin/bash
# lightning node-utxo-list   (FEAT-372)
set -e
result=$(lightning-cli listfunds 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
utxos = data.get('outputs', [])
out = [
    {'txid': u.get('txid', ''), 'output': u.get('output', 0),
     'amount_msat': u.get('amount_msat', 0), 'status': u.get('status', ''),
     'reserved': u.get('reserved', False)}
    for u in utxos
]
print(json.dumps(out, separators=(',', ':')))
" "$result"
