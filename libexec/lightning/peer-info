#!/bin/bash
# lightning peer-info <peer_id>   (FEAT-493)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-info <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeers "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
peers = json.loads(sys.argv[1]).get('peers', [])
peer = next((p for p in peers if p.get('id') == sys.argv[2]), None)
if peer:
    print(json.dumps({'id': peer.get('id',''), 'connected': peer.get('connected', False),
        'num_channels': len(peer.get('channels', []))}, separators=(',', ':')))
else:
    print(json.dumps({'error': 'peer_not_found'}))
" "$result" "$peer_id"
