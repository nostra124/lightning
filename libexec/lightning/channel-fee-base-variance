#!/bin/bash
# lightning channel-fee-base-variance   (FEAT-2425)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('fee_base_msat', 0) for c in channels if 'fee_base_msat' in c]
if vals:
    mean = sum(vals) / len(vals)
    variance = round(sum((v - mean) ** 2 for v in vals) / len(vals), 4)
else:
    variance = 0.0
print(json.dumps({'fee_base_msat_variance': variance, 'channel_count': len(vals)}))
" "$result"
