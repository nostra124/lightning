#!/bin/bash
# lightning node-pay-amount-percentile   (FEAT-2222)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete' and p.get('amount_msat')]
amounts = sorted(int(str(p['amount_msat']).replace('msat','')) for p in pays)
def pct(lst, p):
    if not lst: return 0
    idx = int(len(lst) * p / 100)
    return lst[min(idx, len(lst)-1)]
print(json.dumps({'p25': pct(amounts,25), 'p50': pct(amounts,50), 'p75': pct(amounts,75), 'p90': pct(amounts,90), 'count': len(amounts)}))
" "\$result"
