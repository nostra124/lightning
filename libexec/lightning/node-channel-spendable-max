#!/bin/bash
# lightning node-channel-spendable-max   (FEAT-1269)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
max_spend = max((c.get('spendable_msat', 0) for c in channels), default=0)
print(json.dumps({'max_spendable_msat': max_spend, 'active_channels': len(channels)}))
" "$result"
