#!/bin/bash
# lightning node-listpeers-count-connected   (FEAT-1101)
if ! result=$(lightning-cli listpeers 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
connected = [p for p in peers if p.get('connected')]
print(json.dumps({'total': len(peers), 'connected': len(connected)}))
" "$result"
