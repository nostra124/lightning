#!/bin/bash
# lightning invoice-description <label>   (FEAT-1005)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-description <label>"}'
    exit 0
fi
label="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
label = sys.argv[2]
for inv in data.get('invoices', []):
    if inv.get('label') == label:
        print(json.dumps({'label': label, 'description': inv.get('description', '')}))
        sys.exit(0)
print(json.dumps({'error': 'invoice not found'}))
" "$result" "$label"
