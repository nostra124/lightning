#!/bin/bash
# lightning invoice-description <label>   (FEAT-695)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-description <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if invoices:
    print(json.dumps({'label': invoices[0].get('label'), 'description': invoices[0].get('description')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
