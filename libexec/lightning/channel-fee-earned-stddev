#!/bin/bash
# lightning channel-fee-earned-stddev   (FEAT-2973)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = [c.get('fee_earned_msat', 0) for c in channels]
if len(fees) < 2:
    stddev = 0
else:
    mean = sum(fees) / len(fees)
    stddev = math.sqrt(sum((x - mean) ** 2 for x in fees) / len(fees))
print(json.dumps({'fee_earned_stddev_msat': round(stddev, 6)}))
" "$result"
