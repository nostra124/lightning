#!/bin/bash
# lightning channel-capacity-stddev   (FEAT-2307)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    local = ch.get('local_msat', 0)
    remote = ch.get('remote_msat', 0)
    if isinstance(local, str):
        local = int(local.rstrip('msat')) if local.endswith('msat') else int(local)
    if isinstance(remote, str):
        remote = int(remote.rstrip('msat')) if remote.endswith('msat') else int(remote)
    vals.append(local + remote)
if not vals:
    print(json.dumps({'capacity_stddev_msat': 0, 'channel_count': 0}))
    sys.exit(0)
mean = sum(vals) / len(vals)
stddev = math.sqrt(sum((x - mean) ** 2 for x in vals) / len(vals)) if len(vals) > 1 else 0
print(json.dumps({'capacity_stddev_msat': round(stddev, 4), 'channel_count': len(vals)}))
" "$result"
