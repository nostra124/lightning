#!/bin/bash
# lightning channel-both-balances-stddev   (FEAT-2969)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    local = int(ch.get('to_us_msat', 0))
    total = int(ch.get('total_msat', 0))
    remote = total - local
    vals.extend([local, remote])
if len(vals) < 2:
    stddev = 0
else:
    mean = sum(vals) / len(vals)
    stddev = math.sqrt(sum((v - mean) ** 2 for v in vals) / len(vals))
print(json.dumps({'both_balances_stddev_msat': round(stddev)}))
" "$result"
