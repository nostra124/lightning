#!/bin/bash
# lightning channel-capacity-avg   (FEAT-2407)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'capacity_avg_msat': 0, 'channel_count': 0}))
    sys.exit(0)
caps = []
for ch in channels:
    local = ch.get('to_us_msat', ch.get('local_msat', 0))
    remote = ch.get('to_them_msat', ch.get('remote_msat', 0))
    caps.append(local + remote)
avg = sum(caps) / len(caps)
print(json.dumps({'capacity_avg_msat': avg, 'channel_count': len(channels)}))
" "$result"
