#!/bin/bash
# lightning node-peer-fees <node_id>   (FEAT-675)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-peer-fees <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nid = sys.argv[2]
channels = [c for c in data.get('channels', []) if c.get('peer_id') == nid]
fees = [{'channel_id': c.get('channel_id'), 'fee_base_msat': c.get('fee_base_msat'), 'fee_proportional_millionths': c.get('fee_proportional_millionths')} for c in channels]
print(json.dumps({'node_id': nid, 'channels': fees}))
" "$result" "$node_id"
