#!/bin/bash
# lightning wallet-notes-find-tag <wallet> <key>   (FEAT-1548)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-find-tag <wallet> <key>"}'; exit 0; fi
wname="$1"; key="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
tag=$(sqlite3 "$db" "SELECT tag FROM notes WHERE key='$key';" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"tag\":$([ -n "$tag" ] && echo "\"$tag\"" || echo 'null')}"
