#!/bin/bash
# lightning channel-max-htlc-count   (FEAT-1942)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
count = 0
for c in channels:
    v = c.get('max_accepted_htlcs')
    if v is not None:
        total += v
        count += 1
print(json.dumps({'channel_count': count, 'total_max_htlcs': total}))
" "$result"
