#!/bin/bash
# lightning peer-disconnect-all   (FEAT-657)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, subprocess
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
disconnected = []
for p in peers:
    if p.get('connected'):
        pid = p.get('id')
        r = subprocess.run(['lightning-cli', 'disconnect', pid], capture_output=True)
        disconnected.append(pid)
print(json.dumps({'disconnected': disconnected, 'count': len(disconnected)}))
" "$result"
