#!/bin/bash
# lightning peer-disconnect-all   (FEAT-967)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, subprocess
data = json.loads(sys.argv[1])
peers = [p.get('id') for p in data.get('peers', []) if p.get('connected')]
print(json.dumps({'disconnecting': len(peers), 'peer_ids': peers}))
" "$result"
