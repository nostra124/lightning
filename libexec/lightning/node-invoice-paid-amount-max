#!/bin/bash
# lightning node-invoice-paid-amount-max   (FEAT-2689)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i.get('amount_received_msat', i.get('amount_msat', 0)) for i in invoices if i.get('status') == 'paid']
max_paid = max(paid) if paid else 0
print(json.dumps({'max_paid_amount_msat': max_paid}))
" "$result"
