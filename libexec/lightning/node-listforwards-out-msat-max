#!/bin/bash
# lightning node-listforwards-out-msat-max   (FEAT-2611)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
max_out = max((f.get('out_msat', 0) or 0 for f in forwards), default=0)
print(json.dumps({'max_out_msat': max_out}))
" "$result"
