#!/bin/bash
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
ages = [p.get('age_seconds', 0) for p in peers if 'age_seconds' in p]
if len(ages) < 4:
    kurtosis = 0.0
else:
    n = len(ages)
    mean = sum(ages) / n
    variance = sum((x - mean) ** 2 for x in ages) / n
    if variance == 0:
        kurtosis = 0.0
    else:
        kurtosis = (sum((x - mean) ** 4 for x in ages) / n) / (variance ** 2) - 3
print(json.dumps({'age_kurtosis_peer': kurtosis}))
" "$result"
