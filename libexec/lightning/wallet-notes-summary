#!/bin/bash
# lightning wallet-notes-summary   (FEAT-2103)
WALLET_DB="${LIGHTNING_WALLET_DB:-wallet.db}"
if [ ! -f "$WALLET_DB" ]; then
    echo '{"error":"wallet db not found","count":0,"tags":[]}'
    exit 0
fi
result=$(sqlite3 "$WALLET_DB" "SELECT tag, COUNT(*) FROM notes GROUP BY tag;" 2>/dev/null) || { echo '{"error":"sqlite3 error","count":0,"tags":[]}'; exit 0; }
python3 -c "
import sys, json
lines = sys.argv[1].strip().splitlines() if sys.argv[1].strip() else []
tags = []
total = 0
for line in lines:
    parts = line.split('|')
    if len(parts) == 2:
        tag, cnt = parts[0], int(parts[1])
        tags.append({'tag': tag, 'count': cnt})
        total += cnt
print(json.dumps({'count': total, 'tags': tags}))
" "$result"
