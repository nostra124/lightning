#!/bin/bash
# lightning node-invoice-paid-oldest   (FEAT-2167)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid' and i.get('paid_at')]
if not paid:
    print(json.dumps({'error': 'no paid invoices'}))
    sys.exit(0)
oldest = min(paid, key=lambda i: i.get('paid_at', 0))
print(json.dumps({
    'label': oldest.get('label', ''),
    'paid_at': oldest.get('paid_at', 0),
    'amount_received_msat': oldest.get('amount_received_msat', 0),
    'status': oldest.get('status', ''),
}))
" "$result"
