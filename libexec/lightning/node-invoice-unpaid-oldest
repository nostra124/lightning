#!/bin/bash
# lightning node-invoice-unpaid-oldest   (FEAT-2564)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
unpaid = [i for i in invoices if i.get('status') == 'unpaid']
if not unpaid:
    oldest = None
else:
    oldest = min(unpaid, key=lambda i: i.get('created_index', float('inf')))
print(json.dumps({'oldest_unpaid_invoice': oldest}))
" "$result"
