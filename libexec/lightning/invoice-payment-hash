#!/bin/bash
# lightning invoice-payment-hash <label>   (FEAT-1785)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-payment-hash <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if not invoices: print(json.dumps({'error': 'invoice not found'})); sys.exit(0)
i = invoices[0]
print(json.dumps({'label': i.get('label'), 'payment_hash': i.get('payment_hash')}))
" "$result"
