#!/bin/bash
# lightning channel-rebalance-history [--limit N]   (FEAT-444)
limit=20
while [ $# -gt 0 ]; do
    case "$1" in
        --limit) limit="$2"; shift 2 ;;
        *) shift ;;
    esac
done
result=$(lightning-cli listpays 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
pays = json.loads(sys.argv[1]).get('pays', [])
limit = int(sys.argv[2])
# Rebalance pays typically have note containing 'rebalance'
rebalances = [p for p in pays if 'rebalance' in p.get('description', '').lower()]
out = [{'payment_hash': p.get('payment_hash',''), 'status': p.get('status',''),
        'amount_msat': p.get('amount_msat', 0), 'created_at': p.get('created_at', 0)}
       for p in rebalances[:limit]]
print(json.dumps(out, separators=(',', ':')))
" "$result" "$limit"
