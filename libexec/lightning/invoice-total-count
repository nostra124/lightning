#!/bin/bash
# lightning invoice-total-count   (FEAT-975)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
print(json.dumps({'total': len(invs)}))
" "$result"
