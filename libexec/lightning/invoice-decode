#!/bin/bash
# lightning invoice-decode <bolt11_or_bolt12>   (FEAT-411)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-decode <bolt11_or_bolt12>"}'
    exit 0
fi
bolt="$1"
result=$(lightning-cli decode "$bolt" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
