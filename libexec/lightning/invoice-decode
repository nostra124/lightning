#!/bin/bash
# lightning invoice-decode <bolt11>   (FEAT-262)
#
# Decodes a BOLT-11 invoice via lightning-cli decodepay.
# Returns a stable subset:
#   {amount_msat, description, payee, payment_hash, expiry, created_at}

set -e
[ $# -eq 1 ] || { printf 'usage: invoice-decode <bolt11>\n' >&2; exit 1; }
bolt11="$1"

command -v lightning-cli >/dev/null || { echo '{"error":"lightning-cli not installed"}'; exit 127; }

out=$(lightning-cli \
    --lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
    --network="${LIGHTNING_NETWORK:-bitcoin}" \
    decodepay "$bolt11" 2>/dev/null) || { echo '{"error":"decode_failed"}'; exit 5; }

python3 -c "
import sys, json
d = json.loads(sys.argv[1])
amount_msat = d.get('amount_msat', 0)
if isinstance(amount_msat, str):
    amount_msat = int(amount_msat.rstrip('msat') or 0)
print(json.dumps({
    'amount_msat':   amount_msat,
    'amount_sat':    amount_msat // 1000,
    'description':   d.get('description', '') or '',
    'payee':         d.get('payee', '') or d.get('destination', ''),
    'payment_hash':  d.get('payment_hash', ''),
    'expiry':        d.get('expiry', 3600),
    'created_at':    d.get('created_at', 0),
}))
" "$out"
