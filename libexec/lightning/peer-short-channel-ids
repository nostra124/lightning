#!/bin/bash
# lightning peer-short-channel-ids <peer_id>   (FEAT-1697)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-short-channel-ids <peer_id>"}'; exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
scids = [c.get('short_channel_id') for c in channels if c.get('short_channel_id')]
print(json.dumps({'peer_id': sys.argv[2], 'count': len(scids), 'short_channel_ids': scids}))
" "$result" "$peer_id"
