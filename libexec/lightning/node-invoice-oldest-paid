#!/bin/bash
# lightning node-invoice-oldest-paid   (FEAT-2127)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
paid = [i for i in data.get('invoices', []) if i.get('status') == 'paid' and 'paid_at' in i]
if not paid:
    print(json.dumps({'oldest': None, 'count': 0}))
else:
    oldest = min(paid, key=lambda i: i['paid_at'])
    print(json.dumps({'oldest': oldest, 'count': len(paid)}))
" "$result"
