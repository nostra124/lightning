#!/bin/bash
# lightning node-pay-route <bolt11>   (FEAT-694)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-pay-route <bolt11>"}'; exit 0; fi
bolt11="$1"
result=$(lightning-cli decodepay "$bolt11" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
d = json.loads(sys.argv[1])
print(json.dumps({'payee': d.get('payee'), 'amount_msat': d.get('amount_msat'), 'description': d.get('description')}))
" "$result"
