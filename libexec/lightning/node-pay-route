#!/bin/bash
# lightning node-pay-route <dest> <amount_msat>   (FEAT-1111)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: node-pay-route <dest> <amount_msat>"}'
    exit 0
fi
dest="$1"; amount="$2"
result=$(lightning-cli getroute "$dest" "$amount" 1 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
try:
    data = json.loads(sys.argv[1])
    route = data.get('route', [])
    print(json.dumps({'destination': sys.argv[2], 'hops': len(route), 'route': route[:5]}))
except Exception:
    print(json.dumps({'error': 'route not found'}))
" "$result" "$dest"
