#!/bin/bash
# lightning node-listchannels-active   (FEAT-1474)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
active = [c for c in channels if c.get('active')]
print(json.dumps({'total': len(channels), 'active': len(active)}))
" "$result"
