#!/bin/bash
# lightning node-listchannels-active   (FEAT-1159)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
active = [c for c in data.get('channels', []) if c.get('active')]
print(json.dumps({'count': len(active), 'channels': [c.get('short_channel_id') for c in active]}))
" "$result"
