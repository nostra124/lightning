#!/bin/bash
# lightning node-listchannels-active   (FEAT-891)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
active = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'count': len(active), 'channels': [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id')} for c in active]}))
" "$result"
