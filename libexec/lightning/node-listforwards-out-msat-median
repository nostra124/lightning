#!/bin/bash
# lightning node-listforwards-out-msat-median   (FEAT-2950)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
vals = sorted([f.get('out_msat', 0) for f in forwards if 'out_msat' in f])
if not vals:
    median = 0
elif len(vals) % 2 == 1:
    median = vals[len(vals) // 2]
else:
    mid = len(vals) // 2
    median = (vals[mid - 1] + vals[mid]) / 2
print(json.dumps({'out_msat_median': median, 'forward_count': len(vals)}))
" "$result"
