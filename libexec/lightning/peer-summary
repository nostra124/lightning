#!/bin/bash
# lightning peer-summary   (FEAT-2106)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
total = len(peers)
connected = sum(1 for p in peers if p.get('connected', False))
disconnected = total - connected
print(json.dumps({'total': total, 'connected': connected, 'disconnected': disconnected}))
" "$result"
