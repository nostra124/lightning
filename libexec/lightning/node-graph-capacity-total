#!/bin/bash
# lightning node-graph-capacity-total   (FEAT-1999)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('satoshis', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_capacity_sat': total}))
" "$result"
