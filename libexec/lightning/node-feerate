#!/bin/bash
# lightning node-feerate [urgent|normal|slow]   (FEAT-369)
set -e
urgency="${1:-normal}"
result=$(lightning-cli feerates "$urgency" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
perkw = data.get('perkw', {})
perkb = data.get('perkb', {})
print(json.dumps({'urgency': sys.argv[2], 'perkw': perkw, 'perkb': perkb}, separators=(',', ':')))
" "$result" "$urgency"
