#!/bin/bash
# lightning node-splice-status   (FEAT-419)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
splicing = [c for c in channels if 'SPLICING' in c.get('state', '')]
print(json.dumps({'splicing_count': len(splicing),
    'channels': [{'channel_id': c.get('channel_id',''), 'state': c.get('state','')} for c in splicing]},
    separators=(',', ':')))
" "$result"
