#!/bin/bash
# lightning wallet-label-delete <wallet_name> <label>   (FEAT-1228)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-label-delete <wallet_name> <label>"}'; exit 0; fi
wname="$1"; label="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "DELETE FROM labels WHERE key='$label';" 2>/dev/null
echo "{\"ok\":true,\"wallet\":\"$wname\",\"deleted\":\"$label\"}"
