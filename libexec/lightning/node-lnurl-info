#!/bin/bash
# lightning node-lnurl-info   (FEAT-439)
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, base64
info = json.loads(sys.argv[1])
node_id = info.get('id', '')
alias = info.get('alias', '')
addrs = info.get('address', [])
lnaddr = alias.lower().replace(' ', '') + '@' + (addrs[0].get('address','') + ':' + str(addrs[0].get('port', 9735)) if addrs else 'unknown')
print(json.dumps({'node_id': node_id, 'alias': alias, 'lightning_address': lnaddr,
    'addresses': addrs}, separators=(',', ':')))
" "$result"
