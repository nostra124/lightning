#!/bin/bash
# lightning node-pay-streak-days   (FEAT-2246)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid_ts = sorted(set(i['paid_at'] // 86400 for i in invoices if i.get('status') == 'paid' and i.get('paid_at')))
if not paid_ts:
    print(json.dumps({'streak_days': 0}))
else:
    max_streak = 1
    streak = 1
    for i in range(1, len(paid_ts)):
        if paid_ts[i] == paid_ts[i-1] + 1:
            streak += 1
            max_streak = max(max_streak, streak)
        elif paid_ts[i] != paid_ts[i-1]:
            streak = 1
    print(json.dumps({'streak_days': max_streak}))
" "$result"
