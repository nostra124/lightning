#!/bin/bash
# lightning channel-capacity-total-btc   (FEAT-2477)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_msat = sum(int(c.get('local_msat', 0)) + int(c.get('remote_msat', 0)) for c in channels)
btc = total_msat / 100000000000
print(json.dumps({'capacity_total_btc': round(btc, 8)}))
" "$result"
