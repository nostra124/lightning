#!/bin/bash
# lightning node-listforwards-fee-median   (FEAT-2956)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
fees = sorted([f.get('fee_msat', 0) for f in forwards if 'fee_msat' in f])
if not fees:
    print(json.dumps({'fee_median_msat': 0, 'forward_count': 0}))
else:
    n = len(fees)
    median = fees[n // 2] if n % 2 == 1 else (fees[n // 2 - 1] + fees[n // 2]) / 2
    print(json.dumps({'fee_median_msat': median, 'forward_count': n}))
" "$result"
