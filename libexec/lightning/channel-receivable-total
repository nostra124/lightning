#!/bin/bash
# lightning channel-receivable-total   (FEAT-1642)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
total = sum(c.get('receivable_msat', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_receivable_msat': total}))
" "$result"
