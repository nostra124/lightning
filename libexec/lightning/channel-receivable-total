#!/bin/bash
# lightning channel-receivable-total   (FEAT-942)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(c.get('receivable_msat', 0) for c in data.get('channels', []))
print(json.dumps({'total_receivable_msat': total}))
" "$result"
