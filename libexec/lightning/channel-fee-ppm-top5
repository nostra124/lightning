#!/bin/bash
# lightning channel-fee-ppm-top5   (FEAT-2365)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ranked = sorted(channels, key=lambda c: c.get('fee_proportional_millionths', 0), reverse=True)[:5]
top5 = [{'peer_id': c.get('peer_id', ''), 'channel_id': c.get('channel_id', ''), 'fee_proportional_millionths': c.get('fee_proportional_millionths', 0)} for c in ranked]
print(json.dumps({'top5_fee_ppm': top5}))
" "$result"
