#!/bin/bash
# lightning node-fee-ppm   (FEAT-1054)
if ! result=$(lightning-cli getinfo 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fees = data.get('fees_collected_msat', 0)
print(json.dumps({'fees_collected_msat': fees}))
" "$result"
