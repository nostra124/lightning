#!/bin/bash
# lightning peer-connect <peer_id> <host> [<port>]   (FEAT-479)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: peer-connect <peer_id> <host> [<port>]"}'
    exit 0
fi
peer_id="$1"; host="$2"; port="${3:-9735}"
result=$(lightning-cli connect "${peer_id}@${host}:${port}" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
