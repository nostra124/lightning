#!/bin/bash
# lightning node-rune-create [<restriction>...]   (FEAT-362)
set -e
result=$(lightning-cli createrune "$@" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'rune': data.get('rune', ''), 'unique_id': data.get('unique_id', '')}, separators=(',', ':')))
" "$result"
