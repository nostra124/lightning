#!/bin/bash
# lightning channel-htlc-expiry-soonest   (FEAT-2372)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
soonest = None
soonest_expiry = None
soonest_channel_id = None
for ch in channels:
    for htlc in ch.get('htlcs', []):
        expiry = htlc.get('cltv_expiry')
        if expiry is not None:
            if soonest_expiry is None or expiry < soonest_expiry:
                soonest_expiry = expiry
                soonest_channel_id = ch.get('short_channel_id') or ch.get('channel_id')
                soonest = htlc
if soonest is None:
    print(json.dumps({'cltv_expiry': None, 'channel_id': None, 'htlc_count': 0}))
else:
    print(json.dumps({'cltv_expiry': soonest_expiry, 'channel_id': soonest_channel_id, 'amount_msat': soonest.get('amount_msat')}))
" "$result"
