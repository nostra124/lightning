#!/bin/bash
# lightning node-listforwards-out-msat-min   (FEAT-2601)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
if not forwards:
    print(json.dumps({'min_out_msat': None}))
    sys.exit(0)
amounts = [f['out_msat'] for f in forwards if 'out_msat' in f]
if not amounts:
    print(json.dumps({'min_out_msat': None}))
else:
    print(json.dumps({'min_out_msat': min(amounts)}))
" "$result"
