#!/bin/bash
# lightning wallet-notes-count-pinned   (FEAT-1778)
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE tag='pinned';" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"count\":$count}"
