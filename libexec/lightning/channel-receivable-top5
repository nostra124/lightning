#!/bin/bash
# lightning channel-receivable-top5   (FEAT-2627)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
sorted_ch = sorted(channels, key=lambda c: c.get('receivable_msat', 0), reverse=True)
top5 = sorted_ch[:5]
out = [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id'), 'receivable_msat': c.get('receivable_msat')} for c in top5]
print(json.dumps({'top5_by_receivable': out}))
" "$result"
