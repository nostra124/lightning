#!/bin/bash
# lightning peer-alias <peer_id>   (FEAT-348)
set -e
[ $# -ge 1 ] || { echo '{"error":"usage: peer-alias <peer_id>"}'; exit 0; }
peer_id="$1"
result=$(lightning-cli listnodes "$peer_id" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
if nodes:
    n = nodes[0]
    print(json.dumps({'peer_id': n.get('nodeid', ''), 'alias': n.get('alias', ''), 'color': n.get('color', '')}, separators=(',', ':')))
else:
    print(json.dumps({'error': 'not_found'}))
" "$result"
