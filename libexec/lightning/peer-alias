#!/bin/bash
# lightning peer-alias <node_id>   (FEAT-657)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-alias <node_id>"}'
    exit 0
fi
node_id="$1"
result=$(lightning-cli listnodes "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
if nodes:
    print(json.dumps({'node_id': nodes[0].get('nodeid'), 'alias': nodes[0].get('alias')}))
else:
    print(json.dumps({'error': 'node not found'}))
" "$result"
