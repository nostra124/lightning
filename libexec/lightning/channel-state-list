#!/bin/bash
# lightning channel-state-list   (FEAT-2105)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
out = [{'channel_id': c.get('channel_id', ''), 'state': c.get('state', '')} for c in channels]
print(json.dumps({'channels': out}))
" "$result"
