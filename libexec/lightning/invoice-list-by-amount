#!/bin/bash
# lightning invoice-list-by-amount <amount_msat>   (FEAT-1615)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-by-amount <amount_msat>"}'; exit 0
fi
amount="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
amt = int(sys.argv[2])
invs = [i for i in data.get('invoices', []) if i.get('amount_msat') == amt]
print(json.dumps({'count': len(invs), 'invoices': [i.get('label') for i in invs]}))
" "$result" "$amount"
