#!/bin/bash
# lightning wallet-address-count <wallet_name>   (FEAT-933)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-address-count <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$wname" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
db="$root/$wname/state.db"
count=0
[ -f "$db" ] && count=$(sqlite3 "$db" "SELECT COUNT(*) FROM addresses;" 2>/dev/null) || count=0
echo "{\"wallet\":\"$wname\",\"address_count\":${count:-0}}"
