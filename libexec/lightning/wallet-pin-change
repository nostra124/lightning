#!/bin/bash
# lightning wallet-pin-change <wallet_name> <old_pin> <new_pin>   (FEAT-928)
if [ $# -lt 3 ]; then echo '{"error":"usage: wallet-pin-change <wallet_name> <old_pin> <new_pin>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$wname" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
echo "{\"wallet\":\"$wname\",\"ok\":true}"
