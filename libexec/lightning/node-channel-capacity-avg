#!/bin/bash
# lightning node-channel-capacity-avg   (FEAT-1009)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(ch.get('total_msat', 0) for ch in channels)
avg = total // len(channels) if channels else 0
print(json.dumps({'channel_count': len(channels), 'avg_capacity_msat': avg}))
" "$result"
