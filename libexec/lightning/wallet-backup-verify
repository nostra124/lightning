#!/bin/bash
# lightning wallet-backup-verify <backup_path> [<wallet>]   (FEAT-345)
set -e
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-backup-verify <backup_path> [wallet]"}'
    exit 0
fi
backup_path="$1"
wname="${2:-default}"
if [ ! -f "$backup_path" ]; then
    echo '{"ok":false,"reason":"backup_not_found"}'
    exit 0
fi
# Verify it's a valid SQLite file
result=$(sqlite3 "$backup_path" "PRAGMA integrity_check;" 2>/dev/null) || {
    echo '{"ok":false,"reason":"not_sqlite"}'
    exit 0
}
if [ "$result" = "ok" ]; then
    size=$(stat -c%s "$backup_path" 2>/dev/null || stat -f%z "$backup_path" 2>/dev/null || echo 0)
    echo "{\"ok\":true,\"size_bytes\":$size}"
else
    echo '{"ok":false,"reason":"integrity_check_failed"}'
fi
