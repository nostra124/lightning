#!/bin/bash
# lightning wallet-backup-verify <backup_path>   (FEAT-903)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-backup-verify <backup_path>"}'; exit 0; fi
backup_path="$1"
if [ ! -f "$backup_path" ]; then echo '{"error":"backup_not_found"}'; exit 0; fi
result=$(sqlite3 "$backup_path" "PRAGMA integrity_check;" 2>/dev/null) || { echo '{"error":"not a valid sqlite3 database"}'; exit 0; }
if [ "$result" = "ok" ]; then
    echo "{\"backup\":\"$backup_path\",\"integrity\":\"ok\"}"
else
    echo "{\"backup\":\"$backup_path\",\"integrity\":\"error\"}"
fi
