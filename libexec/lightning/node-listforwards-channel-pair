#!/bin/bash
# lightning node-listforwards-channel-pair <in_scid> <out_scid>   (FEAT-1899)
if [ $# -lt 2 ]; then echo '{"error":"usage: node-listforwards-channel-pair <in_scid> <out_scid>"}'; exit 0; fi
in_scid="$1"
out_scid="$2"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
in_s, out_s = sys.argv[2], sys.argv[3]
fwds = [f for f in data.get('forwards', []) if f.get('in_channel') == in_s and f.get('out_channel') == out_s]
print(json.dumps({'in_channel': in_s, 'out_channel': out_s, 'count': len(fwds)}))
" "$result" "$in_scid" "$out_scid"
