#!/bin/bash
# lightning node-invoice-expired-rate   (FEAT-2424)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
total = len(invoices)
expired = sum(1 for i in invoices if i.get('status') == 'expired')
rate = round(expired / total, 4) if total else 0.0
print(json.dumps({'expired_invoice_rate': rate, 'expired_count': expired, 'total_count': total}))
" "$result"
