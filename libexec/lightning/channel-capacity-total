#!/bin/bash
# lightning channel-capacity-total   (FEAT-1592)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_sat = sum(c.get('funding_amount_msat', 0) // 1000 for c in channels if c.get('funding_amount_msat'))
if not total_sat:
    total_sat = sum(c.get('total_msat', 0) // 1000 for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_sat': total_sat}))
" "$result"
