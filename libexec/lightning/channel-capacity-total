#!/bin/bash
# lightning channel-capacity-total   (FEAT-1070)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(ch.get('total_msat', 0) for ch in channels)
print(json.dumps({'channel_count': len(channels), 'total_capacity_msat': total}))
" "$result"
