#!/bin/bash
# lightning node-invoice-unpaid-total   (FEAT-1161)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
unpaid = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid']
total = sum(i.get('amount_msat', 0) for i in unpaid if isinstance(i.get('amount_msat'), int))
print(json.dumps({'count': len(unpaid), 'total_msat': total}))
" "$result"
