#!/bin/bash
# lightning node-htlc-total-msat   (FEAT-1251)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = 0
for ch in data.get('channels', []):
    for htlc in ch.get('htlcs', []):
        amt = htlc.get('amount_msat', 0)
        if isinstance(amt, int):
            total += amt
print(json.dumps({'total_htlc_msat': total}))
" "$result"
