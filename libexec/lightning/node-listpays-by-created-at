#!/bin/bash
# lightning node-listpays-by-created-at <since_ts>   (FEAT-1721)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-listpays-by-created-at <since_ts>"}'; exit 0
fi
since="$1"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
since = int(sys.argv[2])
pays = [p for p in data.get('pays', []) if p.get('created_at') and p['created_at'] >= since]
print(json.dumps({'count': len(pays), 'pays': [p.get('payment_hash') for p in pays]}))
" "$result" "$since"
