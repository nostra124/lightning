#!/bin/bash
# lightning channel-htlc-timeout-stddev   (FEAT-2775)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    for h in ch.get('htlcs', []):
        e = h.get('expiry')
        if e is not None:
            vals.append(e)
if not vals:
    print(json.dumps({'htlc_cltv_expiry_stddev': None}))
else:
    avg = sum(vals) / len(vals)
    stddev = math.sqrt(sum((v - avg) ** 2 for v in vals) / len(vals))
    print(json.dumps({'htlc_cltv_expiry_stddev': round(stddev, 4)}))
" "$result"
