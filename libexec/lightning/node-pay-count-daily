#!/bin/bash
# lightning node-pay-count-daily   (FEAT-2884)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
day_ago = time.time() - 86400
count = sum(1 for p in pays if p.get('completed_at', 0) >= day_ago)
print(json.dumps({'pay_count_daily': count}))
" "$result"
