#!/bin/bash
# lightning node-listpays-complete-fee-total   (FEAT-2181)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
total_fee_msat = 0
for p in complete:
    sent = p.get('amount_sent_msat', 0)
    amt  = p.get('amount_msat', 0)
    if isinstance(sent, str): sent = int(sent.replace('msat',''))
    if isinstance(amt,  str): amt  = int(amt.replace('msat',''))
    total_fee_msat += max(0, sent - amt)
print(json.dumps({'complete_pay_count': len(complete), 'total_fee_msat': total_fee_msat}))
" "$result"
