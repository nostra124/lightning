#!/bin/bash
# lightning channel-private-count   (FEAT-1740)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
private = sum(1 for c in channels if c.get('private'))
print(json.dumps({'total': len(channels), 'private': private, 'public': len(channels) - private}))
" "$result"
