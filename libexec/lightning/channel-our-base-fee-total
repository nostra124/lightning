#!/bin/bash
# lightning channel-our-base-fee-total   (FEAT-1822)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('fee_base_msat', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_base_fee_msat': total}))
" "$result"
