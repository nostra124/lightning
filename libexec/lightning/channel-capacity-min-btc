#!/bin/bash
# lightning channel-capacity-min-btc   (FEAT-2497)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
caps = []
for c in channels:
    total = c.get('total_msat')
    if total is not None:
        caps.append(total)
if caps:
    min_msat = min(caps)
    print(json.dumps({'capacity_min_btc': min_msat / 100_000_000_000, 'capacity_min_msat': min_msat}))
else:
    print(json.dumps({'capacity_min_btc': None, 'capacity_min_msat': None}))
" "$result"
