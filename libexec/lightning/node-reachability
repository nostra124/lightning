#!/bin/bash
# lightning node-reachability <peer_id>   (FEAT-310)
#
# Checks if a remote node is reachable via a probe payment route.
# Returns {peer_id, reachable, route_hops, fee_estimate_msat}

set -e
[ $# -ge 1 ] || { printf 'usage: node-reachability <peer_id>\n' >&2; exit 1; }
peer_id="$1"

command -v lightning-cli >/dev/null || {
    echo '{"error":"lightning-cli not found"}'; exit 0; }

LD="--lightning-dir=${LIGHTNING_DIR:-$HOME/.lightning}"
NET="--network=${LIGHTNING_NETWORK:-bitcoin}"

# Use 1000 msat probe to check route existence
raw=$(lightning-cli $LD $NET getroute "$peer_id" 1000 1 2>/dev/null) || {
    python3 -c "
import sys, json
print(json.dumps({'peer_id': sys.argv[1], 'reachable': False, 'route_hops': 0, 'fee_estimate_msat': 0}, separators=(',', ':')))
" "$peer_id"
    exit 0
}

python3 -c "
import sys, json
d = json.loads(sys.argv[1])
route = d.get('route', [])
fee = sum(h.get('msatoshi', 0) for h in route[:-1]) - (route[-1].get('msatoshi', 0) if len(route) > 1 else 0) if len(route) > 1 else 0
print(json.dumps({
    'peer_id': sys.argv[2],
    'reachable': len(route) > 0,
    'route_hops': len(route),
    'fee_estimate_msat': max(0, fee),
}, separators=(',', ':')))
" "$raw" "$peer_id"
