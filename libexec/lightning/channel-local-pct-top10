#!/bin/bash
# lightning channel-local-pct-top10   (FEAT-2730)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
def local_pct(c):
    local = c.get('to_us_msat', 0)
    total = c.get('total_msat', 0)
    return (local / total * 100) if total else 0
annotated = [dict(c, local_pct=local_pct(c)) for c in channels]
top10 = sorted(annotated, key=lambda c: c['local_pct'], reverse=True)[:10]
print(json.dumps({'top10_by_local_pct': top10}))
" "$result"
