#!/bin/bash
# lightning wallet-notes-list-archived <wallet>   (FEAT-1973)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-list-archived <wallet>"}'; exit 0; fi
wallet="$1"
db="$HOME/.lightning/wallets/$wallet/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet db not found"}'; exit 0; fi
result=$(sqlite3 "$db" "SELECT json_object('key', key, 'value', value, 'tag', tag) FROM notes WHERE archived = 1;" 2>/dev/null) || { echo '{"error":"sqlite3 not found"}'; exit 0; }
python3 -c "
import sys, json
wallet = sys.argv[1]
lines = sys.argv[2].strip().split('\n') if sys.argv[2].strip() else []
notes = [json.loads(l) for l in lines if l.strip()]
print(json.dumps({'wallet': wallet, 'notes': notes, 'count': len(notes)}))
" "$wallet" "$result"
