#!/bin/bash
# lightning channel-spendable-total   (FEAT-932)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(c.get('spendable_msat', 0) for c in data.get('channels', []))
print(json.dumps({'total_spendable_msat': total}))
" "$result"
