#!/bin/bash
# lightning node-pay-newest   (FEAT-1601)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'created_at': None, 'pay': None}))
    sys.exit(0)
newest = max(pays, key=lambda p: p.get('created_at', 0))
print(json.dumps({'pay': newest.get('payment_hash'), 'created_at': newest.get('created_at'), 'amount_msat': newest.get('amount_sent_msat')}))
" "$result"
