#!/bin/bash
# lightning node-total-sent   (FEAT-611)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
total = sum(p.get('amount_sent_msat', 0) for p in pays)
print(json.dumps({'total_payments': len(pays), 'total_sent_msat': total, 'total_sent_sat': total // 1000}))
" "$result"
