#!/bin/bash
# lightning channel-balance-local-total   (FEAT-1970)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for c in channels:
    v = c.get('to_us_msat', 0)
    if isinstance(v, str): v = int(v.replace('msat',''))
    total += v
print(json.dumps({'channel_count': len(channels), 'total_local_msat': total}))
" "$result"
