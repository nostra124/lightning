#!/bin/bash
# lightning node-listchannels-by-peer <peer_id>   (FEAT-1504)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listchannels-by-peer <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
print(json.dumps({'peer_id': sys.argv[2], 'count': len(channels), 'channels': [{'channel_id': c.get('channel_id'), 'state': c.get('state')} for c in channels]}))
" "$result" "$peer_id"
