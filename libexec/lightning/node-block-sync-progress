#!/bin/bash
# lightning node-block-sync-progress   (FEAT-661)
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
d = json.loads(sys.argv[1])
print(json.dumps({'blockheight': d.get('blockheight'), 'warning_bitcoind_sync': d.get('warning_bitcoind_sync'), 'warning_lightningd_sync': d.get('warning_lightningd_sync')}))
" "$result"
