#!/bin/bash
# lightning invoice-expire-soon <seconds>   (FEAT-805)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-expire-soon <seconds>"}'; exit 0; fi
seconds="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
threshold = int(sys.argv[2])
now = time.time()
soon = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid' and isinstance(i.get('expires_at', 0), (int, float)) and 0 < i.get('expires_at', 0) - now < threshold]
print(json.dumps({'expiring_soon': len(soon), 'invoices': soon}))
" "$result" "$seconds"
