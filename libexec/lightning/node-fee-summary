#!/bin/bash
# lightning node-fee-summary   (FEAT-677)
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
result2=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
info = json.loads(sys.argv[1])
fwds_data = json.loads(sys.argv[2])
fwds = fwds_data.get('forwards', [])
settled = [f for f in fwds if f.get('status') == 'settled']
total_fee = sum(f.get('fee_msat', 0) for f in settled if isinstance(f.get('fee_msat', 0), int))
print(json.dumps({'node_id': info.get('id'), 'settled_forwards': len(settled), 'total_fee_earned_msat': total_fee}))
" "$result" "$result2"
