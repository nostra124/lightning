#!/bin/bash
# lightning channel-cltv-expiry <channel_id>   (FEAT-1955)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-cltv-expiry <channel_id>"}'; exit 0; fi
arg="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        print(json.dumps({'channel_id': cid, 'our_to_self_delay': ch.get('our_to_self_delay'), 'their_to_self_delay': ch.get('their_to_self_delay')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$arg"
