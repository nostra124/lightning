#!/bin/bash
# lightning channel-htlc-value-min   (FEAT-2492)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
totals = {}
for ch in channels:
    peer_id = ch.get('peer_id', '')
    total = sum(h.get('amount_msat', 0) for h in ch.get('htlcs', []))
    totals[peer_id] = totals.get(peer_id, 0) + total
if totals:
    min_peer = min(totals, key=lambda k: totals[k])
    print(json.dumps({'peer_id': min_peer, 'htlc_value_min_msat': totals[min_peer]}))
else:
    print(json.dumps({'peer_id': None, 'htlc_value_min_msat': None}))
" "$result"
