#!/bin/bash
# lightning peer-total-balance   (FEAT-1966)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
total = 0
for p in peers:
    for c in p.get('channels', []):
        v = c.get('to_us_msat', 0)
        if isinstance(v, str): v = int(v.replace('msat',''))
        total += v
print(json.dumps({'peer_count': len(peers), 'total_local_msat': total}))
" "$result"
