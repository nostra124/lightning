#!/bin/bash
# lightning channel-stuckd-msat   (FEAT-1965)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
with_htlcs = sum(1 for c in channels if c.get('htlcs'))
print(json.dumps({'channel_count': len(channels), 'channels_with_htlcs': with_htlcs}))
" "$result"
