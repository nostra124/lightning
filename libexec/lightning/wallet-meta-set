#!/bin/bash
# lightning wallet-meta-set <wallet_name> <key> <value>   (FEAT-963)
if [ $# -lt 3 ]; then echo '{"error":"usage: wallet-meta-set <wallet_name> <key> <value>"}'; exit 0; fi
wname="$1"; key="$2"; value="$3"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$wname" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
meta_dir="$root/$wname/meta"
mkdir -p "$meta_dir"
echo "$value" > "$meta_dir/$key"
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"value\":\"$value\",\"ok\":true}"
