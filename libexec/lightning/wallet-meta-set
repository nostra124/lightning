#!/bin/bash
# lightning wallet-meta-set <wallet_name> <key> <value>   (FEAT-584)
if [ $# -lt 3 ]; then
    echo '{"error":"usage: wallet-meta-set <wallet_name> <key> <value>"}'
    exit 0
fi
wname="$1"; key="$2"; value="$3"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('$key','$value');" 2>/dev/null || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"ok\":true,\"wallet\":\"$wname\",\"key\":\"$key\",\"value\":\"$value\"}"
