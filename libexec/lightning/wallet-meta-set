#!/bin/bash
# lightning wallet-meta-set <wallet_name> <key> <value>   (FEAT-1393)
if [ $# -lt 3 ]; then echo '{"error":"usage: wallet-meta-set <wallet_name> <key> <value>"}'; exit 0; fi
wname="$1"; key="$2"; value="$3"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, sqlite3, json
db = sys.argv[1]; key = sys.argv[2]; val = sys.argv[3]; wname = sys.argv[4]
conn = sqlite3.connect(db)
conn.execute('INSERT OR REPLACE INTO meta (key, value) VALUES (?, ?)', (key, val))
conn.commit(); conn.close()
print(json.dumps({'wallet': wname, 'key': key, 'value': val, 'ok': True}))
" "$db" "$key" "$value" "$wname" 2>/dev/null || echo '{"error":"db_error"}'
