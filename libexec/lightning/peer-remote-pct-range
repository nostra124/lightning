#!/bin/bash
# lightning peer-remote-pct-range   (FEAT-2798)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for c in channels:
    total = c.get('total_msat', 0)
    remote = c.get('receivable_msat', 0)
    if total > 0:
        vals.append(remote / total * 100)
if len(vals) >= 2:
    remote_pct_range = max(vals) - min(vals)
else:
    remote_pct_range = 0.0
print(json.dumps({'remote_pct_range': round(remote_pct_range, 6), 'count': len(vals)}))
" "$result"
