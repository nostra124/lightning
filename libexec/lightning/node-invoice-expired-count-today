#!/bin/bash
# lightning node-invoice-expired-count-today   (FEAT-2649)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
now = int(time.time())
today_start = now - (now % 86400)
count = sum(1 for inv in invoices
            if inv.get('status') == 'expired'
            and inv.get('expires_at', 0) >= today_start)
print(json.dumps({'expired_today_count': count}))
" "$result"
