#!/bin/bash
# lightning wallet-tag-list <wallet_name>   (FEAT-1128)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-tag-list <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
tags=$(sqlite3 "$db" "SELECT DISTINCT tag FROM notes WHERE tag IS NOT NULL;" 2>/dev/null | python3 -c "import sys,json; print(json.dumps([l.strip() for l in sys.stdin if l.strip()]))" 2>/dev/null || echo '[]')
echo "{\"wallet\":\"$wname\",\"tags\":$tags}"
