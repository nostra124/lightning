#!/bin/bash
# lightning node-invoices-total-msat   (FEAT-731)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
total = sum(i.get('amount_msat', 0) for i in invoices if isinstance(i.get('amount_msat', 0), int))
print(json.dumps({'total_invoiced_msat': total, 'count': len(invoices)}))
" "$result"
