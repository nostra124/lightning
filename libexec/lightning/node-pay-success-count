#!/bin/bash
# lightning node-pay-success-count   (FEAT-1391)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
done = [p for p in pays if p.get('status') == 'complete']
total = len(pays); success = len(done)
rate = round(success / total * 100, 2) if total else 0
print(json.dumps({'total': total, 'success': success, 'success_rate_pct': rate}))
" "$result"
