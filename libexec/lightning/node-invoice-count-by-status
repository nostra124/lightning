#!/bin/bash
# lightning node-invoice-count-by-status   (FEAT-2147)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
counts = {}
for inv in invoices:
    s = inv.get('status', 'unknown')
    counts[s] = counts.get(s, 0) + 1
print(json.dumps({'by_status': counts, 'total': len(invoices)}))
" "$result"
