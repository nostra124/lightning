#!/bin/bash
# lightning node-invoice-preimage-list   (FEAT-1421)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = [{'label': i.get('label'), 'payment_preimage': i.get('payment_preimage')} for i in data.get('invoices', []) if i.get('payment_preimage')]
print(json.dumps({'count': len(invs), 'invoices': invs}))
" "$result"
