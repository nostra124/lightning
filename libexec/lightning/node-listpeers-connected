#!/bin/bash
# lightning node-listpeers-connected   (FEAT-904)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
connected = [p for p in data.get('peers', []) if p.get('connected')]
print(json.dumps([{'id': p.get('id'), 'connected': True} for p in connected]))
" "$result"
