#!/bin/bash
# lightning node-graph-neighbors <node_id>   (FEAT-1081)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-graph-neighbors <node_id>"}'
    exit 0
fi
node_id="$1"
result=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nid = sys.argv[2]
nodes = data.get('nodes', [])
print(json.dumps({'node_id': nid, 'total_nodes': len(nodes)}))
" "$result" "$node_id"
