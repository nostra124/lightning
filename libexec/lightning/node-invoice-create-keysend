#!/bin/bash
# lightning node-invoice-create-keysend <node_id> <amount_msat>   (FEAT-709)
if [ $# -lt 2 ]; then echo '{"error":"usage: node-invoice-create-keysend <node_id> <amount_msat>"}'; exit 0; fi
node_id="$1"; amount="$2"
result=$(lightning-cli keysend "$node_id" "$amount" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps(d))" "$result"
