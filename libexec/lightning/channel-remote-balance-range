#!/bin/bash
# lightning channel-remote-balance-range   (FEAT-2929)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if isinstance(total, str): total = int(total)
    if isinstance(local, str): local = int(local)
    vals.append(total - local)
result = (max(vals) - min(vals)) if len(vals) >= 2 else (vals[0] if vals else 0)
print(json.dumps({'remote_balance_range_msat': result}))
" "$result"
