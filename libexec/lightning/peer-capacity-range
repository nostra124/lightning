#!/bin/bash
# lightning peer-capacity-range   (FEAT-2803)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_cap = {}
for c in channels:
    peer = c.get('peer_id', '')
    peer_cap[peer] = peer_cap.get(peer, 0) + c.get('total_msat', 0)
vals = list(peer_cap.values())
if len(vals) >= 2:
    peer_capacity_range_msat = max(vals) - min(vals)
else:
    peer_capacity_range_msat = 0
print(json.dumps({'peer_capacity_range_msat': peer_capacity_range_msat, 'count': len(vals)}))
" "$result"
