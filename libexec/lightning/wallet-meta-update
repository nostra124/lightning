#!/bin/bash
# lightning wallet-meta-update <wallet> <key> <value>   (FEAT-1638)
if [ $# -lt 3 ]; then
    echo '{"error":"usage: wallet-meta-update <wallet> <key> <value>"}'; exit 0
fi
wname="$1"; key="$2"; value="$3"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('$key','$value');" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"updated\":true}"
