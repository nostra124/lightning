#!/bin/bash
# lightning node-invoice-paid-total   (FEAT-1034)
if ! result=$(lightning-cli listinvoices 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
paid = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
total = sum(i.get('amount_received_msat', 0) for i in paid)
print(json.dumps({'paid_count': len(paid), 'total_received_msat': total}))
" "$result"
