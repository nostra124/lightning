#!/bin/bash
# lightning node-node-id   (FEAT-384)
set -e
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'id': data.get('id', '')}, separators=(',', ':')))
" "$result"
