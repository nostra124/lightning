#!/bin/bash
# lightning peer-open-channel <peer_id> <amount_sat>   (FEAT-1087)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: peer-open-channel <peer_id> <amount_sat>"}'
    exit 0
fi
peer_id="$1"; amount="$2"
result=$(lightning-cli fundchannel "$peer_id" "$amount" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
try:
    data = json.loads(sys.argv[1])
    print(json.dumps({'ok': True, 'peer_id': sys.argv[2], 'txid': data.get('txid')}))
except Exception:
    print(json.dumps({'error': 'failed to open channel'}))
" "$result" "$peer_id"
