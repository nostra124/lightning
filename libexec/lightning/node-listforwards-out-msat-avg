#!/bin/bash
# lightning node-listforwards-out-msat-avg   (FEAT-2571)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
if not forwards:
    print(json.dumps({'avg_out_msat': 0}))
else:
    total = sum(f.get('out_msat', 0) for f in forwards)
    avg = total // len(forwards)
    print(json.dumps({'avg_out_msat': avg}))
" "$result"
