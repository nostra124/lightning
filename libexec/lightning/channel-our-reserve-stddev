#!/bin/bash
# lightning channel-our-reserve-stddev   (FEAT-2837)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [ch['our_reserve_msat'] for ch in channels if 'our_reserve_msat' in ch]
if not vals:
    print(json.dumps({'our_reserve_stddev_msat': 0, 'channel_count': 0}))
    sys.exit(0)
mean = sum(vals) / len(vals)
stddev = math.sqrt(sum((x - mean) ** 2 for x in vals) / len(vals)) if len(vals) > 1 else 0
print(json.dumps({'our_reserve_stddev_msat': round(stddev, 4), 'channel_count': len(vals)}))
" "$result"
