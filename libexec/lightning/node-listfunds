#!/bin/bash
# lightning node-listfunds   (FEAT-417)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
channels = data.get('channels', [])
onchain_sat = sum(o.get('amount_msat', 0) // 1000 for o in outputs if o.get('status') == 'confirmed')
offchain_msat = sum(c.get('our_amount_msat', 0) for c in channels)
print(json.dumps({'onchain_sat': onchain_sat, 'offchain_msat': offchain_msat,
    'offchain_sat': offchain_msat // 1000, 'utxo_count': len(outputs),
    'channel_count': len(channels)}, separators=(',', ':')))
" "$result"
