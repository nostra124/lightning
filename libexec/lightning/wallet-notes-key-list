#!/bin/bash
# lightning wallet-notes-key-list   (FEAT-2043)
db="${LIGHTNING_WALLET_DB:-$HOME/.lightning/wallet.db}"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet db not found","keys":[]}'
    exit 0
fi
result=$(sqlite3 "$db" "SELECT key FROM notes ORDER BY key;" 2>/dev/null) || { echo '{"error":"sqlite3 failed","keys":[]}'; exit 0; }
python3 -c "
import sys, json
lines = sys.argv[1].strip().split('\n') if sys.argv[1].strip() else []
print(json.dumps({'keys': lines, 'count': len(lines)}))
" "$result"
