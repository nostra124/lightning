#!/bin/bash
# lightning node-feerate-urgent   (FEAT-1734)
result=$(lightning-cli feerates urgent 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
perkw = data.get('perkw', {})
print(json.dumps({'feerate_urgent_perkw': perkw.get('urgent'), 'feerate_normal_perkw': perkw.get('normal'), 'feerate_slow_perkw': perkw.get('slow')}))
" "$result"
