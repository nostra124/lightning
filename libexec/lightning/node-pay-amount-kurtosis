#!/bin/bash
# lightning node-pay-amount-kurtosis   (FEAT-2824)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
vals = [p['amount_msat'] for p in pays if 'amount_msat' in p]
n = len(vals)
if n < 4:
    print(json.dumps({'amount_kurtosis': None, 'n': n}))
    sys.exit(0)
mean = sum(vals) / n
var = sum((v - mean)**2 for v in vals) / n
if var == 0:
    kurt = 0.0
else:
    kurt = (sum((v - mean)**4 for v in vals) / n) / (var**2) - 3
print(json.dumps({'amount_kurtosis': kurt, 'n': n}))
" "$result"
