#!/bin/bash
# lightning channel-list-funded   (FEAT-790)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
funded = [{'channel_id': c.get('channel_id'), 'total_msat': c.get('total_msat'), 'state': c.get('state')} for c in data.get('channels', []) if c.get('funding_txid')]
print(json.dumps(funded))
" "$result"
