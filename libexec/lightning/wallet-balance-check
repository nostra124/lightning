#!/bin/bash
# lightning wallet-balance-check <wallet_name>   (FEAT-893)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-balance-check <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
balance=$(sqlite3 "$db" "SELECT COALESCE(SUM(amount),0) FROM transactions WHERE type='receive';" 2>/dev/null) || balance=0
echo "{\"wallet\":\"$wname\",\"balance_msat\":$balance}"
