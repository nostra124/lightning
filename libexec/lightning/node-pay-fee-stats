#!/bin/bash
# lightning node-pay-fee-stats   (FEAT-2119)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
fees = []
for p in pays:
    if p.get('status') == 'complete':
        sent = p.get('amount_sent_msat', 0)
        amt = p.get('amount_msat', 0)
        if sent and amt:
            fees.append(sent - amt)
if fees:
    out = {'min_fee_msat': min(fees), 'max_fee_msat': max(fees), 'avg_fee_msat': int(sum(fees)/len(fees)), 'count': len(fees)}
else:
    out = {'min_fee_msat': None, 'max_fee_msat': None, 'avg_fee_msat': None, 'count': 0}
print(json.dumps(out))
" "$result"
