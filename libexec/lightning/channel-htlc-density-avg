#!/bin/bash
# lightning channel-htlc-density-avg   (FEAT-2752)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
counts = [len(c.get('htlcs', [])) for c in channels]
avg = sum(counts) / len(counts) if counts else 0
print(json.dumps({'htlc_density_avg': avg}))
" "$result"
