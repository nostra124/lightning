#!/bin/bash
# lightning channel-total-capacity   (FEAT-1876)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('total_msat', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_capacity_msat': total, 'total_capacity_sat': total // 1000}))
" "$result"
