#!/bin/bash
# lightning channel-total-capacity   (FEAT-1000)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
chs = data.get('channels', [])
total = sum(c.get('total_msat', 0) for c in chs)
active = sum(c.get('total_msat', 0) for c in chs if c.get('state') == 'CHANNELD_NORMAL')
print(json.dumps({'total_capacity_msat': total, 'active_capacity_msat': active, 'channel_count': len(chs)}))
" "$result"
