#!/bin/bash
# lightning api-account-list [--search <term>] [--limit N]   (FEAT-256)
#
# Operator-only CLI verb — lists accounts in the active wallet.
# Returns a JSON array of {address, name, balance_sat, created_at}.

set -e
search=""; limit=50
while [ $# -gt 0 ]; do
    case "$1" in
        --search) search="$2"; shift 2 ;;
        --limit)  limit="$2";  shift 2 ;;
        *) exit 2 ;;
    esac
done
case "$limit" in ''|*[!0-9]*) limit=50 ;; esac
[ "$limit" -gt 500 ] && limit=500

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '[]'; exit 0; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }

if [ -n "$search" ]; then
    like_term="%${search//%/%%}%"
    where="WHERE a.name LIKE $(sql_quote "$like_term") OR a.description LIKE $(sql_quote "$like_term")"
else
    where=""
fi

rows=$(sqlite3 -json "$db" "
    SELECT a.address, a.name,
           CAST(COALESCE((SELECT SUM(amount_msat) FROM ledger WHERE account = a.name),0)/1000 AS INTEGER) AS balance_sat,
           a.created_at
    FROM accounts a
    $where
    ORDER BY a.created_at DESC
    LIMIT $limit;" 2>/dev/null || echo "[]")
[ -n "$rows" ] || rows="[]"
printf '%s\n' "$rows"
