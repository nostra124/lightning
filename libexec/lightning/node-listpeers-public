#!/bin/bash
# lightning node-listpeers-public   (FEAT-1484)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
public = [{'id': p.get('id'), 'connected': p.get('connected')} for p in peers if not p.get('private_channel')]
print(json.dumps({'count': len(public), 'peers': public}))
" "$result"
