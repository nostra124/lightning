#!/bin/bash
# lightning node-listforwards-rate   (FEAT-1889)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
settled = [f for f in fwds if f.get('status') == 'settled']
failed = [f for f in fwds if f.get('status') == 'failed']
total = len(fwds)
rate = round(len(settled) / total, 4) if total else 0
print(json.dumps({'total': total, 'settled': len(settled), 'failed': len(failed), 'success_rate': rate}))
" "$result"
