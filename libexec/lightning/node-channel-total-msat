#!/bin/bash
# lightning node-channel-total-msat   (FEAT-994)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(c.get('total_msat', 0) for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL')
print(json.dumps({'total_capacity_msat': total}))
" "$result"
