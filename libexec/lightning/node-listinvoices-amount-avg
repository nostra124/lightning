#!/bin/bash
# lightning node-listinvoices-amount-avg   (FEAT-2619)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
amounts = [inv.get('amount_msat', 0) or 0 for inv in invoices if inv.get('amount_msat') is not None]
avg = sum(amounts) / len(amounts) if amounts else 0
print(json.dumps({'avg_invoice_amount_msat': avg}))
" "$result"
