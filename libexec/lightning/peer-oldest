#!/bin/bash
# lightning peer-oldest   (FEAT-2166)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
with_open = [c for c in channels if c.get('opened_at')]
if not with_open:
    print(json.dumps({'error': 'no channel open timestamps'}))
    sys.exit(0)
oldest = min(with_open, key=lambda c: c.get('opened_at', 0))
print(json.dumps({
    'peer_id': oldest.get('peer_id', ''),
    'channel_id': oldest.get('channel_id', ''),
    'opened_at': oldest.get('opened_at', 0),
    'state': oldest.get('state', ''),
}))
" "$result"
