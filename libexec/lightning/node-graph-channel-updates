#!/bin/bash
# lightning node-graph-channel-updates   (FEAT-1974)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
with_update = sum(1 for c in channels if c.get('last_update') is not None)
print(json.dumps({'channel_count': len(channels), 'with_update': with_update}))
" "$result"
