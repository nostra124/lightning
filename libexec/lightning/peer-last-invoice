#!/bin/bash
# lightning peer-last-invoice <peer_id>   (FEAT-1127)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-last-invoice <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
invs = sorted(data.get('invoices', []), key=lambda i: i.get('expires_at', 0), reverse=True)
last = invs[0] if invs else None
print(json.dumps({'peer_id': pid, 'last_invoice': last}))
" "$result" "$peer_id"
