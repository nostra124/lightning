#!/bin/bash
# lightning channel-receivable-bottom5   (FEAT-2620)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
entries = []
for ch in channels:
    receivable = ch.get('receivable_msat', 0) or 0
    entries.append({
        'channel_id': ch.get('short_channel_id') or ch.get('channel_id'),
        'peer_id': ch.get('peer_id'),
        'receivable_msat': receivable
    })
entries.sort(key=lambda x: x['receivable_msat'])
print(json.dumps({'bottom5_by_receivable': entries[:5]}))
" "$result"
