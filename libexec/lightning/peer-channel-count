#!/bin/bash
# lightning peer-channel-count <peer_id>   (FEAT-1537)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-channel-count <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
print(json.dumps({'peer_id': sys.argv[2], 'channel_count': len(channels)}))
" "$result" "$peer_id"
