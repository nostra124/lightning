#!/bin/bash
# lightning wallet-info <wallet_name>   (FEAT-833)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-info <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
label=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='label'" 2>/dev/null) || label=""
created=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='created_at'" 2>/dev/null) || created=""
echo "{\"wallet\":\"$wname\",\"label\":\"$label\",\"created_at\":\"$created\",\"path\":\"$root/$wname\"}"
