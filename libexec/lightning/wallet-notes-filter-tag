#!/bin/bash
# lightning wallet-notes-filter-tag <tag>   (FEAT-1878)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-filter-tag <tag>"}'; exit 0; fi
tag="$1"
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE tag='$tag';" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"tag\":\"$tag\",\"count\":$count}"
