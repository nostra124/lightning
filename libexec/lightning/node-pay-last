#!/bin/bash
# lightning node-pay-last   (FEAT-1501)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'error': 'no completed pays'}))
    sys.exit(0)
pays.sort(key=lambda p: p.get('created_at', 0))
p = pays[-1]
print(json.dumps({'payment_hash': p.get('payment_hash'), 'created_at': p.get('created_at'), 'amount_msat': p.get('amount_msat')}))
" "$result"
