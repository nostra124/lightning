#!/bin/bash
# lightning channel-both-reserves-sum   (FEAT-2872)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum((c.get('our_reserve_msat', 0) + c.get('their_reserve_msat', 0)) for c in data.get('channels', []))
print(json.dumps({'both_reserves_sum_msat': total}))
" "$result"
