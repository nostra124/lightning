#!/bin/bash
# lightning payment-probe <node_id> <amount_msat>   (FEAT-326)
set -e
if [ $# -lt 2 ]; then
    echo '{"error":"usage: payment-probe <node_id> <amount_msat>"}'
    exit 0
fi
node_id="$1"
amount_msat="$2"
result=$(lightning-cli getroute "$node_id" "$amount_msat" 1 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
route = data.get('route', [])
if route:
    total_fee = sum(h.get('amount_msat', 0) for h in route[:-1]) - int(sys.argv[2]) if len(route) > 1 else 0
    print(json.dumps({'reachable': True, 'hops': len(route), 'fee_msat': max(0, total_fee)}, separators=(',', ':')))
else:
    print(json.dumps({'reachable': False}))
" "$result" "$amount_msat"
