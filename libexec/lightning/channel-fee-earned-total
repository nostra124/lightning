#!/bin/bash
# lightning channel-fee-earned-total   (FEAT-2345)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total = sum(f.get('fee_msat', 0) for f in forwards if f.get('status') == 'settled')
print(json.dumps({'fee_earned_msat_total': total}))
" "$result"
