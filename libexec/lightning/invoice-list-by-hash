#!/bin/bash
# lightning invoice-list-by-hash <payment_hash>   (FEAT-1145)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-by-hash <payment_hash>"}'
    exit 0
fi
phash="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
phash = sys.argv[2]
invs = [i for i in data.get('invoices', []) if i.get('payment_hash') == phash]
print(json.dumps(invs))
" "$result" "$phash"
