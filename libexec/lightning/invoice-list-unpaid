#!/bin/bash
# lightning invoice-list-unpaid   (FEAT-905)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
unpaid = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid']
print(json.dumps(unpaid))
" "$result"
