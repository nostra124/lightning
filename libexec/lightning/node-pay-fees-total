#!/bin/bash
# lightning node-pay-fees-total   (FEAT-1481)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
fees = sum((p.get('amount_sent_msat', 0) - p.get('amount_msat', 0)) for p in pays if p.get('amount_msat'))
print(json.dumps({'complete_count': len(pays), 'total_fees_msat': fees}))
" "$result"
