#!/bin/bash
# lightning node-listinvoices-label-count   (FEAT-2359)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
labels = set(i.get('label') for i in invoices if i.get('label'))
print(json.dumps({'distinct_label_count': len(labels)}))
" "$result"
