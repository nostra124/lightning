#!/bin/bash
# lightning wallet-unlock <wallet_name>   (FEAT-568)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-unlock <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
check=$(sqlite3 "$db" "SELECT 1;" 2>/dev/null) || { echo '{"error":"sqlite3 not found or db locked"}'; exit 0; }
echo "{\"ok\":true,\"wallet\":\"$wname\",\"status\":\"unlocked\"}"
