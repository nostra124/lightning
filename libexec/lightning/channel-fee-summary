#!/bin/bash
# lightning channel-fee-summary   (FEAT-2108)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_base = 0
total_ppm = 0
count = 0
for c in channels:
    updates = c.get('updates', {}).get('local', {})
    total_base += updates.get('fee_base_msat', 0)
    total_ppm += updates.get('fee_proportional_millionths', 0)
    count += 1
print(json.dumps({'channel_count': count, 'total_base_msat': total_base, 'total_ppm': total_ppm}))
" "$result"
