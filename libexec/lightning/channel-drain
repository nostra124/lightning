#!/bin/bash
# lightning channel-drain <channel_id> [--to <peer_id>]   (FEAT-309)
#
# Checks drain status of a channel — how much can be pushed out.
# Returns {channel_id, local_sat, pushable_sat, local_ratio}
# Pushable is local_sat minus channel reserve.

set -e
[ $# -ge 1 ] || { printf 'usage: channel-drain <channel_id>\n' >&2; exit 1; }
channel_id="$1"

command -v lightning-cli >/dev/null || {
    echo '{"error":"lightning-cli not found"}'; exit 0; }

LD="--lightning-dir=${LIGHTNING_DIR:-$HOME/.lightning}"
NET="--network=${LIGHTNING_NETWORK:-bitcoin}"

raw=$(lightning-cli $LD $NET listpeerchannels 2>/dev/null) || {
    echo '{"error":"listpeerchannels_failed"}'; exit 0; }

python3 -c "
import sys, json
chans = json.loads(sys.argv[1]).get('channels', [])
target = sys.argv[2]
found = None
for c in chans:
    if (c.get('channel_id') or c.get('short_channel_id', '')) == target:
        found = c
        break
if not found:
    print(json.dumps({'error': 'not_found'}))
    sys.exit(0)
local = found.get('to_us_msat', 0)
total = found.get('total_msat', 1)
reserve = found.get('our_reserve_msat', 0)
pushable = max(0, local - reserve)
print(json.dumps({
    'channel_id': target,
    'local_sat': local // 1000,
    'pushable_sat': pushable // 1000,
    'local_ratio': round(local / total, 3) if total else 0,
}, separators=(',', ':')))
" "$raw" "$channel_id"
