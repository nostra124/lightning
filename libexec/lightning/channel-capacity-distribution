#!/bin/bash
# lightning channel-capacity-distribution   (FEAT-2110)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
buckets = {'small_under_1m': 0, 'medium_1m_to_10m': 0, 'large_10m_to_100m': 0, 'xlarge_over_100m': 0}
for c in channels:
    sat = c.get('total_msat', 0) // 1000
    if sat < 1_000_000:
        buckets['small_under_1m'] += 1
    elif sat < 10_000_000:
        buckets['medium_1m_to_10m'] += 1
    elif sat < 100_000_000:
        buckets['large_10m_to_100m'] += 1
    else:
        buckets['xlarge_over_100m'] += 1
print(json.dumps({'channel_count': len(channels), 'distribution': buckets}))
" "$result"
