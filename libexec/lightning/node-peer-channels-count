#!/bin/bash
# lightning node-peer-channels-count <peer_id>   (FEAT-464)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-peer-channels-count <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
print(json.dumps({'peer_id': sys.argv[2], 'channel_count': len(channels)}, separators=(',', ':')))
" "$result" "$peer_id"
