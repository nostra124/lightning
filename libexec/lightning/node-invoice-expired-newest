#!/bin/bash
# lightning node-invoice-expired-newest   (FEAT-2766)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
expired = [i for i in invoices if i.get('status') == 'expired']
if not expired:
    print(json.dumps({'newest_expired_invoice': None}))
else:
    newest = max(expired, key=lambda i: i.get('expires_at', 0))
    print(json.dumps({'newest_expired_invoice': newest}))
" "$result"
