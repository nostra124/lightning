#!/bin/bash
# lightning channel-funding-sat <channel_id>   (FEAT-1985)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-funding-sat <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
channels = data.get('channels', [])
for ch in channels:
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        msat = ch.get('funding_amount_msat') or ch.get('total_msat') or 0
        print(json.dumps({'channel_id': cid, 'funding_amount_sat': msat // 1000}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
