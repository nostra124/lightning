#!/bin/bash
# lightning node-graph-capacity-stats   (FEAT-2124)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
sats = [c.get('satoshis', 0) for c in data.get('channels', []) if 'satoshis' in c]
if not sats:
    print(json.dumps({'min': None, 'max': None, 'avg': None, 'total': 0, 'count': 0}))
else:
    print(json.dumps({'min': min(sats), 'max': max(sats), 'avg': sum(sats)//len(sats), 'total': sum(sats), 'count': len(sats)}))
" "$result"
