#!/bin/bash
# lightning api-account-pay <address> <target> [--sat <sat>]   (FEAT-212 PR-2)
#
# Pays a BOLT-11 / BOLT-12 / LNURL / Lightning address / node-pubkey
# target against the account.  Returns the payment receipt as JSON.
#
#   {"payment_hash":"...","amount_sat":<int>,"fee_sat":<int>,"status":"complete"}

set -e
[ $# -ge 2 ] || exit 1
address="$1"; target="$2"; shift 2
sat=""
while [ $# -gt 0 ]; do
	case "$1" in
		--sat) sat="$2"; shift 2 ;;
		*) exit 2 ;;
	esac
done

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
if [ -n "$sat" ]; then
	case "$sat" in ''|*[!0-9]*) exit 2 ;; esac
fi

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }
name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

now=$(date -u +%s)
sqlite3 "$db" "UPDATE accounts SET last_api_call_at = $now WHERE address = $(sql_quote "$address");" 2>/dev/null || true

# FEAT-233 — compliance hook dispatch.  Fast no-op unless the operator
# has opted in via a compliance.recfile; a pre-hook may deny (fail
# closed).  Cheap file check short-circuits before any verb spawn.
cc_self=$(cd "$(dirname "$0")" && pwd)
compliance_hook() {
	[ -s "$WALLETS_ROOT/$wname/compliance.recfile" ] || return 0
	local out rc
	out=$("$cc_self/compliance" hook "$1" "$2" "$3" 2>/dev/null); rc=$?
	[ "$rc" -eq 0 ] || { [ -n "$out" ] && echo "$out"; }
	return "$rc"
}
cc_ctx="{\"account\":\"$name\",\"op\":\"pay\"}"
compliance_hook pre pay "$cc_ctx" || exit 6

# FEAT-243 — capability gate: paying an external node is a banking op
# the account's profile may forbid.
"$cc_self/account" capability "$address" pay_external 2>/dev/null \
	|| { echo '{"error":"capability_disabled","capability":"pay_external"}'; exit 6; }

# Only BOLT-11 path is wired in PR-2 (it's the common case for the
# external-caller use case).  BOLT-12 / LNURL / keysend live behind
# the existing CLI verbs and will be projected into the same JSON
# shape in a follow-up; calling them via this endpoint returns 501
# rather than half-working garbage.
command -v lightning-cli >/dev/null || { echo '{"error":"lightning-cli not installed"}'; exit 127; }
lower=$(printf '%s' "$target" | tr 'A-Z' 'a-z')
case "$lower" in
	lnbc*|lntb*) ;;
	*)
		printf '{"error":"target_shape_not_implemented","target_prefix":%s}\n' \
			"$(jq -Rs . <<<"${lower:0:6}")"
		exit 6 ;;
esac

pay_json=$(lightning-cli \
	--lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
	--network="${LIGHTNING_NETWORK:-bitcoin}" \
	pay "$target" 2>/dev/null) || {
		echo '{"error":"pay_failed"}'
		exit 5
	}

payment_hash=$(jq -r '.payment_hash // empty' <<<"$pay_json")
# clightning's `pay` returns:
#   .amount_sent_msat = total deducted (invoice + routing fee)
#   .amount_msat      = invoice amount that arrived at the destination
# Variable naming kept to match the FEAT-212 PR-2 prior art even
# though the labels are confusing.
sent_total_msat=$(jq -r '.amount_sent_msat // .msatoshi_sent // "0"' <<<"$pay_json" \
	| sed 's/msat$//')
invoice_msat=$(jq -r '.amount_msat // .msatoshi // "0"' <<<"$pay_json" \
	| sed 's/msat$//')
status=$(jq -r '.status // "complete"' <<<"$pay_json")
network_fee_msat=$(( sent_total_msat - invoice_msat ))

# FEAT-213 — operator-fee skim.  Reads $wallet/fees.recfile;
# missing file or zero rates = no skim.  Fee basis: invoice
# amount (we charge for value delivered, not for our routing
# costs which the user already absorbs via network_fee_msat).
fees_file="$WALLETS_ROOT/$wname/fees.recfile"
operator_fee_msat=0
if [ -f "$fees_file" ]; then
	read -r fee_base_sat fee_rate_ppm < <(awk -v op="pay" '
		BEGIN { RS=""; FS="\n"; b=0; r=0 }
		{
			in_op=0; bb=0; rr=0
			for (i=1; i<=NF; i++) {
				if ($i == "operation: " op) in_op=1
				if ($i ~ /^base_sat: *[0-9-]/) { bb=$i; sub(/^base_sat: */, "", bb) }
				if ($i ~ /^rate_ppm: *[0-9-]/) { rr=$i; sub(/^rate_ppm: */, "", rr) }
			}
			if (in_op) { b=bb; r=rr }
		}
		END { printf "%d %d\n", b+0, r+0 }
	' "$fees_file")
	operator_fee_msat=$(( fee_base_sat * 1000 + invoice_msat * fee_rate_ppm / 1000000 ))
fi
operator_fee_sat=$(( operator_fee_msat / 1000 ))
network_fee_sat=$(( network_fee_msat / 1000 ))
sent_sat=$(( invoice_msat / 1000 ))

# Ensure the house account exists (lazy bootstrap — no schema
# migration step needed; just an idempotent INSERT).  Same
# overdraft=allow as the unassigned '-' account since the
# operator is the issuer.
if [ "$operator_fee_msat" -gt 0 ]; then
	sqlite3 "$db" "INSERT OR IGNORE INTO accounts(name, description, overdraft) \
		VALUES('house', 'operator fee revenue', 'allow');" 2>/dev/null || true
fi

# FEAT-219 — referral split.  Direct referrer takes a configurable
# percentage of the skim, rest goes to house.  Default 0 (back-compat
# with FEAT-213: house keeps everything).  Sybil defences:
#   * min referee activity threshold (non-fee in/out volume)
#   * per-day cap on credits to any one referrer
# Both checked here at skim time; either failure routes the would-be
# referrer share to house instead (silently — no error to the caller).
referral_msat=0
referrer=""
direct_pct="${LIGHTNING_REFERRAL_DIRECT_PCT:-0}"
case "$direct_pct" in ''|*[!0-9]*) direct_pct=0 ;; esac
[ "$direct_pct" -gt 100 ] && direct_pct=100
if [ "$operator_fee_msat" -gt 0 ] && [ "$direct_pct" -gt 0 ]; then
	referrer=$(sqlite3 "$db" "SELECT COALESCE(referrer, 'house') FROM accounts WHERE name = $(sql_quote "$name");" 2>/dev/null)
	case "$referrer" in
		""|"house"|"-") referrer="" ;;
		*)
			# Sybil 1: referee must have transacted ≥ N sats of
			# non-fee volume.
			min_msat=$(( ${LIGHTNING_REFERRAL_MIN_ACTIVITY_SAT:-10000} * 1000 ))
			act_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(ABS(amount_msat)), 0) FROM ledger \
				WHERE account = $(sql_quote "$name") AND message NOT LIKE 'fee:%';" 2>/dev/null)
			[ "${act_msat:-0}" -lt "$min_msat" ] && referrer=""
			;;
	esac
	if [ -n "$referrer" ]; then
		# Sybil 2: per-day cap on credits to this referrer.
		cap_msat=$(( ${LIGHTNING_REFERRAL_MAX_PER_DAY_SAT:-10000} * 1000 ))
		today_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(amount_msat), 0) FROM ledger \
			WHERE account = $(sql_quote "$referrer") \
			  AND direction = 'in' \
			  AND message LIKE 'fee:referral%' \
			  AND date(ts) = date('now');" 2>/dev/null)
		[ "${today_msat:-0}" -ge "$cap_msat" ] && referrer=""
	fi
	if [ -n "$referrer" ]; then
		referral_msat=$(( operator_fee_msat * direct_pct / 100 ))
	fi
fi
house_share_msat=$(( operator_fee_msat - referral_msat ))
referral_sat=$(( referral_msat / 1000 ))

# Record the debits + the house credit.  Up to five separate rows so
# the ledger stays double-entry-clean: the user's out-rows sum to
# -sent_total_msat-operator_fee_msat; the in-rows on house +
# referrer sum to +operator_fee_msat.  Same payment_hash on all
# rows for trace.
sql="BEGIN;"
sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, payment_hash, message)"
sql+=" VALUES(datetime('now'), $(sql_quote "$name"), 'out', -$invoice_msat, $(sql_quote "$payment_hash"), 'api pay');"
sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, payment_hash, message)"
sql+=" VALUES(datetime('now'), $(sql_quote "$name"), 'out', -$network_fee_msat, $(sql_quote "$payment_hash"), 'network fee');"
if [ "$operator_fee_msat" -gt 0 ]; then
	sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, payment_hash, message)"
	sql+=" VALUES(datetime('now'), $(sql_quote "$name"), 'out', -$operator_fee_msat, $(sql_quote "$payment_hash"), 'fee:pay');"
	if [ "$house_share_msat" -gt 0 ]; then
		sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, payment_hash, message)"
		sql+=" VALUES(datetime('now'), 'house', 'in', $house_share_msat, $(sql_quote "$payment_hash"), $(sql_quote "fee:pay from $name"));"
	fi
	if [ "$referral_msat" -gt 0 ] && [ -n "$referrer" ]; then
		sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, payment_hash, message)"
		sql+=" VALUES(datetime('now'), $(sql_quote "$referrer"), 'in', $referral_msat, $(sql_quote "referee:$name"), $(sql_quote "$payment_hash"), $(sql_quote "fee:referral from $name"));"
	fi
fi
sql+=" COMMIT;"
sqlite3 "$db" "$sql" 2>/dev/null || true

# FEAT-233 — post-hook: observe + record (never blocks).
compliance_hook post pay "$cc_ctx" || true

jq -nc \
	--arg hash "$payment_hash" \
	--argjson amount "$sent_sat" \
	--argjson fee "$network_fee_sat" \
	--argjson ofee "$operator_fee_sat" \
	--argjson rfee "$referral_sat" \
	--arg status "$status" \
	'{payment_hash: $hash, amount_sat: $amount, fee_sat: $fee,
	  operator_fee_sat: $ofee, referral_fee_sat: $rfee, status: $status}'
