#!/bin/bash
# lightning channel-close-initiated   (FEAT-836)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
closing_states = ['CLOSINGD_SIGEXCHANGE', 'CLOSINGD_COMPLETE', 'AWAITING_UNILATERAL', 'FUNDING_SPEND_SEEN', 'ONCHAIN']
closing = [{'channel_id': c.get('channel_id'), 'state': c.get('state')} for c in data.get('channels', []) if c.get('state') in closing_states]
print(json.dumps({'closing': closing, 'count': len(closing)}))
" "$result"
