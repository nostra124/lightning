#!/bin/bash
# lightning node-onchain-confirmed   (FEAT-1509)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
confirmed = [o for o in outputs if o.get('status') == 'confirmed']
total = sum(o.get('amount_msat', 0) for o in confirmed)
print(json.dumps({'confirmed_count': len(confirmed), 'confirmed_msat': total}))
" "$result"
