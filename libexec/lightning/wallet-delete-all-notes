#!/bin/bash
# lightning wallet-delete-all-notes <wallet_name>   (FEAT-813)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-delete-all-notes <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
if sqlite3 "$db" "DELETE FROM meta WHERE key LIKE '%note%'" 2>/dev/null; then
    echo "{\"ok\":true,\"wallet\":\"$wname\"}"
else
    echo '{"error":"delete notes failed"}'
fi
