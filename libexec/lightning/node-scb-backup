#!/bin/bash
# lightning node-scb-backup [<output_path>]   (FEAT-376)
out_path="${1:-./static_channel_backup_$(date +%Y%m%d_%H%M%S).bin}"
if ! result=$(lightning-cli staticbackup 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
try:
    data = json.loads(sys.argv[1]) if len(sys.argv) > 1 and sys.argv[1] else {}
    scb = data.get('scb', '')
    out = sys.argv[2] if len(sys.argv) > 2 else '/tmp/scb_backup.bin'
    if scb:
        raw = bytes.fromhex(scb)
        try:
            with open(out, 'wb') as f:
                f.write(raw)
            print(json.dumps({'ok': True, 'path': out, 'size': len(raw)}, separators=(',', ':')))
        except OSError as e:
            print(json.dumps({'ok': False, 'reason': str(e)}))
    else:
        print(json.dumps({'ok': False, 'reason': 'no_scb'}))
except Exception as e:
    print(json.dumps({'error': str(e)}))
" "$result" "$out_path" || echo '{"error":"internal"}'
