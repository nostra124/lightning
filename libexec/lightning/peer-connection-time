#!/bin/bash
# lightning peer-connection-time <peer_id>   (FEAT-917)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-connection-time <peer_id>"}'; exit 0; fi
peer_id="$1"
if ! result=$(lightning-cli listpeers "$peer_id" 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); peers = data.get('peers', [])
if peers:
    p = peers[0]
    print(json.dumps({'peer_id': sys.argv[2], 'connected': p.get('connected'), 'channels': len(p.get('channels', []))}))
else:
    print(json.dumps({'error': 'peer not found'}))
" "$result" "$peer_id"
