#!/bin/bash
# lightning channel-capacity-bottom10   (FEAT-2605)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
sorted_ch = sorted(channels, key=lambda c: c.get('total_msat', 0))
bottom10 = sorted_ch[:10]
out = [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id'), 'total_msat': c.get('total_msat')} for c in bottom10]
print(json.dumps({'bottom10_channels_by_capacity': out}))
" "$result"
