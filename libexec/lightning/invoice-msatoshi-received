#!/bin/bash
# lightning invoice-msatoshi-received <label>   (FEAT-1225)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-msatoshi-received <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if invoices:
    inv = invoices[0]
    print(json.dumps({'label': inv.get('label'), 'amount_received_msat': inv.get('amount_received_msat')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
