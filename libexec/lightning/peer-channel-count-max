#!/bin/bash
# lightning peer-channel-count-max   (FEAT-2363)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from collections import Counter
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'peer_id': None, 'channel_count': 0}))
    sys.exit(0)
counts = Counter(c.get('peer_id', '') for c in channels)
top_peer, top_count = counts.most_common(1)[0]
print(json.dumps({'peer_id': top_peer, 'channel_count': top_count}))
" "$result"
