#!/bin/bash
# lightning node-liquidity-summary   (FEAT-649)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
spendable = sum(c.get('spendable_msat', 0) for c in channels)
receivable = sum(c.get('receivable_msat', 0) for c in channels)
total = sum(c.get('total_msat', 0) for c in channels)
print(json.dumps({'active_channels': len(channels), 'spendable_msat': spendable, 'receivable_msat': receivable, 'total_capacity_msat': total}))
" "$result"
