#!/bin/bash
# lightning channel-spendable-pct-max   (FEAT-2555)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_pct = -1
for ch in channels:
    total = ch.get('total_msat', 0)
    if total > 0:
        pct = ch.get('spendable_msat', 0) / total * 100
        if pct > best_pct:
            best_pct = pct
            best = ch
if best is None:
    print(json.dumps({'error': 'no channels'}))
else:
    print(json.dumps({'channel_id': best.get('channel_id', ''), 'spendable_pct': round(best_pct, 4)}))
" "$result"
