}

cmd_htlc_stats() {
	local result; result=$(LC listpeerchannels 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json
chans = json.loads(sys.argv[1]).get('channels', [])
total = 0; offered = 0; received = 0
for c in chans:
    htlcs = c.get('htlcs', [])
    total += len(htlcs)
    offered  += sum(1 for h in htlcs if h.get('direction')=='out')
    received += sum(1 for h in htlcs if h.get('direction')=='in')
print(json.dumps({'total_htlcs': total, 'offered': offered, 'received': received,
    'channels_with_htlcs': sum(1 for c in chans if c.get('htlcs'))}))
" "$result"
}

