cmd_backup_state() {
	local out_dir="${1:-.}"
	local ts; ts=$(date +%Y%m%d_%H%M%S)
	local result; result=$(LC staticbackup 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json, os
try:
    data = json.loads(sys.argv[1]) if sys.argv[1] else {}
    scb = data.get('scb', '')
    out_dir = sys.argv[2]; ts = sys.argv[3]
    if scb:
        out = os.path.join(out_dir, 'node-backup-' + ts + '.bin')
        with open(out, 'wb') as f:
            f.write(bytes.fromhex(scb))
        print(json.dumps({'ok': True, 'path': out, 'size': len(scb)//2}))
    else:
        print(json.dumps({'ok': False, 'reason': 'no_scb'}))
except Exception as e:
    print(json.dumps({'error': str(e)}))
" "$result" "$out_dir" "$ts"
}

