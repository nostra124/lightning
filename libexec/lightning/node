cmd_check_route() {
	[ $# -lt 2 ] && { echo '{"error":"usage: lightning node check-route <dest> <amount_msat>"}'; return; }
	local dest="$1" amount="$2"
	local result; result=$(LC getroute "$dest" "$amount" 1 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json
data = json.loads(sys.argv[1])
if 'route' in data:
    print(json.dumps({'reachable': True, 'hops': len(data['route']), 'route': data['route']}))
else:
    print(json.dumps({'reachable': False, 'error': data.get('message','no route')}))
" "$result"
}

cmd_getroute() {
	[ $# -lt 2 ] && { echo '{"error":"usage: lightning node getroute <node_id> <amount_msat>"}'; return; }
	local node_id="$1" amount="$2"
	local result; result=$(LC getroute "$node_id" "$amount" 1 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json
d = json.loads(sys.argv[1])
print(json.dumps({'hops': len(d.get('route',[])), 'route': d.get('route',[])}))
" "$result"
}

cmd_pay_status() {
	[ $# -lt 1 ] && { echo '{"error":"usage: lightning node pay-status <payment_hash>"}'; return; }
