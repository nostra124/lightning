# ---------------------------------------------------------------------------
# STATISTICS (one-pass over all lightning-cli calls)
# ---------------------------------------------------------------------------

cmd_stats() {
	local field="" format="json"
	while [ $# -gt 0 ]; do
		case "$1" in
			--field)  field="$2"; shift 2 ;;
			--format) format="$2"; shift 2 ;;
			*) echo "node stats: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	local info chans peers fwds funds
	info=$(LC getinfo 2>/dev/null)         || info='{}'
	chans=$(LC listpeerchannels 2>/dev/null) || chans='{"channels":[]}'
	peers=$(LC listpeers 2>/dev/null)       || peers='{"peers":[]}'
	fwds=$(LC listforwards 2>/dev/null)     || fwds='{"forwards":[]}'
	funds=$(LC listfunds 2>/dev/null)       || funds='{"outputs":[],"channels":[]}'

	python3 -c "
import sys, json, math

def safe_mean(lst):
    return sum(lst)/len(lst) if lst else 0.0

def safe_median(lst):
    if not lst: return 0.0
    s = sorted(lst)
    n = len(s)
    return (s[n//2] + s[(n-1)//2]) / 2.0

def safe_stddev(lst):
    if len(lst) < 2: return 0.0
    m = safe_mean(lst)
    return math.sqrt(sum((x-m)**2 for x in lst) / len(lst))

def safe_skewness(lst):
    if len(lst) < 3: return 0.0
    m = safe_mean(lst)
    s = safe_stddev(lst)
    if s == 0: return 0.0
    return sum(((x-m)/s)**3 for x in lst) / len(lst)

def safe_kurtosis(lst):
    if len(lst) < 4: return 0.0
    m = safe_mean(lst)
    s = safe_stddev(lst)
    if s == 0: return 0.0
    return sum(((x-m)/s)**4 for x in lst) / len(lst) - 3.0

def gini(lst):
    if not lst: return 0.0
    s = sorted(lst)
    n = len(s)
    cumsum = 0; total = sum(s)
    if total == 0: return 0.0
    for i, v in enumerate(s):
        cumsum += v
    return (2 * sum((i+1)*v for i,v in enumerate(s)) / (n * total)) - (n+1)/n

info  = json.loads(sys.argv[1])
chans = json.loads(sys.argv[2]).get('channels', [])
peers = json.loads(sys.argv[3]).get('peers', [])
fwds  = json.loads(sys.argv[4]).get('forwards', [])
funds = json.loads(sys.argv[5])

# --- channel metrics ---
active = [c for c in chans if c.get('state') == 'CHANNELD_NORMAL']
cap_msat = [c.get('total_msat', 0) for c in active]
local_msat = [c.get('to_us_msat', 0) for c in active]
remote_msat = [c.get('total_msat', 0) - c.get('to_us_msat', 0) for c in active]
htlc_counts = [len(c.get('htlcs', [])) for c in chans]

by_state = {}
for c in chans:
    s = c.get('state', 'unknown')
    by_state[s] = by_state.get(s, 0) + 1

bandwidth = sum(min(l, r) for l, r in zip(local_msat, remote_msat))

# --- peer metrics ---
conn_peers = sum(1 for p in peers if p.get('connected'))

# --- forwarding metrics ---
settled = [f for f in fwds if f.get('status') == 'settled']
failed  = [f for f in fwds if f.get('status') == 'failed']
fee_msat_list = [f.get('fee_msat', 0) for f in settled if isinstance(f.get('fee_msat'), (int, float))]
in_msat_list  = [f.get('in_msat', 0)  for f in settled if isinstance(f.get('in_msat'), (int, float))]
out_msat_list = [f.get('out_msat', 0) for f in settled if isinstance(f.get('out_msat'), (int, float))]

# --- fund metrics ---
outputs = funds.get('outputs', [])
fund_chans = funds.get('channels', [])
onchain_sat = sum(o.get('amount_msat', 0)//1000 for o in outputs if o.get('status') == 'confirmed')
offchain_msat = sum(c.get('our_amount_msat', 0) for c in fund_chans)

result = {
    'node': {
        'id':                    info.get('id'),
        'alias':                 info.get('alias'),
        'color':                 info.get('color'),
        'version':               info.get('version'),
        'network':               info.get('network'),
        'blockheight':           info.get('blockheight'),
        'num_peers':             info.get('num_peers', 0),
        'num_active_channels':   info.get('num_active_channels', 0),
        'num_inactive_channels': info.get('num_inactive_channels', 0),
        'num_pending_channels':  info.get('num_pending_channels', 0),
    },
    'peers': {
        'total':        len(peers),
        'connected':    conn_peers,
        'disconnected': len(peers) - conn_peers,
    },
    'channels': {
        'total':          len(chans),
        'active':         len(active),
        'by_state':       by_state,
        'capacity': {
            'total_msat':  sum(cap_msat),
            'avg_msat':    safe_mean(cap_msat),
            'median_msat': safe_median(cap_msat),
            'stddev_msat': safe_stddev(cap_msat),
            'skewness':    safe_skewness(cap_msat),
            'kurtosis':    safe_kurtosis(cap_msat),
            'gini':        gini(cap_msat),
        },
        'balance_local': {
            'total_msat':  sum(local_msat),
            'avg_msat':    safe_mean(local_msat),
            'median_msat': safe_median(local_msat),
        },
        'balance_remote': {
            'total_msat':  sum(remote_msat),
            'avg_msat':    safe_mean(remote_msat),
            'median_msat': safe_median(remote_msat),
        },
        'bandwidth_msat': bandwidth,
        'htlcs': {
            'total':  sum(htlc_counts),
            'max_per_channel': max(htlc_counts) if htlc_counts else 0,
        },
    },
    'forwarding': {
        'total':          len(fwds),
        'settled':        len(settled),
        'failed':         len(failed),
        'pending':        len(fwds) - len(settled) - len(failed),
        'settle_rate':    len(settled)/len(fwds) if fwds else 0.0,
        'fee_msat': {
            'total':   sum(fee_msat_list),
            'avg':     safe_mean(fee_msat_list),
            'median':  safe_median(fee_msat_list),
            'stddev':  safe_stddev(fee_msat_list),
            'skewness':safe_skewness(fee_msat_list),
        },
        'in_msat': {
            'total':  sum(in_msat_list),
            'avg':    safe_mean(in_msat_list),
            'median': safe_median(in_msat_list),
        },
        'out_msat': {
            'total':  sum(out_msat_list),
            'avg':    safe_mean(out_msat_list),
            'median': safe_median(out_msat_list),
        },
    },
    'funds': {
        'onchain_sat':    onchain_sat,
        'offchain_msat':  offchain_msat,
        'offchain_sat':   offchain_msat // 1000,
        'utxo_count':     len(outputs),
        'channel_count':  len(fund_chans),
    },
}

field = sys.argv[6]
fmt   = sys.argv[7]
if field:
    # Support dotted paths like 'channels.capacity.total_msat'
    parts = field.split('.')
    val = result
    for p in parts:
        val = val.get(p) if isinstance(val, dict) else None
        if val is None:
            break
    if fmt == 'tsv':
        print(val)
    else:
        print(json.dumps({field: val}))
elif fmt == 'tsv':
    def flatten(d, prefix=''):
        for k, v in d.items():
            key = prefix + k if not prefix else prefix + '.' + k
            if isinstance(v, dict):
                yield from flatten(v, key)
            else:
                yield key, v
    for k, v in flatten(result):
        print(k + '\t' + str(v))
else:
    print(json.dumps(result, separators=(',', ':')))
" "$info" "$chans" "$peers" "$fwds" "$funds" "$field" "$format"
}

