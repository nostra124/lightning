		channel-graph-dump) echo "usage: lightning node channel-graph-dump" ;;
		lnurl-pay)        echo "usage: lightning node lnurl-pay <lnurl>" ;;
		*) usage; return 1 ;;
	esac
}

SUB="$1"; shift || true
case "${1:-}" in --help|-h) subhelp "$SUB"; exit ;; esac
case "$SUB" in help) subhelp "${1:-}" || usage; exit ;; esac

# Dispatch to sub-scripts that manage their own lightning-cli requirement
# before we do a blanket require_cli check.
case "$SUB" in
	tor)              exec "$(dirname "$0")/_tor" "$@" ;;
	unlock)           exec "$(dirname "$0")/_unlock" "$@" ;;
	tower)            exec "$(dirname "$0")/_tower" "$@" ;;
esac

require_cli

case "$SUB" in
	# info / identity — delegate to _info for correct exit codes
	info)             exec "$(dirname "$0")/_info" "$@" ;;
	id)               cmd_pubkey "$@" ;;
	pubkey)           cmd_pubkey "$@" ;;
	# delegating: full implementations in _-prefixed siblings
	tor)              shift; exec "$(dirname "$0")/_tor" "$@" ;;
	unlock)           shift; exec "$(dirname "$0")/_unlock" "$@" ;;
	tower)            shift; exec "$(dirname "$0")/_tower" "$@" ;;
	alias)            cmd_alias "$@" ;;
	alias-lookup)     cmd_alias_lookup "$@" ;;
	color)            cmd_color "$@" ;;
	network)          cmd_network "$@" ;;
	block-height)     cmd_block_height "$@" ;;
	sync-progress)    cmd_sync_progress "$@" ;;
	announce-addr)    cmd_announce_addr "$@" ;;
	lnurl-info)       cmd_lnurl_info "$@" ;;
	uptime)           cmd_uptime "$@" ;;
	# config / policy
	fee-policy)       cmd_fee_policy "$@" ;;
	fee-rate)         cmd_fee_rate "$@" ;;
	check-config)     cmd_check_config "$@" ;;
	# routing / payments
	check-route)      cmd_check_route "$@" ;;
	getroute)         cmd_getroute "$@" ;;
	pay-route)        cmd_getroute "$@" ;;
	pay-status)       cmd_pay_status "$@" ;;
	reachability)     cmd_reachability "$@" ;;
	routing-table)    cmd_routing_table "$@" ;;
	# peers
	connect-check)    cmd_connect_check "$@" ;;
	connect-auto)     cmd_connect_auto "$@" ;;
	ping)             cmd_ping "$@" ;;
	peer-score)       cmd_peer_score "$@" ;;
	# decoding
	bolt12-decode)    cmd_bolt12_decode "$@" ;;
	invoice-decode)   cmd_invoice_decode "$@" ;;
	onion-decode)     cmd_onion_decode "$@" ;;
	# offers / runes
	invoice-create-keysend) cmd_invoice_create_keysend "$@" ;;
	offer-create)     cmd_offer_create "$@" ;;
	offers-list)      cmd_offers_list "$@" ;;
	rune-create)      cmd_rune_create "$@" ;;
	rune-list)        cmd_rune_list "$@" ;;
	# operations
	backup-state)     cmd_backup_state "$@" ;;
	emergency-recover) cmd_emergency_recover "$@" ;;
	emergency-stop)   cmd_emergency_stop "$@" ;;
	close-all)        cmd_close_all "$@" ;;
	channel-graph)    cmd_channel_graph "$@" ;;
	channel-graph-dump) cmd_channel_graph_dump "$@" ;;
	lnurl-pay)        cmd_lnurl_pay "$@" ;;
	*) usage; exit 1 ;;
esac
