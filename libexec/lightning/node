chans = [c for c in json.loads(sys.argv[1]).get('channels',[]) if c.get('state')=='CHANNELD_NORMAL']
out = []
for c in chans:
    upd = c.get('updates',{}).get('local',{})
    out.append({'channel_id': c.get('channel_id',''), 'peer_id': c.get('peer_id',''),
        'base_fee_msat': upd.get('fee_base_msat',0),
        'fee_ppm': upd.get('fee_proportional_millionths',0),
        'htlc_min_msat': upd.get('htlc_minimum_msat',0),
        'htlc_max_msat': upd.get('htlc_maximum_msat',0)})
print(json.dumps(out))
" "$result"
}

