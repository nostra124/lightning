pays = json.loads(sys.argv[1]).get('pays', [])
if pays:
    print(json.dumps({'payment_hash': sys.argv[2], 'status': pays[0].get('status')}))
else:
    print(json.dumps({'error': 'payment not found'}))
" "$result" "$phash"
}

cmd_reachability() {
	[ $# -lt 1 ] && { echo '{"error":"usage: lightning node reachability <peer_id>"}'; return; }
	local peer_id="$1"
	local raw; raw=$(LC getroute "$peer_id" 1000 1 2>/dev/null) || {
		python3 -c "import json,sys; print(json.dumps({'peer_id':sys.argv[1],'reachable':False,'route_hops':0}))" "$peer_id"
