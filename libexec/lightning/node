d = json.loads(sys.argv[1])
print(json.dumps({'alias': d.get('alias'), 'id': d.get('id')}))
" "$result"
	fi
}

cmd_alias_lookup() {
	[ $# -lt 1 ] && { echo '{"error":"usage: lightning node alias-lookup <alias>"}'; return; }
	local needle="$1"
	local result; result=$(LC listnodes 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json
nodes = json.loads(sys.argv[1]).get('nodes', [])
needle = sys.argv[2].lower()
match = [{'id': n.get('nodeid'), 'alias': n.get('alias')}
         for n in nodes if (n.get('alias','') or '').lower() == needle]
print(json.dumps(match))
" "$result" "$needle"
