cmd_bandwidth() {
	local result; result=$(LC listpeerchannels 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json
chans = [c for c in json.loads(sys.argv[1]).get('channels',[]) if c.get('state')=='CHANNELD_NORMAL']
bw = sum(min(c.get('to_us_msat',0), c.get('total_msat',0)-c.get('to_us_msat',0)) for c in chans)
print(json.dumps({'bandwidth_msat': bw, 'channels': len(chans)}))
" "$result"
}

cmd_channel_count() {
	local result; result=$(LC listpeerchannels 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json
chans = json.loads(sys.argv[1]).get('channels', [])
by_state = {}
for c in chans:
    s = c.get('state','unknown'); by_state[s] = by_state.get(s,0)+1
active = sum(1 for c in chans if c.get('state')=='CHANNELD_NORMAL')
print(json.dumps({'total': len(chans), 'active': active, 'by_state': by_state}))
" "$result"
}

cmd_peer_count() {
