cmd_gossip() {
	local nodes_raw chans_raw
	nodes_raw=$(LC listnodes 2>/dev/null)   || { echo '{"error":"listnodes_failed"}'; return; }
	chans_raw=$(LC listchannels 2>/dev/null) || chans_raw='{"channels":[]}'
	python3 -c "
import sys, json
nodes = json.loads(sys.argv[1]).get('nodes', [])
chans = json.loads(sys.argv[2]).get('channels', [])
last_ts = max((n.get('last_timestamp',0) for n in nodes), default=0)
