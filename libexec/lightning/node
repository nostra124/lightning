#!/bin/bash
# lightning node — node management, diagnostics, and statistics.
#
# Subcommands:
#   info                              — short node summary (alias, id, etc.)
#   pubkey                            — node public key
#   alias [<name>]                    — get or set node alias
#   alias-lookup <alias>              — resolve alias to pubkey
#   color                             — node colour
#   network                           — network name
#   block-height                      — current block height
#   sync-progress                     — sync warnings from getinfo
#   announce-addr                     — announced addresses
#   lnurl-info                        — LNURL / lightning-address info
#   stats [--field <name>] [--format tsv]
#                                     — comprehensive statistics JSON
#   bandwidth                         — routing bandwidth (min local/remote)
#   channel-count                     — channel counts by state
#   peer-count                        — peer counts
#   htlc-stats                        — in-flight HTLC summary
#   fee-policy                        — per-channel fee policies
#   fee-rate [urgent|normal|slow]     — on-chain fee rates
#   forward-stats                     — forwarding summary
#   routing-stats                     — alias for forward-stats
#   gossip                            — gossip graph summary
#   gossip-stats                      — gossip node/channel counts
#   listfunds                         — on-chain + off-chain fund summary
#   check-config                      — key config values
#   check-route <dest> <msat>         — probe a route
#   check-funds                       — alias for listfunds
#   connect-check <node_id>           — is peer connected?
#   connect-auto                      — schedule reconnects to known peers
#   ping <peer_id>                    — send ping to peer
#   reachability <peer_id>            — route-probe reachability check
#   peer-score <peer_id>              — connectivity score for peer
#   getroute <node_id> <msat>         — find a route
#   pay-route <dest> <msat>           — alias for getroute
#   pay-status <payment_hash>         — payment status by hash
#   bolt12-decode <offer>             — decode a BOLT-12 offer
#   invoice-decode <bolt11>           — decode a BOLT-11 invoice
#   onion-decode <onion_hex>          — decode an onion packet
#   invoice-create-keysend <id> <msat>— keysend payment
#   offer-create [<desc>]             — create a BOLT-12 offer
#   offers-list [--limit N]           — list offers
#   rune-create [<restriction>...]    — create a rune
#   rune-list                         — list runes
#   plugin-list                       — list loaded plugins
#   plugin-start <path>               — start a plugin
#   plugin-stop <name>                — stop a plugin
#   backup-state [<dir>]              — write SCB backup
#   emergency-recover <scb_file>      — emergency SCB recovery
#   emergency-stop                    — stop the daemon
#   close-all [--force]               — close all channels
#   channel-graph [--limit N]         — channel graph edges
#   channel-graph-dump                — raw channel graph dump
#   routing-table [--limit N]         — routing table excerpt
#   lnurl-pay <lnurl>                 — fetch invoice via LNURL
#   uptime                            — node liveness info

set -e

usage() {
	cat >&2 <<'EOF'
usage: lightning node <subcommand> [args]

   Node management, diagnostics, and statistics.
   Each sub-command also accepts --help.

subcommands (info / identity):
   info                              short node summary
   pubkey                            node public key
   alias [<name>]                    get or set node alias
   color                             node colour hex
   network                           bitcoin / testnet / regtest
   block-height                      current block height
   sync-progress                     sync state warnings
   announce-addr                     announced + bound addresses
   lnurl-info                        LNURL / lightning-address info
   uptime                            node liveness info

subcommands (statistics):
   stats [--field <name>] [--format tsv]
                                     comprehensive one-pass JSON stats
   bandwidth                         routing bandwidth (sum min local/remote)
   channel-count                     channel counts by state
   peer-count                        peer counts (total / connected)
   htlc-stats                        in-flight HTLC summary
   forward-stats                     forwarding settle/fail summary
   routing-stats                     alias for forward-stats
   gossip                            gossip graph summary
   gossip-stats                      gossip node / channel counts
   listfunds                         on-chain + off-chain fund totals
   check-funds                       alias for listfunds

subcommands (config / policy):
   fee-policy                        per-channel local fee policy
   fee-rate [urgent|normal|slow]     on-chain fee rates
   check-config                      key lightningd config values

subcommands (routing / payments):
   check-route <dest> <msat>         probe a route
   getroute <node_id> <msat>         find a route
   pay-route <dest> <msat>           alias for getroute
   pay-status <payment_hash>         payment status by hash
   reachability <peer_id>            route-probe reachability check
   routing-table [--limit N]         routing table excerpt

subcommands (peers):
   connect-check <node_id>           is peer currently connected?
   connect-auto                      reconnect to known disconnected peers
   ping <peer_id>                    send ping to peer
   peer-score <peer_id>              simple connectivity score

subcommands (decoding):
   bolt12-decode <offer>             decode a BOLT-12 offer
   invoice-decode <bolt11>           decode a BOLT-11 invoice
   onion-decode <onion_hex>          decode an onion packet

subcommands (offers / runes):
   invoice-create-keysend <id> <msat>  keysend payment
   offer-create [<desc>]             create a BOLT-12 offer
   offers-list [--limit N]           list offers
   rune-create [<restriction>...]    create a rune
   rune-list                         list runes

subcommands (plugins):
   plugin-list                       list loaded plugins
   plugin-start <path>               load a plugin at runtime
   plugin-stop <name>                stop a running plugin

subcommands (operations):
   alias-lookup <alias>              resolve alias → pubkey in gossip
   announce-addr                     announced + bound addresses
   backup-state [<dir>]              write SCB snapshot
   emergency-recover <scb_file>      force-close via SCB
   emergency-stop                    stop lightningd
   close-all [--force]               close every channel
   channel-graph [--limit N]         channel graph edge list
   channel-graph-dump                raw graph dump (first 10 chans)
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LDIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LNET="${LIGHTNING_NETWORK:-bitcoin}"
LC() { lightning-cli --lightning-dir="$LDIR" --network="$LNET" "$@"; }

require_cli() {
	command -v lightning-cli >/dev/null || {
		echo "lightning-cli not found — install Core Lightning" >&2; exit 127; }
}

