cmd_info() {
	local result; result=$(LC getinfo 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json
d = json.loads(sys.argv[1])
print(json.dumps({
    'id': d.get('id'),
    'alias': d.get('alias'),
    'color': d.get('color'),
    'num_peers': d.get('num_peers'),
    'num_active_channels': d.get('num_active_channels'),
    'num_inactive_channels': d.get('num_inactive_channels'),
    'num_pending_channels': d.get('num_pending_channels'),
    'blockheight': d.get('blockheight'),
    'network': d.get('network'),
    'version': d.get('version'),
}))
" "$result"
}

