		uptime)           echo "usage: lightning node uptime" ;;
		fee-policy)       echo "usage: lightning node fee-policy" ;;
		fee-rate)         echo "usage: lightning node fee-rate [urgent|normal|slow]" ;;
		check-config)     echo "usage: lightning node check-config" ;;
