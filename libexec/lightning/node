cmd_close_all() {
	local force=""
	while [ $# -gt 0 ]; do
		case "$1" in --force) force="1"; shift ;; *) shift ;; esac
	done
	local chans_raw; chans_raw=$(LC listpeerchannels 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; return; }
	python3 -c "
import sys, json, subprocess, os
chans = json.loads(sys.argv[1]).get('channels', [])
force = sys.argv[2]
closed = []; errors = []
for c in chans:
    cid = c.get('channel_id') or c.get('short_channel_id','')
    if not cid: continue
    cmd = ['lightning-cli', 'close', cid] + (['1'] if force else [])
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode == 0:
        closed.append(cid)
    else:
        errors.append({'channel_id': cid, 'error': r.stderr.strip()})
print(json.dumps({'closed': closed, 'errors': errors}))
" "$chans_raw" "$force"
}

