#!/bin/bash
# lightning wallet-notes-unique-tags <wallet>   (FEAT-1708)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-notes-unique-tags <wallet>"}'; exit 0
fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
tags=$(sqlite3 "$db" "SELECT DISTINCT tag FROM notes WHERE tag IS NOT NULL;" 2>/dev/null | tr '\n' ',' | sed 's/,$//')
echo "{\"wallet\":\"$wname\",\"tags\":\"$tags\"}"
