#!/bin/bash
# lightning channel-capacity-max   (FEAT-2287)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel': None}))
    sys.exit(0)
best = max(channels, key=lambda c: c.get('local_msat', 0) + c.get('remote_msat', 0))
total = best.get('local_msat', 0) + best.get('remote_msat', 0)
print(json.dumps({'channel': best, 'total_msat': total}))
" "$result"
