#!/bin/bash
# lightning node-peer-score <peer_id>   (FEAT-534)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-peer-score <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeers "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
if peers:
    p = peers[0]
    connected = p.get('connected', False)
    print(json.dumps({'peer_id': p.get('id'), 'connected': connected, 'score': 1 if connected else 0}))
else:
    print(json.dumps({'peer_id': sys.argv[2], 'connected': False, 'score': 0}))
" "$result" "$peer_id"
