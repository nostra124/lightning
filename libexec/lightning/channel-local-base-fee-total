#!/bin/bash
# lightning channel-local-base-fee-total   (FEAT-1362)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(ch.get('updates', {}).get('local', {}).get('fee_base_msat', 0) for ch in data.get('channels', []))
print(json.dumps({'channel_count': len(data.get('channels', [])), 'total_base_fee_msat': total}))
" "$result"
