#!/bin/bash
# lightning wallet-pin-reset <wallet_name>   (FEAT-390)
set -e
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-pin-reset <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
sqlite3 "$db" "DELETE FROM meta WHERE key IN ('pin_hash','pin_attempts');" 2>/dev/null || true
echo '{"status":"pin_reset","wallet":"'"$wname"'"}'
