#!/bin/bash
# lightning invoice-list-by-paid-at <since_ts>   (FEAT-1675)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-by-paid-at <since_ts>"}'; exit 0
fi
since="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
since = int(sys.argv[2])
invs = [i for i in data.get('invoices', []) if i.get('paid_at') and i['paid_at'] >= since]
print(json.dumps({'count': len(invs), 'invoices': [i.get('label') for i in invs]}))
" "$result" "$since"
