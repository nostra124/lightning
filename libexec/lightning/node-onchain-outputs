#!/bin/bash
# lightning node-onchain-outputs   (FEAT-1479)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
print(json.dumps({'output_count': len(outputs), 'outputs': outputs}))
" "$result"
