#!/bin/bash
# lightning node-listchannels-disabled   (FEAT-1694)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if not c.get('active')]
print(json.dumps({'total': len(data.get('channels', [])), 'disabled': len(channels), 'channels': [c.get('short_channel_id') for c in channels[:20]]}))
" "$result"
