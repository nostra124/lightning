#!/bin/bash
# lightning peer-last-forward <peer_id>   (FEAT-1247)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-last-forward <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
matched = [f for f in data.get('forwards', []) if pid in (f.get('in_channel',''), f.get('out_channel',''))]
last = sorted(matched, key=lambda f: f.get('received_time', 0), reverse=True)[:1]
print(json.dumps({'peer_id': pid, 'last_forward': last[0] if last else None}))
" "$result" "$peer_id"
