#!/bin/bash
# lightning peer-total-sent-msat   (FEAT-2056)
PEER_ID=${1:-}
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
peer_id = sys.argv[2] if len(sys.argv) > 2 else ''
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
count = 0
for c in channels:
    if peer_id and c.get('peer_id') != peer_id:
        continue
    total += int(c.get('out_payments_fulfilled', 0))
    count += 1
print(json.dumps({'peer_id': peer_id or 'all', 'total_sent_msat': total, 'channel_count': count}))
" "$result" "$PEER_ID"
