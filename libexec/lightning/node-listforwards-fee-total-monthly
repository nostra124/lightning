#!/bin/bash
# lightning node-listforwards-fee-total-monthly   (FEAT-2871)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time, calendar
data = json.loads(sys.argv[1])
now = time.time()
t = time.gmtime(now)
month_start = calendar.timegm((t.tm_year, t.tm_mon, 1, 0, 0, 0, 0, 0, 0))
total = sum(f.get('fee_msat', 0) for f in data.get('forwards', []) if f.get('resolved_time', 0) >= month_start)
print(json.dumps({'fee_total_monthly_msat': total}))
" "$result"
