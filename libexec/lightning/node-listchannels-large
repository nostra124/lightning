#!/bin/bash
# lightning node-listchannels-large <min_sat>   (FEAT-1904)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listchannels-large <min_sat>"}'; exit 0; fi
min_sat="$1"
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
min_s = int(sys.argv[2]) * 1000
channels = [c for c in data.get('channels', []) if c.get('amount_msat', 0) >= min_s]
print(json.dumps({'count': len(channels), 'min_sat': int(sys.argv[2])}))
" "$result" "$min_sat"
