#!/bin/bash
# lightning channel-opener-remote-count   (FEAT-2080)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
count = sum(1 for c in channels if c.get('opener') == 'remote')
print(json.dumps({'remote_opener_count': count}))
" "$result"
