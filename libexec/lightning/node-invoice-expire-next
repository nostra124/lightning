#!/bin/bash
# lightning node-invoice-expire-next   (FEAT-2526)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
unpaid = [i for i in invoices if i.get('status') == 'unpaid']
if not unpaid:
    print(json.dumps({'next_expiring_invoice': None}))
    sys.exit(0)
soonest = min(unpaid, key=lambda i: i.get('expires_at', float('inf')))
print(json.dumps({'next_expiring_invoice': {'label': soonest.get('label'), 'expires_at': soonest.get('expires_at')}}))
" "$result"
