#!/bin/bash
# lightning peer-disconnected-count   (FEAT-2348)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
count = sum(1 for p in peers if not p.get('connected', True))
print(json.dumps({'disconnected_count': count}))
" "$result"
