#!/bin/bash
# lightning node-listforwards-in-out-diff   (FEAT-2960)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total_in = sum(f.get('in_msat', 0) for f in forwards)
total_out = sum(f.get('out_msat', 0) for f in forwards)
diff = total_in - total_out
print(json.dumps({'in_out_diff_msat': diff, 'total_in_msat': total_in, 'total_out_msat': total_out, 'forward_count': len(forwards)}))
" "$result"
