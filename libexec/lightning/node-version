#!/bin/bash
# lightning node-version   (FEAT-480)
if ! result=$(lightning-cli getinfo 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
info = json.loads(sys.argv[1])
print(json.dumps({'version': info.get('version', ''), 'network': info.get('network', '')}, separators=(',', ':')))
" "$result"
