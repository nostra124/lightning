#!/bin/bash
# lightning channel-htlc-min-kurtosis   (FEAT-3621)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('htlc_minimum_msat', 0) for c in channels if 'htlc_minimum_msat' in c]
if len(vals) < 4:
    kurtosis = 0
else:
    n = len(vals)
    mean = sum(vals) / n
    variance = sum((x - mean) ** 2 for x in vals) / n
    std = math.sqrt(variance) if variance > 0 else 0
    if std == 0:
        kurtosis = 0
    else:
        kurtosis = (sum((x - mean) ** 4 for x in vals) / n) / (std ** 4) - 3
print(json.dumps({'htlc_min_kurtosis_msat': kurtosis}))
" "$result"
