#!/bin/bash
# lightning node-graph-node-capacity   (FEAT-2174)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
capacity = {}
for ch in channels:
    src = ch.get('source', '')
    amt = ch.get('amount_msat', 0) or 0
    capacity[src] = capacity.get(src, 0) + amt
top = sorted(capacity.items(), key=lambda x: -x[1])[:10]
print(json.dumps({'node_count': len(capacity), 'top_nodes_by_capacity_msat': [{'node_id': n, 'capacity_msat': c} for n, c in top]}))
" "$result"
