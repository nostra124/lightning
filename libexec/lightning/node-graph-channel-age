#!/bin/bash
# lightning node-graph-channel-age   (FEAT-1609)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ages = [c.get('last_update', 0) for c in channels if c.get('last_update')]
if not ages:
    print(json.dumps({'count': 0, 'oldest_update': None, 'newest_update': None}))
    sys.exit(0)
print(json.dumps({'count': len(channels), 'oldest_update': min(ages), 'newest_update': max(ages)}))
" "$result"
