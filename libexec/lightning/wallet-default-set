#!/bin/bash
# lightning wallet-default-set <wallet_name>   (FEAT-519)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-default-set <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
cfg_file="${HOME}/.lightning/default_wallet"
mkdir -p "$(dirname "$cfg_file")"
printf '%s\n' "$wname" > "$cfg_file"
echo '{"ok":true,"default_wallet":"'"$wname"'"}'
