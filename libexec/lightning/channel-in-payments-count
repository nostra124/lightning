#!/bin/bash
# lightning channel-in-payments-count <channel_id>   (FEAT-1270)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-in-payments-count <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        print(json.dumps({'channel_id': ch.get('channel_id'), 'in_payments_offered': ch.get('in_payments_offered'), 'in_payments_fulfilled': ch.get('in_payments_fulfilled')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
