#!/bin/bash
# lightning channel-htlc-count-max   (FEAT-2228)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
else:
    best = max(channels, key=lambda c: len(c.get('htlcs', [])))
    print(json.dumps({'short_channel_id': best.get('short_channel_id'), 'htlc_count': len(best.get('htlcs', []))}))
" "\$result"
