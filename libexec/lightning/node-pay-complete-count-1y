#!/bin/bash
# lightning node-pay-complete-count-1y   (FEAT-2476)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
cutoff = time.time() - 365 * 86400
pays = data.get('pays', [])
count = sum(1 for p in pays if p.get('status') == 'complete' and float(p.get('created_at', 0)) >= cutoff)
print(json.dumps({'pay_complete_count_1y': count}))
" "$result"
