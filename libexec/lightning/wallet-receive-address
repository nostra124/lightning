#!/bin/bash
# lightning wallet-receive-address <wallet_name>   (FEAT-1168)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-receive-address <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
addr=$(sqlite3 "$db" "SELECT address FROM addresses ORDER BY rowid DESC LIMIT 1;" 2>/dev/null)
if [ -z "$addr" ]; then
    result=$(lightning-cli newaddr 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
    echo "$result"
else
    echo "{\"wallet\":\"$wname\",\"address\":\"$addr\"}"
fi
