#!/bin/bash
# lightning node-invoice-paid-amount-min   (FEAT-2699)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
if not invoices:
    print(json.dumps({'min_paid_amount_msat': None}))
else:
    amounts = [i.get('amount_received_msat', i.get('amount_msat', 0)) for i in invoices]
    print(json.dumps({'min_paid_amount_msat': min(amounts)}))
" "$result"
