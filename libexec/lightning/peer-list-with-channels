#!/bin/bash
# lightning peer-list-with-channels   (FEAT-1377)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = [{'id': p.get('id'), 'connected': p.get('connected')} for p in data.get('peers', []) if p.get('channels')]
print(json.dumps({'count': len(peers), 'peers': peers}))
" "$result"
