#!/bin/bash
# lightning peer-local-balance-max   (FEAT-2368)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from collections import defaultdict
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'peer_id': None, 'local_msat_total': 0}))
    sys.exit(0)
totals = defaultdict(int)
for c in channels:
    totals[c.get('peer_id', '')] += c.get('local_msat', 0)
top_peer = max(totals, key=totals.get)
print(json.dumps({'peer_id': top_peer, 'local_msat_total': totals[top_peer]}))
" "$result"
