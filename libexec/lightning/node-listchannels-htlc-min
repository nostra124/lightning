#!/bin/bash
# lightning node-listchannels-htlc-min   (FEAT-1814)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels: print(json.dumps({'count': 0, 'min_htlc_msat': 0})); sys.exit(0)
mins = [c.get('htlc_minimum_msat', 0) for c in channels]
print(json.dumps({'count': len(channels), 'min_htlc_msat': min(mins)}))
" "$result"
