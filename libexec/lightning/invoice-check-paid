#!/bin/bash
# lightning invoice-check-paid <label>   (FEAT-765)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-check-paid <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if invoices:
    i = invoices[0]
    print(json.dumps({'label': i.get('label'), 'paid': i.get('status') == 'paid', 'status': i.get('status')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
