#!/bin/bash
# lightning node-invoice-unpaid-newest   (FEAT-2594)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid']
if not invoices:
    print(json.dumps({'newest_unpaid_invoice': None}))
else:
    newest = max(invoices, key=lambda i: int(i.get('created_index', 0)))
    print(json.dumps({'newest_unpaid_invoice': newest}))
" "$result"
