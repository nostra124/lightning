#!/bin/bash
# lightning channel-local-balance-stddev   (FEAT-2745)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('to_us_msat', 0) for c in channels if 'to_us_msat' in c]
if len(vals) > 1:
    mean = sum(vals) / len(vals)
    variance = sum((v - mean) ** 2 for v in vals) / len(vals)
    stddev = math.sqrt(variance)
else:
    stddev = 0
print(json.dumps({'local_balance_stddev_msat': stddev, 'count': len(vals)}))
" "$result"
