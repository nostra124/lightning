#!/bin/bash
# lightning node-self-payment <amount_msat>   (FEAT-574)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-self-payment <amount_msat>"}'
    exit 0
fi
amount_msat="$1"
info=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
node_id=$(python3 -c "import sys,json; print(json.loads(sys.argv[1]).get('id',''))" "$info")
if [ -z "$node_id" ]; then
    echo '{"error":"could not get node id"}'
    exit 0
fi
label="self-pay-$(date +%s)"
inv=$(lightning-cli invoice "$amount_msat" "$label" "self payment" 2>/dev/null) || { echo '{"error":"invoice failed"}'; exit 0; }
bolt11=$(python3 -c "import sys,json; print(json.loads(sys.argv[1]).get('bolt11',''))" "$inv")
result=$(lightning-cli pay "$bolt11" 2>/dev/null) || { echo '{"error":"payment failed"}'; exit 0; }
echo "$result"
