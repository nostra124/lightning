#!/bin/bash
# lightning peer-channels-avg   (FEAT-2623)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'avg_channels_per_peer': 0}))
    sys.exit(0)
from collections import Counter
peer_counts = Counter(c.get('peer_id') for c in channels)
avg = sum(peer_counts.values()) / len(peer_counts)
print(json.dumps({'avg_channels_per_peer': avg}))
" "$result"
