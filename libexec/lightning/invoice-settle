#!/bin/bash
# lightning invoice-settle <label>   (FEAT-635)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-settle <label>"}'
    exit 0
fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if invoices:
    inv = invoices[0]
    print(json.dumps({'label': inv.get('label'), 'status': inv.get('status'), 'settled': inv.get('status') == 'paid'}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
