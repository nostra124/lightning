#!/bin/bash
# lightning node-graph-channel-count   (FEAT-939)
if ! result=$(lightning-cli listchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
chs = data.get('channels', [])
print(json.dumps({'total_channels': len(chs)}))
" "$result"
