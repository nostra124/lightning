#!/bin/bash
# lightning node-fee-collect <since_unix>   (FEAT-809)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-fee-collect <since_unix>"}'; exit 0; fi
since="$1"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
since = int(sys.argv[2])
fwds = [f for f in data.get('forwards', []) if f.get('status') == 'settled' and isinstance(f.get('resolved_time', 0), (int, float)) and f.get('resolved_time', 0) >= since]
total_fee = sum(f.get('fee_msat', 0) for f in fwds if isinstance(f.get('fee_msat', 0), int))
print(json.dumps({'since': since, 'settled_count': len(fwds), 'fee_collected_msat': total_fee}))
" "$result" "$since"
