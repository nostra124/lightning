#!/bin/bash
# lightning invoice-list-created-after <ts>   (FEAT-1725)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-created-after <ts>"}'; exit 0
fi
ts="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
ts = int(sys.argv[2])
invs = [i for i in data.get('invoices', []) if i.get('created_index', 0) >= ts or i.get('expires_at', 0) >= ts]
print(json.dumps({'count': len(invs), 'invoices': [i.get('label') for i in invs]}))
" "$result" "$ts"
