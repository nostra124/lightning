#!/bin/bash
# lightning channel-local-balance-range   (FEAT-2927)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    v = ch.get('to_us_msat', 0)
    if isinstance(v, str): v = int(v)
    vals.append(v)
result = (max(vals) - min(vals)) if len(vals) >= 2 else (vals[0] if vals else 0)
print(json.dumps({'local_balance_range_msat': result}))
" "$result"
