#!/bin/bash
# lightning node-graph-short-channel-ids <node_id>   (FEAT-1849)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-graph-short-channel-ids <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listchannels "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
scids = [c.get('short_channel_id') for c in data.get('channels', [])]
print(json.dumps({'count': len(scids), 'scids': scids}))
" "$result"
