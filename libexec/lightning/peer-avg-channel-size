#!/bin/bash
# lightning peer-avg-channel-size <peer_id>   (FEAT-1837)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-avg-channel-size <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
if not channels: print(json.dumps({'peer_id': pid, 'avg_size_msat': 0, 'count': 0})); sys.exit(0)
total = sum(c.get('total_msat', 0) for c in channels)
avg = total // len(channels)
print(json.dumps({'peer_id': pid, 'avg_size_msat': avg, 'count': len(channels)}))
" "$result" "$peer_id"
