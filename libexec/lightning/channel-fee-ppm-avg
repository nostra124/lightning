#!/bin/bash
# lightning channel-fee-ppm-avg   (FEAT-2275)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ppms = [ch.get('fee_proportional_millionths', 0) for ch in channels if 'fee_proportional_millionths' in ch]
avg = sum(ppms) / len(ppms) if ppms else 0
print(json.dumps({'fee_ppm_avg': avg, 'channel_count': len(ppms)}))
" "$result"
