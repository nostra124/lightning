#!/bin/bash
# lightning peer-channel-age-avg   (FEAT-2258)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
by_peer = {}
for c in channels:
    pid = c.get('peer_id', 'unknown')
    scid = c.get('short_channel_id', '')
    if scid and 'x' in scid:
        block = int(scid.split('x')[0])
    else:
        block = None
    if pid not in by_peer:
        by_peer[pid] = []
    if block is not None:
        by_peer[pid].append(block)
result = {}
for pid, blocks in by_peer.items():
    if blocks:
        result[pid] = {'avg_open_block': sum(blocks) / len(blocks), 'channel_count': len(blocks)}
    else:
        result[pid] = {'avg_open_block': None, 'channel_count': 0}
print(json.dumps({'peers': result}))
" "$result"
