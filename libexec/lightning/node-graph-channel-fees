#!/bin/bash
# lightning node-graph-channel-fees   (FEAT-1584)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = [c.get('fee_per_millionth', 0) for c in channels if c.get('fee_per_millionth') is not None]
avg = sum(fees) / len(fees) if fees else 0
print(json.dumps({'channel_count': len(channels), 'avg_fee_ppm': round(avg, 2)}))
" "$result"
