#!/bin/bash
# lightning peer-capacity-max   (FEAT-2453)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_cap = {}
for ch in channels:
    pid = ch.get('peer_id', '')
    cap = ch.get('local_msat', 0) + ch.get('remote_msat', 0)
    peer_cap[pid] = peer_cap.get(pid, 0) + cap
if not peer_cap:
    print(json.dumps({'peer_id': None, 'total_capacity_msat': 0}))
else:
    best = max(peer_cap, key=lambda p: peer_cap[p])
    print(json.dumps({'peer_id': best, 'total_capacity_msat': peer_cap[best]}))
" "$result"
