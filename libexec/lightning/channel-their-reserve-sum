#!/bin/bash
# lightning channel-their-reserve-sum   (FEAT-2870)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('their_reserve_msat', 0) for c in channels)
print(json.dumps({'their_reserve_sum_msat': total}))
" "$result"
