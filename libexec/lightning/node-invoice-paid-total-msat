#!/bin/bash
# lightning node-invoice-paid-total-msat   (FEAT-1914)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
total = sum(i.get('amount_received_msat', 0) for i in invoices)
print(json.dumps({'paid_count': len(invoices), 'total_received_msat': total}))
" "$result"
