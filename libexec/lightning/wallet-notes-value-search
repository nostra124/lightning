#!/bin/bash
# lightning wallet-notes-value-search <wallet_name> <query>   (FEAT-1378)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-value-search <wallet_name> <query>"}'; exit 0; fi
wname="$1"; query="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, sqlite3, json
db = sys.argv[1]; q = sys.argv[2]; wname = sys.argv[3]
conn = sqlite3.connect(db)
rows = conn.execute('SELECT key, value FROM notes WHERE value LIKE ?', ('%'+q+'%',)).fetchall()
conn.close()
results = [{'key': r[0], 'value': r[1]} for r in rows]
print(json.dumps({'wallet': wname, 'query': q, 'count': len(results), 'results': results}))
" "$db" "$query" "$wname" 2>/dev/null || echo '{"error":"db_error"}'
