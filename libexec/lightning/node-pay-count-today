#!/bin/bash
# lightning node-pay-count-today   (FEAT-2764)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
today_start = int(time.time()) - (int(time.time()) % 86400)
count = sum(1 for p in pays if p.get('created_at', 0) >= today_start)
print(json.dumps({'pay_count_today': count}))
" "$result"
