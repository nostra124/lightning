#!/bin/bash
# lightning wallet-check-integrity <wallet_name>   (FEAT-878)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-check-integrity <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"database_not_found"}'; exit 0; fi
result=$(sqlite3 "$db" "PRAGMA integrity_check;" 2>/dev/null) || { echo '{"error":"sqlite3 not available"}'; exit 0; }
if [ "$result" = "ok" ]; then
    echo "{\"wallet\":\"$wname\",\"integrity\":\"ok\"}"
else
    echo "{\"wallet\":\"$wname\",\"integrity\":\"error\",\"details\":\"$result\"}"
fi
