#!/bin/bash
# lightning node-channel-age-avg   (FEAT-824)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
indexes = [c.get('created_index', 0) for c in channels if isinstance(c.get('created_index', 0), int)]
avg = round(sum(indexes) / len(indexes), 1) if indexes else 0
print(json.dumps({'channel_count': len(channels), 'avg_created_index': avg}))
" "$result"
