#!/bin/bash
# lightning node-channel-age-avg   (FEAT-1221)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
now = int(time.time())
ages = [now - ch.get('created_at', now) for ch in channels if ch.get('created_at')]
avg = int(sum(ages) / len(ages)) if ages else 0
print(json.dumps({'channel_count': len(channels), 'avg_age_seconds': avg}))
" "$result"
