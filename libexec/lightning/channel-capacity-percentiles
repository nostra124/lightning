#!/bin/bash
# lightning channel-capacity-percentiles   (FEAT-2210)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
caps = []
for c in channels:
    total = c.get('total_msat', 0)
    try:
        caps.append(int(str(total).replace('msat','')))
    except Exception:
        pass
if not caps:
    print(json.dumps({'error': 'no capacity data'}))
    sys.exit(0)
caps.sort()
def pct(lst, p):
    idx = max(0, int(len(lst) * p / 100) - 1)
    return lst[idx]
print(json.dumps({'p25_msat': pct(caps,25), 'p50_msat': pct(caps,50), 'p75_msat': pct(caps,75), 'p90_msat': pct(caps,90), 'channel_count': len(caps)}))
" "$result"
