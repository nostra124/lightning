#!/bin/bash
# lightning channel-balance-pct <channel_id>   (FEAT-1990)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-balance-pct <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
channels = data.get('channels', [])
for ch in channels:
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        total = ch.get('total_msat') or 0
        to_us = ch.get('to_us_msat') or 0
        pct = round(to_us / total * 100, 2) if total > 0 else None
        print(json.dumps({'channel_id': cid, 'local_pct': pct}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
