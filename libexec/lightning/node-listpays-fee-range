#!/bin/bash
# lightning node-listpays-fee-range   (FEAT-1951)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
fees = []
for p in pays:
    if p.get('status') == 'complete':
        sent = p.get('amount_sent_msat', 0)
        amt = p.get('amount_msat', 0)
        if isinstance(sent, str): sent = int(sent.replace('msat',''))
        if isinstance(amt, str): amt = int(amt.replace('msat',''))
        fees.append(sent - amt)
if fees:
    print(json.dumps({'count': len(fees), 'min_fee_msat': min(fees), 'max_fee_msat': max(fees)}))
else:
    print(json.dumps({'count': 0, 'min_fee_msat': None, 'max_fee_msat': None}))
" "$result"
