#!/bin/bash
# lightning peer-htlc-count <peer_id>   (FEAT-1187)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-htlc-count <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
total_htlcs = sum(len(c.get('htlcs', [])) for c in data.get('channels', []) if c.get('peer_id') == pid)
print(json.dumps({'peer_id': pid, 'htlc_count': total_htlcs}))
" "$result" "$peer_id"
