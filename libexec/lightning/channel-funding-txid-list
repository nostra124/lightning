#!/bin/bash
# lightning channel-funding-txid-list   (FEAT-2250)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
txids = [c.get('funding_txid') for c in channels if c.get('funding_txid')]
print(json.dumps({'funding_txids': txids}))
" "$result"
