#!/bin/bash
# lightning peer-channel-state <peer_id>   (FEAT-1237)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-channel-state <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [{'channel_id': c.get('channel_id'), 'state': c.get('state')} for c in data.get('channels', []) if c.get('peer_id') == pid]
print(json.dumps({'peer_id': pid, 'channels': channels}))
" "$result" "$peer_id"
