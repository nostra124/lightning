#!/bin/bash
# lightning channel-local-pct-median   (FEAT-2667)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pcts = []
for ch in channels:
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if isinstance(total, str): total = int(total.replace('msat',''))
    if isinstance(local, str): local = int(local.replace('msat',''))
    if total > 0:
        pcts.append(100.0 * local / total)
if pcts:
    s = sorted(pcts)
    n = len(s)
    mid = n // 2
    median = s[mid] if n % 2 == 1 else (s[mid-1] + s[mid]) / 2.0
    print(json.dumps({'local_pct_median': round(median, 4)}))
else:
    print(json.dumps({'local_pct_median': None}))
" "$result"
