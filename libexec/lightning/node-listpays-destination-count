#!/bin/bash
# lightning node-listpays-destination-count   (FEAT-1791)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
destinations = set(p.get('destination') for p in pays if p.get('destination'))
print(json.dumps({'total_pays': len(pays), 'unique_destinations': len(destinations)}))
" "$result"
