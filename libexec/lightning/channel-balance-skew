#!/bin/bash
# lightning channel-balance-skew   (FEAT-2172)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
skews = []
for ch in channels:
    total = (ch.get('to_us_msat', 0) or 0) + (ch.get('to_them_msat', 0) or 0)
    if total > 0:
        local_pct = (ch.get('to_us_msat', 0) or 0) / total * 100
        skews.append(abs(local_pct - 50))
avg_skew = sum(skews) / len(skews) if skews else 0
print(json.dumps({'channel_count': len(skews), 'avg_imbalance_score': round(avg_skew, 4)}))
" "$result"
