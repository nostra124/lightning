#!/bin/bash
# lightning channel-fee-ppm-variance   (FEAT-2415)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [ch.get('fee_proportional_millionths', 0) for ch in channels if 'fee_proportional_millionths' in ch]
mean = sum(vals) / len(vals) if vals else 0
variance = sum((x - mean) ** 2 for x in vals) / len(vals) if vals else 0
print(json.dumps({'fee_ppm_variance': variance, 'fee_ppm_mean': mean, 'channel_count': len(vals)}))
" "$result"
