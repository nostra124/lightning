#!/bin/bash
# lightning channel-capacity-largest   (FEAT-2165)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
largest = max(channels, key=lambda c: c.get('total_msat', 0))
print(json.dumps({
    'peer_id': largest.get('peer_id', ''),
    'channel_id': largest.get('channel_id', ''),
    'total_msat': largest.get('total_msat', 0),
    'state': largest.get('state', ''),
}))
" "$result"
