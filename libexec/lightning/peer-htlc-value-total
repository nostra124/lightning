#!/bin/bash
# lightning peer-htlc-value-total   (FEAT-2964)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    for h in ch.get('htlcs', []):
        total += int(h.get('amount_msat', 0))
print(json.dumps({'htlc_value_total_msat': total}))
" "$result"
