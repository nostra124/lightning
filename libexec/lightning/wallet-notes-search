#!/bin/bash
# lightning wallet-notes-search <wallet_name> <query>   (FEAT-1163)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-search <wallet_name> <query>"}'; exit 0; fi
wname="$1"; query="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "SELECT key, value FROM notes WHERE value LIKE '%${query}%';" 2>/dev/null | python3 -c "
import sys, json
rows = []
for line in sys.stdin:
    parts = line.rstrip('\n').split('|', 1)
    if len(parts) == 2:
        rows.append({'key': parts[0], 'value': parts[1]})
print(json.dumps({'results': rows, 'count': len(rows)}))
"
