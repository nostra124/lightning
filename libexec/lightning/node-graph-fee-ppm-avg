#!/bin/bash
# lightning node-graph-fee-ppm-avg   (FEAT-1969)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('fee_per_millionth', 0) for c in channels if 'fee_per_millionth' in c]
avg = round(sum(vals)/len(vals), 2) if vals else None
print(json.dumps({'channel_count': len(channels), 'avg_fee_ppm': avg}))
" "$result"
