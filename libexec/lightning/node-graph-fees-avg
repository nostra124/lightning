#!/bin/bash
# lightning node-graph-fees-avg   (FEAT-2004)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'avg_base_fee_millisatoshi': 0, 'channel_count': 0}))
    sys.exit(0)
total = sum(c.get('base_fee_millisatoshi', 0) for c in channels)
avg = total / len(channels)
print(json.dumps({'avg_base_fee_millisatoshi': avg, 'channel_count': len(channels)}))
" "$result"
