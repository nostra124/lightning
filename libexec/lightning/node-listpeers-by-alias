#!/bin/bash
# lightning node-listpeers-by-alias <alias>   (FEAT-1194)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listpeers-by-alias <alias>"}'; exit 0; fi
alias_query="$1"
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
alias = sys.argv[2].lower()
matched = [p for p in data.get('peers', []) if alias in (p.get('alias') or '').lower()]
print(json.dumps({'count': len(matched), 'peers': [p.get('id') for p in matched]}))
" "$result" "$alias_query"
