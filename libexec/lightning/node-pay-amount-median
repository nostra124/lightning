#!/bin/bash
# lightning node-pay-amount-median   (FEAT-2576)
result=$(lightning-cli listsendpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('payments', [])
amounts = sorted(p.get('amount_msat', 0) for p in pays)
if not amounts:
    print(json.dumps({'amount_median_msat': 0}))
else:
    n = len(amounts)
    mid = n // 2
    median = amounts[mid] if n % 2 else (amounts[mid-1] + amounts[mid]) // 2
    print(json.dumps({'amount_median_msat': median}))
" "$result"
