#!/bin/bash
# lightning channel-remote-htlc-total-msat   (FEAT-2045)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    htlcs = ch.get('htlcs', [])
    for h in htlcs:
        if h.get('direction') == 'in':
            amt = h.get('amount_msat', 0)
            if isinstance(amt, str) and amt.endswith('msat'):
                amt = int(amt[:-4])
            total += int(amt)
print(json.dumps({'remote_htlc_total_msat': total}))
" "$result"
