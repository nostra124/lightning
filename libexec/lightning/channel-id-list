#!/bin/bash
# lightning channel-id-list   (FEAT-1140)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
ids = [ch.get('channel_id') for ch in data.get('channels', []) if ch.get('channel_id')]
print(json.dumps(ids))
" "$result"
