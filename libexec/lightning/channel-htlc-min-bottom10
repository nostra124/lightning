#!/bin/bash
# lightning channel-htlc-min-bottom10   (FEAT-2722)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
channels_with_min = [c for c in channels if 'htlc_minimum_msat' in c]
bottom10 = sorted(channels_with_min, key=lambda c: c.get('htlc_minimum_msat', 0))[:10]
print(json.dumps({'bottom10_by_htlc_min': bottom10}))
" "$result"
