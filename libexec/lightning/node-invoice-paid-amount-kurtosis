#!/bin/bash
# lightning node-invoice-paid-amount-kurtosis   (FEAT-2826)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
vals = [i['amount_received_msat'] for i in invoices if i.get('status') == 'paid' and 'amount_received_msat' in i]
n = len(vals)
if n < 4:
    print(json.dumps({'paid_amount_kurtosis': None, 'n': n}))
    sys.exit(0)
mean = sum(vals) / n
var = sum((v - mean)**2 for v in vals) / n
if var == 0:
    kurt = 0.0
else:
    kurt = (sum((v - mean)**4 for v in vals) / n) / (var**2) - 3
print(json.dumps({'paid_amount_kurtosis': kurt, 'n': n}))
" "$result"
