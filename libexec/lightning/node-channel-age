#!/bin/bash
# lightning node-channel-age   (FEAT-520)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json, time
channels = json.loads(sys.argv[1]).get('channels', [])
now = int(time.time())
out = [{'channel_id': c.get('channel_id',''), 'age_seconds': now - c.get('opened_at', now),
    'state': c.get('state', '')} for c in channels if c.get('channel_id')]
print(json.dumps(out, separators=(',', ':')))
" "$result"
