#!/bin/bash
# lightning channel-local-ratio-min   (FEAT-2230)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_ratio = None
for ch in channels:
    total = int(str(ch.get('total_msat', 0) or 0).replace('msat',''))
    local = int(str(ch.get('to_us_msat', ch.get('local_msat', 0)) or 0).replace('msat',''))
    if total == 0: continue
    ratio = local / total
    if best_ratio is None or ratio < best_ratio:
        best_ratio = ratio
        best = {'short_channel_id': ch.get('short_channel_id'), 'local_ratio': round(ratio, 4), 'local_msat': local, 'total_msat': total}
if best is None:
    print(json.dumps({'error': 'no channels'}))
else:
    print(json.dumps(best))
" "\$result"
