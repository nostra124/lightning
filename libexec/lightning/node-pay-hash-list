#!/bin/bash
# lightning node-pay-hash-list   (FEAT-1411)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
hashes = [p.get('payment_hash') for p in data.get('pays', [])]
print(json.dumps({'count': len(hashes), 'payment_hashes': hashes}))
" "$result"
