#!/bin/bash
# lightning node-channel-open-pending   (FEAT-964)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pending_states = {'CHANNELD_AWAITING_LOCKIN', 'DUALOPEND_AWAITING_LOCKIN', 'DUALOPEND_OPEN_INIT'}
pending = [c for c in data.get('channels', []) if c.get('state') in pending_states]
print(json.dumps({'count': len(pending), 'channels': [c.get('channel_id') for c in pending]}))
" "$result"
