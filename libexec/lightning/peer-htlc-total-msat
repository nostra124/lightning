#!/bin/bash
# lightning peer-htlc-total-msat <peer_id>   (FEAT-1357)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-htlc-total-msat <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
total = 0; count = 0
for ch in data.get('channels', []):
    if ch.get('peer_id') == pid:
        for h in ch.get('htlcs', []):
            total += h.get('amount_msat', 0); count += 1
print(json.dumps({'peer_id': pid, 'htlc_count': count, 'total_msat': total}))
" "$result" "$peer_id"
