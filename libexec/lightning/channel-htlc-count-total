#!/bin/bash
# lightning channel-htlc-count-total   (FEAT-2392)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(len(c.get('htlcs', [])) for c in channels)
print(json.dumps({'htlc_count_total': total}))
" "$result"
