#!/bin/bash
# lightning node-funding-txids   (FEAT-466)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
txids = [{'funding_txid': c.get('funding_txid', ''), 'funding_outnum': c.get('funding_outnum', 0),
    'peer_id': c.get('peer_id', '')} for c in channels if c.get('funding_txid')]
print(json.dumps(txids, separators=(',', ':')))
" "$result"
