#!/bin/bash
# lightning node-listpays-amount-avg   (FEAT-1761)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
amounts = [p.get('amount_sent_msat', 0) for p in pays]
avg = int(sum(amounts) / len(amounts)) if amounts else 0
print(json.dumps({'count': len(pays), 'avg_msat': avg}))
" "$result"
