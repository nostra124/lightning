#!/bin/bash
# lightning wallet-notes-pin <wallet_name> <key>   (FEAT-1248)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-pin <wallet_name> <key>"}'; exit 0; fi
wname="$1"; key="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "UPDATE notes SET pinned=1 WHERE key='$key';" 2>/dev/null
echo "{\"ok\":true,\"wallet\":\"$wname\",\"pinned\":\"$key\"}"
