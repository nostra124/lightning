#!/bin/bash
# lightning wallet-notes-pin <wallet> <key>   (FEAT-1453)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-pin <wallet> <key>"}'; exit 0; fi
wname="$1"; key="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "UPDATE notes SET pinned=1 WHERE key='$key';" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"pinned\":true}"
