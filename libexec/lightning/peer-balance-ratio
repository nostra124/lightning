#!/bin/bash
# lightning peer-balance-ratio   (FEAT-2186)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peers = {}
for c in channels:
    pid = c.get('peer_id', 'unknown')
    local = c.get('to_us_msat', 0)
    total = c.get('total_msat', 0)
    if isinstance(local, str): local = int(local.replace('msat',''))
    if isinstance(total, str): total = int(total.replace('msat',''))
    if pid not in peers:
        peers[pid] = {'local': 0, 'total': 0}
    peers[pid]['local'] += local
    peers[pid]['total'] += total
result = []
for pid, v in peers.items():
    ratio = round(v['local']/v['total']*100, 2) if v['total'] > 0 else None
    result.append({'peer_id': pid, 'local_msat': v['local'], 'total_msat': v['total'], 'local_pct': ratio})
print(json.dumps({'peers': result}))
" "$result"
