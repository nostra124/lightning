#!/bin/bash
# lightning peer-local-reserve-avg   (FEAT-2678)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('local_reserve_msat', 0) for c in channels if 'local_reserve_msat' in c]
avg = sum(vals) / len(vals) if vals else 0
print(json.dumps({'avg_local_reserve_msat': avg}))
" "$result"
