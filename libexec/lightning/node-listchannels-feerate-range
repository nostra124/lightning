#!/bin/bash
# lightning node-listchannels-feerate-range   (FEAT-1554)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
rates = [c.get('fee_per_millionth', 0) for c in channels if c.get('fee_per_millionth') is not None]
if not rates:
    print(json.dumps({'min_ppm': None, 'max_ppm': None, 'count': len(channels)}))
else:
    print(json.dumps({'min_ppm': min(rates), 'max_ppm': max(rates), 'count': len(channels)}))
" "$result"
