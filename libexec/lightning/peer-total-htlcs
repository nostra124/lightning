#!/bin/bash
# lightning peer-total-htlcs <peer_id>   (FEAT-1017)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-total-htlcs <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
total = 0
for ch in data.get('channels', []):
    if ch.get('peer_id') == pid:
        total += len(ch.get('htlcs', []))
print(json.dumps({'peer_id': pid, 'total_htlcs': total}))
" "$result" "$peer_id"
