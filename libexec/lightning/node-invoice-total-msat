#!/bin/bash
# lightning node-invoice-total-msat   (FEAT-1191)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
paid = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
total = sum(i.get('amount_received_msat', 0) for i in paid if isinstance(i.get('amount_received_msat'), int))
print(json.dumps({'paid_count': len(paid), 'total_received_msat': total}))
" "$result"
