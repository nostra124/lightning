#!/bin/bash
# lightning node-invoice-total-msat   (FEAT-1967)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
total = 0
for i in invoices:
    v = i.get('amount_msat', 0)
    if isinstance(v, str): v = int(v.replace('msat',''))
    if isinstance(v, int): total += v
print(json.dumps({'total_invoices': len(invoices), 'total_amount_msat': total}))
" "$result"
