#!/bin/bash
# lightning node-invoice-paid-amount-total-monthly   (FEAT-2876)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time, calendar
data = json.loads(sys.argv[1])
now = time.time()
t = time.gmtime(now)
month_start = calendar.timegm((t.tm_year, t.tm_mon, 1, 0, 0, 0, 0, 0, 0))
total = sum(i.get('amount_received_msat', 0) for i in data.get('invoices', []) if i.get('status') == 'paid' and i.get('paid_at', 0) >= month_start)
print(json.dumps({'paid_amount_total_monthly_msat': total}))
" "$result"
