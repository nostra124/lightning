#!/bin/bash
# lightning channel-local-balance-min   (FEAT-2262)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel_id': None, 'local_msat': None}))
    sys.exit(0)
ch = min(channels, key=lambda c: int(c.get('local_msat', 0)))
print(json.dumps({'channel_id': ch.get('channel_id'), 'local_msat': ch.get('local_msat')}))
" "$result"
