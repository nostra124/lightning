#!/bin/bash
# lightning channel-open-list   (FEAT-1052)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
open_ch = [ch for ch in data.get('channels', []) if ch.get('state') == 'CHANNELD_NORMAL']
out = [{'channel_id': ch.get('channel_id'), 'peer_id': ch.get('peer_id')} for ch in open_ch]
print(json.dumps({'count': len(out), 'channels': out}))
" "$result"
