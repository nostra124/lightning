#!/bin/bash
# lightning node-gossip   (FEAT-319)
#
# Returns gossip graph summary from CLN.
# {num_nodes, num_channels, last_timestamp}

set -e
LD="--lightning-dir=${LIGHTNING_DIR:-$HOME/.lightning}"
NET="--network=${LIGHTNING_NETWORK:-bitcoin}"

command -v lightning-cli >/dev/null || {
    echo '{"error":"lightning-cli not found"}'; exit 0; }

nodes_raw=$(lightning-cli $LD $NET listnodes 2>/dev/null) || {
    echo '{"error":"listnodes_failed"}'; exit 0; }
chans_raw=$(lightning-cli $LD $NET listchannels 2>/dev/null) \
    || chans_raw='{"channels":[]}'

python3 -c "
import sys, json
nodes = json.loads(sys.argv[1]).get('nodes', [])
chans = json.loads(sys.argv[2]).get('channels', [])
last_ts = max((n.get('last_timestamp', 0) for n in nodes), default=0)
print(json.dumps({
    'num_nodes': len(nodes),
    'num_channels': len(chans),
    'last_timestamp': last_ts,
}, separators=(',', ':')))
" "$nodes_raw" "$chans_raw"
