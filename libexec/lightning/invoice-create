#!/bin/bash
# lightning invoice-create <sat> <label> [<description>]   (FEAT-300)
#
# Creates a BOLT-11 invoice.
# sat: amount in satoshis; use "any" for zero-amount.
# Returns {bolt11, payment_hash, label, expires_at}

set -e
[ $# -ge 2 ] || {
    printf 'usage: invoice-create <sat|any> <label> [<description>]\n' >&2
    exit 1
}
sat="$1"; label="$2"; desc="${3:-$label}"

command -v lightning-cli >/dev/null || {
    echo '{"error":"lightning-cli not found"}'; exit 0; }

LD="--lightning-dir=${LIGHTNING_DIR:-$HOME/.lightning}"
NET="--network=${LIGHTNING_NETWORK:-bitcoin}"

if [ "$sat" = "any" ]; then
    msat="any"
else
    msat=$((sat * 1000))
fi

raw=$(lightning-cli $LD $NET invoice "$msat" "$label" "$desc" 2>/dev/null) || {
    echo '{"error":"invoice_failed"}'; exit 0; }

python3 -c "
import sys, json
d = json.loads(sys.argv[1])
print(json.dumps({
    'bolt11': d.get('bolt11', ''),
    'payment_hash': d.get('payment_hash', ''),
    'label': sys.argv[2],
    'expires_at': d.get('expires_at'),
}, separators=(',', ':')))
" "$raw" "$label"
