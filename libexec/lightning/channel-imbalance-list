#!/bin/bash
# lightning channel-imbalance-list   (FEAT-2145)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
imbalanced = []
for c in channels:
    local  = c.get('to_us_msat', 0)
    total  = c.get('total_msat', 0)
    if isinstance(local, str): local = int(local.replace('msat',''))
    if isinstance(total, str): total = int(total.replace('msat',''))
    if total == 0: continue
    pct = local * 100 // total
    if pct < 30 or pct > 70:
        imbalanced.append({'peer_id': c.get('peer_id',''), 'local_pct': pct, 'short_channel_id': c.get('short_channel_id','')})
print(json.dumps({'imbalanced': imbalanced, 'count': len(imbalanced)}))
" "$result"
