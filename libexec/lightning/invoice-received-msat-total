#!/bin/bash
# lightning invoice-received-msat-total   (FEAT-1735)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
paid = [i for i in data.get('invoices', []) if i.get('status') == 'paid' and i.get('amount_received_msat')]
total = sum(i['amount_received_msat'] for i in paid)
print(json.dumps({'count': len(paid), 'total_received_msat': total}))
" "$result"
