#!/bin/bash
# lightning node-invoice-paid-rate   (FEAT-2324)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
total = len(invoices)
paid = sum(1 for inv in invoices if inv.get('status') == 'paid')
rate = round(paid / total, 4) if total > 0 else 0.0
print(json.dumps({'paid_invoices': paid, 'total_invoices': total, 'paid_rate': rate}))
" "$result"
