#!/bin/bash
# lightning channel-total-fees   (FEAT-1120)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_out = sum(ch.get('out_fulfilled_msat', 0) for ch in channels)
total_in = sum(ch.get('in_fulfilled_msat', 0) for ch in channels)
print(json.dumps({'channel_count': len(channels), 'total_out_msat': total_out, 'total_in_msat': total_in}))
" "$result"
