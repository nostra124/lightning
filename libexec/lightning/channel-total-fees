#!/bin/bash
# lightning channel-total-fees <channel_id>   (FEAT-780)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-total-fees <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
related = [f for f in data.get('forwards', []) if f.get('status') == 'settled' and (f.get('in_channel') == cid or f.get('out_channel') == cid)]
total_fee = sum(f.get('fee_msat', 0) for f in related if isinstance(f.get('fee_msat', 0), int))
print(json.dumps({'channel_id': cid, 'total_fee_msat': total_fee, 'forwards': len(related)}))
" "$result" "$channel_id"
