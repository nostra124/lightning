#!/bin/bash
# lightning channel-balance-check   (FEAT-800)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
imbalanced = []
for c in channels:
    total = c.get('total_msat', 0)
    to_us = c.get('to_us_msat', 0)
    if isinstance(total, int) and isinstance(to_us, int) and total > 0:
        ratio = to_us / total
        if ratio < 0.2 or ratio > 0.8:
            imbalanced.append({'channel_id': c.get('channel_id'), 'ratio': round(ratio, 3)})
print(json.dumps({'imbalanced_count': len(imbalanced), 'total_channels': len(channels), 'imbalanced': imbalanced}))
" "$result"
