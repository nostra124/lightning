#!/bin/bash
# lightning node-onchain-utxo-count   (FEAT-794)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
confirmed = [o for o in outputs if o.get('status') == 'confirmed']
print(json.dumps({'total_utxos': len(outputs), 'confirmed': len(confirmed)}))
" "$result"
