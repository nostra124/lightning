#!/bin/bash
# lightning wallet-cold-storage <wallet_name>   (FEAT-923)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-cold-storage <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$wname" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
echo "{\"wallet\":\"$wname\",\"cold_storage\":false,\"type\":\"hot\"}"
