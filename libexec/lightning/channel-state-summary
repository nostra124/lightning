#!/bin/bash
# lightning channel-state-summary   (FEAT-1430)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from collections import Counter
data = json.loads(sys.argv[1])
states = Counter(ch.get('state', 'unknown') for ch in data.get('channels', []))
print(json.dumps({'total': sum(states.values()), 'by_state': dict(states)}))
" "$result"
