#!/bin/bash
# lightning channel-htlc-list <channel_id>   (FEAT-530)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-htlc-list <channel_id>"}'
    exit 0
fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        htlcs = ch.get('htlcs', [])
        print(json.dumps(htlcs))
        sys.exit(0)
print('[]')
" "$result" "$channel_id"
