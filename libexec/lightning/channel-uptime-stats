#!/bin/bash
# lightning channel-uptime-stats   (FEAT-2092)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
stats = []
for ch in channels:
    stats.append({
        'channel_id': ch.get('channel_id'),
        'state': ch.get('state'),
        'lifetime': ch.get('lifetime'),
        'uptime': ch.get('uptime'),
    })
print(json.dumps({'uptime_stats': stats, 'count': len(stats)}))
" "$result"
