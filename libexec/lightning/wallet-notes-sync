#!/bin/bash
# lightning wallet-notes-sync <wallet>   (FEAT-1713)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-notes-sync <wallet>"}'; exit 0
fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"note_count\":$count,\"synced\":true}"
