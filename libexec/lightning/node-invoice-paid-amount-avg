#!/bin/bash
# lightning node-invoice-paid-amount-avg   (FEAT-2659)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
amounts = [i.get('amount_received_msat', i.get('amount_msat', 0)) or 0 for i in invoices]
avg = int(sum(amounts) / len(amounts)) if amounts else 0
print(json.dumps({'avg_paid_amount_msat': avg}))
" "$result"
