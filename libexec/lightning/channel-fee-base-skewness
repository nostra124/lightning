#!/bin/bash
# lightning channel-fee-base-skewness   (FEAT-2802)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('fee_base_msat', 0) for c in channels if 'fee_base_msat' in c]
n = len(vals)
if n >= 3:
    mean = sum(vals) / n
    std = math.sqrt(sum((v - mean)**2 for v in vals) / n)
    skewness = (sum((v - mean)**3 for v in vals) / n) / (std**3) if std > 0 else 0.0
else:
    skewness = 0.0
print(json.dumps({'fee_base_skewness': round(skewness, 6), 'count': n}))
" "$result"
