#!/bin/bash
# lightning peer-reputation <peer_id>   (FEAT-399)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-reputation <peer_id>"}'
    exit 0
fi
peer_id="$1"
result_peers=$(lightning-cli listpeers "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
result_chans=$(lightning-cli listpeerchannels 2>/dev/null) || result_chans='{"channels":[]}'
python3 -c "
import sys, json
peer_id = sys.argv[3]
peers = json.loads(sys.argv[1]).get('peers', [])
channels = [c for c in json.loads(sys.argv[2]).get('channels', []) if c.get('peer_id') == peer_id]
peer = peers[0] if peers else {}
num_channels = len(channels)
connected = peer.get('connected', False)
total_cap = sum(c.get('total_msat', 0) for c in channels)
print(json.dumps({'peer_id': peer_id, 'connected': connected,
    'num_channels': num_channels, 'total_capacity_msat': total_cap}, separators=(',', ':')))
" "$result_peers" "$result_chans" "$peer_id"
