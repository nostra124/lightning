#!/bin/bash
# lightning channel-htlc-count-min   (FEAT-2967)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
counts = [len(ch.get('htlcs', [])) for ch in channels]
result = min(counts) if counts else 0
print(json.dumps({'htlc_count_min': result}))
" "$result"
