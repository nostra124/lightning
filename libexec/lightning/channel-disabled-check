#!/bin/bash
# lightning channel-disabled-check   (FEAT-636)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
disabled = [ch for ch in data.get('channels', []) if not ch.get('peer_connected', True) or ch.get('state') != 'CHANNELD_NORMAL']
print(json.dumps({'disabled_count': len(disabled), 'disabled': [{'channel_id': c.get('channel_id'), 'state': c.get('state')} for c in disabled]}))
" "$result"
