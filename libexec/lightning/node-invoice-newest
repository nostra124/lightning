#!/bin/bash
# lightning node-invoice-newest   (FEAT-2274)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if not invoices:
    print(json.dumps({'newest_invoice': None}))
    sys.exit(0)
newest = max(invoices, key=lambda i: i.get('paid_at', i.get('expires_at', 0)))
print(json.dumps({'newest_invoice': newest}))
" "$result"
