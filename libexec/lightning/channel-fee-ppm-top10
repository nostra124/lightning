#!/bin/bash
# lightning channel-fee-ppm-top10   (FEAT-2712)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
sorted_ch = sorted(channels, key=lambda c: c.get('fee_proportional_millionths', 0), reverse=True)[:10]
top10 = [{'short_channel_id': c.get('short_channel_id'), 'fee_proportional_millionths': c.get('fee_proportional_millionths', 0)} for c in sorted_ch]
print(json.dumps({'top10_by_fee_ppm': top10}))
" "$result"
