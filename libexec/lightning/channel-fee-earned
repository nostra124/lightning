#!/bin/bash
# lightning channel-fee-earned [<channel_id>]   (FEAT-343)
set -e
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '[]'; exit 0; }
filter="${1:-}"
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
filt = sys.argv[2]
fwds = data.get('forwards', [])
if filt:
    fwds = [f for f in fwds if f.get('in_channel') == filt or f.get('out_channel') == filt]
totals = {}
for f in fwds:
    ch = f.get('in_channel', '')
    fee = f.get('fee_msat', 0)
    if ch not in totals:
        totals[ch] = 0
    totals[ch] += fee
out = [{'channel_id': ch, 'total_fee_msat': fee} for ch, fee in totals.items()]
out.sort(key=lambda x: x['total_fee_msat'], reverse=True)
print(json.dumps(out, separators=(',', ':')))
" "$result" "$filter"
