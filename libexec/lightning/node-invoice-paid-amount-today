#!/bin/bash
# lightning node-invoice-paid-amount-today   (FEAT-2629)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
today_start = int(time.mktime(time.strptime(time.strftime('%Y-%m-%d'), '%Y-%m-%d')))
total = sum(i.get('amount_received_msat', 0) for i in invoices if i.get('status') == 'paid' and i.get('paid_at', 0) >= today_start)
print(json.dumps({'paid_amount_today_msat': total}))
" "$result"
