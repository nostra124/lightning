#!/bin/bash
# lightning channel-capacity-rank   (FEAT-1100)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ranked = sorted(channels, key=lambda c: c.get('total_msat', 0), reverse=True)
out = [{'rank': i+1, 'channel_id': ch.get('channel_id'), 'total_msat': ch.get('total_msat', 0)} for i, ch in enumerate(ranked[:10])]
print(json.dumps({'channel_count': len(channels), 'top_channels': out}))
" "$result"
