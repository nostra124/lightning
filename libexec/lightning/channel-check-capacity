#!/bin/bash
# lightning channel-check-capacity <channel_id> <amount_msat>   (FEAT-756)
if [ $# -lt 2 ]; then echo '{"error":"usage: channel-check-capacity <channel_id> <amount_msat>"}'; exit 0; fi
channel_id="$1"; amount="$2"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
amount = int(sys.argv[3])
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        spendable = ch.get('spendable_msat', 0)
        print(json.dumps({'channel_id': ch.get('channel_id'), 'spendable_msat': spendable, 'requested_msat': amount, 'can_send': isinstance(spendable, int) and spendable >= amount}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id" "$amount"
