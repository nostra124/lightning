#!/bin/bash
# lightning channel-open-batch <peer_id:sat> [<peer_id:sat> ...]   (FEAT-371)
set -e
[ $# -ge 1 ] || { echo '{"error":"usage: channel-open-batch <peer_id:sat> [...]"}'; exit 0; }
results="["
sep=""
for arg in "$@"; do
    peer_id="${arg%%:*}"
    sat="${arg##*:}"
    r=$(lightning-cli fundchannel "$peer_id" "${sat}sat" 2>/dev/null) || r='{"error":"failed"}'
    ch=$(python3 -c "import sys,json; d=json.loads(sys.argv[1]); print(json.dumps({'peer_id':sys.argv[2],'channel_id':d.get('channel_id',''),'ok':bool(d.get('channel_id',''))}))" "$r" "$peer_id" 2>/dev/null || echo "{\"peer_id\":\"$peer_id\",\"ok\":false}")
    results="${results}${sep}${ch}"
    sep=","
done
echo "${results}]"
