#!/bin/bash
# lightning invoice-paid-at <label>   (FEAT-895)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-paid-at <label>"}'; exit 0; fi
label="$1"
if ! result=$(lightning-cli listinvoices "$label" 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); invs = data.get('invoices', [])
if invs:
    print(json.dumps({'label': sys.argv[2], 'paid_at': invs[0].get('paid_at'), 'status': invs[0].get('status')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result" "$label"
