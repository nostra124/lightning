#!/bin/bash
# lightning invoice-paid-at <label>   (FEAT-1245)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-paid-at <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if invoices:
    inv = invoices[0]
    print(json.dumps({'label': inv.get('label'), 'paid_at': inv.get('paid_at'), 'status': inv.get('status')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
