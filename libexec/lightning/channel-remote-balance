#!/bin/bash
# lightning channel-remote-balance   (FEAT-460)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
active = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
total = sum(c.get('total_msat', 0) for c in active)
local = sum(c.get('to_us_msat', 0) for c in active)
remote = total - local
print(json.dumps({'total_msat': total, 'local_msat': local, 'remote_msat': remote,
    'active_channels': len(active)}, separators=(',', ':')))
" "$result"
