#!/bin/bash
# lightning channel-remote-balance   (FEAT-361)
set -e
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
total_remote = sum(c.get('total_msat', 0) - c.get('to_us_msat', 0) for c in channels)
total_cap = sum(c.get('total_msat', 0) for c in channels)
per_ch = [
    {'channel_id': c.get('channel_id', ''), 'peer_id': c.get('peer_id', ''),
     'remote_msat': c.get('total_msat', 0) - c.get('to_us_msat', 0),
     'total_msat': c.get('total_msat', 0)}
    for c in channels
]
print(json.dumps({'total_remote_msat': total_remote, 'total_capacity_msat': total_cap, 'channels': per_ch}, separators=(',', ':')))
" "$result"
