#!/bin/bash
# lightning channel-updates-count <channel_id>   (FEAT-1282)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-updates-count <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        updates = ch.get('updates', {})
        print(json.dumps({'channel_id': ch.get('channel_id'), 'local_updates': updates.get('local', {}).get('fee_base_msat'), 'remote_updates': updates.get('remote', {}).get('fee_base_msat')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
