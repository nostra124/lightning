#!/bin/bash
# lightning node-pay-failed-count-30d   (FEAT-2436)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
cutoff = time.time() - 30 * 86400
count = sum(
    1 for p in data.get('pays', [])
    if p.get('status') == 'failed' and p.get('created_at', 0) >= cutoff
)
print(json.dumps({'failed_pay_count_30d': count}))
" "$result"
