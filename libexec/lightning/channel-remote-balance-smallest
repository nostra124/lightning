#!/bin/bash
# lightning channel-remote-balance-smallest   (FEAT-2200)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
def remote(ch):
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if isinstance(total, str): total = int(total.rstrip('msat'))
    if isinstance(local, str): local = int(local.rstrip('msat'))
    return total - local
ch = min(channels, key=remote)
print(json.dumps({'channel_id': ch.get('channel_id',''), 'peer_id': ch.get('peer_id',''), 'remote_msat': remote(ch)}))
" "$result"
