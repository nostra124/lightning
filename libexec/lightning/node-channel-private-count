#!/bin/bash
# lightning node-channel-private-count   (FEAT-1564)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
private = [c for c in channels if c.get('private')]
print(json.dumps({'total': len(channels), 'private': len(private), 'public': len(channels) - len(private)}))
" "$result"
