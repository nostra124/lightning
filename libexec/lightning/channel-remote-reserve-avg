#!/bin/bash
# lightning channel-remote-reserve-avg   (FEAT-2440)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [ch.get('their_reserve_msat', 0) for ch in channels if 'their_reserve_msat' in ch]
avg = sum(vals) / len(vals) if vals else 0
print(json.dumps({'remote_reserve_avg_msat': int(avg), 'channel_count': len(vals)}))
" "$result"
