#!/bin/bash
# lightning node-macaroon-info   (FEAT-360)
# Core Lightning uses rune-based auth, not macaroons; show rune info
set -e
result=$(lightning-cli listaccess 2>/dev/null) || {
    echo '{"error":"lightning-cli not found or listaccess unavailable"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
runes = data.get('runes', [])
print(json.dumps({'count': len(runes), 'runes': runes}, separators=(',', ':')))
" "$result"
