#!/bin/bash
# lightning node-color   (FEAT-951)
if ! result=$(lightning-cli getinfo 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'color': data.get('color'), 'id': data.get('id')}))
" "$result"
