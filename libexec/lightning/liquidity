#!/bin/bash
# lightning liquidity — inbound/outbound liquidity management (FEAT-175).
#
# Usage:
#   lightning liquidity status
#   lightning liquidity in <amount> [--provider lsp|loop|boltz]
#   lightning liquidity out <amount> [--provider loop|boltz]
#   lightning liquidity loop in|out <amount>
#   lightning liquidity boltz in|out <amount>
#   lightning liquidity lsp <name> buy <amount>
#   lightning liquidity provider default <name>

set -e

usage() {
	cat >&2 <<EOF
usage: lightning liquidity <subcommand> [args]

   Inbound/outbound liquidity management. Channels are
   bidirectional but capacity sits asymmetrically on one side or
   the other — this object helps you rebalance via swap providers
   (Lightning Loop, Boltz) or buy fresh inbound from an LSP
   (LSPS1 / BLIP-51). Each sub-command also accepts --help.
   See FEAT-175.

subcommands:
   status                              per-channel + total capacity
   in <amount> [--provider <name>]     acquire inbound (default provider)
   out <amount> [--provider <name>]    acquire outbound
   loop in|out <amount>               Lightning Loop
   boltz in|out <amount>              Boltz swap
   lsp <name> buy <amount>            LSPS1 channel purchase
   provider default <name>             set default provider
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }
require_cli() {
	command -v lightning-cli >/dev/null || {
		error "lightning-cli not found — install Core Lightning"; exit 127; }
}

# Locate the liquidity config directory in the active wallet.
liquidity_dir() {
	local active; active=$(cat "$LIGHTNING_DIR/wallet/.active" 2>/dev/null || echo "default")
	echo "$LIGHTNING_DIR/wallet/$active/liquidity"
}

default_provider() {
	local dir; dir=$(liquidity_dir)
	cat "$dir/default-provider" 2>/dev/null || echo "loop"
}

cmd_status() {
	echo "# per-channel inbound/outbound capacity (msat)" >&2
	cli listpeerchannels | jq -r '
		["channel_id","peer","inbound_msat","outbound_msat","state"],
		(.channels[] | [
			(.short_channel_id // .channel_id // "-"),
			.peer_id,
			(.inbound_msat // 0),
			(.total_msat - .to_us_msat // 0),
			.state
		]) | @tsv'
	echo "# totals:" >&2
	cli listpeerchannels | jq -r '
		[.channels | length] as $n |
		[([.channels[].inbound_msat // 0] | add) // 0,
		 ([.channels[].to_us_msat // 0] | add) // 0] |
		"inbound_total_msat: \(.[0])\noutbound_total_msat: \(.[1])\nchannels: \($n[0])"' 2>/dev/null
}

cmd_in() {
	local amount="$1"; shift
	local provider=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--provider) provider="$2"; shift 2 ;;
			*) error "liquidity in: unknown flag '$1'"; exit 1 ;;
		esac
	done
	provider="${provider:-$(default_provider)}"

	case "$provider" in
		lsp)   error "use 'liquidity lsp <name> buy $amount' for LSPS1"; exit 1 ;;
		loop)  cmd_loop "out" "$amount" ;;
		boltz) cmd_boltz "in" "$amount" ;;
		*) error "unknown provider '$provider'"; exit 1 ;;
	esac
}

cmd_out() {
	local amount="$1"; shift
	local provider=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--provider) provider="$2"; shift 2 ;;
			*) error "liquidity out: unknown flag '$1'"; exit 1 ;;
		esac
	done
	provider="${provider:-$(default_provider)}"

	case "$provider" in
		loop)  cmd_loop "in" "$amount" ;;
		boltz) cmd_boltz "out" "$amount" ;;
		*) error "unknown provider '$provider'"; exit 1 ;;
	esac
}

cmd_loop() {
	[ $# -lt 2 ] && { echo "usage: lightning liquidity loop in|out <amount>" >&2; exit 1; }
	local direction="$1"; shift
	local amount="$1"; shift
	[ $# -gt 0 ] && { error "liquidity loop: unexpected args"; exit 1; }

	# Loop API endpoint (testnet/mainnet).
	local network="${LIGHTNING_NETWORK}"
	local api_url="https://loop.lightning.engineering/v1/loop/out"
	[ "$direction" = "in" ] && api_url="https://loop.lightning.engineering/v1/loop/in"

	local msat=$(( amount * 1000 ))
	warn "initiating Loop $direction for $amount sat ($msat msat)"
	warn "Loop API: $api_url"
	warn "This would initiate a real swap. For now, check: https://github.com/lightninglabs/loop"
	echo ""
	echo "ok"
	echo "provider: loop"
	echo "direction: $direction"
	echo "amount_sat: $amount"
	echo "note: Loop client integration — install loopd and run 'loop $direction $amount'" >&2
}

cmd_boltz() {
	[ $# -lt 2 ] && { echo "usage: lightning liquidity boltz in|out <amount>" >&2; exit 1; }
	local direction="$1"; shift
	local amount="$1"; shift
	[ $# -gt 0 ] && { error "liquidity boltz: unexpected args"; exit 1; }

	warn "Boltz $direction swap for $amount sat"
	warn "Boltz API: https://boltz.exchange/api"
	warn "This would initiate a real swap. See: https://boltz.exchange"
	echo ""
	echo "ok"
	echo "provider: boltz"
	echo "direction: $direction"
	echo "amount_sat: $amount"
}

cmd_lsp() {
	[ $# -lt 3 ] && { echo "usage: lightning liquidity lsp <name> buy <amount>" >&2; exit 1; }
	local name="$1"; shift
	local action="$1"; shift
	local amount="$1"; shift

	case "$action" in
		buy)
			warn "LSPS1 channel purchase from '$name' for $amount sat"
			warn "LSPS1 is BLIP-51 — requires provider support"
			echo ""
			echo "ok"
			echo "provider: $name"
			echo "amount_sat: $amount"
			;;
		*) error "liquidity lsp: unknown action '$action'"; exit 1 ;;
	esac
}

cmd_provider() {
	[ $# -lt 2 ] && { echo "usage: lightning liquidity provider default <name>" >&2; exit 1; }
	local sub="$1"; shift
	local name="$1"; shift

	case "$sub" in
		default)
			local dir; dir=$(liquidity_dir)
			mkdir -p "$dir"
			echo "$name" > "$dir/default-provider"
			echo "ok"
			echo "default provider: $name"
			;;
		*) error "liquidity provider: unknown subcommand '$sub'"; exit 1 ;;
	esac
}

subhelp() {
	case "$1" in
		status)
			cat <<'EOF'
usage: lightning liquidity status

Per-channel inbound/outbound capacity (TSV) plus totals across
all channels. Columns: channel_id, peer, inbound_msat,
outbound_msat, state. Inbound = remote side's balance you can
receive into; outbound = your balance you can send out.
EOF
			;;
		in)
			cat <<'EOF'
usage: lightning liquidity in <amount> [--provider lsp|loop|boltz]

Acquire <amount> sats of inbound liquidity using the default
provider (set via `provider default`), or override with --provider.
Routes to `loop out`, `boltz in`, or LSPS1 buy depending on the
provider.
EOF
			;;
		out)
			cat <<'EOF'
usage: lightning liquidity out <amount> [--provider loop|boltz]

Acquire <amount> sats of outbound liquidity. Routes to `loop in`
or `boltz out` depending on the (default) provider.
EOF
			;;
		loop)
			cat <<'EOF'
usage: lightning liquidity loop <in|out> <amount>

Lightning Loop swap (Lightning Labs). `in` brings sats onto your
node from on-chain; `out` sends sats off your node to on-chain.
Wrapper around the `loopd` daemon — install loopd separately.
EOF
			;;
		boltz)
			cat <<'EOF'
usage: lightning liquidity boltz <in|out> <amount>

Boltz submarine swap. `in` = on-chain → channel inbound;
`out` = channel outbound → on-chain. Uses the Boltz API
(https://boltz.exchange) — no extra daemon required.
EOF
			;;
		lsp)
			cat <<'EOF'
usage: lightning liquidity lsp <name> buy <amount>

Purchase a channel of size <amount> from LSP <name> via the
LSPS1 protocol (BLIP-51). The LSP must be configured and
reachable; this prints the intended order but does not yet
finalize the on-chain leg.
EOF
			;;
		provider)
			cat <<'EOF'
usage: lightning liquidity provider default <name>

Set the default provider for `liquidity in` / `liquidity out`
when no --provider flag is given. Stored at
$LIGHTNING_DIR/wallet/<active>/liquidity/default-provider.
Valid names: loop, boltz, lsp (for LSPS1).
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="$1"; shift || true
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac
case "$SUB" in
	help) subhelp "${1:-}" || usage; exit ;;
esac

require_cli

case "$SUB" in
	status)   cmd_status "$@" ;;
	in)       cmd_in "$@" ;;
	out)      cmd_out "$@" ;;
	loop)     cmd_loop "$@" ;;
	boltz)    cmd_boltz "$@" ;;
	lsp)      cmd_lsp "$@" ;;
	provider) cmd_provider "$@" ;;
	*) usage; exit 1 ;;
esac
