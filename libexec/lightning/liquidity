#!/bin/bash
# lightning liquidity — inbound/outbound liquidity management (FEAT-175).
#
# Usage:
#   lightning liquidity status
#   lightning liquidity in <amount> [--provider lsp|loop|boltz]
#   lightning liquidity out <amount> [--provider loop|boltz]
#   lightning liquidity loop in|out <amount>
#   lightning liquidity boltz in|out <amount>
#   lightning liquidity lsp <name> buy <amount>
#   lightning liquidity provider default <name>

set -e

usage() {
	cat >&2 <<EOF
usage: lightning liquidity <subcommand> [args]

subcommands:
   status                              per-channel + total capacity
   in <amount> [--provider <name>]     acquire inbound (default provider)
   out <amount> [--provider <name>]    acquire outbound
   loop in|out <amount>               Lightning Loop
   boltz in|out <amount>              Boltz swap
   lsp <name> buy <amount>            LSPS1 channel purchase
   provider default <name>             set default provider
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"

command -v lightning-cli >/dev/null || {
	echo "lightning: lightning-cli not found — install Core Lightning" >&2; exit 127; }

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

# Locate the liquidity config directory in the active wallet.
liquidity_dir() {
	local active; active=$(cat "$LIGHTNING_DIR/wallet/.active" 2>/dev/null || echo "default")
	echo "$LIGHTNING_DIR/wallet/$active/liquidity"
}

default_provider() {
	local dir; dir=$(liquidity_dir)
	cat "$dir/default-provider" 2>/dev/null || echo "loop"
}

cmd_status() {
	echo "# per-channel inbound/outbound capacity (msat)" >&2
	cli listpeerchannels | jq -r '
		["channel_id","peer","inbound_msat","outbound_msat","state"],
		(.channels[] | [
			(.short_channel_id // .channel_id // "-"),
			.peer_id,
			(.inbound_msat // 0),
			(.total_msat - .to_us_msat // 0),
			.state
		]) | @tsv'
	echo "# totals:" >&2
	cli listpeerchannels | jq -r '
		[.channels | length] as $n |
		[([.channels[].inbound_msat // 0] | add) // 0,
		 ([.channels[].to_us_msat // 0] | add) // 0] |
		"inbound_total_msat: \(.[0])\noutbound_total_msat: \(.[1])\nchannels: \($n[0])"' 2>/dev/null
}

cmd_in() {
	local amount="$1"; shift
	local provider=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--provider) provider="$2"; shift 2 ;;
			*) echo "lightning liquidity in: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done
	provider="${provider:-$(default_provider)}"

	case "$provider" in
		lsp)   echo "lightning: use 'liquidity lsp <name> buy $amount' for LSPS1" >&2; exit 1 ;;
		loop)  cmd_loop "out" "$amount" ;;
		boltz) cmd_boltz "in" "$amount" ;;
		*) echo "lightning: unknown provider '$provider'" >&2; exit 1 ;;
	esac
}

cmd_out() {
	local amount="$1"; shift
	local provider=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--provider) provider="$2"; shift 2 ;;
			*) echo "lightning liquidity out: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done
	provider="${provider:-$(default_provider)}"

	case "$provider" in
		loop)  cmd_loop "in" "$amount" ;;
		boltz) cmd_boltz "out" "$amount" ;;
		*) echo "lightning: unknown provider '$provider'" >&2; exit 1 ;;
	esac
}

cmd_loop() {
	[ $# -lt 2 ] && { echo "usage: lightning liquidity loop in|out <amount>" >&2; exit 1; }
	local direction="$1"; shift
	local amount="$1"; shift
	[ $# -gt 0 ] && { echo "lightning liquidity loop: unexpected args" >&2; exit 1; }

	# Loop API endpoint (testnet/mainnet).
	local network="${LIGHTNING_NETWORK}"
	local api_url="https://loop.lightning.engineering/v1/loop/out"
	[ "$direction" = "in" ] && api_url="https://loop.lightning.engineering/v1/loop/in"

	local msat=$(( amount * 1000 ))
	echo "lightning: initiating Loop $direction for $amount sat ($msat msat)" >&2
	echo "lightning: Loop API: $api_url" >&2
	echo "lightning: This would initiate a real swap. For now, check: https://github.com/lightninglabs/loop" >&2
	echo ""
	echo "ok"
	echo "provider: loop"
	echo "direction: $direction"
	echo "amount_sat: $amount"
	echo "note: Loop client integration — install loopd and run 'loop $direction $amount'" >&2
}

cmd_boltz() {
	[ $# -lt 2 ] && { echo "usage: lightning liquidity boltz in|out <amount>" >&2; exit 1; }
	local direction="$1"; shift
	local amount="$1"; shift
	[ $# -gt 0 ] && { echo "lightning liquidity boltz: unexpected args" >&2; exit 1; }

	echo "lightning: Boltz $direction swap for $amount sat" >&2
	echo "lightning: Boltz API: https://boltz.exchange/api" >&2
	echo "lightning: This would initiate a real swap. See: https://boltz.exchange" >&2
	echo ""
	echo "ok"
	echo "provider: boltz"
	echo "direction: $direction"
	echo "amount_sat: $amount"
}

cmd_lsp() {
	[ $# -lt 3 ] && { echo "usage: lightning liquidity lsp <name> buy <amount>" >&2; exit 1; }
	local name="$1"; shift
	local action="$1"; shift
	local amount="$1"; shift

	case "$action" in
		buy)
			echo "lightning: LSPS1 channel purchase from '$name' for $amount sat" >&2
			echo "lightning: LSPS1 is BLIP-51 — requires provider support" >&2
			echo ""
			echo "ok"
			echo "provider: $name"
			echo "amount_sat: $amount"
			;;
		*) echo "lightning liquidity lsp: unknown action '$action'" >&2; exit 1 ;;
	esac
}

cmd_provider() {
	[ $# -lt 2 ] && { echo "usage: lightning liquidity provider default <name>" >&2; exit 1; }
	local sub="$1"; shift
	local name="$1"; shift

	case "$sub" in
		default)
			local dir; dir=$(liquidity_dir)
			mkdir -p "$dir"
			echo "$name" > "$dir/default-provider"
			echo "ok"
			echo "default provider: $name"
			;;
		*) echo "lightning liquidity provider: unknown subcommand '$sub'" >&2; exit 1 ;;
	esac
}

case "$1" in
	status)   shift; cmd_status "$@" ;;
	in)       shift; cmd_in "$@" ;;
	out)      shift; cmd_out "$@" ;;
	loop)     shift; cmd_loop "$@" ;;
	boltz)    shift; cmd_boltz "$@" ;;
	lsp)      shift; cmd_lsp "$@" ;;
	provider) shift; cmd_provider "$@" ;;
	*) usage; exit 1 ;;
esac
