#!/bin/bash
# lightning node-graph-fee-ppm-dist   (FEAT-1689)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = [c.get('fee_per_millionth', 0) for c in channels]
if not fees:
    print(json.dumps({'count': 0, 'p25': None, 'p50': None, 'p75': None}))
    sys.exit(0)
fees.sort()
n = len(fees)
print(json.dumps({'count': n, 'p25': fees[n//4], 'p50': fees[n//2], 'p75': fees[3*n//4]}))
" "$result"
