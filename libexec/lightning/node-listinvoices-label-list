#!/bin/bash
# lightning node-listinvoices-label-list   (FEAT-2269)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
labels = [i.get('label') for i in data.get('invoices', []) if i.get('label')]
print(json.dumps({'labels': labels}))
" "$result"
