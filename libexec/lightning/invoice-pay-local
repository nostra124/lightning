#!/bin/bash
# lightning invoice-pay-local <bolt11>   (FEAT-532)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-pay-local <bolt11>"}'
    exit 0
fi
bolt11="$1"
if ! result=$(lightning-cli pay "$bolt11" 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
echo "$result"
