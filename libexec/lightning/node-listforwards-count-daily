#!/bin/bash
# lightning node-listforwards-count-daily   (FEAT-2879)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time, calendar
data = json.loads(sys.argv[1])
now = time.time()
t = time.gmtime(now)
day_start = calendar.timegm((t.tm_year, t.tm_mon, t.tm_mday, 0, 0, 0, 0, 0, 0))
count = sum(1 for f in data.get('forwards', []) if f.get('resolved_time', 0) >= day_start)
print(json.dumps({'forwards_count_daily': count}))
" "$result"
