#!/bin/bash
# lightning channel-local-balance-avg   (FEAT-2400)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'local_balance_avg_msat': 0, 'channel_count': 0}))
    sys.exit(0)
total = sum(c.get('local_msat', 0) for c in channels)
avg = total // len(channels)
print(json.dumps({'local_balance_avg_msat': avg, 'channel_count': len(channels)}))
" "$result"
