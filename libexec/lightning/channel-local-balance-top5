#!/bin/bash
# lightning channel-local-balance-top5   (FEAT-2547)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
def get_local(c):
    v = c.get('to_us_msat', 0)
    return int(str(v).rstrip('msat')) if isinstance(v, str) else int(v)
sorted_ch = sorted(channels, key=get_local, reverse=True)[:5]
result = [{'channel_id': c.get('channel_id'), 'to_us_msat': c.get('to_us_msat')} for c in sorted_ch]
print(json.dumps({'top5_channels_by_local_balance': result}))
" "$result"
