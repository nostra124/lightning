#!/bin/bash
# lightning channel-last-forward [<channel_id>]   (FEAT-441)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
fwds = json.loads(sys.argv[1]).get('forwards', [])
cid = sys.argv[2] if len(sys.argv) > 2 else ''
if cid:
    fwds = [f for f in fwds if f.get('in_channel') == cid or f.get('out_channel') == cid]
if fwds:
    last = sorted(fwds, key=lambda f: f.get('resolved_time', 0))[-1]
    print(json.dumps({'in_channel': last.get('in_channel',''), 'out_channel': last.get('out_channel',''),
        'amount_msat': last.get('amount_msat', 0), 'fee_msat': last.get('fee_msat', 0),
        'resolved_time': last.get('resolved_time', 0)}, separators=(',', ':')))
else:
    print(json.dumps({'error': 'no_forwards_found'}))
" "$result" "${1:-}"
