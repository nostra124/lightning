#!/bin/bash
# lightning node-balance-local   (FEAT-1927)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(int(ch.get('to_us_msat', 0)) for ch in channels)
print(json.dumps({'total_local_msat': total, 'channel_count': len(channels)}))
" "$result"
