#!/bin/bash
# lightning channel-fee-revenue-max   (FEAT-2325)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_score = -1
for ch in channels:
    ppm = ch.get('fee_proportional_millionths', 0)
    cap = ch.get('total_msat', 0)
    score = ppm * cap
    if score > best_score:
        best_score = score
        best = ch
if best is None:
    print(json.dumps({'error': 'no channels'}))
else:
    print(json.dumps({'peer_id': best.get('peer_id', ''), 'fee_proportional_millionths': best.get('fee_proportional_millionths', 0), 'total_msat': best.get('total_msat', 0), 'estimated_fee_revenue_score': best_score}))
" "$result"
