#!/bin/bash
# lightning channel-state-pending-count   (FEAT-2185)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pending = [c for c in channels if c.get('state') != 'CHANNELD_NORMAL']
print(json.dumps({'pending_channel_count': len(pending)}))
" "$result"
