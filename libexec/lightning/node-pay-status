#!/bin/bash
# lightning node-pay-status <payment_hash>   (FEAT-614)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-pay-status <payment_hash>"}'
    exit 0
fi
payment_hash="$1"
result=$(lightning-cli listpays payment_hash="$payment_hash" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
if pays:
    print(json.dumps(pays[0]))
else:
    print(json.dumps({'error': 'payment not found'}))
" "$result"
