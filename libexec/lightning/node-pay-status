#!/bin/bash
# lightning node-pay-status <payment_hash>   (FEAT-851)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-pay-status <payment_hash>"}'
    exit 0
fi
phash="$1"
if ! result=$(lightning-cli listpays "$phash" 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
if pays:
    print(json.dumps({'payment_hash': sys.argv[2], 'status': pays[0].get('status')}))
else:
    print(json.dumps({'error': 'payment not found'}))
" "$result" "$phash"
