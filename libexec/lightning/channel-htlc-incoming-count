#!/bin/bash
# lightning channel-htlc-incoming-count   (FEAT-2292)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    for h in ch.get('htlcs', []):
        if h.get('direction') == 'in':
            total += 1
print(json.dumps({'incoming_htlc_count': total}))
" "$result"
