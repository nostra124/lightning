#!/bin/bash
# lightning channel-autopilot-status   (FEAT-407)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
normal = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
total_cap = sum(c.get('total_msat', 0) for c in normal)
total_local = sum(c.get('to_us_msat', 0) for c in normal)
ratio = round(total_local / total_cap, 4) if total_cap else 0
print(json.dumps({'active_channels': len(normal), 'total_capacity_msat': total_cap,
    'local_balance_msat': total_local, 'balance_ratio': ratio,
    'autopilot': 'not_available'}, separators=(',', ':')))
" "$result"
