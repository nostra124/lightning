#!/bin/bash
# lightning channel-htlc-pending-count   (FEAT-2272)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(len(ch.get('htlcs', [])) for ch in channels)
print(json.dumps({'htlc_pending_count': total}))
" "$result"
