#!/bin/bash
# lightning node-graph-reachable <node_id>   (FEAT-1799)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-graph-reachable <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listnodes "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
print(json.dumps({'reachable': len(nodes) > 0, 'node_id': sys.argv[2]}))
" "$result" "$node_id"
