#!/bin/bash
# lightning channel-summary <channel_id>   (FEAT-2000)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-summary <channel_id>"}'; exit 0; fi
arg="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channel_id = sys.argv[2]
channels = data.get('channels', [])
ch = next((c for c in channels if c.get('channel_id') == channel_id), None)
if not ch:
    print(json.dumps({'error': 'channel not found'}))
    sys.exit(0)
print(json.dumps({
    'channel_id': channel_id,
    'state': ch.get('state'),
    'peer_id': ch.get('peer_id'),
    'to_us_msat': ch.get('to_us_msat'),
    'to_them_msat': ch.get('to_them_msat'),
    'spendable_msat': ch.get('spendable_msat'),
    'receivable_msat': ch.get('receivable_msat'),
}))
" "$result" "$arg"
