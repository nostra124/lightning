#!/bin/bash
# lightning node-invoice-count   (FEAT-1074)
if ! result=$(lightning-cli listinvoices 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
by_status = {}
for i in invs:
    s = i.get('status', 'unknown')
    by_status[s] = by_status.get(s, 0) + 1
print(json.dumps({'total': len(invs), 'by_status': by_status}))
" "$result"
