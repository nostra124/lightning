#!/bin/bash
# lightning node-invoice-count   (FEAT-1997)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = sum(1 for i in invoices if i.get('status') == 'paid')
unpaid = sum(1 for i in invoices if i.get('status') == 'unpaid')
expired = sum(1 for i in invoices if i.get('status') == 'expired')
print(json.dumps({'total': len(invoices), 'paid': paid, 'unpaid': unpaid, 'expired': expired}))
" "$result"
