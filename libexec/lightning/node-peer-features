#!/bin/bash
# lightning node-peer-features <peer_id>   (FEAT-449)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-peer-features <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeers "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
peers = json.loads(sys.argv[1]).get('peers', [])
peer_id = sys.argv[2]
peer = next((p for p in peers if p.get('id') == peer_id), None)
if peer:
    print(json.dumps({'peer_id': peer_id, 'features': peer.get('features', ''),
        'connected': peer.get('connected', False)}, separators=(',', ':')))
else:
    print(json.dumps({'error': 'peer_not_found'}))
" "$result" "$peer_id"
