#!/bin/bash
# lightning node-listchannels-sorted-fee   (FEAT-1634)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = sorted(data.get('channels', []), key=lambda c: c.get('fee_per_millionth', 0), reverse=True)
top = [{'short_channel_id': c.get('short_channel_id'), 'fee_ppm': c.get('fee_per_millionth')} for c in channels[:10]]
print(json.dumps({'count': len(channels), 'top_by_fee': top}))
" "$result"
