#!/bin/bash
# lightning invoice-list-by-status <status>   (FEAT-1475)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-list-by-status <status>"}'; exit 0; fi
status="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = [{'label': i.get('label'), 'amount_msat': i.get('amount_msat')} for i in data.get('invoices', []) if i.get('status') == sys.argv[2]]
print(json.dumps({'status': sys.argv[2], 'count': len(invs), 'invoices': invs}))
" "$result" "$status"
