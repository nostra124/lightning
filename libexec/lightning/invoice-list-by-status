#!/bin/bash
# lightning invoice-list-by-status <status>   (FEAT-655)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-by-status <status>"}'
    exit 0
fi
status="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
status = sys.argv[2]
filtered = [i for i in data.get('invoices', []) if i.get('status') == status]
print(json.dumps(filtered))
" "$result" "$status"
