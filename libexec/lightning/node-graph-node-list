#!/bin/bash
# lightning node-graph-node-list   (FEAT-2114)
result=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
node_list = [{'node_id': n.get('nodeid', ''), 'alias': n.get('alias', '')} for n in nodes]
print(json.dumps({'nodes': node_list, 'count': len(node_list)}))
" "$result"
