#!/bin/bash
# lightning node-listpays-by-day   (FEAT-2051)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, datetime
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
by_day = {}
for p in pays:
    if p.get('status') != 'complete':
        continue
    ts = p.get('created_at', 0)
    day = datetime.datetime.utcfromtimestamp(ts).strftime('%Y-%m-%d')
    by_day.setdefault(day, []).append(p)
result = {day: {'count': len(entries), 'total_msat': sum(int(e.get('amount_sent_msat', 0)) for e in entries)} for day, entries in sorted(by_day.items())}
print(json.dumps({'pays_by_day': result}))
" "$result"
