#!/bin/bash
# lightning peer-channel-states <peer_id>   (FEAT-1907)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-channel-states <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
states = {c.get('channel_id'): c.get('state') for c in channels}
print(json.dumps({'peer_id': pid, 'count': len(channels), 'states': states}))
" "$result" "$peer_id"
