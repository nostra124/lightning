#!/bin/bash
# lightning channel-both-balances-min   (FEAT-2919)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'both_balances_min_msat': 0, 'n': 0}))
    sys.exit(0)
combos = [ch.get('to_us_msat', 0) + ch.get('receivable_msat', 0) for ch in channels]
print(json.dumps({'both_balances_min_msat': min(combos), 'n': len(channels)}))
" "$result"
