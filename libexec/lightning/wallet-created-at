#!/bin/bash
# lightning wallet-created-at <wallet_name>   (FEAT-548)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-created-at <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
ts=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='created_at';" 2>/dev/null) || { echo '{"error":"sqlite3 not found"}'; exit 0; }
python3 -c "import sys,json; print(json.dumps({'wallet': sys.argv[1], 'created_at': sys.argv[2] or None}))" "$wname" "$ts"
