#!/bin/bash
# lightning node-htlc-forward-fee   (FEAT-949)
if ! result=$(lightning-cli listforwards status=settled 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
total = sum(f.get('fee_msat', 0) for f in fwds)
print(json.dumps({'settled_count': len(fwds), 'total_fee_msat': total}))
" "$result"
