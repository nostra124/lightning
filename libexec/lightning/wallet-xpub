#!/bin/bash
# lightning wallet-xpub <wallet_name>   (FEAT-823)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-xpub <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
xpub=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='xpub'" 2>/dev/null) || xpub=""
echo "{\"wallet\":\"$wname\",\"xpub\":\"$xpub\"}"
