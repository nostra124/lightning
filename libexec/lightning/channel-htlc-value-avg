#!/bin/bash
# lightning channel-htlc-value-avg   (FEAT-2402)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'htlc_value_avg_msat': 0, 'channel_count': 0}))
    sys.exit(0)
totals = []
for ch in channels:
    htlcs = ch.get('htlcs', [])
    total = sum(h.get('amount_msat', 0) for h in htlcs)
    totals.append(total)
avg = sum(totals) / len(totals) if totals else 0
print(json.dumps({'htlc_value_avg_msat': avg, 'channel_count': len(channels)}))
" "$result"
