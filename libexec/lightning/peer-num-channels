#!/bin/bash
# lightning peer-num-channels <peer_id>   (FEAT-1067)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-num-channels <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
count = sum(1 for ch in data.get('channels', []) if ch.get('peer_id') == pid)
print(json.dumps({'peer_id': pid, 'channel_count': count}))
" "$result" "$peer_id"
