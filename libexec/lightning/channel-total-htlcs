#!/bin/bash
# lightning channel-total-htlcs   (FEAT-2032)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    total += len(ch.get('htlcs', []))
print(json.dumps({'total_htlcs': total}))
" "$result"
