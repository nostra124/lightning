#!/bin/bash
# lightning peer-channel-ids <peer_id>   (FEAT-1607)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-channel-ids <peer_id>"}'; exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ids = [c.get('channel_id') for c in channels if c.get('channel_id')]
print(json.dumps({'peer_id': sys.argv[2], 'count': len(ids), 'channel_ids': ids}))
" "$result" "$peer_id"
