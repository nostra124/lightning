#!/bin/bash
# lightning peer-channel-ids <peer_id>   (FEAT-1307)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-channel-ids <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
cids = [ch.get('channel_id') for ch in data.get('channels', []) if ch.get('peer_id') == pid]
print(json.dumps({'peer_id': pid, 'count': len(cids), 'channel_ids': cids}))
" "$result" "$peer_id"
