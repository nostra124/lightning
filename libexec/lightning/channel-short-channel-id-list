#!/bin/bash
# lightning channel-short-channel-id-list   (FEAT-1440)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
scids = [ch.get('short_channel_id') for ch in data.get('channels', []) if ch.get('short_channel_id')]
print(json.dumps({'count': len(scids), 'short_channel_ids': scids}))
" "$result"
