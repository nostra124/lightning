#!/bin/bash
# lightning node-payment-limits   (FEAT-524)
if ! result=$(lightning-cli listconfigs 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
configs = data.get('configs', {})
max_payment = configs.get('max-payment-size-msat', {}).get('value_msat', None)
min_payment = 1
print(json.dumps({'min_payment_msat': min_payment, 'max_payment_msat': max_payment}))
" "$result"
