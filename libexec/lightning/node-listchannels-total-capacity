#!/bin/bash
# lightning node-listchannels-total-capacity   (FEAT-1289)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('amount_msat', 0) for c in channels if isinstance(c.get('amount_msat'), int))
print(json.dumps({'channel_count': len(channels), 'total_capacity_msat': total}))
" "$result"
