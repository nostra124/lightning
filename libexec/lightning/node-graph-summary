#!/bin/bash
# lightning node-graph-summary   (FEAT-2104)
channels=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
nodes=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
ch_data = json.loads(sys.argv[1])
nd_data = json.loads(sys.argv[2])
channels = ch_data.get('channels', [])
node_list = nd_data.get('nodes', [])
total_capacity = sum(c.get('satoshis', 0) for c in channels) // 2
print(json.dumps({'channel_count': len(channels), 'node_count': len(node_list), 'total_capacity_sat': total_capacity}))
" "$channels" "$nodes"
