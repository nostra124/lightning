#!/bin/bash
# lightning node-pay-count-weekly   (FEAT-2892)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
week_ago = time.time() - 7 * 86400
count = sum(1 for p in pays if p.get('created_at', 0) >= week_ago)
print(json.dumps({'pay_count_weekly': count}))
" "$result"
