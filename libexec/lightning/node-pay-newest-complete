#!/bin/bash
# lightning node-pay-newest-complete   (FEAT-2296)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
if complete:
    newest = max(complete, key=lambda p: p.get('created_at', 0))
    print(json.dumps({'newest_complete_pay': newest}))
else:
    print(json.dumps({'newest_complete_pay': None}))
" "$result"
