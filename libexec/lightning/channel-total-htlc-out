#!/bin/bash
# lightning channel-total-htlc-out   (FEAT-1462)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(len([h for h in ch.get('htlcs', []) if h.get('direction') == 'out']) for ch in data.get('channels', []))
print(json.dumps({'total_htlcs_out': total}))
" "$result"
