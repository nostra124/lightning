#!/bin/bash
# lightning channel-total-htlc-out <channel_id>   (FEAT-1792)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-total-htlc-out <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        htlcs = ch.get('htlcs', [])
        out_htlcs = [h for h in htlcs if h.get('direction') == 'out']
        total = sum(h.get('amount_msat', 0) for h in out_htlcs)
        print(json.dumps({'channel_id': ch.get('channel_id'), 'out_count': len(out_htlcs), 'out_total_msat': total}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
