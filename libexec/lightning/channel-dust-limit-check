#!/bin/bash
# lightning channel-dust-limit-check   (FEAT-2223)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
dust = []
for ch in data.get('channels', []):
    local = int(str(ch.get('to_us_msat', ch.get('local_msat', 0)) or 0).replace('msat',''))
    if local < 1_000_000:
        dust.append({'short_channel_id': ch.get('short_channel_id'), 'local_msat': local})
print(json.dumps({'dust_channels': dust, 'count': len(dust)}))
" "\$result"
