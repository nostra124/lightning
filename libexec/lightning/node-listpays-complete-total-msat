#!/bin/bash
# lightning node-listpays-complete-total-msat   (FEAT-1971)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
total = sum(int(str(p.get('amount_sent_msat', 0)).replace('msat', '')) for p in complete)
print(json.dumps({'count': len(complete), 'total_sent_msat': total}))
" "$result"
