#!/bin/bash
# lightning channel-count-total   (FEAT-2880)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
count = len(data.get('channels', []))
print(json.dumps({'total_channel_count': count}))
" "$result"
