#!/bin/bash
# lightning wallet-notes-by-tag <wallet> <tag>   (FEAT-1478)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-by-tag <wallet> <tag>"}'; exit 0; fi
wname="$1"; tag="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
rows=$(sqlite3 "$db" "SELECT key||'='||value FROM notes WHERE tag='$tag' ORDER BY key;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
pairs = {}
for r in sys.argv[1].split('\n'):
    if '=' in r:
        k, v = r.split('=', 1)
        pairs[k] = v
print(json.dumps({'wallet': sys.argv[2], 'tag': sys.argv[3], 'notes': pairs}))
" "$rows" "$wname" "$tag"
