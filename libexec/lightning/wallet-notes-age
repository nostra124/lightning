#!/bin/bash
# lightning wallet-notes-age <wallet> <key>   (FEAT-1668)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-notes-age <wallet> <key>"}'; exit 0
fi
wname="$1"; key="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
ts=$(sqlite3 "$db" "SELECT created_at FROM notes WHERE key='$key';" 2>/dev/null)
if [ -z "$ts" ]; then echo '{"error":"key not found"}'; exit 0; fi
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"created_at\":\"$ts\"}"
