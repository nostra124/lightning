#!/bin/bash
# lightning node-listpays-total-msat   (FEAT-1134)
if ! result=$(lightning-cli listpays 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
total = sum(p.get('amount_sent_msat', 0) for p in complete)
print(json.dumps({'complete_count': len(complete), 'total_sent_msat': total}))
" "$result"
