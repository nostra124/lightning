#!/bin/bash
# lightning channel-our-reserve <channel_id>   (FEAT-1945)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-our-reserve <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for c in data.get('channels', []):
    if c.get('channel_id') == cid or c.get('short_channel_id') == cid:
        print(json.dumps({'channel_id': cid, 'our_channel_reserve_satoshis': c.get('our_channel_reserve_satoshis'), 'our_reserve_msat': c.get('our_reserve_msat')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
