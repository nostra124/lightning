#!/bin/bash
# lightning node-watched-txids   (FEAT-518)
if ! result=$(lightning-cli listfunds 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
funds = json.loads(sys.argv[1])
outputs = funds.get('outputs', [])
unconf = [{'txid': o.get('txid',''), 'output': o.get('output', 0),
    'amount_msat': o.get('amount_msat', 0)} for o in outputs if o.get('status') == 'unconfirmed']
print(json.dumps({'unconfirmed_count': len(unconf), 'outputs': unconf}, separators=(',', ':')))
" "$result"
