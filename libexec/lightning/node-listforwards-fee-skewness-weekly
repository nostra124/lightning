#!/bin/bash
# lightning node-listforwards-fee-skewness-weekly   (FEAT-2849)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
from datetime import datetime, timezone, timedelta
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
now = datetime.now(timezone.utc)
week_ago = now - timedelta(weeks=1)
fees = []
for f in forwards:
    ts = f.get('received_time', f.get('resolved_time', 0))
    if datetime.fromtimestamp(ts, tz=timezone.utc) >= week_ago:
        fee = f.get('fee_msat', f.get('fee', 0))
        if isinstance(fee, str): fee = int(fee.rstrip('msat'))
        fees.append(float(fee))
n = len(fees)
if n < 3:
    print(json.dumps({'fee_skewness_weekly': None, 'n': n}))
    sys.exit(0)
mean = sum(fees) / n
var = sum((x - mean)**2 for x in fees) / n
if var == 0:
    print(json.dumps({'fee_skewness_weekly': None, 'n': n}))
    sys.exit(0)
std = math.sqrt(var)
skew = (sum((x - mean)**3 for x in fees) / n) / (std**3)
print(json.dumps({'fee_skewness_weekly': round(skew, 6), 'n': n}))
" "$result"
