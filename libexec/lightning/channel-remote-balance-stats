#!/bin/bash
# lightning channel-remote-balance-stats   (FEAT-2118)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
balances = []
for ch in channels:
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if 'total_msat' in ch:
        balances.append(total - local)
if balances:
    out = {'min_msat': min(balances), 'max_msat': max(balances), 'avg_msat': int(sum(balances)/len(balances)), 'count': len(balances)}
else:
    out = {'min_msat': None, 'max_msat': None, 'avg_msat': None, 'count': 0}
print(json.dumps(out))
" "$result"
