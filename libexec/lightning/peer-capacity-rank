#!/bin/bash
# lightning peer-capacity-rank   (FEAT-2393)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_cap = {}
for c in channels:
    pid = c.get('peer_id', '')
    local = c.get('local_msat', 0)
    remote = c.get('remote_msat', 0)
    peer_cap[pid] = peer_cap.get(pid, 0) + local + remote
ranked = [{'peer_id': k, 'total_capacity_msat': v} for k, v in sorted(peer_cap.items(), key=lambda x: -x[1])]
print(json.dumps({'peers_by_capacity': ranked}))
" "$result"
