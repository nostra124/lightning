#!/bin/bash
# lightning node-graph-fee-range   (FEAT-1619)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = [c.get('fee_per_millionth', 0) for c in channels]
if not fees:
    print(json.dumps({'count': 0, 'min_ppm': None, 'max_ppm': None}))
    sys.exit(0)
print(json.dumps({'count': len(fees), 'min_ppm': min(fees), 'max_ppm': max(fees)}))
" "$result"
