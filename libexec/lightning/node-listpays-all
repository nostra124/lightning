#!/bin/bash
# lightning node-listpays-all   (FEAT-1901)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
by_status = {}
for p in pays:
    s = p.get('status', 'unknown')
    by_status[s] = by_status.get(s, 0) + 1
print(json.dumps({'total': len(pays), 'by_status': by_status}))
" "$result"
