#!/bin/bash
# lightning channel-our-reserve-avg   (FEAT-2570)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
reserves = [c.get('our_reserve_msat', 0) for c in channels if 'our_reserve_msat' in c]
avg = sum(reserves) / len(reserves) if reserves else 0
print(json.dumps({'our_reserve_avg_msat': avg}))
" "$result"
