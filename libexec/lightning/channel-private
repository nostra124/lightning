#!/bin/bash
# lightning channel-private   (FEAT-1925)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
private_count = sum(1 for c in channels if c.get('private') == True)
public_count = sum(1 for c in channels if not c.get('private'))
total = len(channels)
print(json.dumps({'private_count': private_count, 'public_count': public_count, 'total': total}))
" "$result"
