#!/bin/bash
# lightning node-listinvoices-paid-today   (FEAT-2549)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
import datetime
today = datetime.datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
today_ts = int(today.timestamp())
count = sum(1 for i in invoices if i.get('status') == 'paid' and i.get('paid_at', 0) >= today_ts)
print(json.dumps({'paid_today_count': count}))
" "$result"
