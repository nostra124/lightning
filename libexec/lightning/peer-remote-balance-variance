#!/bin/bash
# lightning peer-remote-balance-variance   (FEAT-2958)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
from collections import defaultdict
peer_balances = defaultdict(list)
for c in channels:
    peer_id = c.get('peer_id', '')
    total = c.get('total_msat', 0)
    local = c.get('to_us_msat', 0)
    remote = total - local
    if peer_id:
        peer_balances[peer_id].append(remote)
all_remotes = [b for balances in peer_balances.values() for b in balances]
if not all_remotes:
    print(json.dumps({'remote_balance_variance_msat': 0, 'peer_count': 0}))
else:
    mean = sum(all_remotes) / len(all_remotes)
    variance = sum((b - mean) ** 2 for b in all_remotes) / len(all_remotes)
    print(json.dumps({'remote_balance_variance_msat': variance, 'peer_count': len(peer_balances)}))
" "$result"
