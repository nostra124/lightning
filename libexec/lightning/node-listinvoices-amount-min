#!/bin/bash
# lightning node-listinvoices-amount-min   (FEAT-2409)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
with_amount = [i for i in invoices if i.get('amount_msat') is not None]
if not with_amount:
    print(json.dumps({'smallest_invoice': None}))
    sys.exit(0)
smallest = min(with_amount, key=lambda i: i.get('amount_msat', 0))
print(json.dumps({'smallest_invoice': smallest}))
" "$result"
