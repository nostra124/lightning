#!/bin/bash
# lightning node-pay-by-hash   (FEAT-2099)
hash="${1:-}"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
search = sys.argv[2] if len(sys.argv) > 2 else ''
pays = data.get('pays', [])
if search:
    found = [p for p in pays if p.get('payment_hash') == search]
else:
    found = pays
print(json.dumps({'pays': found, 'count': len(found)}))
" "$result" "$hash"
