#!/bin/bash
# lightning channel-remote-balance-stddev   (FEAT-2750)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for c in channels:
    total = c.get('total_msat', 0)
    local = c.get('to_us_msat', 0)
    if 'total_msat' in c and 'to_us_msat' in c:
        vals.append(total - local)
if len(vals) > 1:
    mean = sum(vals) / len(vals)
    variance = sum((v - mean) ** 2 for v in vals) / len(vals)
    stddev = math.sqrt(variance)
else:
    stddev = 0
print(json.dumps({'remote_balance_stddev_msat': stddev, 'count': len(vals)}))
" "$result"
