#!/bin/bash
# lightning node-graph-local-node   (FEAT-1739)
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'id': data.get('id'), 'alias': data.get('alias'), 'color': data.get('color'), 'num_peers': data.get('num_peers'), 'num_active_channels': data.get('num_active_channels')}))
" "$result"
