#!/bin/bash
# lightning channel-htlc-density   (FEAT-2215)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
rows = []
for c in channels:
    cap = c.get('total_msat', 0)
    if isinstance(cap, str): cap = int(cap.rstrip('msat'))
    htlcs = len(c.get('htlcs', []))
    density = round(htlcs / (cap / 1_000_000) if cap > 0 else 0.0, 6)
    rows.append({'short_channel_id': c.get('short_channel_id',''), 'htlc_count': htlcs, 'capacity_msat': cap, 'htlc_density_per_msats': density})
print(json.dumps({'channels': rows, 'channel_count': len(rows)}))
" "$result"
