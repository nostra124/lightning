#!/bin/bash
# lightning node-graph-size   (FEAT-624)
if ! nodes=$(lightning-cli listnodes 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
channels=$(lightning-cli listchannels 2>/dev/null) || channels='{"channels":[]}'
python3 -c "
import sys, json
nodes = json.loads(sys.argv[1])
chans = json.loads(sys.argv[2])
print(json.dumps({'nodes': len(nodes.get('nodes', [])), 'channels': len(chans.get('channels', []))}))
" "$nodes" "$channels"
