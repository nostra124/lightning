#!/bin/bash
# lightning wallet-notes-count <wallet_name>   (FEAT-853)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-notes-count <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
notes_file="$root/$wname/notes"
if [ ! -f "$notes_file" ]; then
    echo "{\"wallet\":\"$wname\",\"count\":0}"
    exit 0
fi
count=$(wc -l < "$notes_file")
echo "{\"wallet\":\"$wname\",\"count\":$count}"
