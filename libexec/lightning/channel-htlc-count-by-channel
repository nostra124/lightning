#!/bin/bash
# lightning channel-htlc-count-by-channel   (FEAT-2342)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
out = []
for ch in channels:
    out.append({'peer_id': ch.get('peer_id', ''), 'htlc_count': len(ch.get('htlcs', []))})
print(json.dumps({'channels': out}))
" "$result"
