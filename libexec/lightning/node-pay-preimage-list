#!/bin/bash
# lightning node-pay-preimage-list   (FEAT-1641)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('preimage')]
print(json.dumps({'count': len(pays), 'preimages': [p.get('preimage') for p in pays]}))
" "$result"
