#!/bin/bash
# lightning node-listforwards-local   (FEAT-1559)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
settled = [f for f in fwds if f.get('status') == 'settled']
total_fee = sum(f.get('fee_msat', 0) for f in settled)
print(json.dumps({'total_forwards': len(fwds), 'settled': len(settled), 'total_fee_msat': total_fee}))
" "$result"
