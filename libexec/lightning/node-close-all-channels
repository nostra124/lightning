#!/bin/bash
# lightning node-close-all-channels   (FEAT-789)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
open_channels = [c.get('channel_id') for c in channels if c.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'to_close': open_channels, 'count': len(open_channels)}))
" "$result"
