#!/bin/bash
# lightning peer-newest   (FEAT-2176)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels found'}))
    sys.exit(0)
newest = max(channels, key=lambda ch: ch.get('funding_txid', '') or '')
print(json.dumps({'peer_id': newest.get('peer_id', ''), 'channel_id': newest.get('channel_id', ''), 'state': newest.get('state', '')}))
" "$result"
