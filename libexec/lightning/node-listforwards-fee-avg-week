#!/bin/bash
# lightning node-listforwards-fee-avg-week   (FEAT-2528)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
cutoff = time.time() - 604800
recent = [f for f in forwards if f.get('resolved_time', 0) >= cutoff]
if not recent:
    print(json.dumps({'avg_fee_msat_week': 0}))
    sys.exit(0)
fees = []
for f in recent:
    fee = f.get('fee_msat', 0)
    if isinstance(fee, str):
        fee = int(fee.replace('msat',''))
    fees.append(fee)
avg = round(sum(fees) / len(fees), 2)
print(json.dumps({'avg_fee_msat_week': avg}))
" "$result"
