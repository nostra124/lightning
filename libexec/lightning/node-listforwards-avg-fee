#!/bin/bash
# lightning node-listforwards-avg-fee   (FEAT-1829)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
fees = [f.get('fee_msat', 0) for f in fwds]
avg = int(sum(fees) / len(fees)) if fees else 0
print(json.dumps({'count': len(fwds), 'avg_fee_msat': avg}))
" "$result"
