#!/bin/bash
# lightning channel-htlc-max-skewness   (FEAT-3624)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('htlc_maximum_msat', 0) for c in channels if 'htlc_maximum_msat' in c]
if len(vals) < 3:
    skewness = 0
else:
    n = len(vals)
    mean = sum(vals) / n
    variance = sum((x - mean) ** 2 for x in vals) / n
    std = math.sqrt(variance) if variance > 0 else 0
    if std == 0:
        skewness = 0
    else:
        skewness = (sum((x - mean) ** 3 for x in vals) / n) / (std ** 3)
print(json.dumps({'htlc_max_skewness_msat': skewness}))
" "$result"
