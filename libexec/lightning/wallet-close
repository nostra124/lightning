#!/bin/bash
# lightning wallet-close <wallet_name>   (FEAT-983)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-close <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$wname" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
echo "{\"wallet\":\"$wname\",\"status\":\"closed\"}"
