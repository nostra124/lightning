#!/bin/bash
# lightning wallet-close <wallet_name>   (FEAT-514)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-close <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
sqlite3 "$db" "PRAGMA wal_checkpoint(TRUNCATE);" 2>/dev/null
echo '{"ok":true,"wallet":"'"$wname"'","closed":true}'
