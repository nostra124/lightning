#!/bin/bash
# lightning wallet-notes-bulk-tag <wallet> <tag> <key1> [key2...]   (FEAT-1553)
if [ $# -lt 3 ]; then echo '{"error":"usage: wallet-notes-bulk-tag <wallet> <tag> <key1> [key2...]"}'; exit 0; fi
wname="$1"; tag="$2"; shift 2
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=0
for key in "$@"; do
    sqlite3 "$db" "UPDATE notes SET tag='$tag' WHERE key='$key';" 2>/dev/null && count=$((count+1))
done
echo "{\"wallet\":\"$wname\",\"tag\":\"$tag\",\"tagged_count\":$count}"
