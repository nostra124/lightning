#!/bin/bash
# lightning wallet-notes-export-keys <wallet>   (FEAT-1598)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-export-keys <wallet>"}'; exit 0; fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
keys=$(sqlite3 "$db" "SELECT key FROM notes ORDER BY key;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
keys = [k for k in sys.argv[1].split('\n') if k]
print(json.dumps({'wallet': sys.argv[2], 'key_count': len(keys), 'keys': keys}))
" "$keys" "$wname"
