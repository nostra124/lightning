#!/bin/bash
# lightning node-listpays-complete-last   (FEAT-1991)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
if not complete:
    print(json.dumps({'pay': None, 'created_at': None}))
else:
    latest = max(complete, key=lambda p: p.get('created_at', 0))
    print(json.dumps({'pay': latest.get('payment_hash'), 'created_at': latest.get('created_at')}))
" "$result"
