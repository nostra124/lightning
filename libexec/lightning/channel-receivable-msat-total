#!/bin/bash
# lightning channel-receivable-msat-total   (FEAT-1960)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    val = ch.get('receivable_msat', 0)
    if isinstance(val, str): val = int(val.replace('msat',''))
    total += val
print(json.dumps({'channel_count': len(channels), 'total_receivable_msat': total}))
" "$result"
