#!/bin/bash
# lightning node-listfunds-onchain   (FEAT-704)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
total = sum(o.get('amount_msat', 0) for o in outputs if isinstance(o.get('amount_msat', 0), int))
print(json.dumps({'outputs': len(outputs), 'total_msat': total}))
" "$result"
