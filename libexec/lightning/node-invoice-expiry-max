#!/bin/bash
# lightning node-invoice-expiry-max   (FEAT-2394)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
unpaid = [i for i in invoices if i.get('status') == 'unpaid']
if not unpaid:
    print(json.dumps({'invoice_expiry_max': None}))
    sys.exit(0)
best = max(unpaid, key=lambda i: i.get('expiry', 0))
print(json.dumps({'invoice_expiry_max': best}))
" "$result"
