#!/bin/bash
# lightning node-listpeers-with-channels   (FEAT-1261)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = [p for p in data.get('peers', []) if p.get('channels')]
print(json.dumps({'count': len(peers), 'peers': [p.get('id') for p in peers]}))
" "$result"
