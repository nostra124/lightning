#!/bin/bash
# lightning wallet-notes-list-by-tag <tag>   (FEAT-1913)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-list-by-tag <tag>"}'; exit 0; fi
tag="$1"
db="$HOME/.lightning/wallets/default/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet db not found"}'; exit 0; fi
rows=$(sqlite3 "$db" "SELECT key, value FROM notes WHERE tag='$tag';" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
rows = [r.split('|') for r in sys.argv[1].splitlines() if r]
notes = [{'key': r[0], 'value': r[1] if len(r)>1 else ''} for r in rows]
print(json.dumps({'tag': sys.argv[2], 'notes': notes, 'count': len(notes)}))
" "$rows" "$tag"
