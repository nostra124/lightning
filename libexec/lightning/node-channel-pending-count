#!/bin/bash
# lightning node-channel-pending-count   (FEAT-1279)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pending_states = {'CHANNELD_AWAITING_LOCKIN', 'DUALOPEND_OPEN_INIT', 'DUALOPEND_AWAITING_LOCKIN'}
pending = [c for c in data.get('channels', []) if c.get('state') in pending_states]
print(json.dumps({'pending_count': len(pending)}))
" "$result"
