#!/bin/bash
# lightning wallet-pin-verify <wallet_name> <pin>   (FEAT-1268)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-pin-verify <wallet_name> <pin>"}'; exit 0; fi
wname="$1"; pin="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
stored=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='pin_hash';" 2>/dev/null)
computed=$(echo -n "$pin" | sha256sum | awk '{print $1}')
if [ "$stored" = "$computed" ]; then
    echo '{"ok":true,"verified":true}'
else
    echo '{"ok":false,"verified":false}'
fi
