#!/bin/bash
# lightning channel-fee-earned-median   (FEAT-2710)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = []
for ch in channels:
    fee = ch.get('fee_msat', ch.get('fees_collected_msat', 0))
    if isinstance(fee, str): fee = int(fee)
    fees.append(fee)
if fees:
    fees_sorted = sorted(fees)
    n = len(fees_sorted)
    if n % 2 == 1:
        median = fees_sorted[n // 2]
    else:
        median = (fees_sorted[n // 2 - 1] + fees_sorted[n // 2]) / 2.0
else:
    median = 0
print(json.dumps({'median_fee_earned_msat': median}))
" "$result"
