#!/bin/bash
# lightning channel-fee-revenue-avg   (FEAT-2297)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if channels:
    # Estimate fee revenue as fee_base_msat per channel (simple proxy)
    revenues = [ch.get('fee_base_msat', 0) for ch in channels]
    avg = sum(revenues) / len(revenues)
else:
    avg = 0
print(json.dumps({'fee_revenue_avg_msat': avg, 'channel_count': len(channels)}))
" "$result"
