#!/bin/bash
# lightning wallet-notes-export-json <wallet_name>   (FEAT-1303)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-export-json <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, json, sqlite3
db = sys.argv[1]
conn = sqlite3.connect(db)
rows = conn.execute('SELECT key, value FROM notes ORDER BY key').fetchall()
conn.close()
notes = [{'key': r[0], 'value': r[1]} for r in rows]
print(json.dumps({'count': len(notes), 'notes': notes}))
" "$db" 2>/dev/null || echo '{"error":"db_error"}'
