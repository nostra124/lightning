#!/bin/bash
# lightning node-channel-receivable-total   (FEAT-1259)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
total = sum(c.get('receivable_msat', 0) for c in channels if isinstance(c.get('receivable_msat'), int))
print(json.dumps({'receivable_total_msat': total, 'active_channels': len(channels)}))
" "$result"
