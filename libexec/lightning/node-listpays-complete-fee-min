#!/bin/bash
# lightning node-listpays-complete-fee-min   (FEAT-2201)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
fees = []
for p in pays:
    amt = p.get('amount_msat', 0)
    sent = p.get('amount_sent_msat', 0)
    try:
        fee = int(str(sent).replace('msat','')) - int(str(amt).replace('msat',''))
        fees.append(fee)
    except Exception:
        pass
if not fees:
    print(json.dumps({'error': 'no complete pays'}))
    sys.exit(0)
print(json.dumps({'min_fee_msat': min(fees)}))
" "$result"
