#!/bin/bash
# lightning wallet-notes-export-csv <wallet>   (FEAT-1473)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-export-csv <wallet>"}'; exit 0; fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
rows=$(sqlite3 -separator ',' "$db" "SELECT key,value,tag,pinned FROM notes ORDER BY key;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
rows = [r for r in sys.argv[1].split('\n') if r]
print(json.dumps({'wallet': sys.argv[2], 'row_count': len(rows), 'csv': rows}))
" "$rows" "$wname"
