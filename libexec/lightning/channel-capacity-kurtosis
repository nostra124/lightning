#!/bin/bash
# lightning channel-capacity-kurtosis   (FEAT-2805)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('total_msat', 0) for c in channels if 'total_msat' in c]
n = len(vals)
if n >= 4:
    mean = sum(vals) / n
    std = math.sqrt(sum((v - mean)**2 for v in vals) / n)
    kurtosis = (sum((v - mean)**4 for v in vals) / n) / (std**4) - 3 if std > 0 else 0.0
else:
    kurtosis = 0.0
print(json.dumps({'capacity_kurtosis': round(kurtosis, 6), 'count': n}))
" "$result"
