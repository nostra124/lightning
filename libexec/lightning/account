#!/bin/bash
# lightning account — virtual-account management.
#
# Implements FEAT-174 (account concept) + FEAT-195 (bank-mode
# overdraft + limits) + FEAT-211 (account-centric verb facade) +
# FEAT-212 PR-1 (bitcoin-address ID + API key + nickname store).
#
# Subcommands:
#   list                                       all accounts
#   create <name> [<description>]              now also mints a
#          [--limit <sat>] [--overdraft deny|warn|allow]   bc1q… ID + API key
#   delete <name>
#   show <handle>                              looks up by address,
#                                              nickname, or name
#   close <handle>                             FEAT-212 — revoke key,
#                                              mark closed
#   nickname add|list|remove                   FEAT-212 — operator-local
#                                              aliases for addresses

set -e

command -v sqlite3 >/dev/null || { echo "lightning: sqlite3 not installed" >&2; exit 127; }

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"

active_wallet_name() {
	local name="default"
	[ -f "$ACTIVE_LINK" ] && name=$(cat "$ACTIVE_LINK")
	echo "$name"
}

active_db() {
	local name; name=$(active_wallet_name)
	local db="$WALLETS_ROOT/$name/state.db"
	[ -f "$db" ] || { echo "lightning account: no active wallet (try \`lightning wallet new\`)" >&2; exit 2; }
	migrate_accounts_schema "$db"
	echo "$db"
}

# FEAT-212 — additive, idempotent migration of the accounts table.
# Pre-FEAT-212 wallets are missing address / created_at / closed_at /
# last_api_call_at; add whichever are absent.  FEAT-218 extends with
# the `referrer` column + the `invite_codes` table.
migrate_accounts_schema() {
	local db="$1"
	local cols
	cols=$(sqlite3 "$db" "PRAGMA table_info(accounts);" 2>/dev/null | awk -F'|' '{print $2}')
	local col
	for col in address created_at closed_at last_api_call_at referrer; do
		echo "$cols" | grep -qx "$col" || {
			local type=TEXT
			case "$col" in created_at|closed_at|last_api_call_at) type=INTEGER ;; esac
			sqlite3 "$db" "ALTER TABLE accounts ADD COLUMN $col $type;" 2>/dev/null || true
		}
	done

	# FEAT-218 — invite codes table.
	sqlite3 "$db" "CREATE TABLE IF NOT EXISTS invite_codes ( \
		code        TEXT PRIMARY KEY, \
		account     TEXT NOT NULL REFERENCES accounts(name) ON DELETE CASCADE, \
		created_at  INTEGER NOT NULL, \
		uses        INTEGER NOT NULL DEFAULT 0 \
	);" 2>/dev/null || true
}

# FEAT-212 — mint a fresh on-chain address from lightningd; that
# address IS the account's canonical ID for the HTTP API and the
# on-chain top-up destination.
mint_address() {
	command -v lightning-cli >/dev/null 2>&1 || {
		echo "lightning account: lightning-cli not found — needed to mint account address" >&2
		return 127
	}
	local addr_json
	addr_json=$(lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" newaddr 2>/dev/null) || return 1
	jq -r '.bech32 // .p2tr // .p2wkh // empty' <<<"$addr_json"
}

# FEAT-212 — 32-byte random API key, base64url-encoded (43 chars
# after stripping padding), prefixed `lt_` for type tagging.
mint_api_key() {
	local raw
	raw=$(head -c 32 /dev/urandom | base64 | tr '+/' '-_' | tr -d '=\n')
	echo "lt_$raw"
}

# FEAT-212 — operator-local nickname store.  Records are blank-line
# separated and look like:
#
#     nickname: rent
#     address: bc1q...
#
# Never sent over the wire; purely for human-readable CLI lookups.
nicknames_file() {
	local wallet; wallet=$(active_wallet_name)
	echo "$WALLETS_ROOT/$wallet/accounts/nicknames.recfile"
}

nickname_to_address() {
	local nick="$1" f
	f=$(nicknames_file)
	[ -f "$f" ] || return 1
	awk -v nick="$nick" '
		BEGIN { RS=""; FS="\n" }
		{
			has_nick=0; addr=""
			for (i=1; i<=NF; i++) {
				if ($i == "nickname: "nick) has_nick=1
				if ($i ~ /^address: /) { addr=$i; sub(/^address: /, "", addr) }
			}
			if (has_nick && addr != "") { print addr; exit }
		}
	' "$f"
}

address_to_nickname() {
	local addr="$1" f
	f=$(nicknames_file)
	[ -f "$f" ] || return 0
	awk -v addr="$addr" '
		BEGIN { RS=""; FS="\n" }
		{
			has_addr=0; nick=""
			for (i=1; i<=NF; i++) {
				if ($i == "address: "addr) has_addr=1
				if ($i ~ /^nickname: /) { nick=$i; sub(/^nickname: /, "", nick) }
			}
			if (has_addr && nick != "") { print nick; exit }
		}
	' "$f"
}

# Resolve a user-supplied handle (address, nickname, or legacy name)
# to (address, name) pair from the accounts table.  Sets two globals
# RESOLVED_ADDRESS and RESOLVED_NAME so callers can use both.
RESOLVED_ADDRESS=""
RESOLVED_NAME=""
resolve_account() {
	local handle="$1"
	RESOLVED_ADDRESS=""
	RESOLVED_NAME=""
	[ -n "$handle" ] || return 1

	# Bitcoin-address shape → direct address lookup.
	case "$handle" in
		bc1*|tb1*|bcrt1*)
			RESOLVED_ADDRESS="$handle"
			RESOLVED_NAME=$(sqlite3 "$(active_db)" \
				"SELECT name FROM accounts WHERE address = $(sql_quote "$handle") LIMIT 1;" 2>/dev/null)
			[ -n "$RESOLVED_NAME" ] || return 1
			return 0 ;;
	esac

	# Operator-local nickname → resolve to address, then look up.
	local mapped; mapped=$(nickname_to_address "$handle" 2>/dev/null)
	if [ -n "$mapped" ]; then
		RESOLVED_ADDRESS="$mapped"
		RESOLVED_NAME=$(sqlite3 "$(active_db)" \
			"SELECT name FROM accounts WHERE address = $(sql_quote "$mapped") LIMIT 1;" 2>/dev/null)
		[ -n "$RESOLVED_NAME" ] || return 1
		return 0
	fi

	# Legacy: handle IS the name column.
	local row
	row=$(sqlite3 -separator $'\t' "$(active_db)" \
		"SELECT name, COALESCE(address,'') FROM accounts WHERE name = $(sql_quote "$handle") LIMIT 1;" 2>/dev/null)
	[ -n "$row" ] || return 1
	IFS=$'\t' read -r RESOLVED_NAME RESOLVED_ADDRESS <<<"$row"
	return 0
}

sq() { sqlite3 -separator $'\t' "$(active_db)" "$@"; }
sqh() { sqlite3 -header -separator $'\t' "$(active_db)" "$@"; }

usage() {
	cat >&2 <<EOF
usage: lightning account <subcommand>

   list [--balances]                             TSV of accounts
   create <name> [<desc>] [--limit <sat>]
                          [--overdraft deny|warn|allow]
                          [--host <domain>]      auto-create user@<domain>
                                                 also mints a bc1q... ID
                                                 + lt_... API key (FEAT-212)
   delete <name>
   show <handle>                                 balance + recent ledger
                                                 (handle: address, nickname,
                                                 or legacy name)
   close <handle>                                revoke API key + mark closed
   nickname add <bc1q...> <name>                 operator-local alias
   nickname list                                 TSV of aliases
   nickname remove <name>
   apikey create <name> --scope read|write       issue an API key
   apikey list <name>                            which scopes exist
   apikey revoke <name> --scope read|write
   topup-watcher run|dry-run|status              credit new on-chain
                                                 deposits to known
                                                 account-addresses
   gc run|dry-run|status                         close stale + delete
                                                 long-closed accounts
   invite-code create <handle> [--code <s>]      mint a referral code
   invite-code list [<handle>]                   TSV: code, account, uses
   invite-code revoke <code>
   topup <name> <sat> [--via lightning]          QR for on-chain top-up
   withdraw <name> <sat> <onchain-addr>          submarine swap out
   pay <name> <bolt11|bolt12|lnurl|addr|node-id>
                                                 dispatch by string shape
        [--sat <sat>]                             (keysend needs amount)
   receive <name> <sat> [--desc <text>]
                          [--reusable]            BOLT-12 + QR; default BOLT-11
EOF
}

# FEAT-211 — account-centric user-facing verb surface.  Each new
# subcommand below is a thin wrapper around an existing power-user
# verb (invoice / offer / liquidity / lnurl / send) with the
# --account context already plumbed.
require_account() {
	local name="$1"
	[ -n "$name" ] || { echo "lightning account: missing account name" >&2; exit 1; }
	local found
	found=$(sqlite3 "$(active_db)" "SELECT 1 FROM accounts WHERE name = '${name//\'/\'\'}' LIMIT 1;" 2>/dev/null)
	[ "$found" = "1" ] || {
		echo "lightning account: account '$name' not found" >&2
		echo "  list with: lightning account list" >&2
		echo "  create with: lightning account create $name" >&2
		exit 2
	}
}

cmd_list() {
	local with_balances=0
	[ "${1:-}" = "--balances" ] && with_balances=1
	if [ $with_balances -eq 1 ]; then
		sqlite3 -header -separator $'\t' "$(active_db)" "
			SELECT a.name,
			       COALESCE(a.limit_sat, -1) AS limit_sat,
			       COALESCE(SUM(l.amount_msat),0)/1000 AS balance_sat,
			       a.overdraft
			FROM accounts a
			LEFT JOIN ledger l ON l.account = a.name
			WHERE a.name NOT IN ('-', 'house')
			GROUP BY a.name
			ORDER BY a.name;"
	else
		sqlite3 -header -separator $'\t' "$(active_db)" \
			"SELECT name, description, COALESCE(limit_sat, -1) AS limit_sat, overdraft FROM accounts WHERE name NOT IN ('-', 'house') ORDER BY name;"
	fi
}

# Bash doesn't have a clean SQL-injection-safe quoter; we constrain
# the inputs (name regex, numeric limit, enum overdraft) before
# building the query.
sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }

cmd_create() {
	[ $# -lt 1 ] && { echo "usage: lightning account create <name> [<desc>] [--limit <sat>] [--overdraft deny|warn|allow] [--host <domain>]" >&2; exit 1; }
	local name="$1"; shift
	local desc=""
	[ $# -gt 0 ] && [[ "$1" != --* ]] && { desc="$1"; shift; }
	local limit="NULL"
	local overdraft="deny"
	local host=""

	while [ $# -gt 0 ]; do
		case "$1" in
			--limit)
				[[ "$2" =~ ^[0-9]+$ ]] || { echo "--limit: integer required" >&2; exit 1; }
				limit="$2"; shift 2 ;;
			--overdraft)
				case "$2" in deny|warn|allow) overdraft="$2"; shift 2 ;;
					*) echo "--overdraft: must be deny|warn|allow" >&2; exit 1 ;;
				esac ;;
			--host)
				host="$2"; shift 2 ;;
			*) echo "lightning account create: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	[[ "$name" =~ ^[a-z][a-z0-9_-]*$ ]] || {
		echo "lightning account: name must match [a-z][a-z0-9_-]*" >&2; exit 1; }

	# FEAT-212 — mint the canonical address ID + API key.  Account
	# creation against a daemon-down installation still works (legacy
	# operator path); the address/key fields stay NULL and the operator
	# can promote later.  Set LIGHTNING_ACCOUNT_NO_MINT=1 to skip the
	# mint explicitly (used by some tests and by `wallet new` bootstrap).
	local address="" api_key="" now
	now=$(date -u +%s)
	if [ -z "$LIGHTNING_ACCOUNT_NO_MINT" ]; then
		address=$(mint_address 2>/dev/null || true)
		if [ -n "$address" ]; then
			api_key=$(mint_api_key)
			# Best-effort secret store; operators without the `secret`
			# package can still create accounts, they just won't have a
			# server-side key cache.  PR-2's HTTP layer will refuse such
			# accounts at request time with a clear error.
			if command -v secret >/dev/null 2>&1; then
				echo "$api_key" | secret put "lightning.account.$address.apikey" >/dev/null 2>&1 || true
			fi
		fi
	fi

	# INSERT covers the new columns when address was minted; falls back
	# to the legacy three-column write when it wasn't.
	if [ -n "$address" ]; then
		sqlite3 "$(active_db)" \
			"INSERT INTO accounts(name, description, limit_sat, overdraft, address, created_at) VALUES($(sql_quote "$name"), $(sql_quote "$desc"), $limit, $(sql_quote "$overdraft"), $(sql_quote "$address"), $now);"
	else
		sqlite3 "$(active_db)" \
			"INSERT INTO accounts(name, description, limit_sat, overdraft) VALUES($(sql_quote "$name"), $(sql_quote "$desc"), $limit, $(sql_quote "$overdraft"));"
	fi

	# Operator-local nickname binding (the `name` doubles as the
	# first nickname so `account show <name>` still works without an
	# explicit `nickname add`).
	if [ -n "$address" ]; then
		local nf; nf=$(nicknames_file)
		mkdir -p "$(dirname "$nf")"
		printf 'nickname: %s\naddress: %s\n\n' "$name" "$address" >> "$nf"
	fi

	echo "lightning account: created $name"
	if [ -n "$address" ]; then
		echo "  address:  $address"
	fi
	if [ -n "$api_key" ]; then
		echo "  api_key:  $api_key"
		echo "  (save it now — this is the only time it'll be printed)" >&2
	fi

	# Auto-address (FEAT-195): chain into `lightning address create`.
	if [ -n "$host" ]; then
		"$(dirname "$0")/address" create "${name}@${host}" --account "$name" || {
			echo "lightning account: address create failed; account remains" >&2
		}
	fi
}

cmd_delete() {
	[ $# -lt 1 ] && { echo "usage: lightning account delete <name>" >&2; exit 1; }
	local name="$1"
	[ "$name" = "-" ] && { echo "lightning account: cannot delete the unassigned account" >&2; exit 2; }
	sqlite3 "$(active_db)" "DELETE FROM accounts WHERE name = $(sql_quote "$name");"
	echo "lightning account: deleted $name"
}

cmd_show() {
	[ $# -lt 1 ] && { echo "usage: lightning account show <handle>" >&2; exit 1; }
	local handle="$1"
	local db; db=$(active_db)

	resolve_account "$handle" || {
		echo "lightning account: no such account '$handle'" >&2; exit 2
	}
	local name="$RESOLVED_NAME" address="$RESOLVED_ADDRESS"

	local row
	row=$(sqlite3 -separator $'\t' "$db" \
		"SELECT description, COALESCE(limit_sat,-1), overdraft, COALESCE(closed_at, 0) \
		 FROM accounts WHERE name = $(sql_quote "$name");")

	local desc limit overdraft closed_at
	IFS=$'\t' read -r desc limit overdraft closed_at <<<"$row"
	local balance_msat
	balance_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(amount_msat),0) FROM ledger WHERE account = $(sql_quote "$name");")
	local balance_sat=$(( balance_msat / 1000 ))

	printf "name:        %s\n"  "$name"
	if [ -n "$address" ]; then
		printf "address:     %s\n"  "$address"
	fi
	printf "description: %s\n"  "$desc"
	printf "balance_sat: %s\n"  "$balance_sat"
	if [ "$limit" != "-1" ]; then
		printf "limit_sat:   %s\n"  "$limit"
	else
		printf "limit_sat:   (none)\n"
	fi
	printf "overdraft:   %s\n"  "$overdraft"
	if [ "$closed_at" != "0" ] && [ "$closed_at" != "" ]; then
		printf "closed_at:   %s (UTC epoch)\n"  "$closed_at"
	fi
	printf "\nrecent ledger:\n"
	sqlite3 -header -separator $'\t' "$db" "SELECT ts, direction, amount_msat, peer, message FROM ledger WHERE account = $(sql_quote "$name") ORDER BY id DESC LIMIT 10;"
}

# FEAT-212 — close an account.  Revoke its API key (if any) and stamp
# closed_at.  The row stays in the table so the ledger still
# resolves; a cleanup cron (PR-5) deletes long-empty closed accounts
# after a grace window.
cmd_close() {
	[ $# -lt 1 ] && { echo "usage: lightning account close <handle>" >&2; exit 1; }
	local handle="$1"
	resolve_account "$handle" || {
		echo "lightning account: no such account '$handle'" >&2; exit 2
	}
	local name="$RESOLVED_NAME" address="$RESOLVED_ADDRESS"
	[ "$name" = "-" ] && { echo "lightning account: cannot close the unassigned account" >&2; exit 2; }

	local now; now=$(date -u +%s)
	sqlite3 "$(active_db)" \
		"UPDATE accounts SET closed_at = $now WHERE name = $(sql_quote "$name");"
	if [ -n "$address" ] && command -v secret >/dev/null 2>&1; then
		secret rm "lightning.account.$address.apikey" 2>/dev/null || true
	fi
	echo "lightning account: closed $name${address:+ ($address)}"
}

# FEAT-212 — operator-local nickname store (recfile under
# $wallet/accounts/nicknames.recfile).  Never sent over the wire.
cmd_nickname() {
	local op="${1:-}"; shift 2>/dev/null || true
	local nf; nf=$(nicknames_file)
	case "$op" in
		add)
			[ $# -lt 2 ] && { echo "usage: lightning account nickname add <address> <name>" >&2; exit 1; }
			local addr="$1" nick="$2"
			case "$addr" in
				bc1*|tb1*|bcrt1*) ;;
				*) echo "lightning account nickname add: '$addr' must be a bitcoin address" >&2; exit 1 ;;
			esac
			mkdir -p "$(dirname "$nf")"
			# Drop any existing record for this nickname or this address
			# so add is idempotent + acts as rename.
			if [ -f "$nf" ]; then
				awk -v nick="$nick" -v addr="$addr" '
					BEGIN { RS=""; FS="\n" }
					{
						drop=0
						for (i=1; i<=NF; i++) {
							if ($i == "nickname: "nick || $i == "address: "addr) { drop=1; break }
						}
						if (!drop) { print; print "" }
					}
				' "$nf" > "$nf.tmp" && mv "$nf.tmp" "$nf"
			fi
			printf 'nickname: %s\naddress: %s\n\n' "$nick" "$addr" >> "$nf"
			echo "lightning account nickname: $nick -> $addr"
			;;
		list|"")
			[ -f "$nf" ] || { return 0; }
			printf "nickname\taddress\n"
			awk '
				BEGIN { RS=""; FS="\n"; OFS="\t" }
				{
					nick=""; addr=""
					for (i=1; i<=NF; i++) {
						if ($i ~ /^nickname: /) { nick=$i; sub(/^nickname: /, "", nick) }
						if ($i ~ /^address: /)  { addr=$i; sub(/^address: /, "", addr) }
					}
					if (nick != "" && addr != "") print nick, addr
				}
			' "$nf"
			;;
		remove)
			[ $# -lt 1 ] && { echo "usage: lightning account nickname remove <name>" >&2; exit 1; }
			local nick="$1"
			[ -f "$nf" ] || { return 0; }
			awk -v nick="$nick" '
				BEGIN { RS=""; FS="\n" }
				{
					drop=0
					for (i=1; i<=NF; i++) {
						if ($i == "nickname: "nick) { drop=1; break }
					}
					if (!drop) { print; print "" }
				}
			' "$nf" > "$nf.tmp" && mv "$nf.tmp" "$nf"
			echo "lightning account nickname: removed $nick"
			;;
		*)
			echo "usage: lightning account nickname {add <address> <name>|list|remove <name>}" >&2
			exit 1 ;;
	esac
}

# FEAT-212 PR-4 — deposit watcher.
#
# Each account's ID is a bitcoin address (FEAT-212), which doubles as
# the on-chain top-up destination.  This verb polls `lightning-cli
# listfunds` for new confirmed UTXOs at any known account-address and
# books a credit into the ledger.  Idempotent — UTXOs are deduped by
# the synthetic payment_hash "txid:vout".
#
# Subcommands:
#   run            credit any new UTXOs (default if no arg)
#   dry-run        list what would be credited; don't write
#   status         show the last-seen UTXO + count of credits
#
# Driven by `daemon install --topup-watcher` (one-shot timer; same
# pattern as autopilot).  Manual invocation: `lightning account
# topup-watcher run`.
cmd_topup_watcher() {
	local op="${1:-run}"
	local dry=0
	case "$op" in
		run)            dry=0 ;;
		dry-run|--dry-run) dry=1 ;;
		status)         _topup_watcher_status; return ;;
		*) echo "usage: lightning account topup-watcher {run|dry-run|status}" >&2; exit 1 ;;
	esac

	command -v lightning-cli >/dev/null || {
		echo "lightning account topup-watcher: lightning-cli not found" >&2
		exit 127
	}
	command -v jq >/dev/null || {
		echo "lightning account topup-watcher: jq not installed" >&2
		exit 127
	}

	local db; db=$(active_db)
	# Active accounts only — closed accounts (closed_at IS NOT NULL)
	# stop receiving credits at the watcher level.  An incoming UTXO
	# to a closed-account address is logged as orphan but not booked.
	local known
	known=$(sqlite3 -separator $'\t' "$db" \
		"SELECT address, name FROM accounts WHERE address IS NOT NULL AND closed_at IS NULL;")
	# Don't early-return on empty `known` — UTXOs at closed-account
	# addresses still need to be detected so the operator sees the
	# orphan warning rather than silently dropping the deposit.

	local listfunds
	listfunds=$(lightning-cli \
		--lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
		--network="${LIGHTNING_NETWORK:-bitcoin}" \
		listfunds 2>/dev/null) || {
			echo "lightning account topup-watcher: listfunds failed (is lightningd running?)" >&2
			exit 4
		}

	# Project the UTXO list into a TSV of (txid \t output \t address
	# \t amount_msat).  Only confirmed UTXOs are credited; pending
	# ones are picked up on a later pass.  amount_msat normalises
	# both the post-23.02 string form and the legacy `value` field.
	local utxos
	utxos=$(jq -r '
		.outputs[]?
		| select(.status == "confirmed")
		| [ .txid,
		    (.output|tostring),
		    (.address // ""),
		    ( (.amount_msat // empty)
		      | (if type == "string" then sub("msat$"; "") | tonumber
		         else . end)
		    )
		  ]
		| @tsv' <<<"$listfunds")

	local credited=0 skipped_dupe=0 unknown=0 closed=0
	local txid vout addr amount_msat name pmt_hash
	while IFS=$'\t' read -r txid vout addr amount_msat; do
		[ -n "$addr" ] || continue
		# Match against known account-addresses.
		name=$(awk -F'\t' -v a="$addr" '$1 == a { print $2; exit }' <<<"$known")
		if [ -z "$name" ]; then
			# Possibly a closed-account address — log it but don't credit.
			if sqlite3 "$db" "SELECT 1 FROM accounts WHERE address = $(sql_quote "$addr") AND closed_at IS NOT NULL LIMIT 1;" 2>/dev/null | grep -q 1; then
				closed=$((closed+1))
				printf 'skip\t%s\taccount closed\t+%s msat\t%s:%s\n' "$addr" "$amount_msat" "$txid" "$vout"
			else
				unknown=$((unknown+1))
			fi
			continue
		fi
		pmt_hash="$txid:$vout"
		# Dedupe via payment_hash.  Cheap — the column is indexed
		# implicitly only on the PK, but the table is small enough
		# that the full scan is fine.
		if sqlite3 "$db" "SELECT 1 FROM ledger WHERE payment_hash = $(sql_quote "$pmt_hash") LIMIT 1;" 2>/dev/null | grep -q 1; then
			skipped_dupe=$((skipped_dupe+1))
			continue
		fi
		# FEAT-213 — operator-fee skim at credit time.  Read fees.recfile
		# lazily (once per UTXO is fine — file is small) so an operator
		# edit to the recfile takes effect on the next watcher pass.
		operator_fee_msat=0
		if [ -f "$WALLETS_ROOT/$(active_wallet_name)/fees.recfile" ]; then
			read -r fee_base_sat fee_rate_ppm < <(awk -v op="topup-onchain" '
				BEGIN { RS=""; FS="\n"; b=0; r=0 }
				{
					in_op=0; bb=0; rr=0
					for (i=1; i<=NF; i++) {
						if ($i == "operation: " op) in_op=1
						if ($i ~ /^base_sat: *[0-9-]/) { bb=$i; sub(/^base_sat: */, "", bb) }
						if ($i ~ /^rate_ppm: *[0-9-]/) { rr=$i; sub(/^rate_ppm: */, "", rr) }
					}
					if (in_op) { b=bb; r=rr }
				}
				END { printf "%d %d\n", b+0, r+0 }
			' "$WALLETS_ROOT/$(active_wallet_name)/fees.recfile")
			operator_fee_msat=$(( fee_base_sat * 1000 + amount_msat * fee_rate_ppm / 1000000 ))
		fi
		if [ $dry -eq 1 ]; then
			if [ "$operator_fee_msat" -gt 0 ]; then
				printf 'would-credit\t%s\t%s\t+%s msat (skim %s msat)\t%s\n' "$name" "$addr" "$amount_msat" "$operator_fee_msat" "$pmt_hash"
			else
				printf 'would-credit\t%s\t%s\t+%s msat\t%s\n' "$name" "$addr" "$amount_msat" "$pmt_hash"
			fi
		else
			if [ "$operator_fee_msat" -gt 0 ]; then
				sqlite3 "$db" "INSERT OR IGNORE INTO accounts(name, description, overdraft) \
					VALUES('house', 'operator fee revenue', 'allow');" 2>/dev/null || true
			fi
			# FEAT-219 — referral split (same shape as api-account-pay).
			tw_referral_msat=0
			tw_referrer=""
			tw_direct_pct="${LIGHTNING_REFERRAL_DIRECT_PCT:-0}"
			case "$tw_direct_pct" in ''|*[!0-9]*) tw_direct_pct=0 ;; esac
			[ "$tw_direct_pct" -gt 100 ] && tw_direct_pct=100
			if [ "$operator_fee_msat" -gt 0 ] && [ "$tw_direct_pct" -gt 0 ]; then
				tw_referrer=$(sqlite3 "$db" "SELECT COALESCE(referrer, 'house') FROM accounts WHERE name = $(sql_quote "$name");" 2>/dev/null)
				case "$tw_referrer" in
					""|"house"|"-") tw_referrer="" ;;
					*)
						tw_min_msat=$(( ${LIGHTNING_REFERRAL_MIN_ACTIVITY_SAT:-10000} * 1000 ))
						tw_act_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(ABS(amount_msat)), 0) FROM ledger \
							WHERE account = $(sql_quote "$name") AND message NOT LIKE 'fee:%';" 2>/dev/null)
						[ "${tw_act_msat:-0}" -lt "$tw_min_msat" ] && tw_referrer=""
						;;
				esac
				if [ -n "$tw_referrer" ]; then
					tw_cap_msat=$(( ${LIGHTNING_REFERRAL_MAX_PER_DAY_SAT:-10000} * 1000 ))
					tw_today_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(amount_msat), 0) FROM ledger \
						WHERE account = $(sql_quote "$tw_referrer") \
						  AND direction = 'in' \
						  AND message LIKE 'fee:referral%' \
						  AND date(ts) = date('now');" 2>/dev/null)
					[ "${tw_today_msat:-0}" -ge "$tw_cap_msat" ] && tw_referrer=""
				fi
				if [ -n "$tw_referrer" ]; then
					tw_referral_msat=$(( operator_fee_msat * tw_direct_pct / 100 ))
				fi
			fi
			tw_house_msat=$(( operator_fee_msat - tw_referral_msat ))

			sql="BEGIN;"
			sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, payment_hash, message)"
			sql+=" VALUES(datetime('now'), $(sql_quote "$name"), 'in', $amount_msat, 'on-chain', $(sql_quote "$pmt_hash"), 'topup-watcher');"
			if [ "$operator_fee_msat" -gt 0 ]; then
				sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, payment_hash, message)"
				sql+=" VALUES(datetime('now'), $(sql_quote "$name"), 'out', -$operator_fee_msat, 'on-chain', $(sql_quote "$pmt_hash"), 'fee:topup-onchain');"
				if [ "$tw_house_msat" -gt 0 ]; then
					sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, payment_hash, message)"
					sql+=" VALUES(datetime('now'), 'house', 'in', $tw_house_msat, 'on-chain', $(sql_quote "$pmt_hash"), $(sql_quote "fee:topup-onchain from $name"));"
				fi
				if [ "$tw_referral_msat" -gt 0 ] && [ -n "$tw_referrer" ]; then
					sql+=" INSERT INTO ledger(ts, account, direction, amount_msat, peer, payment_hash, message)"
					sql+=" VALUES(datetime('now'), $(sql_quote "$tw_referrer"), 'in', $tw_referral_msat, $(sql_quote "referee:$name"), $(sql_quote "$pmt_hash"), $(sql_quote "fee:referral from $name"));"
				fi
			fi
			sql+=" COMMIT;"
			sqlite3 "$db" "$sql"
			printf 'credit\t%s\t%s\t+%s msat\t%s\n' "$name" "$addr" "$amount_msat" "$pmt_hash"
		fi
		credited=$((credited+1))
	done <<<"$utxos"

	# One-line summary to stderr so the systemd journal stays tidy.
	if [ $dry -eq 1 ]; then
		echo "topup-watcher dry-run: would credit $credited (dupes $skipped_dupe, closed $closed, unknown $unknown)" >&2
	else
		echo "topup-watcher: credited $credited (dupes $skipped_dupe, closed $closed, unknown $unknown)" >&2
	fi
}

_topup_watcher_status() {
	local db; db=$(active_db)
	local last
	last=$(sqlite3 -separator $'\t' "$db" \
		"SELECT ts, account, amount_msat, payment_hash FROM ledger WHERE message = 'topup-watcher' ORDER BY id DESC LIMIT 1;")
	local total
	total=$(sqlite3 "$db" "SELECT COUNT(*) FROM ledger WHERE message = 'topup-watcher';")
	local watched
	watched=$(sqlite3 "$db" "SELECT COUNT(*) FROM accounts WHERE address IS NOT NULL AND closed_at IS NULL;")
	printf "watched_accounts: %s\n" "$watched"
	printf "total_credits:    %s\n" "$total"
	if [ -n "$last" ]; then
		printf "last_credit:      %s\n" "$last"
	else
		printf "last_credit:      (none yet)\n"
	fi
}

# FEAT-212 PR-5 — account garbage collection.
#
# Two stages, both safe:
#
#   1. "idle close" — accounts that are:
#        * address-keyed (FEAT-212 minted, not legacy)
#        * not already closed
#        * balance_sat == 0
#        * no API call in LIGHTNING_ACCOUNT_GC_DAYS days (default 90)
#        * no pending invoice
#      get their API key revoked + closed_at stamped.  Same effect
#      as `account close` but driven by inactivity.
#
#   2. "expired close cleanup" — accounts that:
#        * closed_at is set
#        * closed more than LIGHTNING_ACCOUNT_GC_CLOSED_DAYS ago
#          (default 7)
#        * balance_sat == 0
#      are DELETED from the schema.  The ledger's FK `ON DELETE
#      SET DEFAULT` lifts any historical entries onto the '-'
#      account, so audit history survives.  Nickname recfile
#      entries pointing at the deleted address are stripped.
#
# Subcommands:
#   run            do both stages
#   dry-run        list what would happen, don't write
#   status         show the candidate counts for the next run
cmd_gc() {
	local op="${1:-run}"
	local dry=0
	case "$op" in
		run)               dry=0 ;;
		dry-run|--dry-run) dry=1 ;;
		status)            _gc_status; return ;;
		*) echo "usage: lightning account gc {run|dry-run|status}" >&2; exit 1 ;;
	esac

	local db; db=$(active_db)
	local now; now=$(date -u +%s)
	local idle_days="${LIGHTNING_ACCOUNT_GC_DAYS:-90}"
	local closed_days="${LIGHTNING_ACCOUNT_GC_CLOSED_DAYS:-7}"
	case "$idle_days"    in ''|*[!0-9]*) idle_days=90 ;; esac
	case "$closed_days"  in ''|*[!0-9]*) closed_days=7 ;; esac
	local idle_cutoff=$(( now - idle_days * 86400 ))
	local closed_cutoff=$(( now - closed_days * 86400 ))

	# Stage 1 — idle accounts to close.
	local stage1
	stage1=$(sqlite3 -separator $'\t' "$db" "
		SELECT a.name, a.address
		FROM accounts a
		WHERE a.address IS NOT NULL
		  AND a.closed_at IS NULL
		  AND a.name NOT IN ('-', 'house')
		  AND COALESCE(a.last_api_call_at, a.created_at, 0) < $idle_cutoff
		  AND COALESCE((SELECT SUM(amount_msat) FROM ledger WHERE account = a.name), 0) = 0
		  AND NOT EXISTS (SELECT 1 FROM invoices WHERE account = a.name AND state = 'pending');")

	# Stage 2 — already-closed accounts to delete.
	local stage2
	stage2=$(sqlite3 -separator $'\t' "$db" "
		SELECT a.name, a.address
		FROM accounts a
		WHERE a.closed_at IS NOT NULL
		  AND a.closed_at < $closed_cutoff
		  AND a.name NOT IN ('-', 'house')
		  AND COALESCE((SELECT SUM(amount_msat) FROM ledger WHERE account = a.name), 0) = 0;")

	local closed=0 deleted=0 name addr
	while IFS=$'\t' read -r name addr; do
		[ -n "$name" ] || continue
		if [ $dry -eq 1 ]; then
			printf 'would-close\t%s\t%s\n' "$name" "$addr"
		else
			sqlite3 "$db" "UPDATE accounts SET closed_at = $now WHERE name = $(sql_quote "$name");"
			if [ -n "$addr" ] && command -v secret >/dev/null 2>&1; then
				secret rm "lightning.account.$addr.apikey" 2>/dev/null || true
			fi
			printf 'close\t%s\t%s\n' "$name" "$addr"
		fi
		closed=$((closed+1))
	done <<<"$stage1"

	while IFS=$'\t' read -r name addr; do
		[ -n "$name" ] || continue
		if [ $dry -eq 1 ]; then
			printf 'would-delete\t%s\t%s\n' "$name" "$addr"
		else
			sqlite3 "$db" "DELETE FROM accounts WHERE name = $(sql_quote "$name");"
			if [ -n "$addr" ]; then
				if command -v secret >/dev/null 2>&1; then
					secret rm "lightning.account.$addr.apikey" 2>/dev/null || true
				fi
				# Strip any nickname entries pointing at this address.
				local nf; nf=$(nicknames_file)
				if [ -f "$nf" ]; then
					awk -v addr="$addr" '
						BEGIN { RS=""; FS="\n" }
						{
							drop=0
							for (i=1; i<=NF; i++) {
								if ($i == "address: "addr) { drop=1; break }
							}
							if (!drop) { print; print "" }
						}
					' "$nf" > "$nf.tmp" && mv "$nf.tmp" "$nf"
				fi
			fi
			printf 'delete\t%s\t%s\n' "$name" "$addr"
		fi
		deleted=$((deleted+1))
	done <<<"$stage2"

	if [ $dry -eq 1 ]; then
		echo "gc dry-run: would close $closed, would delete $deleted (idle=${idle_days}d, closed=${closed_days}d)" >&2
	else
		echo "gc: closed $closed, deleted $deleted (idle=${idle_days}d, closed=${closed_days}d)" >&2
	fi
}

_gc_status() {
	local db; db=$(active_db)
	local now; now=$(date -u +%s)
	local idle_days="${LIGHTNING_ACCOUNT_GC_DAYS:-90}"
	local closed_days="${LIGHTNING_ACCOUNT_GC_CLOSED_DAYS:-7}"
	case "$idle_days"    in ''|*[!0-9]*) idle_days=90 ;; esac
	case "$closed_days"  in ''|*[!0-9]*) closed_days=7 ;; esac
	local idle_cutoff=$(( now - idle_days * 86400 ))
	local closed_cutoff=$(( now - closed_days * 86400 ))

	local n_idle n_closed n_total
	n_total=$(sqlite3 "$db" "SELECT COUNT(*) FROM accounts WHERE name NOT IN ('-', 'house');")
	n_idle=$(sqlite3 "$db" "
		SELECT COUNT(*) FROM accounts a
		WHERE a.address IS NOT NULL
		  AND a.closed_at IS NULL
		  AND a.name NOT IN ('-', 'house')
		  AND COALESCE(a.last_api_call_at, a.created_at, 0) < $idle_cutoff
		  AND COALESCE((SELECT SUM(amount_msat) FROM ledger WHERE account = a.name), 0) = 0
		  AND NOT EXISTS (SELECT 1 FROM invoices WHERE account = a.name AND state = 'pending');")
	n_closed=$(sqlite3 "$db" "
		SELECT COUNT(*) FROM accounts a
		WHERE a.closed_at IS NOT NULL
		  AND a.closed_at < $closed_cutoff
		  AND a.name NOT IN ('-', 'house')
		  AND COALESCE((SELECT SUM(amount_msat) FROM ledger WHERE account = a.name), 0) = 0;")
	printf "total_accounts:    %s\n" "$n_total"
	printf "idle_days:         %s\n" "$idle_days"
	printf "closed_grace_days: %s\n" "$closed_days"
	printf "would_close:       %s\n" "$n_idle"
	printf "would_delete:      %s\n" "$n_closed"
}

# FEAT-218 — invite code management.  Codes are 7-char base32-ish
# strings (uppercase letters + digits, [A-Z2-9] minus 0/1/I/O which
# confuse humans) that map back to an account name via the
# invite_codes table.  Used by `POST /api/accounts {"invite_code":...}`
# to stamp `referrer` on new accounts.
cmd_invite_code() {
	local op="${1:-}"
	case "$op" in
		create) shift; _invite_code_create "$@" ;;
		list)   shift; _invite_code_list "$@" ;;
		revoke) shift; _invite_code_revoke "$@" ;;
		*) echo "usage: lightning account invite-code {create|list|revoke}" >&2; exit 1 ;;
	esac
}

_invite_code_mint() {
	# 7 chars from [a-z0-9] (lowercase to dodge the I/O/1/0 readability
	# issue without resorting to a custom alphabet).  Source: urandom
	# → base32 → lowercase → strip pad → first 7 chars.
	head -c 8 /dev/urandom | base32 | tr 'A-Z' 'a-z' | tr -d '=\n' | head -c 7
}

_invite_code_create() {
	local handle="" code=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--code) code="$2"; shift 2 ;;
			*) handle="$1"; shift ;;
		esac
	done
	local db; db=$(active_db)
	# Default account = the active wallet's name-equivalent — fall
	# back to the operator's own account if not supplied.  Most CLI
	# users want to mint a code for an existing account they own.
	if [ -z "$handle" ]; then
		echo "usage: lightning account invite-code create <handle> [--code <vanity>]" >&2
		exit 1
	fi
	resolve_account "$handle" || {
		echo "lightning account invite-code: no such account '$handle'" >&2
		exit 2
	}
	local name="$RESOLVED_NAME"

	if [ -z "$code" ]; then
		code=$(_invite_code_mint)
	else
		# Sanity-check operator-supplied codes — keep them in the
		# expected alphabet so resolution stays predictable.
		[[ "$code" =~ ^[a-z0-9]{3,32}$ ]] || {
			echo "lightning account invite-code: --code must be 3-32 chars of [a-z0-9]" >&2
			exit 1
		}
	fi

	local now; now=$(date -u +%s)
	sqlite3 "$db" "INSERT INTO invite_codes(code, account, created_at) \
		VALUES($(sql_quote "$code"), $(sql_quote "$name"), $now);" 2>/dev/null || {
			echo "lightning account invite-code: '$code' already exists" >&2
			exit 3
		}
	echo "code:    $code"
	echo "account: $name"
	echo "link:    ?invite=$code"
}

_invite_code_list() {
	local handle="$1"
	local where=""
	if [ -n "$handle" ]; then
		resolve_account "$handle" || {
			echo "lightning account invite-code: no such account '$handle'" >&2
			exit 2
		}
		where="WHERE account = $(sql_quote "$RESOLVED_NAME")"
	fi
	local db; db=$(active_db)
	printf "code\taccount\tuses\tcreated_at\n"
	sqlite3 -separator $'\t' "$db" \
		"SELECT code, account, uses, created_at FROM invite_codes $where ORDER BY created_at DESC;"
}

_invite_code_revoke() {
	[ $# -lt 1 ] && { echo "usage: lightning account invite-code revoke <code>" >&2; exit 1; }
	local code="$1"
	local db; db=$(active_db)
	# Use change-count to tell whether a row was actually deleted.
	local before after
	before=$(sqlite3 "$db" "SELECT COUNT(*) FROM invite_codes WHERE code = $(sql_quote "$code");")
	sqlite3 "$db" "DELETE FROM invite_codes WHERE code = $(sql_quote "$code");" 2>/dev/null || true
	after=$(sqlite3 "$db" "SELECT COUNT(*) FROM invite_codes WHERE code = $(sql_quote "$code");")
	if [ "$before" -gt 0 ] && [ "$after" = "0" ]; then
		echo "lightning account invite-code: revoked $code"
	else
		echo "lightning account invite-code: '$code' not found" >&2
		exit 2
	fi
}

cmd_apikey() {
	[ $# -lt 1 ] && { echo "usage: lightning account apikey {create,list,revoke} <name> --scope read|write" >&2; exit 1; }
	local op="$1"; shift
	[ $# -lt 1 ] && { echo "lightning account apikey: account name required" >&2; exit 1; }
	local name="$1"; shift
	local scope=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--scope)
				case "$2" in read|write) scope="$2"; shift 2 ;;
					*) echo "--scope: must be read|write" >&2; exit 1 ;;
				esac ;;
			*) echo "lightning account apikey: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	command -v secret >/dev/null || {
		echo "lightning account apikey: the \`secret\` package is required" >&2; exit 127; }

	case "$op" in
		create)
			[ -z "$scope" ] && { echo "--scope required" >&2; exit 1; }
			# 32 bytes -> base64url; drop trailing =.
			local key
			key=$(head -c 32 /dev/urandom | base64 | tr '+/' '-_' | tr -d '=\n')
			echo "$key" | secret put "lightning.$name.apikey.$scope" >/dev/null
			echo "lightning account apikey: $name/$scope ="
			echo "$key"
			echo "(save it now — this is the only time it'll be printed)" >&2 ;;
		list)
			for s in read write; do
				if secret get "lightning.$name.apikey.$s" >/dev/null 2>&1; then
					echo "$s"
				fi
			done ;;
		revoke)
			[ -z "$scope" ] && { echo "--scope required" >&2; exit 1; }
			secret rm "lightning.$name.apikey.$scope" 2>/dev/null || true
			echo "lightning account apikey: revoked $name/$scope" ;;
		*) echo "lightning account apikey: unknown op '$op'" >&2; exit 1 ;;
	esac
}

# --- FEAT-211: account-centric verb facade --------------------------------

cmd_topup() {
	[ $# -lt 2 ] && { echo "usage: lightning account topup <name> <sat> [--via lightning]" >&2; exit 1; }
	local name="$1" sat="$2"; shift 2
	local via="onchain"
	while [ $# -gt 0 ]; do
		case "$1" in
			--via)
				case "$2" in
					lightning|onchain) via="$2"; shift 2 ;;
					*) echo "lightning account topup: --via must be 'lightning' or 'onchain'" >&2; exit 1 ;;
				esac ;;
			*) echo "lightning account topup: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done
	require_account "$name"

	if [ "$via" = "lightning" ]; then
		# BOLT-11 invoice tied to the account.
		exec "$SELF_LIBEXEC/lightning/invoice" create "$sat" \
			"topup-$name-$(date +%s)" \
			--description "top-up of $name (Lightning)" \
			--account "$name" --qr
	fi

	# Default: on-chain top-up.  Get a fresh receive address from the
	# daemon, render the BIP-21 URI as QR.
	command -v lightning-cli >/dev/null || {
		echo "lightning account topup: lightning-cli not found" >&2; exit 127; }
	local addr_json addr
	addr_json=$(lightning-cli \
		--lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
		--network="${LIGHTNING_NETWORK:-bitcoin}" \
		newaddr 2>/dev/null) || {
			echo "lightning account topup: newaddr failed (is lightningd running?)" >&2
			exit 4
		}
	addr=$(jq -r '.bech32 // .p2tr // .p2wkh // empty' <<<"$addr_json")
	[ -n "$addr" ] || {
		echo "lightning account topup: lightningd returned no usable address" >&2
		exit 4
	}

	echo "Top up account '$name' with $sat sats to:"
	echo "  $addr"
	echo "  (BIP-21: bitcoin:$addr?amount=$sat)"
	echo ""
	if [ -x "$SELF_LIBEXEC/lightning/qr" ]; then
		"$SELF_LIBEXEC/lightning/qr" "bitcoin:$addr?amount=$sat"
	fi
}

cmd_withdraw() {
	[ $# -lt 3 ] && { echo "usage: lightning account withdraw <name> <sat> <onchain-addr>" >&2; exit 1; }
	local name="$1" sat="$2" addr="$3"
	require_account "$name"
	# Loose bitcoin-address sanity check.  Better-than-nothing — full
	# validation needs bech32 + base58check, which we don't shell out
	# for.  Requires minimum length (26) so a typoed prefix like
	# "not-an-address" doesn't sneak past the `n*` testnet rule.
	if [ "${#addr}" -lt 26 ]; then
		echo "lightning account withdraw: '$addr' doesn't look like a bitcoin address (too short)" >&2
		exit 1
	fi
	case "$addr" in
		bc1*|tb1*|bcrt1*|1*|3*|m*|n*|2*) ;;
		*) echo "lightning account withdraw: '$addr' doesn't look like a bitcoin address" >&2; exit 1 ;;
	esac

	echo "Withdrawing $sat sat from account '$name' to $addr"
	echo "  via reverse submarine swap (Boltz)"
	if ! command -v boltzcli >/dev/null; then
		echo "lightning account withdraw: boltzcli not installed" >&2
		echo "  install:  https://github.com/BoltzExchange/boltz-client" >&2
		echo "  alternative: close a channel and spend the resulting UTXO" >&2
		exit 127
	fi
	boltzcli createreverseswap --amount "$sat" --address "$addr" || {
		echo "lightning account withdraw: boltzcli reverse swap failed" >&2
		exit 1
	}

	# Record the debit in the per-account ledger.
	if [ -x "$SELF_LIBEXEC/lightning/ledger" ]; then
		"$SELF_LIBEXEC/lightning/ledger" add out "$(( sat * 1000 ))" \
			--account "$name" \
			--note "withdraw to $addr" 2>/dev/null || true
	fi
	echo "ok"
}

# Dispatch on the payment-string shape.  Order matters — more specific
# prefixes are checked before more general ones (lnbc* before generic
# hex pubkey check, etc.).
cmd_pay() {
	[ $# -lt 2 ] && { echo "usage: lightning account pay <name> <payment-string> [--sat <sat>]" >&2; exit 1; }
	local name="$1" target="$2"; shift 2
	local sat=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--sat) sat="$2"; shift 2 ;;
			*) echo "lightning account pay: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done
	require_account "$name"

	# Normalise for prefix matching (don't lowercase the original — we
	# pass the operator's exact input down so case-sensitive parsers
	# downstream stay happy).
	local lower; lower=$(printf '%s' "$target" | tr 'A-Z' 'a-z')

	case "$lower" in
		lnbc*|lntb*)
			# BOLT-11 invoice (mainnet lnbc / testnet lntb / regtest lnbcrt
			# — the last is covered by lnbc*).
			exec "$SELF_LIBEXEC/lightning/invoice" pay "$target" --account "$name" ;;
		lno*)
			# BOLT-12 offer.
			if [ -n "$sat" ]; then
				exec "$SELF_LIBEXEC/lightning/offer" pay "$target" "$sat" --account "$name"
			else
				exec "$SELF_LIBEXEC/lightning/offer" pay "$target" --account "$name"
			fi ;;
		lnurl*)
			# LNURL-pay.
			exec "$SELF_LIBEXEC/lightning/lnurl" pay "$target" --account "$name" ;;
		*@*.*)
			# Lightning address (user@host).
			exec "$SELF_LIBEXEC/lightning/lnurl" pay "$target" --account "$name" ;;
		02*|03*)
			# 66-char hex node pubkey → keysend.
			if [ "${#target}" -ne 66 ]; then
				echo "lightning account pay: '$target' starts like a node pubkey but isn't 66 chars" >&2
				exit 1
			fi
			[ -n "$sat" ] || {
				echo "lightning account pay: keysend needs --sat <amount>" >&2
				exit 1
			}
			exec "$SELF_LIBEXEC/lightning/send" "$target" "$sat" --account "$name" ;;
		*)
			echo "lightning account pay: couldn't identify payment-string type" >&2
			echo "  supported shapes:" >&2
			echo "    lnbc* / lntb* / lnbcrt*  (BOLT-11 invoice)" >&2
			echo "    lno*                     (BOLT-12 offer)" >&2
			echo "    lnurl*                   (LNURL)" >&2
			echo "    user@host                (Lightning address)" >&2
			echo "    02xx... / 03xx... (66h)  (node pubkey, needs --sat)" >&2
			exit 1 ;;
	esac
}

cmd_receive() {
	[ $# -lt 2 ] && { echo "usage: lightning account receive <name> <sat> [--desc <text>] [--reusable]" >&2; exit 1; }
	local name="$1" sat="$2"; shift 2
	local desc="" reusable=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--desc) desc="$2"; shift 2 ;;
			--reusable) reusable=1; shift ;;
			*) echo "lightning account receive: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done
	require_account "$name"
	[ -n "$desc" ] || desc="receive to $name"

	if [ "$reusable" -eq 1 ]; then
		# BOLT-12 — reusable, payer fetches an invoice on the wire.
		exec "$SELF_LIBEXEC/lightning/offer" create "$sat" "$desc" \
			--account "$name" --qr
	else
		# BOLT-11 — single-use.
		exec "$SELF_LIBEXEC/lightning/invoice" create "$sat" \
			"receive-$name-$(date +%s)" \
			--description "$desc" \
			--account "$name" --qr
	fi
}

case "${1:-}" in
	list)     shift; cmd_list "$@" ;;
	create)   shift; cmd_create "$@" ;;
	delete)   shift; cmd_delete "$@" ;;
	show)     shift; cmd_show "$@" ;;
	close)    shift; cmd_close "$@" ;;
	nickname) shift; cmd_nickname "$@" ;;
	topup-watcher) shift; cmd_topup_watcher "$@" ;;
	gc)       shift; cmd_gc "$@" ;;
	invite-code) shift; cmd_invite_code "$@" ;;
	apikey)   shift; cmd_apikey "$@" ;;
	topup)    shift; cmd_topup "$@" ;;
	withdraw) shift; cmd_withdraw "$@" ;;
	pay)      shift; cmd_pay "$@" ;;
	receive)  shift; cmd_receive "$@" ;;
	"")       usage; exit 1 ;;
	*)        echo "lightning account: unknown subcommand '$1'" >&2; usage; exit 1 ;;
esac
