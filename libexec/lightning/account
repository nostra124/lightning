#!/bin/bash
# lightning account — virtual-account management.
#
# Implements FEAT-174 (account concept) + FEAT-195 (bank-mode
# overdraft + limits; the API key issuance verbs land with
# FEAT-196 in 0.5.0).
#
# Subcommands:
#   list                                       all accounts
#   create <name> [<description>]
#          [--limit <sat>] [--overdraft deny|warn|allow]
#   delete <name>
#   show <name>                                balance + recent activity

set -e

command -v sqlite3 >/dev/null || { echo "lightning: sqlite3 not installed" >&2; exit 127; }

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"

active_db() {
	local name="default"
	[ -f "$ACTIVE_LINK" ] && name=$(cat "$ACTIVE_LINK")
	local db="$WALLETS_ROOT/$name/state.db"
	[ -f "$db" ] || { echo "lightning account: no active wallet (try \`lightning wallet new\`)" >&2; exit 2; }
	echo "$db"
}

sq() { sqlite3 -separator $'\t' "$(active_db)" "$@"; }
sqh() { sqlite3 -header -separator $'\t' "$(active_db)" "$@"; }

usage() {
	cat >&2 <<EOF
usage: lightning account <subcommand>

   list                                          TSV of accounts
   create <name> [<desc>] [--limit <sat>]
                          [--overdraft deny|warn|allow]
   delete <name>
   show <name>                                   balance + recent ledger
EOF
}

cmd_list() {
	sqh "SELECT name, description, COALESCE(limit_sat, -1) AS limit_sat, overdraft FROM accounts WHERE name != '-' ORDER BY name;"
}

# Bash doesn't have a clean SQL-injection-safe quoter; we constrain
# the inputs (name regex, numeric limit, enum overdraft) before
# building the query.
sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }

cmd_create() {
	[ $# -lt 1 ] && { echo "usage: lightning account create <name> [<desc>] [--limit <sat>] [--overdraft deny|warn|allow]" >&2; exit 1; }
	local name="$1"; shift
	local desc=""
	[ $# -gt 0 ] && [[ "$1" != --* ]] && { desc="$1"; shift; }
	local limit="NULL"
	local overdraft="deny"

	while [ $# -gt 0 ]; do
		case "$1" in
			--limit)
				[[ "$2" =~ ^[0-9]+$ ]] || { echo "--limit: integer required" >&2; exit 1; }
				limit="$2"; shift 2 ;;
			--overdraft)
				case "$2" in deny|warn|allow) overdraft="$2"; shift 2 ;;
					*) echo "--overdraft: must be deny|warn|allow" >&2; exit 1 ;;
				esac ;;
			*) echo "lightning account create: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	[[ "$name" =~ ^[a-z][a-z0-9_-]*$ ]] || {
		echo "lightning account: name must match [a-z][a-z0-9_-]*" >&2; exit 1; }

	sqlite3 "$(active_db)" "INSERT INTO accounts(name, description, limit_sat, overdraft) VALUES($(sql_quote "$name"), $(sql_quote "$desc"), $limit, $(sql_quote "$overdraft"));"
	echo "lightning account: created $name"
}

cmd_delete() {
	[ $# -lt 1 ] && { echo "usage: lightning account delete <name>" >&2; exit 1; }
	local name="$1"
	[ "$name" = "-" ] && { echo "lightning account: cannot delete the unassigned account" >&2; exit 2; }
	sqlite3 "$(active_db)" "DELETE FROM accounts WHERE name = $(sql_quote "$name");"
	echo "lightning account: deleted $name"
}

cmd_show() {
	[ $# -lt 1 ] && { echo "usage: lightning account show <name>" >&2; exit 1; }
	local name="$1"
	local db; db=$(active_db)

	local row
	row=$(sqlite3 -separator $'\t' "$db" "SELECT description, COALESCE(limit_sat,-1), overdraft FROM accounts WHERE name = $(sql_quote "$name");")
	[ -z "$row" ] && { echo "lightning account: no such account '$name'" >&2; exit 2; }

	local desc limit overdraft
	IFS=$'\t' read -r desc limit overdraft <<<"$row"
	local balance_msat
	balance_msat=$(sqlite3 "$db" "SELECT COALESCE(SUM(amount_msat),0) FROM ledger WHERE account = $(sql_quote "$name");")
	local balance_sat=$(( balance_msat / 1000 ))

	printf "name:        %s\n"  "$name"
	printf "description: %s\n"  "$desc"
	printf "balance_sat: %s\n"  "$balance_sat"
	if [ "$limit" != "-1" ]; then
		printf "limit_sat:   %s\n"  "$limit"
	else
		printf "limit_sat:   (none)\n"
	fi
	printf "overdraft:   %s\n"  "$overdraft"
	printf "\nrecent ledger:\n"
	sqlite3 -header -separator $'\t' "$db" "SELECT ts, direction, amount_msat, peer, message FROM ledger WHERE account = $(sql_quote "$name") ORDER BY id DESC LIMIT 10;"
}

case "${1:-}" in
	list)   shift; cmd_list "$@" ;;
	create) shift; cmd_create "$@" ;;
	delete) shift; cmd_delete "$@" ;;
	show)   shift; cmd_show "$@" ;;
	"")     usage; exit 1 ;;
	*)      echo "lightning account: unknown subcommand '$1'" >&2; usage; exit 1 ;;
esac
