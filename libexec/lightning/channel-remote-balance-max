#!/bin/bash
# lightning channel-remote-balance-max   (FEAT-2257)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel': None}))
else:
    best = max(channels, key=lambda c: c.get('remote_msat', 0))
    print(json.dumps({'channel': {'peer_id': best.get('peer_id'), 'short_channel_id': best.get('short_channel_id'), 'remote_msat': best.get('remote_msat', 0)}}))
" "$result"
