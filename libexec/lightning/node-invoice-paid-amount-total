#!/bin/bash
# lightning node-invoice-paid-amount-total   (FEAT-2464)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid']
total = sum(i.get('amount_received_msat', i.get('amount_msat', 0)) for i in paid)
print(json.dumps({'paid_amount_total_msat': total, 'paid_count': len(paid)}))
" "$result"
