#!/bin/bash
# lightning channel-capacity-min   (FEAT-2277)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'min_capacity_channel': None}))
    sys.exit(0)
def capacity(ch):
    l = ch.get('local_msat', 0)
    r = ch.get('remote_msat', 0)
    if isinstance(l, str): l = int(l.rstrip('msat'))
    if isinstance(r, str): r = int(r.rstrip('msat'))
    return l + r
smallest = min(channels, key=capacity)
print(json.dumps({'min_capacity_channel': smallest, 'capacity_msat': capacity(smallest)}))
" "$result"
