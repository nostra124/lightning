#!/bin/bash
# lightning peer-score-list   (FEAT-697)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
scores = [{'id': p.get('id'), 'connected': p.get('connected'), 'channels': len(p.get('channels', []))} for p in peers]
print(json.dumps(scores))
" "$result"
