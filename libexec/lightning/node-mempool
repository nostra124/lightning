#!/bin/bash
# lightning node-mempool   (FEAT-308)
#
# Lists unconfirmed on-chain transactions known to the CLN daemon.
# Returns [{txid, amount_sat, type}] or empty array.

set -e
LD="--lightning-dir=${LIGHTNING_DIR:-$HOME/.lightning}"
NET="--network=${LIGHTNING_NETWORK:-bitcoin}"

command -v lightning-cli >/dev/null || { echo '[]'; exit 0; }

raw=$(lightning-cli $LD $NET listtransactions 2>/dev/null) || { echo '[]'; exit 0; }

python3 -c "
import sys, json
txs = json.loads(sys.argv[1]).get('transactions', [])
result = []
for tx in txs:
    if tx.get('blockheight') is None or tx.get('blockheight', 0) == 0:
        result.append({
            'txid': tx.get('hash', ''),
            'amount_sat': tx.get('amount_msat', 0) // 1000,
            'type': tx.get('type', 'unknown'),
        })
print(json.dumps(result, separators=(',', ':')))
" "$raw"
