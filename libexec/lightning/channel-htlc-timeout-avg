#!/bin/bash
# lightning channel-htlc-timeout-avg   (FEAT-2382)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
expiries = []
for ch in channels:
    for h in ch.get('htlcs', []):
        if 'cltv_expiry' in h:
            expiries.append(h['cltv_expiry'])
avg = round(sum(expiries) / len(expiries), 2) if expiries else 0.0
print(json.dumps({'htlc_count': len(expiries), 'avg_cltv_expiry': avg}))
" "$result"
