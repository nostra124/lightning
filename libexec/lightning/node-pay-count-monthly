#!/bin/bash
# lightning node-pay-count-monthly   (FEAT-2899)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
month_ago = time.time() - 30 * 86400
count = sum(1 for p in pays if p.get('created_at', 0) >= month_ago)
print(json.dumps({'pay_count_monthly': count}))
" "$result"
