#!/bin/bash
# lightning wallet-notes-list-keys   (FEAT-1818)
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
keys=$(sqlite3 "$db" "SELECT key FROM notes ORDER BY key;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
keys = [k for k in sys.argv[1].splitlines() if k]
print(json.dumps({'keys': keys, 'count': len(keys)}))
" "$keys"
