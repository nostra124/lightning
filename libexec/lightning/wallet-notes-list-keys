#!/bin/bash
# lightning wallet-notes-list-keys <wallet>   (FEAT-1923)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-list-keys <wallet>"}'; exit 0; fi
wallet="$1"
db="$HOME/.lightning/wallets/$wallet/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet db not found"}'; exit 0; fi
keys=$(sqlite3 "$db" "SELECT DISTINCT key FROM notes ORDER BY key;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
wallet = sys.argv[2]
keys = [k for k in sys.argv[1].splitlines() if k]
print(json.dumps({'wallet': wallet, 'keys': keys, 'count': len(keys)}))
" "$keys" "$wallet"
