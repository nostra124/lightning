#!/bin/bash
# lightning invoice-list-active   (FEAT-605)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
now = int(time.time())
active = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid' and i.get('expires_at', 0) > now]
print(json.dumps(active))
" "$result"
