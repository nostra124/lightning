#!/bin/bash
# lightning channel-fee-base-list   (FEAT-2515)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
entries = []
for ch in channels:
    entries.append({
        'channel_id': ch.get('short_channel_id') or ch.get('channel_id'),
        'peer_id': ch.get('peer_id'),
        'fee_base_msat': ch.get('fee_base_msat')
    })
print(json.dumps({'channel_fee_base_list': entries, 'count': len(entries)}))
" "$result"
