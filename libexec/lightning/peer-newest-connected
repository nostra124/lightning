#!/bin/bash
# lightning peer-newest-connected   (FEAT-2353)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
connected = [p for p in peers if p.get('connected')]
if connected:
    p = connected[0]
    print(json.dumps({'peer_id': p.get('id'), 'connected': True}))
else:
    print(json.dumps({'peer_id': None, 'connected': False}))
" "$result"
