#!/bin/bash
# lightning channel-balance-ratio-list   (FEAT-2522)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ratios = []
for c in channels:
    local = c.get('to_us_msat', 0)
    total = c.get('total_msat', 0)
    if isinstance(local, str):
        local = int(local.replace('msat',''))
    if isinstance(total, str):
        total = int(total.replace('msat',''))
    ratio = round(local / total, 4) if total > 0 else 0.0
    ratios.append({'channel_id': c.get('channel_id', ''), 'ratio': ratio})
print(json.dumps({'channel_balance_ratio_list': ratios}))
" "$result"
