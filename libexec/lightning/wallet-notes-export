#!/bin/bash
# lightning wallet-notes-export <wallet_name>   (FEAT-993)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-export <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
notes_file="$root/$wname/notes"
if [ ! -f "$notes_file" ]; then echo "{\"wallet\":\"$wname\",\"notes\":[]}"; exit 0; fi
python3 -c "
import sys, json
lines = open(sys.argv[1]).read().splitlines()
print(json.dumps({'wallet': sys.argv[2], 'notes': lines}))
" "$notes_file" "$wname"
