#!/bin/bash
# lightning wallet-encrypt-check <wallet_name>   (FEAT-828)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-encrypt-check <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
has_enc=$(sqlite3 "$db" "SELECT COUNT(*) FROM meta WHERE key='enc_hash'" 2>/dev/null) || has_enc=0
echo "{\"wallet\":\"$wname\",\"encrypted\":$([ "$has_enc" -gt 0 ] && echo true || echo false)}"
