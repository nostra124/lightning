#!/bin/bash
# lightning node-pay-fee-min   (FEAT-2754)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
fees = []
for p in pays:
    sent = p.get('amount_sent_msat', 0)
    amt = p.get('amount_msat', 0)
    if sent and amt:
        fees.append(sent - amt)
min_fee = min(fees) if fees else 0
print(json.dumps({'min_fee_msat': min_fee}))
" "$result"
