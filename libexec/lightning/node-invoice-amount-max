#!/bin/bash
# lightning node-invoice-amount-max   (FEAT-2264)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
if not invoices:
    print(json.dumps({'label': None, 'amount_received_msat': None}))
    sys.exit(0)
inv = max(invoices, key=lambda i: int(i.get('amount_received_msat', 0)))
print(json.dumps({'label': inv.get('label'), 'amount_received_msat': inv.get('amount_received_msat')}))
" "$result"
