#!/bin/bash
# lightning node-listinvoices-paid-amount-avg   (FEAT-2499)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
amounts = [i.get('amount_received_msat', i.get('amount_msat', 0)) for i in invoices if i.get('status') == 'paid']
if amounts:
    print(json.dumps({'paid_invoice_amount_avg_msat': sum(amounts) / len(amounts), 'paid_count': len(amounts)}))
else:
    print(json.dumps({'paid_invoice_amount_avg_msat': None, 'paid_count': 0}))
" "$result"
