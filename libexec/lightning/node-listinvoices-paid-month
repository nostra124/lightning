#!/bin/bash
# lightning node-listinvoices-paid-month   (FEAT-2579)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
cutoff = int(time.time()) - 30 * 86400
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'paid' and i.get('paid_at', 0) >= cutoff]
print(json.dumps({'paid_month_count': len(invoices)}))
" "$result"
