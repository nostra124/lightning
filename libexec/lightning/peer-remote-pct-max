#!/bin/bash
# lightning peer-remote-pct-max   (FEAT-2518)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_pct = None
best_peer = None
for ch in channels:
    local = ch.get('local_msat', 0) or 0
    remote = ch.get('remote_msat', 0) or 0
    total = local + remote
    if total > 0:
        pct = remote / total * 100
        if best_pct is None or pct > best_pct:
            best_pct = pct
            best_peer = ch.get('peer_id')
            best = {'channel_id': ch.get('short_channel_id') or ch.get('channel_id'), 'local_msat': local, 'remote_msat': remote, 'total_msat': total}
if best is None:
    print(json.dumps({'remote_pct_max': None, 'peer_id': None}))
else:
    best['remote_pct'] = round(best_pct, 2)
    best['peer_id'] = best_peer
    print(json.dumps(best))
" "$result"
