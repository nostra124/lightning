#!/bin/bash
# lightning wallet-balance-onchain   (FEAT-1328)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = data.get('outputs', [])
total = sum(o.get('amount_msat', 0) for o in outputs if o.get('status') == 'confirmed')
print(json.dumps({'onchain_confirmed_msat': total, 'output_count': len(outputs)}))
" "$result"
