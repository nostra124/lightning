#!/bin/bash
# lightning wallet-notes-replace <wallet_name> <key> <value>   (FEAT-1208)
if [ $# -lt 3 ]; then echo '{"error":"usage: wallet-notes-replace <wallet_name> <key> <value>"}'; exit 0; fi
wname="$1"; key="$2"; value="$3"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "INSERT OR REPLACE INTO notes(key, value) VALUES('$key', '$value');" 2>/dev/null
echo "{\"ok\":true,\"wallet\":\"$wname\",\"key\":\"$key\"}"
