#!/bin/bash
# lightning wallet-notes-replace <key> <value>   (FEAT-1773)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-replace <key> <value>"}'; exit 0; fi
key="$1"
value="$2"
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "INSERT OR REPLACE INTO notes (key, value) VALUES ('$key', '$value');" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"replaced\":true,\"key\":\"$key\"}"
