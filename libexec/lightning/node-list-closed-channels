#!/bin/bash
# lightning node-list-closed-channels   (FEAT-884)
result=$(lightning-cli listclosedchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
chs = data.get('closedchannels', [])
print(json.dumps({'count': len(chs), 'channels': chs}))
" "$result"
