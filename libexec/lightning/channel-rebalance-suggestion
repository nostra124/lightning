#!/bin/bash
# lightning channel-rebalance-suggestion   (FEAT-890)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
chs = data.get('channels', [])
suggestions = []
for ch in chs:
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if total > 0:
        ratio = local / total
        if ratio > 0.8:
            suggestions.append({'channel_id': ch.get('channel_id'), 'action': 'send', 'local_ratio': round(ratio, 3)})
        elif ratio < 0.2:
            suggestions.append({'channel_id': ch.get('channel_id'), 'action': 'receive', 'local_ratio': round(ratio, 3)})
print(json.dumps({'suggestions': suggestions}))
" "$result"
