#!/bin/bash
# lightning node-graph-connectivity-stats   (FEAT-2164)
result=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
total = len(nodes)
with_addrs = sum(1 for n in nodes if n.get('addresses'))
with_alias = sum(1 for n in nodes if n.get('alias'))
print(json.dumps({
    'total_nodes': total,
    'nodes_with_addresses': with_addrs,
    'nodes_with_alias': with_alias,
    'nodes_without_addresses': total - with_addrs,
}))
" "$result"
