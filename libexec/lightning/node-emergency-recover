#!/bin/bash
# lightning node-emergency-recover <scb_file>   (FEAT-689)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-emergency-recover <scb_file>"}'; exit 0; fi
scb_file="$1"
if [ ! -f "$scb_file" ]; then echo '{"error":"file not found"}'; exit 0; fi
result=$(lightning-cli emergencyrecover "$scb_file" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps(d))" "$result"
