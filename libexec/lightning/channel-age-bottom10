#!/bin/bash
# lightning channel-age-bottom10   (FEAT-2735)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
with_age = [(c.get('short_channel_id',''), c.get('opener',''), c.get('to_us_msat',0), c.get('total_msat',0), c.get('peer_id','')) for c in channels if c.get('short_channel_id')]
# sort descending: newest channels have higher block height prefix
sorted_ch = sorted(with_age, key=lambda x: x[0], reverse=True)
bottom10 = [{'short_channel_id': c[0], 'opener': c[1], 'to_us_msat': c[2], 'total_msat': c[3], 'peer_id': c[4]} for c in sorted_ch[:10]]
print(json.dumps({'bottom10_newest': bottom10}))
" "$result"
