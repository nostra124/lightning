#!/bin/bash
# lightning invoice-list-by-destination <node_id>   (FEAT-1415)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-list-by-destination <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nid = sys.argv[2]
invs = [i for i in data.get('invoices', []) if i.get('local_offer_id') == nid or i.get('payer_note') == nid]
print(json.dumps({'count': len(invs), 'invoices': invs}))
" "$result" "$node_id"
