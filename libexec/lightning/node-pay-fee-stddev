#!/bin/bash
# lightning node-pay-fee-stddev   (FEAT-2586)
result=$(lightning-cli listsendpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
pays = data.get('payments', [])
fees = [int(p.get('amount_sent_msat', 0)) - int(p.get('amount_msat', 0)) for p in pays if 'amount_msat' in p and 'amount_sent_msat' in p]
if not fees:
    print(json.dumps({'fee_stddev_msat': None}))
    sys.exit(0)
mean = sum(fees) / len(fees)
variance = sum((f - mean) ** 2 for f in fees) / len(fees)
print(json.dumps({'fee_stddev_msat': round(math.sqrt(variance), 4)}))
" "$result"
