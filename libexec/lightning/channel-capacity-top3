#!/bin/bash
# lightning channel-capacity-top3   (FEAT-2595)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
channels.sort(key=lambda c: int(c.get('total_msat', 0)), reverse=True)
top3 = [{'channel_id': c.get('channel_id',''), 'peer_id': c.get('peer_id',''), 'total_msat': int(c.get('total_msat', 0))} for c in channels[:3]]
print(json.dumps({'top3_channels_by_capacity': top3}))
" "$result"
