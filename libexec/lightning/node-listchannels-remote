#!/bin/bash
# lightning node-listchannels-remote   (FEAT-1144)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [ch for ch in data.get('channels', []) if ch.get('opener') == 'remote']
out = [{'channel_id': ch.get('channel_id'), 'peer_id': ch.get('peer_id')} for ch in channels]
print(json.dumps({'count': len(out), 'channels': out}))
" "$result"
