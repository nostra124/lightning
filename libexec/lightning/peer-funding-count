#!/bin/bash
# lightning peer-funding-count <peer_id>   (FEAT-1847)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-funding-count <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
local_funded = [c for c in channels if c.get('opener') == 'local']
remote_funded = [c for c in channels if c.get('opener') == 'remote']
print(json.dumps({'peer_id': pid, 'total': len(channels), 'local_funded': len(local_funded), 'remote_funded': len(remote_funded)}))
" "$result" "$peer_id"
