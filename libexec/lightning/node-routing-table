#!/bin/bash
# lightning node-routing-table [--limit N]   (FEAT-494)
limit=50
while [ $# -gt 0 ]; do
    case "$1" in
        --limit) limit="$2"; shift 2 ;;
        *) shift ;;
    esac
done
if ! result=$(lightning-cli listchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])[:int(sys.argv[2])]
out = [{'source': c.get('source',''), 'destination': c.get('destination',''),
    'fee_base_msat': c.get('base_fee_millisatoshi', 0),
    'fee_ppm': c.get('fee_per_millionth', 0)} for c in channels]
print(json.dumps(out, separators=(',', ':')))
" "$result" "$limit"
