#!/bin/bash
# lightning channel-htlc-value-max   (FEAT-2482)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_val = -1
for ch in channels:
    htlcs = ch.get('htlcs', [])
    total = sum(h.get('amount_msat', 0) for h in htlcs)
    if total > best_val:
        best_val = total
        best = ch.get('peer_id')
if best is None:
    print(json.dumps({'htlc_value_max_msat': None, 'peer_id': None}))
else:
    print(json.dumps({'htlc_value_max_msat': best_val, 'peer_id': best}))
" "$result"
