#!/bin/bash
# lightning node-listinvoices-paid-oldest   (FEAT-2429)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid' and 'paid_at' in i]
if not paid:
    print(json.dumps({'label': None, 'paid_at': None, 'amount_msat': None}))
else:
    oldest = min(paid, key=lambda i: i['paid_at'])
    print(json.dumps({'label': oldest.get('label'), 'paid_at': oldest.get('paid_at'), 'amount_msat': oldest.get('amount_msat')}))
" "$result"
