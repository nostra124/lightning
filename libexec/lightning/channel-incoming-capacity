#!/bin/bash
# lightning channel-incoming-capacity   (FEAT-432)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
normal = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
total_msat = sum(c.get('total_msat', 0) for c in normal)
local_msat = sum(c.get('to_us_msat', 0) for c in normal)
incoming_msat = total_msat - local_msat
print(json.dumps({'incoming_capacity_msat': incoming_msat, 'incoming_capacity_sat': incoming_msat // 1000,
    'active_channels': len(normal)}, separators=(',', ':')))
" "$result"
