#!/bin/bash
# lightning channel-balance-remote-pct   (FEAT-990)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
chs = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL' and c.get('total_msat', 0) > 0]
if chs:
    avg_remote_pct = sum((c.get('total_msat', 0) - c.get('to_us_msat', 0)) / c.get('total_msat', 1) * 100 for c in chs) / len(chs)
    print(json.dumps({'active_channels': len(chs), 'avg_remote_pct': round(avg_remote_pct, 1)}))
else:
    print(json.dumps({'active_channels': 0, 'avg_remote_pct': 0}))
" "$result"
