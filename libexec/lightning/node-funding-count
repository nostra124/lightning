#!/bin/bash
# lightning node-funding-count   (FEAT-734)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
outputs = data.get('outputs', [])
print(json.dumps({'channel_count': len(channels), 'utxo_count': len(outputs)}))
" "$result"
