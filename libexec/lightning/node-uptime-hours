#!/bin/bash
# lightning node-uptime-hours   (FEAT-769)
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
d = json.loads(sys.argv[1])
uptime_sec = d.get('server_runtime', 0)
hours = round(uptime_sec / 3600, 2) if isinstance(uptime_sec, (int, float)) else None
print(json.dumps({'uptime_seconds': uptime_sec, 'uptime_hours': hours}))
" "$result"
