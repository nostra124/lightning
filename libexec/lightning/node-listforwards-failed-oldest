#!/bin/bash
# lightning node-listforwards-failed-oldest   (FEAT-2716)
result=$(lightning-cli listforwards status=failed 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
if not forwards:
    print(json.dumps({'oldest_failed_forward': None}))
else:
    oldest = min(forwards, key=lambda f: f.get('received_time', float('inf')))
    print(json.dumps({'oldest_failed_forward': oldest}))
" "$result"
