#!/bin/bash
# lightning channel-spendable-pct-range   (FEAT-2800)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for c in channels:
    total = c.get('total_msat', 0)
    spendable = c.get('spendable_msat', 0)
    if total > 0:
        vals.append(spendable / total * 100)
if len(vals) >= 2:
    spendable_pct_range = max(vals) - min(vals)
else:
    spendable_pct_range = 0.0
print(json.dumps({'spendable_pct_range': round(spendable_pct_range, 6), 'count': len(vals)}))
" "$result"
