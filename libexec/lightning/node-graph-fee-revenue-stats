#!/bin/bash
# lightning node-graph-fee-revenue-stats   (FEAT-2134)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = [f for f in data.get('forwards', []) if f.get('status') == 'settled']
if not forwards:
    print(json.dumps({'count': 0, 'total_fee_msat': 0, 'min_fee_msat': None, 'max_fee_msat': None, 'avg_fee_msat': None}))
    sys.exit(0)
fees = []
for f in forwards:
    fee = f.get('fee_msat')
    if fee is not None:
        try:
            fees.append(int(str(fee).replace('msat', '')))
        except ValueError:
            pass
if not fees:
    print(json.dumps({'count': 0, 'total_fee_msat': 0, 'min_fee_msat': None, 'max_fee_msat': None, 'avg_fee_msat': None}))
else:
    print(json.dumps({'count': len(fees), 'total_fee_msat': sum(fees), 'min_fee_msat': min(fees), 'max_fee_msat': max(fees), 'avg_fee_msat': sum(fees)//len(fees)}))
" "$result"
