#!/bin/bash
# lightning channel-balance-ratio-min   (FEAT-2989)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ratios = []
for ch in channels:
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if isinstance(total, str): total = int(total.replace('msat',''))
    if isinstance(local, str): local = int(local.replace('msat',''))
    if total > 0:
        ratios.append(local / total)
balance_ratio_min = round(min(ratios), 6) if ratios else 0.0
print(json.dumps({'balance_ratio_min': balance_ratio_min, 'channel_count': len(ratios)}))
" "$result"
