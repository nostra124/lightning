#!/bin/bash
# lightning channel-balance-ratio   (FEAT-1722)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL' and c.get('total_msat')]
ratios = [{'channel_id': c.get('channel_id'), 'local_pct': round(c.get('to_us_msat', 0) / c['total_msat'] * 100, 1)} for c in channels]
print(json.dumps({'count': len(ratios), 'channels': ratios}))
" "$result"
