#!/bin/bash
# lightning channel-balance-ratio   (FEAT-1746)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
out = []
for ch in channels:
    total = ch.get('total_msat', 0)
    us = ch.get('to_us_msat', 0)
    ratio = round(us / total, 4) if total else 0
    out.append({'channel_id': ch.get('channel_id'), 'ratio': ratio})
print(json.dumps({'channels': out}))
" "$result"
