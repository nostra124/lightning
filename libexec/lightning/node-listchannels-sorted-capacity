#!/bin/bash
# lightning node-listchannels-sorted-capacity   (FEAT-1419)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = sorted(data.get('channels', []), key=lambda c: c.get('total_msat', 0), reverse=True)
out = [{'channel_id': c.get('channel_id'), 'total_msat': c.get('total_msat')} for c in channels]
print(json.dumps({'count': len(out), 'channels': out}))
" "$result"
