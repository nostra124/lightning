#!/bin/bash
# lightning channel-peer-total <peer_id>   (FEAT-956)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-peer-total <peer_id>"}'; exit 0; fi
peer_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); pid = sys.argv[2]
chs = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
total = sum(c.get('total_msat', 0) for c in chs)
local = sum(c.get('to_us_msat', 0) for c in chs)
print(json.dumps({'peer_id': pid, 'channel_count': len(chs), 'total_msat': total, 'local_msat': local}))
" "$result" "$peer_id"
