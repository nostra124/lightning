#!/bin/bash
# lightning node-graph-channel-peer-count   (FEAT-1989)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
sources = set(ch.get('source') for ch in channels if ch.get('source'))
print(json.dumps({'unique_sources': len(sources), 'channel_count': len(channels)}))
" "$result"
