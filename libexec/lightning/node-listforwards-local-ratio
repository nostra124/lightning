#!/bin/bash
# lightning node-listforwards-local-ratio   (FEAT-2739)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total = len(forwards)
# local-origin forwards: in_channel is absent or null (payment originated locally)
local_count = sum(1 for f in forwards if not f.get('in_channel'))
ratio = round(local_count / total, 4) if total else 0
print(json.dumps({'local_forward_ratio': ratio, 'local_count': local_count, 'total_count': total}))
" "$result"
