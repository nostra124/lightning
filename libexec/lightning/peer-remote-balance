#!/bin/bash
# lightning peer-remote-balance <peer_id>   (FEAT-1827)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-remote-balance <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
remote = sum(c.get('total_msat', 0) - c.get('to_us_msat', 0) for c in channels)
print(json.dumps({'peer_id': pid, 'remote_balance_msat': remote, 'channel_count': len(channels)}))
" "$result" "$peer_id"
