#!/bin/bash
# lightning node-channel-local-count   (FEAT-1109)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
local = [ch for ch in channels if ch.get('opener') == 'local']
print(json.dumps({'total': len(channels), 'local_opened': len(local)}))
" "$result"
