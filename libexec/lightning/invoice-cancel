#!/bin/bash
# lightning invoice-cancel <label>   (FEAT-705)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-cancel <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli delinvoice "$label" unpaid 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps(d))" "$result"
