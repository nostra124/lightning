#!/bin/bash
# lightning invoice-cancel <label>   (FEAT-306)
#
# Cancels a pending (unpaid) BOLT-11 invoice by label.
# Returns {ok, label} or {error, ...}

set -e
[ $# -ge 1 ] || {
    printf 'usage: invoice-cancel <label>\n' >&2; exit 1; }
label="$1"

command -v lightning-cli >/dev/null || {
    echo '{"error":"lightning-cli not found"}'; exit 0; }

LD="--lightning-dir=${LIGHTNING_DIR:-$HOME/.lightning}"
NET="--network=${LIGHTNING_NETWORK:-bitcoin}"

lightning-cli $LD $NET delinvoice "$label" unpaid >/dev/null 2>&1 || {
    echo '{"error":"delinvoice_failed"}'; exit 0; }

python3 -c "
import sys, json
print(json.dumps({'ok': True, 'label': sys.argv[1]}, separators=(',', ':')))
" "$label"
