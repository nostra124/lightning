#!/bin/bash
# lightning node-spendable-msat   (FEAT-541)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
spendable = sum(c.get('spendable_msat', 0) for c in channels if c.get('state') == 'CHANNELD_NORMAL')
receivable = sum(c.get('receivable_msat', 0) for c in channels if c.get('state') == 'CHANNELD_NORMAL')
print(json.dumps({'spendable_msat': spendable, 'receivable_msat': receivable}))
" "$result"
