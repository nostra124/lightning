#!/bin/bash
# lightning channel-both-reserves-stddev   (FEAT-2845)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
values = []
for ch in channels:
    our = ch.get('our_reserve_msat', 0)
    their = ch.get('their_reserve_msat', 0)
    if isinstance(our, str): our = int(our.rstrip('msat'))
    if isinstance(their, str): their = int(their.rstrip('msat'))
    values.append(float(our + their))
n = len(values)
if n < 2:
    print(json.dumps({'both_reserves_stddev_msat': None, 'n': n}))
    sys.exit(0)
mean = sum(values) / n
var = sum((x - mean)**2 for x in values) / (n - 1)
print(json.dumps({'both_reserves_stddev_msat': round(math.sqrt(var), 6), 'n': n}))
" "$result"
