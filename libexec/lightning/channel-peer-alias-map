#!/bin/bash
# lightning channel-peer-alias-map   (FEAT-2072)
channels=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
nodes=$(lightning-cli listnodes 2>/dev/null) || nodes='{"nodes":[]}'
python3 -c "
import sys, json
channels = json.loads(sys.argv[1])
nodes = json.loads(sys.argv[2])
alias_map = {n['nodeid']: n.get('alias', '') for n in nodes.get('nodes', []) if 'alias' in n}
result = {}
for ch in channels.get('channels', []):
    peer = ch.get('peer_id', '')
    if peer:
        result[peer] = alias_map.get(peer, '')
print(json.dumps({'peer_alias_map': result}))
" "$channels" "$nodes"
