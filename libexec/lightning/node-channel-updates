#!/bin/bash
# lightning node-channel-updates   (FEAT-561)
if ! result=$(lightning-cli listchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
print(json.dumps({'total_channel_updates': len(channels)}))
" "$result"
