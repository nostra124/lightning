#!/bin/bash
# lightning node-invoice-unpaid-rate   (FEAT-2444)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
total = len(invoices)
unpaid = sum(1 for inv in invoices if inv.get('status') != 'paid')
rate = round(unpaid / total, 4) if total > 0 else 0.0
print(json.dumps({'unpaid_invoices': unpaid, 'total_invoices': total, 'unpaid_rate': rate}))
" "$result"
