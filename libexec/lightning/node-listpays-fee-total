#!/bin/bash
# lightning node-listpays-fee-total   (FEAT-1831)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
fee = sum((p.get('amount_sent_msat', 0) - p.get('amount_msat', 0)) for p in pays)
print(json.dumps({'count': len(pays), 'total_fee_msat': fee}))
" "$result"
