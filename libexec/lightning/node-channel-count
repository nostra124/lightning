#!/bin/bash
# lightning node-channel-count   (FEAT-337)
set -e
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
states = {}
for c in channels:
    s = c.get('state', 'UNKNOWN')
    states[s] = states.get(s, 0) + 1
print(json.dumps({'total': len(channels), 'by_state': states}, separators=(',', ':')))
" "$result"
