#!/bin/bash
# lightning node-listforwards-out-msat-range   (FEAT-2791)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
vals = [f.get('out_msat', 0) for f in forwards if 'out_msat' in f]
if len(vals) >= 2:
    out_msat_range = max(vals) - min(vals)
else:
    out_msat_range = 0
print(json.dumps({'out_msat_range': out_msat_range, 'count': len(vals)}))
" "$result"
