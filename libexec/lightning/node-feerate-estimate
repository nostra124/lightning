#!/bin/bash
# lightning node-feerate-estimate <style>   (FEAT-749)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-feerate-estimate <style>"}'; exit 0; fi
style="$1"
result=$(lightning-cli feerates "$style" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps(d))" "$result"
