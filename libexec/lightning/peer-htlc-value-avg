#!/bin/bash
# lightning peer-htlc-value-avg   (FEAT-2408)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_htlc = {}
for ch in channels:
    pid = ch.get('peer_id', '')
    htlcs = ch.get('htlcs', [])
    total = sum(h.get('amount_msat', 0) for h in htlcs)
    peer_htlc[pid] = peer_htlc.get(pid, 0) + total
peer_count = len(peer_htlc)
avg = sum(peer_htlc.values()) / peer_count if peer_count else 0
print(json.dumps({'htlc_value_avg_per_peer_msat': avg, 'peer_count': peer_count}))
" "$result"
