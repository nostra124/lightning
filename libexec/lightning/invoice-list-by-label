#!/bin/bash
# lightning invoice-list-by-label <label_prefix>   (FEAT-482)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-list-by-label <label_prefix>"}'
    exit 0
fi
prefix="$1"
if ! result=$(lightning-cli listinvoices 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
invs = json.loads(sys.argv[1]).get('invoices', [])
prefix = sys.argv[2]
matched = [i for i in invs if i.get('label', '').startswith(prefix)]
print(json.dumps(matched, separators=(',', ':')))
" "$result" "$prefix"
