#!/bin/bash
# lightning invoice-list-by-label <label>   (FEAT-1515)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-list-by-label <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
print(json.dumps({'label': sys.argv[2], 'count': len(invs), 'invoices': invs}))
" "$result" "$label"
