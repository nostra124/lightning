#!/bin/bash
# lightning channel-fee-ppm-list   (FEAT-2757)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ppm_list = [c.get('fee_proportional_millionths', 0) for c in channels]
print(json.dumps({'fee_ppm_list': ppm_list}))
" "$result"
