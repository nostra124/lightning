#!/bin/bash
# lightning invoice-list-paid   (FEAT-505)
if ! result=$(lightning-cli listinvoices 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
invs = json.loads(sys.argv[1]).get('invoices', [])
paid = [{'label': i.get('label',''), 'amount_msat': i.get('amount_received_msat', 0),
    'paid_at': i.get('paid_at', 0)} for i in invs if i.get('status') == 'paid']
print(json.dumps(paid, separators=(',', ':')))
" "$result"
