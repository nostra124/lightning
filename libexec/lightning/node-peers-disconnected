#!/bin/bash
# lightning node-peers-disconnected   (FEAT-431)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
peers = json.loads(sys.argv[1]).get('peers', [])
disconnected = [{'peer_id': p.get('id',''), 'alias': p.get('alias','')}
                for p in peers if not p.get('connected', False)]
print(json.dumps(disconnected, separators=(',', ':')))
" "$result"
