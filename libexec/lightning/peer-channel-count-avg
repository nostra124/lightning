#!/bin/bash
# lightning peer-channel-count-avg   (FEAT-2488)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel_count_avg_per_peer': None, 'peer_count': 0}))
else:
    from collections import Counter
    counts = Counter(ch.get('peer_id') for ch in channels)
    avg = sum(counts.values()) / len(counts)
    print(json.dumps({'channel_count_avg_per_peer': avg, 'peer_count': len(counts)}))
" "$result"
