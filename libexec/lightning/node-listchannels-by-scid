#!/bin/bash
# lightning node-listchannels-by-scid <scid>   (FEAT-1644)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-listchannels-by-scid <scid>"}'; exit 0
fi
scid="$1"
result=$(lightning-cli listchannels "$scid" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
print(json.dumps({'count': len(channels), 'channels': channels}))
" "$result"
