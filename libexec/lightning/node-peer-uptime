#!/bin/bash
# lightning node-peer-uptime <peer_id>   (FEAT-1131)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-peer-uptime <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pid = sys.argv[2]
for p in data.get('peers', []):
    if p.get('id') == pid:
        print(json.dumps({'peer_id': pid, 'connected': p.get('connected', False)}))
        sys.exit(0)
print(json.dumps({'error': 'peer not found'}))
" "$result" "$peer_id"
