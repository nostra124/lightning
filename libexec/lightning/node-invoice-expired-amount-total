#!/bin/bash
# lightning node-invoice-expired-amount-total   (FEAT-2992)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
total = 0
for inv in invoices:
    if inv.get('status') == 'expired':
        amt = inv.get('amount_msat', 0)
        if isinstance(amt, str):
            amt = int(amt.replace('msat',''))
        total += amt
print(json.dumps({'expired_amount_total_msat': total, 'expired_count': sum(1 for i in invoices if i.get('status') == 'expired')}))
" "$result"
