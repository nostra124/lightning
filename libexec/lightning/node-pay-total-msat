#!/bin/bash
# lightning node-pay-total-msat   (FEAT-1569)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
total = sum(p.get('amount_msat', 0) for p in pays)
print(json.dumps({'complete_count': len(pays), 'total_msat': total}))
" "$result"
