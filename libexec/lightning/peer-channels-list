#!/bin/bash
# lightning peer-channels-list <peer_id>   (FEAT-526)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-channels-list <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps(data.get('channels', [])))
" "$result"
