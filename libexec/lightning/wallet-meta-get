#!/bin/bash
# lightning wallet-meta-get <wallet_name> <key>   (FEAT-733)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-meta-get <wallet_name> <key>"}'; exit 0; fi
wname="$1"; key="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
val=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='$key'" 2>/dev/null) || val=""
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"value\":\"$val\"}"
