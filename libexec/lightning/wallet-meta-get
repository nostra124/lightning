#!/bin/bash
# lightning wallet-meta-get <wallet_name> <key>   (FEAT-455)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-meta-get <wallet_name> <key>"}'
    exit 0
fi
wname="$1"; key="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
val=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='$key' LIMIT 1;" 2>/dev/null)
if [ -z "$val" ]; then
    echo '{"error":"key_not_found"}'
    exit 0
fi
echo '{"wallet":"'"$wname"'","key":"'"$key"'","value":"'"$val"'"}'
