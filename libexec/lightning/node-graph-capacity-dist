#!/bin/bash
# lightning node-graph-capacity-dist   (FEAT-1729)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
caps = sorted([c.get('satoshis', 0) for c in channels])
if not caps:
    print(json.dumps({'count': 0, 'p25': None, 'p50': None, 'p75': None}))
    sys.exit(0)
n = len(caps)
print(json.dumps({'count': n, 'p25': caps[n//4], 'p50': caps[n//2], 'p75': caps[3*n//4]}))
" "$result"
