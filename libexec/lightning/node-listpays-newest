#!/bin/bash
# lightning node-listpays-newest   (FEAT-2131)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'newest': None}))
    sys.exit(0)
newest = max(pays, key=lambda p: p.get('created_at', 0))
print(json.dumps({'newest': newest}))
" "$result"
