#!/bin/bash
# lightning node-routing-policy   (FEAT-719)
result=$(lightning-cli listconfigs 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
d = json.loads(sys.argv[1])
configs = d.get('configs', d)
def get_val(k):
    v = configs.get(k)
    if isinstance(v, dict): return v.get('value_int') or v.get('value_str') or v.get('value_msat')
    return v
print(json.dumps({'fee-base': get_val('fee-base'), 'fee-per-satoshi': get_val('fee-per-satoshi'), 'cltv-delta': get_val('cltv-final')}))
" "$result"
