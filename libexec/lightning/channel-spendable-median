#!/bin/bash
# lightning channel-spendable-median   (FEAT-2637)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = sorted([c.get('spendable_msat', 0) for c in channels])
if not vals:
    print(json.dumps({'median_spendable_msat': 0}))
else:
    n = len(vals)
    med = vals[n // 2] if n % 2 == 1 else (vals[n // 2 - 1] + vals[n // 2]) // 2
    print(json.dumps({'median_spendable_msat': med}))
" "$result"
