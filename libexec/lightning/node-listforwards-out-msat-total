#!/bin/bash
# lightning node-listforwards-out-msat-total   (FEAT-2351)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total = sum(f.get('out_msat', 0) for f in forwards if f.get('status') == 'settled')
print(json.dumps({'out_msat_total': total}))
" "$result"
