#!/bin/bash
# lightning node-pay-count-7d   (FEAT-2326)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
cutoff = time.time() - 7 * 86400
count = sum(1 for p in pays if p.get('status') == 'complete' and p.get('created_at', 0) >= cutoff)
print(json.dumps({'pay_count_7d': count}))
" "$result"
