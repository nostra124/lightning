#!/bin/bash
# lightning invoice-keysend <node_id> <amount_msat> [<label>]   (FEAT-338)
set -e
if [ $# -lt 2 ]; then
    echo '{"error":"usage: invoice-keysend <node_id> <amount_msat> [label]"}'
    exit 0
fi
node_id="$1"
amount_msat="$2"
label="${3:-keysend-$(date +%s)}"
result=$(lightning-cli keysend "$node_id" "$amount_msat" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({
    'payment_hash': data.get('payment_hash', ''),
    'status': data.get('status', ''),
    'amount_msat': data.get('amount_msat', 0),
    'destination': data.get('destination', ''),
}, separators=(',', ':')))
" "$result"
