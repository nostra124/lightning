#!/bin/bash
# lightning node-listchannels-ppm-sorted   (FEAT-1874)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = sorted(data.get('channels', []), key=lambda c: c.get('fee_per_millionth', 0), reverse=True)
print(json.dumps({'count': len(channels), 'channels': [{'scid': c.get('short_channel_id'), 'ppm': c.get('fee_per_millionth')} for c in channels[:10]]}))
" "$result"
