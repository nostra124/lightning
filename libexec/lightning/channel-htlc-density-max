#!/bin/bash
# lightning channel-htlc-density-max   (FEAT-2532)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_density = -1
for ch in channels:
    htlcs = len(ch.get('htlcs', []))
    capacity = ch.get('total_msat', 0)
    if isinstance(capacity, str):
        capacity = int(capacity.rstrip('msat')) if capacity.endswith('msat') else int(capacity)
    density = htlcs / capacity if capacity > 0 else 0
    if density > best_density:
        best_density = density
        best = ch.get('channel_id', '')
print(json.dumps({'htlc_density_max': best, 'density': best_density}))
" "$result"
