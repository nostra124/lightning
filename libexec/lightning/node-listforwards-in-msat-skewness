#!/bin/bash
# lightning node-listforwards-in-msat-skewness   (FEAT-2821)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
vals = [f['in_msat'] for f in forwards if 'in_msat' in f]
n = len(vals)
if n < 3:
    print(json.dumps({'in_msat_skewness': None, 'n': n}))
    sys.exit(0)
mean = sum(vals) / n
var = sum((v - mean)**2 for v in vals) / n
std = math.sqrt(var)
if std == 0:
    skew = 0.0
else:
    skew = (sum((v - mean)**3 for v in vals) / n) / (std**3)
print(json.dumps({'in_msat_skewness': skew, 'n': n}))
" "$result"
