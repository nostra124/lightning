#!/bin/bash
# lightning node-graph-avg-fee-ppm   (FEAT-1679)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = [c.get('fee_per_millionth', 0) for c in channels]
if not fees:
    print(json.dumps({'count': 0, 'avg_fee_ppm': None}))
    sys.exit(0)
print(json.dumps({'count': len(fees), 'avg_fee_ppm': sum(fees) / len(fees)}))
" "$result"
