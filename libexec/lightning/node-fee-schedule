#!/bin/bash
# lightning node-fee-schedule   (FEAT-504)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
schedule = [{'channel_id': c.get('channel_id',''), 'peer_id': c.get('peer_id',''),
    'fee_base_msat': c.get('fee_base_msat', 0),
    'fee_proportional_millionths': c.get('fee_proportional_millionths', 0)}
    for c in channels]
print(json.dumps(schedule, separators=(',', ':')))
" "$result"
