#!/bin/bash
# lightning channel-both-reserves-avg   (FEAT-2600)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'both_reserves_avg_msat': 0}))
else:
    total = sum(int(c.get('our_reserve_msat', 0)) + int(c.get('their_reserve_msat', 0)) for c in channels)
    print(json.dumps({'both_reserves_avg_msat': total / len(channels)}))
" "$result"
