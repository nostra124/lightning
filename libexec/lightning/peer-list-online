#!/bin/bash
# lightning peer-list-online   (FEAT-960)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
online = [{'id': p.get('id')} for p in data.get('peers', []) if p.get('connected')]
print(json.dumps(online))
" "$result"
