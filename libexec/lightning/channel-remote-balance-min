#!/bin/bash
# lightning channel-remote-balance-min   (FEAT-2267)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel_id': None, 'remote_msat': None}))
    sys.exit(0)
ch = min(channels, key=lambda c: int(c.get('remote_msat', 0)))
print(json.dumps({'channel_id': ch.get('channel_id'), 'remote_msat': ch.get('remote_msat')}))
" "$result"
