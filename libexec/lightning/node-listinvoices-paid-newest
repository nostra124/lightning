#!/bin/bash
# lightning node-listinvoices-paid-newest   (FEAT-2449)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid']
if not paid:
    print(json.dumps({'label': None, 'paid_at': None}))
else:
    newest = max(paid, key=lambda i: i.get('paid_at', 0))
    print(json.dumps({'label': newest.get('label'), 'paid_at': newest.get('paid_at')}))
" "$result"
