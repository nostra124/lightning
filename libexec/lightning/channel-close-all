#!/bin/bash
# lightning channel-close-all [--force]   (FEAT-499)
force=0
[ "$1" = "--force" ] && force=1
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
if [ "$force" = "0" ]; then
    count=$(python3 -c "import sys,json; print(len(json.loads(sys.argv[1]).get('channels',[])))" "$result")
    echo '{"error":"refusing to close '"$count"' channels without --force"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
ids = [c.get('channel_id','') for c in channels if c.get('channel_id')]
print(json.dumps({'scheduled': len(ids), 'channel_ids': ids}, separators=(',', ':')))
" "$result"
