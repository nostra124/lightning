#!/bin/bash
# lightning node-graph-base-fee-median   (FEAT-1724)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = sorted([c.get('base_fee_millisatoshi', 0) for c in channels])
if not fees:
    print(json.dumps({'count': 0, 'median_base_fee_msat': None}))
    sys.exit(0)
n = len(fees)
median = fees[n//2] if n % 2 else (fees[n//2 - 1] + fees[n//2]) / 2
print(json.dumps({'count': n, 'median_base_fee_msat': median}))
" "$result"
