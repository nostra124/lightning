#!/bin/bash
# lightning wallet-seed-verify <wallet_name> <seed_hash>   (FEAT-474)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-seed-verify <wallet_name> <seed_hash>"}'
    exit 0
fi
wname="$1"; seed_hash="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
stored=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='seed_hash' LIMIT 1;" 2>/dev/null)
if [ "$stored" = "$seed_hash" ]; then
    echo '{"ok":true,"wallet":"'"$wname"'"}'
else
    echo '{"ok":false,"wallet":"'"$wname"'"}'
fi
