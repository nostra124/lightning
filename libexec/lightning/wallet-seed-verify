#!/bin/bash
# lightning wallet-seed-verify <wallet_name>   (FEAT-668)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-seed-verify <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
has_seed=$(sqlite3 "$db" "SELECT COUNT(*) FROM meta WHERE key='seed_hash'" 2>/dev/null) || has_seed=0
echo "{\"wallet\":\"$wname\",\"has_seed\":$([ "$has_seed" -gt 0 ] && echo true || echo false)}"
