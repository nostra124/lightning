#!/bin/bash
# lightning channel-feerate-spread   (FEAT-2205)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
feerates = []
for c in channels:
    fr = c.get('feerate', {})
    if isinstance(fr, dict):
        ppm = fr.get('ppm', None)
        if ppm is not None:
            feerates.append(ppm)
    else:
        try:
            feerates.append(int(fr))
        except Exception:
            pass
if not feerates:
    print(json.dumps({'error': 'no feerate data'}))
    sys.exit(0)
print(json.dumps({'min_feerate_ppm': min(feerates), 'max_feerate_ppm': max(feerates), 'spread_ppm': max(feerates) - min(feerates)}))
" "$result"
