#!/bin/bash
# lightning channel-local-htlc-value-total   (FEAT-2387)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_msat = 0
for ch in channels:
    for h in ch.get('htlcs', []):
        if h.get('direction') == 'out':
            amt = h.get('amount_msat', 0)
            if isinstance(amt, str) and amt.endswith('msat'):
                amt = int(amt[:-4])
            total_msat += int(amt)
print(json.dumps({'local_htlc_value_total_msat': total_msat}))
" "$result"
