#!/bin/bash
# lightning node-invoice-paid-count-stddev   (FEAT-2846)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
from datetime import datetime, timezone
from collections import defaultdict
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
daily = defaultdict(int)
for inv in invoices:
    if inv.get('status') == 'paid':
        ts = inv.get('paid_at', inv.get('expires_at', 0))
        day = datetime.fromtimestamp(ts, tz=timezone.utc).date().isoformat()
        daily[day] += 1
counts = list(daily.values())
n = len(counts)
if n < 2:
    print(json.dumps({'paid_count_stddev': None, 'n': n}))
    sys.exit(0)
mean = sum(counts) / n
var = sum((x - mean)**2 for x in counts) / (n - 1)
print(json.dumps({'paid_count_stddev': round(math.sqrt(var), 6), 'n': n}))
" "$result"
