#!/bin/bash
# lightning node-pay-fee-variance   (FEAT-2616)
result=$(lightning-cli listsendpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('payments', [])
fees = [p.get('amount_sent_msat', 0) - p.get('amount_msat', 0) for p in pays if p.get('amount_msat') and p.get('amount_sent_msat')]
if not fees:
    print(json.dumps({'fee_variance_msat': 0}))
else:
    mean = sum(fees) / len(fees)
    variance = sum((f - mean) ** 2 for f in fees) / len(fees)
    print(json.dumps({'fee_variance_msat': variance}))
" "$result"
