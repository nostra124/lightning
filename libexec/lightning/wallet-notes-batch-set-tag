#!/bin/bash
# lightning wallet-notes-batch-set-tag <tag> <key1> [key2...]   (FEAT-1858)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-batch-set-tag <tag> <key1> [key2...]"}'; exit 0; fi
tag="$1"
shift
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=0
for key in "$@"; do
    sqlite3 "$db" "UPDATE notes SET tag='$tag' WHERE key='$key';" 2>/dev/null
    count=$((count+1))
done
echo "{\"updated\":$count,\"tag\":\"$tag\"}"
