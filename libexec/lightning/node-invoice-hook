#!/bin/bash
# lightning node-invoice-hook <url>   (FEAT-585)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-invoice-hook <url>"}'
    exit 0
fi
url="$1"
conf_dir="${LIGHTNING_DIR:-$HOME/.lightning}"
hook_conf="$conf_dir/invoice-hook.conf"
echo "invoice-hook-url=$url" > "$hook_conf" 2>/dev/null || { echo '{"error":"cannot write hook config"}'; exit 0; }
echo "{\"ok\":true,\"hook_url\":\"$url\",\"config\":\"$hook_conf\"}"
