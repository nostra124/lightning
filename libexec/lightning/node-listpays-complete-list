#!/bin/bash
# lightning node-listpays-complete-list   (FEAT-2091)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [{'payment_hash': p.get('payment_hash'), 'amount_msat': p.get('amount_sent_msat'), 'destination': p.get('destination')} for p in pays if p.get('status') == 'complete']
print(json.dumps({'complete_pays': complete, 'count': len(complete)}))
" "$result"
