#!/bin/bash
# lightning channel-remote-balance-total   (FEAT-1842)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_remote = sum(c.get('total_msat', 0) - c.get('to_us_msat', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'remote_balance_msat': total_remote}))
" "$result"
