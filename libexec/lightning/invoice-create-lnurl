#!/bin/bash
# lightning invoice-create-lnurl <amount_msat> <label> [<description>]   (FEAT-437)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: invoice-create-lnurl <amount_msat> <label> [<description>]"}'
    exit 0
fi
amount_msat="$1"; label="$2"; desc="${3:-lnurl invoice}"
result=$(lightning-cli invoice "$amount_msat" "$label" "$desc" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, base64
data = json.loads(sys.argv[1])
bolt11 = data.get('bolt11', '')
if bolt11:
    lnurl = 'lnurl' + base64.b32encode(('lightning:' + bolt11).upper().encode()).decode().rstrip('=').lower()
    print(json.dumps({'bolt11': bolt11, 'lnurl': lnurl, 'label': data.get('label','')}, separators=(',', ':')))
else:
    print(json.dumps(data, separators=(',', ':')))
" "$result"
