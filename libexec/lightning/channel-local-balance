#!/bin/bash
# lightning channel-local-balance   (FEAT-413)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
normal = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
total_local = sum(c.get('to_us_msat', 0) for c in normal)
total_cap = sum(c.get('total_msat', 0) for c in normal)
print(json.dumps({'local_balance_msat': total_local, 'local_balance_sat': total_local // 1000,
    'total_capacity_msat': total_cap, 'active_channels': len(normal)}, separators=(',', ':')))
" "$result"
