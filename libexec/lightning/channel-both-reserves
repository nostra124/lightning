#!/bin/bash
# lightning channel-both-reserves   (FEAT-2070)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
reserves = []
for ch in channels:
    reserves.append({
        'channel_id': ch.get('channel_id', ''),
        'our_reserve_msat': ch.get('our_reserve_msat', 0),
        'their_reserve_msat': ch.get('their_reserve_msat', 0),
    })
print(json.dumps({'reserves': reserves}))
" "$result"
