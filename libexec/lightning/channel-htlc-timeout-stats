#!/bin/bash
# lightning channel-htlc-timeout-stats   (FEAT-2130)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
timeouts = []
for c in data.get('channels', []):
    for h in c.get('htlcs', []):
        expiry = h.get('expiry')
        if expiry is not None:
            timeouts.append(int(expiry))
if not timeouts:
    print(json.dumps({'min': None, 'max': None, 'avg': None, 'count': 0}))
else:
    print(json.dumps({'min': min(timeouts), 'max': max(timeouts), 'avg': sum(timeouts)//len(timeouts), 'count': len(timeouts)}))
" "$result"
