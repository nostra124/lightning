#!/bin/bash
# lightning node-pay-completed-today   (FEAT-2624)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
today_start = int(time.mktime(time.strptime(time.strftime('%Y-%m-%d'), '%Y-%m-%d')))
count = sum(1 for p in pays if p.get('completed_at', 0) >= today_start)
print(json.dumps({'completed_today': count}))
" "$result"
