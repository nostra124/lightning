#!/bin/bash
# lightning wallet-meta-list <wallet_name>   (FEAT-1213)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-meta-list <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "SELECT key, value FROM meta;" 2>/dev/null | python3 -c "
import sys, json
rows = {}
for line in sys.stdin:
    parts = line.rstrip('\n').split('|', 1)
    if len(parts) == 2:
        rows[parts[0]] = parts[1]
print(json.dumps({'wallet': sys.argv[1], 'meta': rows}))
" "$wname"
