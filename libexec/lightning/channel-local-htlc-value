#!/bin/bash
# lightning channel-local-htlc-value   (FEAT-2350)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    for h in ch.get('htlcs', []):
        if h.get('direction') == 'out':
            total += h.get('amount_msat', 0)
print(json.dumps({'local_htlc_value_msat': total}))
" "$result"
