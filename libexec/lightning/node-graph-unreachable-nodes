#!/bin/bash
# lightning node-graph-unreachable-nodes   (FEAT-1669)
result=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
no_addr = [n for n in nodes if not n.get('addresses')]
print(json.dumps({'total_nodes': len(nodes), 'no_address_count': len(no_addr)}))
" "$result"
