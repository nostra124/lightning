#!/bin/bash
# lightning node-route-hints <bolt11>   (FEAT-344)
set -e
[ $# -ge 1 ] || { echo '{"error":"usage: node-route-hints <bolt11>"}'; exit 0; }
bolt11="$1"
result=$(lightning-cli decodepay "$bolt11" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
hints = data.get('routes', [])
print(json.dumps({'route_hint_count': len(hints), 'hints': hints}, separators=(',', ':')))
" "$result"
