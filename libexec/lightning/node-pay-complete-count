#!/bin/bash
# lightning node-pay-complete-count   (FEAT-1231)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
print(json.dumps({'complete_count': len(complete), 'total': len(pays)}))
" "$result"
