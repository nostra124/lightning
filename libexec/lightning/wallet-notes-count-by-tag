#!/bin/bash
# lightning wallet-notes-count-by-tag <wallet>   (FEAT-1963)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-count-by-tag <wallet>"}'; exit 0; fi
wallet="$1"
db="$HOME/.lightning/wallets/$wallet/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet db not found"}'; exit 0; fi
result=$(sqlite3 "$db" "SELECT tag, COUNT(*) as cnt FROM notes GROUP BY tag ORDER BY cnt DESC" 2>/dev/null) || { echo '{"error":"wallet db not found"}'; exit 0; }
python3 -c "
import sys, json
wallet = sys.argv[1]
raw = sys.argv[2]
tags = []
for line in raw.strip().split('\n'):
    if not line: continue
    parts = line.split('|')
    if len(parts) == 2:
        tags.append({'tag': parts[0], 'count': int(parts[1])})
print(json.dumps({'wallet': wallet, 'tags': tags}))
" "$wallet" "$result"
