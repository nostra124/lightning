#!/bin/bash
# lightning wallet-notes-count-by-tag <wallet_name> <tag>   (FEAT-1323)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-count-by-tag <wallet_name> <tag>"}'; exit 0; fi
wname="$1"; tag="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, sqlite3, json
db = sys.argv[1]; tag = sys.argv[2]; wname = sys.argv[3]
conn = sqlite3.connect(db)
row = conn.execute('SELECT COUNT(*) FROM notes WHERE tags LIKE ?', ('%'+tag+'%',)).fetchone()
conn.close()
print(json.dumps({'wallet': wname, 'tag': tag, 'count': row[0]}))
" "$db" "$tag" "$wname" 2>/dev/null || echo '{"error":"db_error"}'
