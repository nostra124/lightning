#!/bin/bash
# lightning node-pay-success-rate   (FEAT-1919)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = sum(1 for p in pays if p.get('status') == 'complete')
failed = sum(1 for p in pays if p.get('status') == 'failed')
pending = sum(1 for p in pays if p.get('status') not in ('complete', 'failed'))
total = len(pays)
rate = round(complete / total * 100, 2) if total > 0 else None
print(json.dumps({'total': total, 'complete': complete, 'failed': failed, 'pending': pending, 'success_rate_pct': rate}))
" "$result"
