#!/bin/bash
# lightning daemon — lightningd lifecycle management.
#
# Implements FEAT-183. Subcommands:
#   start    — bring up lightningd
#   stop     — graceful shutdown via `lightning-cli stop`
#   restart  — stop + start
#   status   — health check (process / RPC / sync / unlock)
#   logs     — tail the live log
#   install  — generate a systemd unit
#              --system: three-user layout (FEAT-183), runs as
#              dedicated `clightning` user.

set -e

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
NETWORK_DIR="$LIGHTNING_DIR/$LIGHTNING_NETWORK"
RPC_FILE="$NETWORK_DIR/lightning-rpc"

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

usage() {
	cat >&2 <<EOF
usage: lightning daemon <subcommand> [args]

   Lifecycle of the underlying clightningd process. Supports
   user-mode (systemctl --user) and system-mode (FEAT-183
   three-user layout: dedicated \`clightning\` user owns the
   daemon, the operator owns the wallet repo, www-data runs the
   CGI). Each sub-command also accepts --help.

subcommands:
   start                  start lightningd (foreground or systemd)
   stop                   graceful shutdown
   restart                stop + start
   status                 health check
   logs [-f]              tail the daemon log
   install [--system] [--migrate]
                          generate a systemd unit (user-mode by
                          default; --system uses the three-user
                          layout under user \`clightning\`)
EOF
}

daemon_running() {
	command -v lightning-cli >/dev/null 2>&1 && cli getinfo >/dev/null 2>&1
}

system_mode() {
	systemctl --quiet is-enabled clightningd.service 2>/dev/null
}

cmd_start() {
	if daemon_running; then
		error "daemon already running"
		exit 0
	fi
	if system_mode; then
		info "starting systemd unit clightningd.service"
		sudo systemctl start clightningd.service
	else
		command -v lightningd >/dev/null || {
			error "lightningd not found — install Core Lightning"
			exit 127
		}
		mkdir -p "$LIGHTNING_DIR"
		info "starting lightningd (user-mode, --daemon)"
		lightningd --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" --daemon
	fi

	# Auto-unlock hook (FEAT-184).
	if [ -x "$SELF_LIBEXEC/lightning/wallet" ] && command -v secret >/dev/null 2>&1; then
		# Wait briefly for the daemon to start asking for a password.
		for _ in 1 2 3 4 5; do
			if cli getinfo >/dev/null 2>&1; then
				return 0
			fi
			# clightning needs the password if the HSM is encrypted;
			# `wallet unlock --stored` is a no-op when not encrypted.
			"$SELF_LIBEXEC/lightning/wallet" unlock --stored 2>/dev/null && return 0 || true
			sleep 1
		done
	fi
}

cmd_stop() {
	if ! daemon_running; then
		error "daemon not running"
		exit 0
	fi
	if system_mode; then
		sudo systemctl stop clightningd.service
	else
		cli stop >/dev/null
	fi
	info "daemon stopped"
}

cmd_restart() {
	cmd_stop || true
	# Give the socket time to disappear.
	for _ in 1 2 3 4 5; do
		[ ! -S "$RPC_FILE" ] && break
		sleep 1
	done
	cmd_start
}

cmd_status() {
	local rc=0
	if daemon_running; then
		local info; info=$(cli getinfo)
		local block; block=$(jq -r .blockheight <<<"$info")
		local warning; warning=$(jq -r '.warning_lightningd_sync // .warning_bitcoind_sync // empty' <<<"$info")
		local mode="user"; system_mode && mode="system"
		if [ -n "$warning" ]; then
			echo "syncing ($mode-mode, block $block): $warning"
			rc=1
		else
			echo "healthy ($mode-mode, block $block)"
		fi
	else
		echo "down"
		rc=2
	fi
	exit $rc
}

cmd_logs() {
	if system_mode; then
		exec journalctl -u clightningd.service "$@"
	fi
	local logfile="$LIGHTNING_DIR/log"
	[ -f "$logfile" ] || logfile="$NETWORK_DIR/log"
	[ -f "$logfile" ] || {
		warn "no log file at $LIGHTNING_DIR/log or $NETWORK_DIR/log"
		error "configure log-file=log in lightningd.conf to enable"
		exit 2
	}
	exec tail "$@" "$logfile"
}

cmd_install() {
	local system=0 migrate=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--system)  system=1; shift ;;
			--migrate) migrate=1; shift ;;
			*) error "daemon install: unknown flag $1"; exit 1 ;;
		esac
	done

	if [ $system -eq 1 ]; then
		install_system "$migrate"
	else
		install_user
	fi
}

install_user() {
	local dir="$HOME/.config/systemd/user"
	local unit="$dir/lightning.service"
	mkdir -p "$dir"
	cat > "$unit" <<EOF
[Unit]
Description=Lightning Network daemon (clightning, user-mode)
After=network.target

[Service]
Type=forking
ExecStart=$(command -v lightningd) --lightning-dir=$LIGHTNING_DIR --network=$LIGHTNING_NETWORK --daemon
ExecStop=$(command -v lightning-cli) --lightning-dir=$LIGHTNING_DIR --network=$LIGHTNING_NETWORK stop
PIDFile=$LIGHTNING_DIR/lightningd-${LIGHTNING_NETWORK}.pid
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
EOF
	systemctl --user daemon-reload 2>/dev/null || true
	info "wrote $unit"
	info "enable with: systemctl --user enable --now lightning"
	info "to survive logout: loginctl enable-linger $USER"
}

install_system() {
	local migrate=$1

	if [ $migrate -eq 0 ] && [ -d "$HOME/.lightning" ] && [ ! -L "$HOME/.lightning" ]; then
		warn "~/.lightning exists (user-mode install detected); refusing"
		error "pass --migrate to move it to /var/lib/clightning"
		exit 3
	fi

	command -v sudo >/dev/null || { error "sudo required for --system"; exit 127; }

	# 1. Create the clightning system user (idempotent).
	if ! getent passwd clightning >/dev/null; then
		sudo useradd --system --home /var/lib/clightning \
			--shell /usr/sbin/nologin --user-group clightning
	fi

	# 2. State dir.
	sudo install -d -o clightning -g clightning -m 0750 /var/lib/clightning

	# 3. Add the operator to the clightning group.
	sudo usermod -a -G clightning "$USER"

	# 4. clightning's config — rpc-file-mode=0660 so the group can read it.
	local cfg=/var/lib/clightning/config
	sudo tee "$cfg" >/dev/null <<EOF
network=$LIGHTNING_NETWORK
log-file=/var/lib/clightning/log
rpc-file-mode=0660
EOF
	sudo chown clightning:clightning "$cfg"

	# 5. Systemd unit.
	local unit=/etc/systemd/system/clightningd.service
	sudo tee "$unit" >/dev/null <<EOF
[Unit]
Description=Lightning Network daemon (clightning, system-mode)
After=network.target

[Service]
Type=simple
User=clightning
Group=clightning
ExecStart=$(command -v lightningd) --lightning-dir=/var/lib/clightning --conf=$cfg
Restart=on-failure
RestartSec=5
ProtectSystem=full
ProtectHome=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
	sudo systemctl daemon-reload

	info "installed system-mode at /var/lib/clightning"
	info "user 'clightning' created; '$USER' added to group 'clightning'"
	info "enable with: sudo systemctl enable --now clightningd"
	info "log out and back in for group membership to take effect"
}

SELF_LIBEXEC="${SELF_LIBEXEC:-$(cd "$(dirname "$0")/.." && pwd)}"

subhelp() {
	case "$1" in
		start)
			cat <<'EOF'
usage: lightning daemon start

Bring up lightningd. If a systemd unit `clightningd.service` is
enabled, starts it; otherwise launches `lightningd --daemon` in
user-mode under $LIGHTNING_DIR. Triggers auto-unlock (FEAT-184)
when the `secret` package is installed.
EOF
			;;
		stop)
			cat <<'EOF'
usage: lightning daemon stop

Graceful shutdown via `lightning-cli stop` (or systemctl stop
clightningd in system-mode). No-op if the daemon isn't running.
EOF
			;;
		restart)
			cat <<'EOF'
usage: lightning daemon restart

`stop` then `start`, waiting up to 5s for the RPC socket to
disappear in between. Re-triggers auto-unlock on the way up.
EOF
			;;
		status)
			cat <<'EOF'
usage: lightning daemon status

Health check. Exits 0 (healthy), 1 (syncing), or 2 (down).
Output names the mode (user|system) and current blockheight, plus
any warning_lightningd_sync / warning_bitcoind_sync from getinfo.
EOF
			;;
		logs)
			cat <<'EOF'
usage: lightning daemon logs [tail-flags...]

Tail the daemon log. In system-mode reads `journalctl -u
clightningd.service` (forwards extra flags); in user-mode tails
$LIGHTNING_DIR/log or $LIGHTNING_DIR/$LIGHTNING_NETWORK/log.
Add -f to follow.
EOF
			;;
		install)
			cat <<'EOF'
usage: lightning daemon install [--system] [--migrate]

Write a systemd unit for the daemon. Default is user-mode at
~/.config/systemd/user/lightning.service. --system writes a
system-mode unit at /etc/systemd/system/clightningd.service,
creates the `clightning` system user, and adds you to its group
(FEAT-183 three-user layout). --migrate moves an existing
~/.lightning into /var/lib/clightning.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="${1:-}"
[ -n "$SUB" ] && shift
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac

case "$SUB" in
	start)   cmd_start "$@" ;;
	stop)    cmd_stop "$@" ;;
	restart) cmd_restart "$@" ;;
	status)  cmd_status "$@" ;;
	logs)    cmd_logs "$@" ;;
	install) cmd_install "$@" ;;
	help)    subhelp "${1:-}" || usage; exit ;;
	"")      usage; exit 1 ;;
	*)       warn "daemon: unknown subcommand '$SUB'"; usage; exit 1 ;;
esac
