install_system() {
	local migrate=$1

	if [ $migrate -eq 0 ] && [ -d "$HOME/.lightning" ] && [ ! -L "$HOME/.lightning" ]; then
		warn "\$HOME/.lightning exists (user-mode install detected); refusing"
		error "pass --migrate to move it to /var/lib/clightning"
		exit 3
	fi

	command -v sudo >/dev/null || { error "sudo required for --system"; exit 127; }

	# 1. Create the clightning system user (idempotent).
	if ! getent passwd clightning >/dev/null; then
		sudo useradd --system --home /var/lib/clightning \
			--shell /usr/sbin/nologin --user-group clightning
	fi

	# 2. State dir.
	sudo install -d -o clightning -g clightning -m 0750 /var/lib/clightning

	# 3. Add the operator to the clightning group.
	sudo usermod -a -G clightning "$USER"

	# 4. clightning's config — rpc-file-mode=0660 so the group can read it.
	local cfg=/var/lib/clightning/config
	sudo tee "$cfg" >/dev/null <<EOF
network=$LIGHTNING_NETWORK
log-file=/var/lib/clightning/log
rpc-file-mode=0660
EOF
	sudo chown clightning:clightning "$cfg"

	# 5. Systemd unit.
	local unit=/etc/systemd/system/clightningd.service
	sudo tee "$unit" >/dev/null <<EOF
[Unit]
Description=Lightning Network daemon (clightning, system-mode)
After=network.target

[Service]
Type=simple
User=clightning
Group=clightning
ExecStart=$(command -v lightningd) --lightning-dir=/var/lib/clightning --conf=$cfg
Restart=on-failure
RestartSec=30
StartLimitIntervalSec=300
StartLimitBurst=3
ProtectSystem=full
ProtectHome=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
	sudo systemctl daemon-reload

	info "installed system-mode at /var/lib/clightning"
	info "user 'clightning' created; '$USER' added to group 'clightning'"
	info "next:"
	info "    sudo systemctl enable clightningd"
	info "    lightning daemon start         # routes through systemctl"
	info "    lightning daemon status"
	info "log out and back in for your group membership to take effect"
}

# ---------------------------------------------------------------------------
# FEAT-207 — install-core (Core Lightning binary installer)
#
# Currently a scaffold: parses flags, computes the planned action, prints
# what it would do, and exits.  The contract and implementation plan live
# in issues/feature/207-clightning-install.md.
# ---------------------------------------------------------------------------

# Returns: darwin / ubuntu / alpine / unknown
platform_id() {
	if is_macos; then echo darwin; return; fi
	local os_release="${LIGHTNING_OS_RELEASE:-/etc/os-release}"
	if [ -r "$os_release" ]; then
		# shellcheck disable=SC1090,SC1091
		. "$os_release"
		case "${ID:-}" in
			ubuntu|debian) echo ubuntu; return ;;
			alpine)        echo alpine; return ;;
		esac
		case "${ID_LIKE:-}" in
			*debian*) echo ubuntu; return ;;
		esac
	fi
	echo unknown
}

# Returns: systemd / launchd / openrc / none
init_system() {
	if is_macos; then echo launchd; return; fi
	if command -v openrc >/dev/null 2>&1 || [ -d /etc/init.d ] && [ "$(platform_id)" = "alpine" ]; then
		echo openrc; return
	fi
	if command -v systemctl >/dev/null 2>&1; then
		echo systemd; return
	fi
	echo none
}

# Returns: rpk / brew / apk / source / podman / none
preferred_backend() {
	command -v rpk    >/dev/null 2>&1 && { echo rpk;    return; }
	if is_macos && command -v brew >/dev/null 2>&1; then
		echo brew; return
	fi
	if [ "$(platform_id)" = "alpine" ] && command -v apk >/dev/null 2>&1; then
		echo apk; return
	fi
	command -v podman >/dev/null 2>&1 && { echo podman; return; }
	if [ "$(platform_id)" = "ubuntu" ]; then
		echo source; return
	fi
	echo none
}

cmd_install_core() {
	local backend="" version="" system=0 yes=0 dry_run=0 force=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--rpk|--brew|--apk|--source|--podman)
				[ -n "$backend" ] && { error "install-core: pick one backend flag, got '$backend' and '$1'"; exit 1; }
				backend="${1#--}"; shift ;;
			--version) version="$2"; shift 2 ;;
			--system)  system=1; shift ;;
			--yes)     yes=1; shift ;;
			--dry-run) dry_run=1; shift ;;
			--force)   force=1; shift ;;
			--help|-h) subhelp install-core; exit 0 ;;
			--docker)
				error "install-core: docker is not supported — use --podman (FEAT-207 §non-goals)"
				info  "  install podman:  https://podman.io/docs/installation"
				exit 1 ;;
			*) error "install-core: unknown flag '$1'"; exit 1 ;;
		esac
	done

	[ -n "$backend" ] || backend=$(preferred_backend)

	if [ "$backend" = "none" ]; then
		error "install-core: cannot auto-detect a backend for platform '$(platform_id)'"
		info  "  pass one of: --rpk --brew --apk --source --podman"
		info  "  see: issues/feature/207-clightning-install.md"
		exit 2
	fi

	# Idempotency — refuse to overwrite an existing install without --force.
	if [ $force -eq 0 ] && [ $dry_run -eq 0 ] && command -v lightningd >/dev/null 2>&1; then
		local existing
		existing=$(lightningd --version 2>/dev/null | head -1)
		error "install-core: lightningd is already on PATH${existing:+ ($existing)}"
		echo "  pass --force to reinstall, or:"                            >&2
		echo "    lightning daemon install         # write the service unit" >&2
		echo "    lightning daemon status          # check the running daemon" >&2
		exit 1
	fi

	# Plan summary (printed in all modes so operators can confirm what's about to happen).
	echo "backend:    $backend"
	echo "platform:   $(platform_id)"
	echo "init:       $(init_system)"
	echo "version:    ${version:-latest}"
	echo "scope:      $([ $system -eq 1 ] && echo system || echo user)"
	echo "confirm:    $([ $yes -eq 1 ] && echo skip || echo prompt)"
	echo "mode:       $([ $dry_run -eq 1 ] && echo dry-run || echo planned)"

	case "$backend" in
		rpk)    ic_run_rpk    "$version" "$dry_run" "$yes" "$force" ;;
		brew)   ic_run_brew   "$version" "$dry_run" "$yes" "$force" ;;
		apk)    ic_run_apk    "$version" "$dry_run" "$yes" "$force" ;;
		source) ic_run_source "$version" "$dry_run" "$yes" "$force" ;;
		podman) ic_run_stub   podman "podman pull elementsproject/lightningd${version:+:$version} + run + cli shim" "$dry_run" ;;
	esac
}

# Picks the privilege-escalation prefix for backends that need root
# (apk, apt-get).  doas is preferred on Alpine; sudo elsewhere.  When
# already root or neither is available, returns the empty string —
# the package manager then either succeeds (root) or fails loudly with
# its own permissions error (no escalation tool installed).
ic_root_prefix() {
	[ "$(id -u 2>/dev/null)" = "0" ] && { echo ""; return; }
	command -v doas >/dev/null 2>&1 && { echo "doas"; return; }
	command -v sudo >/dev/null 2>&1 && { echo "sudo"; return; }
	echo ""
}

# rpk path — assumes a sister `lightningd` rpk package.  Surfaces rpk's
# own exit code on failure; callers see "package not found" or whatever
# rpk reports.  Acceptance criterion #9 (FEAT-207).
ic_run_rpk() {
	local version="$1" dry_run="$2" yes="$3" force="$4"
	local cmd=(rpk install lightningd)
	[ -n "$version" ] && cmd+=(--version "$version")
	[ "$yes"   = "1" ] && cmd+=(--yes)
	[ "$force" = "1" ] && cmd+=(--force)
	echo "plan:       ${cmd[*]}"
	if [ "$dry_run" = "1" ]; then return 0; fi
	if ! command -v rpk >/dev/null 2>&1; then
		error "install-core --rpk: rpk not on PATH"
		echo "  install rpk first, or use a different backend:"                   >&2
		echo "    --brew (macOS) --apk (Alpine) --source (Ubuntu) --podman (any)" >&2
		exit 1
	fi
	"${cmd[@]}" || {
		local rc=$?
		error "install-core --rpk: rpk install failed (exit $rc)"
		echo "  if the lightningd rpk package isn't published yet, try:"          >&2
		echo "    --brew (macOS) --apk (Alpine) --source (Ubuntu) --podman (any)" >&2
		exit "$rc"
	}
	ic_verify_lightningd
}

# Homebrew path — macOS only.  brew handles version pinning via the
# `core-lightning@<version>` formula naming convention.
ic_run_brew() {
	local version="$1" dry_run="$2" yes="$3" force="$4"
	local pkg="core-lightning"
	[ -n "$version" ] && pkg="core-lightning@$version"
	local cmd=(brew install "$pkg")
	[ "$force" = "1" ] && cmd=(brew reinstall "$pkg")
	echo "plan:       ${cmd[*]}"
	if [ "$dry_run" = "1" ]; then return 0; fi
	if ! is_macos; then
		error "install-core --brew: Homebrew is macOS-only"
		echo "  on this platform use: --apk (Alpine) --source (Ubuntu) --podman (any)" >&2
		exit 1
	fi
	if ! command -v brew >/dev/null 2>&1; then
		error "install-core --brew: brew not on PATH"
		echo "  install Homebrew first: https://brew.sh"                              >&2
		echo "  (install-core does not auto-install brew — see FEAT-207 §non-goals)"  >&2
		exit 1
	fi
	"${cmd[@]}" || {
		local rc=$?
		error "install-core --brew: brew install failed (exit $rc)"
		exit "$rc"
	}
	ic_verify_lightningd
}

# Alpine path — `apk add lightningd[=version]`.  Picks doas/sudo as
# the privilege prefix; on a non-Alpine system, refuses with a hint
# pointing at the other backends.  Version pinning uses apk's `=`
# syntax (matches the spec table in FEAT-207).
ic_run_apk() {
	local version="$1" dry_run="$2" yes="$3" force="$4"
	local pkg="lightningd"
	[ -n "$version" ] && pkg="lightningd=$version"
	local cmd=()
	local prefix
	prefix=$(ic_root_prefix)
	[ -n "$prefix" ] && cmd+=("$prefix")
	cmd+=(apk add)
	# `--force-overwrite` is apk's closest analogue to brew reinstall —
	# overwrites files claimed by other packages.  Operators who want a
	# clean reinstall can `apk del lightningd && lightning daemon install-core --apk`.
	[ "$force" = "1" ] && cmd+=(--force-overwrite)
	cmd+=("$pkg")
	echo "plan:       ${cmd[*]}"
	if [ "$dry_run" = "1" ]; then return 0; fi
	if [ "$(platform_id)" != "alpine" ]; then
		error "install-core --apk: this is not an Alpine system (platform: $(platform_id))"
		echo "  on this platform use: --brew (macOS) --source (Ubuntu) --podman (any)" >&2
		exit 1
	fi
	if ! command -v apk >/dev/null 2>&1; then
		error "install-core --apk: apk not on PATH"
		echo "  apk is Alpine's package manager — it should be installed by default" >&2
		exit 1
	fi
	"${cmd[@]}" || {
		local rc=$?
		error "install-core --apk: apk add failed (exit $rc)"
		exit "$rc"
	}
	ic_verify_lightningd
}

# Source-build path — for Ubuntu / Debian, which has no upstream
# Core Lightning apt package.  Multi-step: apt-get build-deps,
# git clone, ./configure && make, sudo make install.  Each step
# propagates the underlying tool's exit code on failure.
#
# Build deps list mirrors Core Lightning's official install docs
# (https://docs.corelightning.org/docs/installation, Ubuntu section).
# Keep in sync if upstream updates them.
ic_source_build_deps() {
	echo "autoconf automake build-essential git libtool libsqlite3-dev"
	echo "libpq-dev python3 python3-pip net-tools zlib1g-dev libsodium-dev"
	echo "gettext valgrind libpython3-dev"
}

ic_run_source() {
	local version="$1" dry_run="$2" yes="$3" force="$4"
	local repo="https://github.com/ElementsProject/lightning.git"
	local builddir="${LIGHTNING_BUILD_DIR:-$HOME/.cache/lightning/build}"

	local prefix
	prefix=$(ic_root_prefix)

	echo "plan:       apt-get install build-deps + git clone + ./configure && make + sudo make install"
	echo "build-dir:  $builddir"
	if [ "$dry_run" = "1" ]; then return 0; fi

	if [ "$(platform_id)" != "ubuntu" ]; then
		error "install-core --source: this isn't an Ubuntu/Debian system (platform: $(platform_id))"
		echo "  --source is wired for apt-get build-deps; on this platform try:"   >&2
		echo "    --brew (macOS) --apk (Alpine) --podman (any) --rpk (anywhere)"    >&2
		exit 1
	fi
	for tool in apt-get git make; do
		if ! command -v "$tool" >/dev/null 2>&1; then
			error "install-core --source: $tool not on PATH"
			echo "  --source needs apt-get, git, and make to be installed" >&2
			exit 1
		fi
	done

	# Acceptance criterion #5 — print the deps list and prompt.  --yes
	# skips the prompt for unattended use.  Refuse when there's no TTY
	# unless --yes is set, so we never block a CI pipeline mid-stream.
	echo ""
	echo "About to install Ubuntu build-deps via apt-get:"
	ic_source_build_deps | sed 's/^/  /'
	if [ "$yes" != "1" ]; then
		if [ ! -t 0 ]; then
			error "install-core --source: stdin is not a TTY; pass --yes to install build-deps non-interactively"
			exit 1
		fi
		printf "Continue? [y/N] "
		local ans
		read -r ans
		case "$ans" in
			y|Y|yes|YES) ;;
			*) error "install-core --source: declined by operator"; exit 1 ;;
		esac
	fi

	# Build-dep install.  apt-get needs root.
	# shellcheck disable=SC2046
	${prefix:+$prefix} apt-get install -y $(ic_source_build_deps | tr '\n' ' ') || {
		local rc=$?
		error "install-core --source: apt-get install failed (exit $rc)"
		exit "$rc"
	}

	# Clone (or fetch if already cloned — supports --force re-runs).
	mkdir -p "$builddir" || exit 1
	if [ -d "$builddir/lightning/.git" ]; then
		echo "lightning repo already cloned, fetching..."
		( cd "$builddir/lightning" && git fetch --tags ) || {
			error "install-core --source: git fetch failed"
			exit 1
		}
	else
		git clone "$repo" "$builddir/lightning" || {
			error "install-core --source: git clone failed"
			exit 1
		}
	fi
	if [ -n "$version" ]; then
		( cd "$builddir/lightning" && git checkout "$version" ) || {
			error "install-core --source: git checkout '$version' failed"
			exit 1
		}
	fi

	# Build.
	( cd "$builddir/lightning" && ./configure && make ) || {
		local rc=$?
		error "install-core --source: build failed (exit $rc)"
		echo "  build dir left at $builddir/lightning for inspection" >&2
		exit "$rc"
	}

	# Install — needs root.
	# shellcheck disable=SC2086
	( cd "$builddir/lightning" && ${prefix:+$prefix} make install ) || {
		local rc=$?
		error "install-core --source: make install failed (exit $rc)"
		exit "$rc"
	}

	ic_verify_lightningd
}

# Scaffold body — backends not yet implemented.  Prints the planned
# command and (outside --dry-run) the scaffold notice.
ic_run_stub() {
	local backend="$1" plan="$2" dry_run="$3"
	echo "plan:       $plan"
	if [ "$dry_run" = "1" ]; then return 0; fi
	echo "note: --$backend is a scaffold today — see FEAT-207 for implementation status" >&2
	echo "      (re-run with --dry-run to suppress this notice)"                          >&2
}

# Post-install sanity check.  The spec says `lightningd --version` must
# succeed after install-core exits 0 — we verify it directly.
ic_verify_lightningd() {
	if ! command -v lightningd >/dev/null 2>&1; then
		error "install-core: install reported success but lightningd is not on PATH"
		echo "  check the package manager's output above; the install may be partial" >&2
		exit 1
	fi
	local ver
	ver=$(lightningd --version 2>/dev/null | head -1)
	echo "✓ lightningd installed${ver:+: $ver}"
	echo "  next: lightning daemon install     # write the service unit"
}

SELF_LIBEXEC="${SELF_LIBEXEC:-$(cd "$(dirname "$0")/.." && pwd)}"

subhelp() {
	case "$1" in
		start)
			cat <<'EOF'
usage: lightning daemon start

Bring up lightningd in the background. Routes through the installed
supervisor (detected by file presence):
   1. launchd       — ~/Library/LaunchAgents/<label>.plist or
                      /Library/LaunchDaemons/<label>.plist
                      => `launchctl load -w` (or `kickstart` if loaded)
   2. systemd-system — clightningd.service enabled
                      => `sudo systemctl start clightningd.service`
   3. systemd-user   — ~/.config/systemd/user/lightning.service
                      => `systemctl --user start lightning`
   4. direct         — no service unit installed
                      => `lightningd --daemon`, output -> log file
Triggers auto-unlock (FEAT-184) when the `secret` package is installed.
EOF
			;;
		run)
			cat <<'EOF'
usage: lightning daemon run

Bring up lightningd in the FOREGROUND — exec the binary without
--daemon, so logs stream to stdout/stderr and exit propagates to
the caller. This is the entry point invoked by launchd and by
systemd units with Type=simple. Refuses if the daemon is already
running.
EOF
			;;
		stop)
			cat <<'EOF'
usage: lightning daemon stop

Graceful shutdown. Same detection order as `start`:
   launchd       => `launchctl unload <plist>` (KeepAlive would
                    fight a plain stop; unload removes the job
                    until the next `daemon start`)
   systemd-system => `sudo systemctl stop clightningd.service`
   systemd-user   => `systemctl --user stop lightning`
   direct         => `lightning-cli stop`
No-op if the daemon isn't running.
EOF
			;;
		restart)
			cat <<'EOF'
usage: lightning daemon restart

`stop` then `start`, waiting up to 5s for the RPC socket to
disappear in between. Re-triggers auto-unlock on the way up.
EOF
			;;
		status)
			cat <<'EOF'
usage: lightning daemon status

Health check. Exits 0 (healthy), 1 (syncing), or 2 (down).
Output names the mode (user|system) and current blockheight, plus
any warning_lightningd_sync / warning_bitcoind_sync from getinfo.
EOF
			;;
		logs)
			cat <<'EOF'
usage: lightning daemon logs [tail-flags...]

Tail the daemon log. In system-mode reads `journalctl -u
clightningd.service` (forwards extra flags); in user-mode tails
$LIGHTNING_DIR/log or $LIGHTNING_DIR/$LIGHTNING_NETWORK/log.
Add -f to follow.
EOF
			;;
		install)
			cat <<EOF
usage: lightning daemon install [--system] [--migrate]
                                [--trustedcoin | --bitcoind]
                                [--no-keepalive] [--no-alert]

Write a service unit for the daemon. Platform-aware:

Default (user-mode) — runs as the current user, no sudo needed:
   macOS  ~/Library/LaunchAgents/network.lightning.lightningd.plist
          (LaunchAgent calling \`lightning daemon run\` so launchd
          supervises lightningd).
   Linux  ~/.config/systemd/user/lightning.service.

--system — runs the daemon as a dedicated unprivileged service
user, with the operator added to its group so they can reach the
RPC socket. Requires sudo for the install step only — the
daemon never runs as root.
   macOS  /Library/LaunchDaemons/network.lightning.lightningd.plist
          UserName=_clightning, state at /usr/local/var/clightning.
   Linux  /etc/systemd/system/clightningd.service
          User=clightning, state at /var/lib/clightning
          (FEAT-183 three-user layout).

--migrate moves an existing ~/.lightning into the system state dir.

Backend selection (writes a managed block to \$LIGHTNING_DIR/config):
--trustedcoin    swap bcli for the trustedcoin plugin, which
                 fetches chain data from multiple public block
                 explorers (blockstream.info, mempool.space, ...)
                 with automatic fallback. Removes the need for a
                 local bitcoind, at the cost of trusting the
                 explorers jointly. The command auto-installs the
                 plugin binary (prebuilt for Linux/BSD, builds via
                 'go install' on macOS).
--bitcoind       strip any managed backend block, fall back to
                 bitcoind/bcli (the CLN default).
Omit both to leave existing backend config untouched.

Sidecars (user-mode only, default ON):
--no-keepalive   skip the FEAT-199 keepalive sidecar.
                 Runs \`peer keepalive\` every 10min + on every
                 network state change (macOS), or via systemd
                 .timer (Linux). Reseeds the gossip graph after
                 laptop sleep / wifi blips.
--no-alert       skip the FEAT-204 alert sidecar.
                 Runs \`alert run\` every 60s. Evaluates rules
                 under \$LIGHTNING_DIR/alerts/ and fires
                 webhooks when conditions trip.
EOF
			;;
		install-core)
			cat <<EOF
usage: lightning daemon install-core
           [--rpk|--brew|--apk|--source|--podman]
           [--version <tag>] [--system] [--yes]
           [--force] [--dry-run]

Install Core Lightning itself — the lightningd binary.  With no
backend flag, the verb auto-detects per platform:

   1. \`rpk\`     when an \`lightningd\` rpk package is on PATH
   2. \`brew\`    on macOS with Homebrew
   3. \`apk\`     on Alpine
   4. \`podman\`  cross-platform fallback (rootless container)
   5. \`source\`  Ubuntu / Debian (no upstream apt package)

Refuses to overwrite an existing \`lightningd\` on PATH unless
\`--force\` is passed.

\`docker\` is not supported — pass \`--podman\` instead.
\`lnd\` and other backends are out of scope (single backend by design).

Status (FEAT-207):
  --rpk    implemented (assumes sister lightningd rpk package)
  --brew   implemented (macOS)
  --apk    implemented (Alpine — uses doas/sudo if not root)
  --source implemented (Ubuntu — apt-get build-deps + make install)
           build dir defaults to ~/.cache/lightning/build, override
           with \$LIGHTNING_BUILD_DIR; requires --yes without a TTY
  --podman scaffold — prints plan

After install-core exits 0, \`lightningd --version\` succeeds.
The follow-up call is \`lightning daemon install\` to write the
service unit (systemd / launchd).  The two verbs compose; neither
calls the other.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="${1:-}"
[ -n "$SUB" ] && shift
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac

case "$SUB" in
	start)        cmd_start "$@" ;;
	run)          cmd_run "$@" ;;
	stop)         cmd_stop "$@" ;;
	restart)      cmd_restart "$@" ;;
	status)       cmd_status "$@" ;;
	logs)         cmd_logs "$@" ;;
	install)      cmd_install "$@" ;;
	install-core) cmd_install_core "$@" ;;
	help)         subhelp "${1:-}" || usage; exit ;;
	"")           usage; exit 1 ;;
	*)            error "daemon: unknown subcommand '$SUB'"; usage; exit 1 ;;
esac
