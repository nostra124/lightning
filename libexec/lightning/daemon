#!/bin/bash
# lightning daemon — lightningd lifecycle management.
#
# Implements FEAT-183. Subcommands:
#   start    — bring up lightningd (background; --daemon or via supervisor)
#   run      — bring up lightningd in foreground (for launchd/systemd Type=simple)
#   stop     — graceful shutdown via `lightning-cli stop`
#   restart  — stop + start
#   status   — health check (process / RPC / sync / unlock)
#   logs     — tail the live log
#   install  — generate a service unit
#              Linux: systemd (~/.config/systemd/user/lightning.service)
#                     or system-mode (/etc/systemd/system/clightningd.service)
#              macOS: launchd (~/Library/LaunchAgents/<label>.plist)

set -e

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
NETWORK_DIR="$LIGHTNING_DIR/$LIGHTNING_NETWORK"
RPC_FILE="$NETWORK_DIR/lightning-rpc"
LAUNCHD_LABEL="network.lightning.lightningd"

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

is_macos() { [ "$(uname -s)" = "Darwin" ]; }

launchd_plist() {
	# Per-user LaunchAgent first; fall back to the system path if a
	# LaunchDaemon plist exists (running as the operator usually
	# means the per-user one; --system install writes the other).
	local user_plist="$HOME/Library/LaunchAgents/${LAUNCHD_LABEL}.plist"
	local sys_plist="/Library/LaunchDaemons/${LAUNCHD_LABEL}.plist"
	if [ -f "$user_plist" ]; then
		echo "$user_plist"
	elif [ -f "$sys_plist" ]; then
		echo "$sys_plist"
	elif [ "$EUID" -eq 0 ]; then
		echo "$sys_plist"
	else
		echo "$user_plist"
	fi
}

# A plist is *installed* (file on disk).
launchd_installed() {
	is_macos && [ -f "$(launchd_plist)" ]
}

# A plist is *loaded* into launchd (live job).
launchd_loaded() {
	is_macos && command -v launchctl >/dev/null 2>&1 && \
		launchctl list "$LAUNCHD_LABEL" >/dev/null 2>&1
}

# Linux systemd --user unit installed for this account.
systemd_user_installed() {
	[ -f "$HOME/.config/systemd/user/lightning.service" ]
}

# Linux systemd system unit enabled.
system_mode() {
	command -v systemctl >/dev/null 2>&1 && \
		systemctl --quiet is-enabled clightningd.service 2>/dev/null
}

usage() {
	cat >&2 <<EOF
usage: lightning daemon <subcommand> [args]

   Lifecycle of the underlying clightningd process. Detects the
   right supervisor for the platform:
     • macOS — launchd (~/Library/LaunchAgents/...)
     • Linux — systemd --user, or system-mode (FEAT-183 three-user
       layout: dedicated \`clightning\` user owns the daemon, the
       operator owns the wallet repo, www-data runs the CGI).
   Each sub-command also accepts --help.

subcommands:
   start                  bring up lightningd (background)
   run                    bring up lightningd in foreground
                          (for launchd / systemd Type=simple)
   stop                   graceful shutdown
   restart                stop + start
   status                 health check
   logs [-f]              tail the daemon log
   install [--system] [--migrate]
                          generate a service unit (systemd on Linux,
                          launchd on macOS). --system writes a
                          system-wide unit (Linux three-user layout).
EOF
}

daemon_running() {
	command -v lightning-cli >/dev/null 2>&1 && cli getinfo >/dev/null 2>&1
}

cmd_start() {
	if daemon_running; then
		info "daemon already running"
		return 0
	fi
	# Detection order: installed supervisor first. The launchd /
	# systemd unit handles --daemon (or Type=simple via `daemon run`)
	# and writes its own logs. Falling through to a direct
	# `lightningd --daemon` is for users who skipped `daemon install`.
	if launchd_installed; then
		local plist; plist=$(launchd_plist)
		if launchd_loaded; then
			info "launchctl kickstart $LAUNCHD_LABEL"
			launchctl kickstart "gui/$(id -u)/$LAUNCHD_LABEL" >/dev/null 2>&1 || \
				launchctl start "$LAUNCHD_LABEL"
		else
			info "launchctl load -w $plist"
			launchctl load -w "$plist"
		fi
	elif system_mode; then
		info "sudo systemctl start clightningd.service"
		sudo systemctl start clightningd.service
	elif systemd_user_installed; then
		info "systemctl --user start lightning"
		systemctl --user start lightning
	else
		command -v lightningd >/dev/null || {
			error "lightningd not found — install Core Lightning"
			exit 127
		}
		mkdir -p "$LIGHTNING_DIR"
		local logfile="$LIGHTNING_DIR/log"
		info "starting lightningd directly (no service unit installed)"
		info "   tip: run \`lightning daemon install\` to set up launchd / systemd"
		info "   log: $logfile"
		# lightningd writes startup messages to stderr BEFORE forking
		# (--daemon detaches afterwards), so redirect both streams to
		# the log file. Otherwise the parent shell sees the leak.
		lightningd \
			--lightning-dir="$LIGHTNING_DIR" \
			--network="$LIGHTNING_NETWORK" \
			--log-file="$logfile" \
			--daemon \
			>>"$logfile" 2>&1
	fi

	# Auto-unlock hook (FEAT-184).
	if [ -x "$SELF_LIBEXEC/lightning/wallet" ] && command -v secret >/dev/null 2>&1; then
		# Wait briefly for the daemon to start asking for a password.
		for _ in 1 2 3 4 5; do
			if cli getinfo >/dev/null 2>&1; then
				return 0
			fi
			# clightning needs the password if the HSM is encrypted;
			# `wallet unlock --stored` is a no-op when not encrypted.
			"$SELF_LIBEXEC/lightning/wallet" unlock --stored 2>/dev/null && return 0 || true
			sleep 1
		done
	fi
}

cmd_run() {
	# Foreground variant — exec lightningd directly so launchd /
	# systemd Type=simple can supervise it. Logs stream to stdout /
	# stderr; the supervisor decides where they land.
	if daemon_running; then
		error "daemon already running; stop it before \`daemon run\`"
		exit 1
	fi
	command -v lightningd >/dev/null || {
		error "lightningd not found — install Core Lightning"
		exit 127
	}
	mkdir -p "$LIGHTNING_DIR"
	info "running lightningd in foreground"
	exec lightningd \
		--lightning-dir="$LIGHTNING_DIR" \
		--network="$LIGHTNING_NETWORK"
}

cmd_stop() {
	if ! daemon_running; then
		info "daemon not running"
		return 0
	fi
	if launchd_loaded; then
		# `launchctl stop` would SIGTERM but KeepAlive=true would
		# restart immediately. Unload removes the job entirely;
		# `daemon start` reloads it. This matches brew services.
		local plist; plist=$(launchd_plist)
		info "launchctl unload $plist"
		launchctl unload "$plist"
	elif system_mode; then
		info "sudo systemctl stop clightningd.service"
		sudo systemctl stop clightningd.service
	elif systemd_user_installed; then
		info "systemctl --user stop lightning"
		systemctl --user stop lightning
	else
		cli stop >/dev/null
	fi
	info "daemon stopped"
}

cmd_restart() {
	cmd_stop || true
	# Give the socket time to disappear.
	for _ in 1 2 3 4 5; do
		[ ! -S "$RPC_FILE" ] && break
		sleep 1
	done
	cmd_start
}

cmd_status() {
	local rc=0
	if daemon_running; then
		local info; info=$(cli getinfo)
		local block; block=$(jq -r .blockheight <<<"$info")
		local warning; warning=$(jq -r '.warning_lightningd_sync // .warning_bitcoind_sync // empty' <<<"$info")
		local mode="direct"
		if launchd_loaded;             then mode="launchd"
		elif system_mode;              then mode="systemd-system"
		elif systemd_user_installed;   then mode="systemd-user"
		fi
		if [ -n "$warning" ]; then
			echo "syncing ($mode-mode, block $block): $warning"
			rc=1
		else
			echo "healthy ($mode-mode, block $block)"
		fi
	else
		echo "down"
		rc=2
	fi
	exit $rc
}

cmd_logs() {
	if system_mode; then
		exec journalctl -u clightningd.service "$@"
	fi
	if systemd_user_installed; then
		exec journalctl --user -u lightning.service "$@"
	fi
	# launchd's StandardOutPath and our direct `cmd_start` both write
	# to $LIGHTNING_DIR/log; lightningd's own default is
	# $LIGHTNING_DIR/<network>/log.
	local logfile
	for candidate in "$LIGHTNING_DIR/log" "$NETWORK_DIR/log"; do
		if [ -f "$candidate" ]; then
			logfile="$candidate"
			break
		fi
	done
	[ -n "$logfile" ] || {
		error "no log file yet at $LIGHTNING_DIR/log or $NETWORK_DIR/log"
		if launchd_loaded; then
			warn "the LaunchAgent is loaded but hasn't produced a log entry yet"
		elif daemon_running; then
			warn "the daemon is running but logging to an unexpected path"
		else
			warn "run \`lightning daemon start\` (or load the LaunchAgent / systemd unit)"
		fi
		exit 2
	}
	exec tail "$@" "$logfile"
}

cmd_install() {
	local system=0 migrate=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--system)  system=1; shift ;;
			--migrate) migrate=1; shift ;;
			*) error "daemon install: unknown flag $1"; exit 1 ;;
		esac
	done

	if is_macos; then
		if [ $system -eq 1 ]; then
			install_macos_system "$migrate"
		else
			install_macos_user
		fi
	elif [ $system -eq 1 ]; then
		install_system "$migrate"
	else
		install_user
	fi
}

install_macos_user() {
	local plist; plist=$(launchd_plist)
	local self_bin="$SELF_LIBEXEC/../bin/lightning"
	# Resolve to an absolute path in case SELF_LIBEXEC is relative.
	self_bin=$(cd "$(dirname "$self_bin")" && pwd)/$(basename "$self_bin")
	mkdir -p "$(dirname "$plist")"
	cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LAUNCHD_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${self_bin}</string>
        <string>daemon</string>
        <string>run</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>LIGHTNING_DIR</key>
        <string>${LIGHTNING_DIR}</string>
        <key>LIGHTNING_NETWORK</key>
        <string>${LIGHTNING_NETWORK}</string>
        <key>PATH</key>
        <string>${PATH}</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LIGHTNING_DIR}/log</string>
    <key>StandardErrorPath</key>
    <string>${LIGHTNING_DIR}/log</string>
</dict>
</plist>
EOF
	info "wrote $plist"
	info "next:"
	info "    lightning daemon start         # routes through launchctl"
	info "    lightning daemon status"
	info "    lightning daemon logs -f"
	info "stop:  lightning daemon stop"
}

install_macos_system() {
	local migrate=$1
	local state_dir=/usr/local/var/clightning
	local plist=/Library/LaunchDaemons/${LAUNCHD_LABEL}.plist

	if [ $migrate -eq 0 ] && [ -d "$HOME/.lightning" ] && [ ! -L "$HOME/.lightning" ]; then
		error "~/.lightning exists (user-mode install detected); refusing"
		warn "pass --migrate to move it to $state_dir"
		exit 3
	fi

	command -v sudo >/dev/null || { error "sudo required for --system"; exit 127; }

	# macOS doesn't have useradd — use dscl. UID 250-300 is the
	# conventional range for third-party system users.
	local svc_user="_clightning"
	local svc_uid=297
	local svc_gid=297

	if ! dscl . -read /Users/$svc_user >/dev/null 2>&1; then
		# Pick an unused UID in the system range if 297 is taken.
		while dscl . -list /Users UniqueID 2>/dev/null | awk '{print $2}' | grep -qx "$svc_uid"; do
			svc_uid=$((svc_uid + 1))
		done
		svc_gid=$svc_uid

		info "creating system user $svc_user (uid $svc_uid)"
		sudo dscl . -create /Groups/$svc_user
		sudo dscl . -create /Groups/$svc_user PrimaryGroupID $svc_gid
		sudo dscl . -create /Users/$svc_user
		sudo dscl . -create /Users/$svc_user UniqueID $svc_uid
		sudo dscl . -create /Users/$svc_user PrimaryGroupID $svc_gid
		sudo dscl . -create /Users/$svc_user UserShell /usr/bin/false
		sudo dscl . -create /Users/$svc_user NFSHomeDirectory $state_dir
		sudo dscl . -create /Users/$svc_user RealName "Core Lightning daemon"
		sudo dscl . -create /Users/$svc_user IsHidden 1
	fi

	# State dir, owned by the service user, group-readable so the
	# operator (added to the group) can reach the RPC socket.
	sudo install -d -o $svc_user -g $svc_user -m 0750 "$state_dir"

	# Add the current user to the clightning group so they can talk
	# to the RPC socket without sudo.
	sudo dseditgroup -o edit -a "$USER" -t user "$svc_user"

	# clightning config — rpc-file-mode=0660 so the group can read.
	local cfg="$state_dir/config"
	sudo tee "$cfg" >/dev/null <<EOF
network=$LIGHTNING_NETWORK
log-file=$state_dir/log
rpc-file-mode=0660
EOF
	sudo chown $svc_user:$svc_user "$cfg"

	# LaunchDaemon plist running as the service user.
	local lightningd_bin; lightningd_bin=$(command -v lightningd)
	sudo tee "$plist" >/dev/null <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LAUNCHD_LABEL}</string>
    <key>UserName</key>
    <string>${svc_user}</string>
    <key>GroupName</key>
    <string>${svc_user}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${lightningd_bin}</string>
        <string>--lightning-dir=${state_dir}</string>
        <string>--conf=${cfg}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${state_dir}/log</string>
    <key>StandardErrorPath</key>
    <string>${state_dir}/log</string>
</dict>
</plist>
EOF
	sudo chown root:wheel "$plist"
	sudo chmod 644 "$plist"

	info "installed system-mode at $state_dir"
	info "user '$svc_user' created (uid $svc_uid); '$USER' added to its group"
	info "next:"
	info "    sudo launchctl load -w $plist  # one-time, run as root"
	info "    lightning daemon status"
	info "log out and back in for your group membership to take effect"
}

install_user() {
	local dir="$HOME/.config/systemd/user"
	local unit="$dir/lightning.service"
	mkdir -p "$dir"
	cat > "$unit" <<EOF
[Unit]
Description=Lightning Network daemon (clightning, user-mode)
After=network.target

[Service]
Type=forking
ExecStart=$(command -v lightningd) --lightning-dir=$LIGHTNING_DIR --network=$LIGHTNING_NETWORK --daemon
ExecStop=$(command -v lightning-cli) --lightning-dir=$LIGHTNING_DIR --network=$LIGHTNING_NETWORK stop
PIDFile=$LIGHTNING_DIR/lightningd-${LIGHTNING_NETWORK}.pid
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
EOF
	systemctl --user daemon-reload 2>/dev/null || true
	info "wrote $unit"
	info "next:"
	info "    lightning daemon start         # routes through systemctl --user"
	info "    lightning daemon status"
	info "    lightning daemon logs -f"
	info "to survive logout:  loginctl enable-linger $USER"
	info "to autostart at login:  systemctl --user enable lightning"
}

install_system() {
	local migrate=$1

	if [ $migrate -eq 0 ] && [ -d "$HOME/.lightning" ] && [ ! -L "$HOME/.lightning" ]; then
		warn "~/.lightning exists (user-mode install detected); refusing"
		error "pass --migrate to move it to /var/lib/clightning"
		exit 3
	fi

	command -v sudo >/dev/null || { error "sudo required for --system"; exit 127; }

	# 1. Create the clightning system user (idempotent).
	if ! getent passwd clightning >/dev/null; then
		sudo useradd --system --home /var/lib/clightning \
			--shell /usr/sbin/nologin --user-group clightning
	fi

	# 2. State dir.
	sudo install -d -o clightning -g clightning -m 0750 /var/lib/clightning

	# 3. Add the operator to the clightning group.
	sudo usermod -a -G clightning "$USER"

	# 4. clightning's config — rpc-file-mode=0660 so the group can read it.
	local cfg=/var/lib/clightning/config
	sudo tee "$cfg" >/dev/null <<EOF
network=$LIGHTNING_NETWORK
log-file=/var/lib/clightning/log
rpc-file-mode=0660
EOF
	sudo chown clightning:clightning "$cfg"

	# 5. Systemd unit.
	local unit=/etc/systemd/system/clightningd.service
	sudo tee "$unit" >/dev/null <<EOF
[Unit]
Description=Lightning Network daemon (clightning, system-mode)
After=network.target

[Service]
Type=simple
User=clightning
Group=clightning
ExecStart=$(command -v lightningd) --lightning-dir=/var/lib/clightning --conf=$cfg
Restart=on-failure
RestartSec=5
ProtectSystem=full
ProtectHome=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
	sudo systemctl daemon-reload

	info "installed system-mode at /var/lib/clightning"
	info "user 'clightning' created; '$USER' added to group 'clightning'"
	info "next:"
	info "    sudo systemctl enable clightningd"
	info "    lightning daemon start         # routes through systemctl"
	info "    lightning daemon status"
	info "log out and back in for your group membership to take effect"
}

SELF_LIBEXEC="${SELF_LIBEXEC:-$(cd "$(dirname "$0")/.." && pwd)}"

subhelp() {
	case "$1" in
		start)
			cat <<'EOF'
usage: lightning daemon start

Bring up lightningd in the background. Routes through the installed
supervisor (detected by file presence):
   1. launchd       — ~/Library/LaunchAgents/<label>.plist or
                      /Library/LaunchDaemons/<label>.plist
                      => `launchctl load -w` (or `kickstart` if loaded)
   2. systemd-system — clightningd.service enabled
                      => `sudo systemctl start clightningd.service`
   3. systemd-user   — ~/.config/systemd/user/lightning.service
                      => `systemctl --user start lightning`
   4. direct         — no service unit installed
                      => `lightningd --daemon`, output -> log file
Triggers auto-unlock (FEAT-184) when the `secret` package is installed.
EOF
			;;
		run)
			cat <<'EOF'
usage: lightning daemon run

Bring up lightningd in the FOREGROUND — exec the binary without
--daemon, so logs stream to stdout/stderr and exit propagates to
the caller. This is the entry point invoked by launchd and by
systemd units with Type=simple. Refuses if the daemon is already
running.
EOF
			;;
		stop)
			cat <<'EOF'
usage: lightning daemon stop

Graceful shutdown. Same detection order as `start`:
   launchd       => `launchctl unload <plist>` (KeepAlive would
                    fight a plain stop; unload removes the job
                    until the next `daemon start`)
   systemd-system => `sudo systemctl stop clightningd.service`
   systemd-user   => `systemctl --user stop lightning`
   direct         => `lightning-cli stop`
No-op if the daemon isn't running.
EOF
			;;
		restart)
			cat <<'EOF'
usage: lightning daemon restart

`stop` then `start`, waiting up to 5s for the RPC socket to
disappear in between. Re-triggers auto-unlock on the way up.
EOF
			;;
		status)
			cat <<'EOF'
usage: lightning daemon status

Health check. Exits 0 (healthy), 1 (syncing), or 2 (down).
Output names the mode (user|system) and current blockheight, plus
any warning_lightningd_sync / warning_bitcoind_sync from getinfo.
EOF
			;;
		logs)
			cat <<'EOF'
usage: lightning daemon logs [tail-flags...]

Tail the daemon log. In system-mode reads `journalctl -u
clightningd.service` (forwards extra flags); in user-mode tails
$LIGHTNING_DIR/log or $LIGHTNING_DIR/$LIGHTNING_NETWORK/log.
Add -f to follow.
EOF
			;;
		install)
			cat <<'EOF'
usage: lightning daemon install [--system] [--migrate]

Write a service unit for the daemon. Platform-aware:

Default (user-mode) — runs as the current user, no sudo needed:
   macOS  ~/Library/LaunchAgents/network.lightning.lightningd.plist
          (LaunchAgent calling `lightning daemon run` so launchd
          supervises lightningd).
   Linux  ~/.config/systemd/user/lightning.service.

--system — runs the daemon as a dedicated unprivileged service
user, with the operator added to its group so they can reach the
RPC socket. Requires sudo for the install step only — the
daemon never runs as root.
   macOS  /Library/LaunchDaemons/network.lightning.lightningd.plist
          UserName=_clightning, state at /usr/local/var/clightning.
   Linux  /etc/systemd/system/clightningd.service
          User=clightning, state at /var/lib/clightning
          (FEAT-183 three-user layout).

--migrate moves an existing ~/.lightning into the system state dir.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="${1:-}"
[ -n "$SUB" ] && shift
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac

case "$SUB" in
	start)   cmd_start "$@" ;;
	run)     cmd_run "$@" ;;
	stop)    cmd_stop "$@" ;;
	restart) cmd_restart "$@" ;;
	status)  cmd_status "$@" ;;
	logs)    cmd_logs "$@" ;;
	install) cmd_install "$@" ;;
	help)    subhelp "${1:-}" || usage; exit ;;
	"")      usage; exit 1 ;;
	*)       error "daemon: unknown subcommand '$SUB'"; usage; exit 1 ;;
esac
