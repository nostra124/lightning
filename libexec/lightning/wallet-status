#!/bin/bash
# lightning wallet-status <wallet_name>   (FEAT-633)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-status <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
check=$(sqlite3 "$db" "PRAGMA integrity_check;" 2>/dev/null) || check="error"
size=$(du -sh "$db" 2>/dev/null | cut -f1) || size="unknown"
echo "{\"wallet\":\"$wname\",\"integrity\":\"$check\",\"size\":\"$size\"}"
