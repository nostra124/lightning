#!/bin/bash
# lightning channel-to-us-msat-total   (FEAT-1940)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(ch.get('to_us_msat', 0) for ch in channels)
print(json.dumps({'channel_count': len(channels), 'total_to_us_msat': total}))
" "$result"
