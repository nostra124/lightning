#!/bin/bash
# lightning scb — static channel backup (FEAT-185).
#
# Usage:
#   lightning scb emit [--out <file>]
#   lightning scb restore <file>

set -e

usage() {
	cat >&2 <<EOF
usage: lightning scb <subcommand> [args]

subcommands:
   emit [--out <file>]
   restore <file>
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"

command -v lightning-cli >/dev/null || {
	echo "lightning: lightning-cli not found — install Core Lightning" >&2; exit 127; }

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

wallet_scb_dir() {
	local active; active=$(cat "$LIGHTNING_DIR/wallet/.active" 2>/dev/null || echo "default")
	echo "$LIGHTNING_DIR/wallet/$active/scb"
}

cmd_emit() {
	local outfile=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--out) outfile="$2"; shift 2 ;;
			*) echo "lightning scb emit: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	scb_json=$(cli staticbackup 2>/dev/null || cli listpeerchannels 2>/dev/null | jq '{scb: .}' 2>/dev/null) || {
		echo "lightning: failed to read SCB from daemon" >&2; exit 4; }

	if [ -n "$outfile" ]; then
		echo "$scb_json" > "$outfile"
		echo "ok"
		echo "path: $outfile"
	else
		# Write to wallet scb/ directory.
		local scb_dir; scb_dir=$(wallet_scb_dir)
		mkdir -p "$scb_dir"
		local ts; ts=$(date -u +%Y%m%dT%H%M%SZ)
		local path="$scb_dir/scb-$ts.json"
		echo "$scb_json" > "$path"
		echo "ok"
		echo "path: $path"

		# Auto-commit to wallet git if applicable.
		local wdir; wdir=$(dirname "$scb_dir")
		if [ -d "$wdir/.git" ]; then
			git -C "$wdir" add "$path" 2>/dev/null || true
			git -C "$wdir" commit -m "scb: snapshot $ts" --quiet 2>/dev/null || true
		fi
	fi
}

cmd_restore() {
	[ $# -lt 1 ] && { echo "usage: lightning scb restore <file>" >&2; exit 1; }
	local file="$1"
	[ -f "$file" ] || { echo "lightning: SCB file not found: $file" >&2; exit 4; }

	result=$(cli staticbackup restore "$file" 2>/dev/null || cli emergency recover "$file" 2>/dev/null) || {
		echo "lightning: SCB restore failed — daemon may need to be unlocked first" >&2
		exit 4
	}

	echo "ok"
	echo "lightning: SCB restore initiated; force-closes expected within the next block" >&2
	echo "$result" | jq . 2>/dev/null || echo "$result"
}

case "$1" in
	emit)    shift; cmd_emit "$@" ;;
	restore) shift; cmd_restore "$@" ;;
	*) usage; exit 1 ;;
esac
