#!/bin/bash
# lightning node-listchannels-high-capacity <min_msat>   (FEAT-1404)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listchannels-high-capacity <min_msat>"}'; exit 0; fi
min_msat="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
mn = int(sys.argv[2])
channels = [{'channel_id': c.get('channel_id'), 'total_msat': c.get('total_msat')} for c in data.get('channels', []) if c.get('total_msat', 0) >= mn]
print(json.dumps({'count': len(channels), 'channels': channels}))
" "$result" "$min_msat"
