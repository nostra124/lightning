#!/bin/bash
# lightning channel-age [<channel_id>]   (FEAT-340)
set -e
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '[]'; exit 0; }
filter="${1:-}"
now=$(date +%s)
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
filt = sys.argv[2]
now = int(sys.argv[3])
channels = data.get('channels', [])
if filt:
    channels = [c for c in channels if c.get('channel_id') == filt]
out = []
for c in channels:
    opened = c.get('opened_at', 0)
    age_s = now - opened if opened else 0
    out.append({
        'channel_id': c.get('channel_id', ''),
        'peer_id': c.get('peer_id', ''),
        'state': c.get('state', ''),
        'opened_at': opened,
        'age_days': round(age_s / 86400, 1),
    })
out.sort(key=lambda x: x['opened_at'])
print(json.dumps(out, separators=(',', ':')))
" "$result" "$filter" "$now"
