#!/bin/bash
# lightning node-listforwards-fee-total-alltime   (FEAT-2511)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
total = sum(f.get('fee_msat', 0) for f in fwds)
print(json.dumps({'settled_count': len(fwds), 'total_fee_msat_alltime': total}))
" "$result"
