#!/bin/bash
# lightning channel-htlc-timeout-max   (FEAT-2502)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best_exp = None
best_chan = None
for c in channels:
    for h in c.get('htlcs', []):
        exp = h.get('cltv_expiry')
        if exp is not None and (best_exp is None or exp > best_exp):
            best_exp = exp
            best_chan = c.get('channel_id') or c.get('short_channel_id')
print(json.dumps({'channel_id': best_chan, 'htlc_cltv_expiry_max': best_exp}))
" "$result"
