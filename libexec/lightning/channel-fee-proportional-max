#!/bin/bash
# lightning channel-fee-proportional-max   (FEAT-2527)
result=$(lightning-cli listchannels mine=true 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'short_channel_id': None, 'fee_proportional_millionths': 0}))
    sys.exit(0)
top = max(channels, key=lambda c: c.get('fee_per_millionth', 0))
print(json.dumps({'short_channel_id': top.get('short_channel_id'), 'fee_proportional_millionths': top.get('fee_per_millionth', 0)}))
" "$result"
