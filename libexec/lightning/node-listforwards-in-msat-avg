#!/bin/bash
# lightning node-listforwards-in-msat-avg   (FEAT-2371)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
settled = [f for f in forwards if f.get('status') == 'settled']
if not settled:
    print(json.dumps({'avg_in_msat': 0, 'settled_count': 0}))
else:
    total = sum(f.get('in_msat', 0) for f in settled)
    avg = total // len(settled)
    print(json.dumps({'avg_in_msat': avg, 'settled_count': len(settled)}))
" "$result"
