#!/bin/bash
# lightning node-pay-destination-count   (FEAT-1431)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
dests = set(p.get('destination') for p in data.get('pays', []) if p.get('destination'))
print(json.dumps({'unique_destination_count': len(dests)}))
" "$result"
