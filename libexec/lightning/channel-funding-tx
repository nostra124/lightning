#!/bin/bash
# lightning channel-funding-tx <channel_id>   (FEAT-1952)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-funding-tx <channel_id>"}'; exit 0; fi
arg="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channel_id = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == channel_id or ch.get('short_channel_id') == channel_id:
        print(json.dumps({'channel_id': ch.get('channel_id'), 'funding_txid': ch.get('funding_txid'), 'funding_outnum': ch.get('funding_outnum')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$arg"
