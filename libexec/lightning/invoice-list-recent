#!/bin/bash
# lightning invoice-list-recent [<limit>]   (FEAT-550)
limit="${1:-10}"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
limit = int(sys.argv[2])
invoices = data.get('invoices', [])
recent = sorted(invoices, key=lambda i: i.get('expires_at', 0), reverse=True)[:limit]
print(json.dumps(recent))
" "$result" "$limit"
