#!/bin/bash
# lightning invoice-list-recent <n>   (FEAT-1205)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-list-recent <n>"}'; exit 0; fi
n="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
n = int(sys.argv[2])
invoices = sorted(data.get('invoices', []), key=lambda i: i.get('expires_at', 0), reverse=True)[:n]
print(json.dumps(invoices))
" "$result" "$n"
