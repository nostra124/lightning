#!/bin/bash
# lightning invoice-list-recent [--limit N]   (FEAT-443)
limit=10
while [ $# -gt 0 ]; do
    case "$1" in
        --limit) limit="$2"; shift 2 ;;
        *) shift ;;
    esac
done
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
invoices = json.loads(sys.argv[1]).get('invoices', [])
limit = int(sys.argv[2])
recent = sorted(invoices, key=lambda i: i.get('expires_at', 0), reverse=True)[:limit]
out = [{'label': i.get('label',''), 'status': i.get('status',''), 'amount_msat': i.get('amount_msat', 0),
        'expires_at': i.get('expires_at', 0)} for i in recent]
print(json.dumps(out, separators=(',', ':')))
" "$result" "$limit"
