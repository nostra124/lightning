#!/bin/bash
# lightning node-feerate-min   (FEAT-1429)
result=$(lightning-cli feerates perkw 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
perkw = data.get('perkw', {})
print(json.dumps({'feerate_min_perkw': perkw.get('min_acceptable')}))
" "$result"
