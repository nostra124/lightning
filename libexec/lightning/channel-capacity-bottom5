#!/bin/bash
# lightning channel-capacity-bottom5   (FEAT-2517)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
entries = []
for ch in channels:
    local = ch.get('local_msat', 0) or 0
    remote = ch.get('remote_msat', 0) or 0
    total = local + remote
    entries.append({
        'channel_id': ch.get('short_channel_id') or ch.get('channel_id'),
        'peer_id': ch.get('peer_id'),
        'total_capacity_msat': total
    })
entries.sort(key=lambda x: x['total_capacity_msat'])
print(json.dumps({'bottom5_channels_by_capacity': entries[:5]}))
" "$result"
