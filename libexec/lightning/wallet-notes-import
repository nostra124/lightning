#!/bin/bash
# lightning wallet-notes-import <wallet_name> <notes_file>   (FEAT-1003)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-notes-import <wallet_name> <notes_file>"}'
    exit 0
fi
wname="$1"; nfile="$2"
if [ ! -f "$nfile" ]; then
    echo '{"error":"notes_file_not_found"}'
    exit 0
fi
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
count=$(wc -l < "$nfile" 2>/dev/null || echo 0)
echo "{\"ok\":true,\"wallet\":\"$wname\",\"imported\":$count}"
