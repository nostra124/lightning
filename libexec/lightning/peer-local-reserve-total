#!/bin/bash
# lightning peer-local-reserve-total   (FEAT-2493)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('our_reserve_msat', 0) for c in channels)
print(json.dumps({'local_reserve_total_msat': total}))
" "$result"
