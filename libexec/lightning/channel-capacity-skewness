#!/bin/bash
# lightning channel-capacity-skewness   (FEAT-2565)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
capacities = [c.get('total_msat', 0) for c in channels if 'total_msat' in c]
if len(capacities) < 3:
    skewness = 0
else:
    n = len(capacities)
    mean = sum(capacities) / n
    variance = sum((x - mean) ** 2 for x in capacities) / n
    std = math.sqrt(variance) if variance > 0 else 0
    if std == 0:
        skewness = 0
    else:
        skewness = (sum((x - mean) ** 3 for x in capacities) / n) / (std ** 3)
print(json.dumps({'capacity_skewness': skewness}))
" "$result"
