#!/bin/bash
# lightning node-listpays-complete-newest   (FEAT-2161)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
if not complete:
    print(json.dumps({'error': 'no complete pays'}))
    sys.exit(0)
newest = max(complete, key=lambda p: p.get('created_at', 0))
print(json.dumps(newest))
" "$result"
