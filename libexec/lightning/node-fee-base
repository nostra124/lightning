#!/bin/bash
# lightning node-fee-base   (FEAT-879)
if ! result=$(lightning-cli listconfigs 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fee_base = data.get('configs', {}).get('fee-base', {}).get('value_int', None)
print(json.dumps({'fee_base_msat': fee_base}))
" "$result"
