#!/bin/bash
# lightning channel-balance-ratio-stddev   (FEAT-2991)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ratios = []
for ch in channels:
    total = ch.get('total_msat', 0)
    if isinstance(total, str):
        total = int(total.replace('msat',''))
    spendable = ch.get('spendable_msat', 0)
    if isinstance(spendable, str):
        spendable = int(spendable.replace('msat',''))
    if total > 0:
        ratios.append(spendable / total)
if ratios:
    mean = sum(ratios) / len(ratios)
    variance = sum((r - mean) ** 2 for r in ratios) / len(ratios)
    stddev = math.sqrt(variance)
else:
    stddev = 0.0
print(json.dumps({'balance_ratio_stddev': stddev, 'channel_count': len(ratios)}))
" "$result"
