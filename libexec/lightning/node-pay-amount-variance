#!/bin/bash
# lightning node-pay-amount-variance   (FEAT-2606)
result=$(lightning-cli listsendpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('payments', [])
amounts = [p['amount_msat'] for p in pays if 'amount_msat' in p]
if len(amounts) < 2:
    print(json.dumps({'amount_variance_msat': 0}))
else:
    mean = sum(amounts) / len(amounts)
    variance = sum((x - mean) ** 2 for x in amounts) / len(amounts)
    print(json.dumps({'amount_variance_msat': variance}))
" "$result"
