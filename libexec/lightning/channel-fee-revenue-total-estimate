#!/bin/bash
# lightning channel-fee-revenue-total-estimate   (FEAT-2520)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_estimate = 0
for ch in channels:
    local = ch.get('local_msat', 0) or 0
    remote = ch.get('remote_msat', 0) or 0
    capacity = local + remote
    fee_base = ch.get('fee_base_msat', 0) or 0
    fee_ppm = ch.get('fee_proportional_millionths', 0) or 0
    # estimate: assume capacity turns over once per day, 365 days/year
    annual_volume = capacity * 365
    estimate = fee_base * 365 + (annual_volume * fee_ppm // 1_000_000)
    total_estimate += estimate
print(json.dumps({'total_fee_revenue_estimate_annual_msat': total_estimate, 'channel_count': len(channels)}))
" "$result"
