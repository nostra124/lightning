#!/bin/bash
# lightning node-total-received   (FEAT-621)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
paid = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
total = sum(i.get('amount_received_msat', i.get('amount_msat', 0)) for i in paid)
print(json.dumps({'paid_invoices': len(paid), 'total_received_msat': total, 'total_received_sat': total // 1000}))
" "$result"
