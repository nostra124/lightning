#!/bin/bash
# lightning peer-balance-ratio-avg   (FEAT-2994)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_data = {}
for ch in channels:
    peer = ch.get('peer_id', 'unknown')
    total = ch.get('total_msat', 0)
    if isinstance(total, str):
        total = int(total.replace('msat',''))
    spendable = ch.get('spendable_msat', 0)
    if isinstance(spendable, str):
        spendable = int(spendable.replace('msat',''))
    if total > 0:
        ratio = spendable / total
        if peer not in peer_data:
            peer_data[peer] = []
        peer_data[peer].append(ratio)
peer_avgs = {p: sum(r)/len(r) for p, r in peer_data.items()}
overall_avg = sum(peer_avgs.values()) / len(peer_avgs) if peer_avgs else 0.0
print(json.dumps({'balance_ratio_avg_peer': overall_avg, 'peer_count': len(peer_avgs), 'per_peer': peer_avgs}))
" "$result"
