#!/bin/bash
# lightning node-uptime   (FEAT-415)
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
info = json.loads(sys.argv[1])
now = int(time.time())
started = info.get('blockheight', 0)
print(json.dumps({'alias': info.get('alias',''), 'color': info.get('color',''),
    'num_peers': info.get('num_peers', 0), 'num_active_channels': info.get('num_active_channels', 0),
    'version': info.get('version',''), 'network': info.get('network','')}, separators=(',', ':')))
" "$result"
