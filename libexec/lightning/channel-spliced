#!/bin/bash
# lightning channel-spliced   (FEAT-740)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
spliced = [c for c in channels if c.get('splice_state') or c.get('inflight')]
print(json.dumps({'count': len(spliced), 'channels': [c.get('channel_id') for c in spliced]}))
" "$result"
