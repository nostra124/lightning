#!/bin/bash
# lightning channel-receivable-min   (FEAT-2587)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'receivable_msat': None}))
    sys.exit(0)
min_ch = min(channels, key=lambda c: int(c.get('receivable_msat', 0)))
print(json.dumps({'receivable_msat': min_ch.get('receivable_msat'), 'channel_id': min_ch.get('channel_id'), 'peer_id': min_ch.get('peer_id')}))
" "$result"
