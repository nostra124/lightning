#!/bin/bash
# lightning wallet-ledger-summary <wallet_name>   (FEAT-497)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-ledger-summary <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
python3 -c "
import sqlite3, json, sys
db = sys.argv[1]; wname = sys.argv[2]
conn = sqlite3.connect(db)
cur = conn.cursor()
cur.execute('SELECT direction, COUNT(*), COALESCE(SUM(amount_sat),0) FROM ledger GROUP BY direction')
rows = cur.fetchall()
conn.close()
summary = {r[0]: {'count': r[1], 'total_sat': r[2]} for r in rows}
print(json.dumps({'wallet': wname, 'by_direction': summary}, separators=(',', ':')))
" "$db" "$wname"
