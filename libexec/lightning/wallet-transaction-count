#!/bin/bash
# lightning wallet-transaction-count <wallet_name>   (FEAT-672)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-transaction-count <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM transactions" 2>/dev/null) || count=0
echo "{\"wallet\":\"$wname\",\"count\":$count}"
