#!/bin/bash
# lightning node-listforwards-in-msat-min   (FEAT-2581)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
if not forwards:
    print(json.dumps({'min_in_msat': None}))
    sys.exit(0)
min_val = min(int(f.get('in_msat', 0)) for f in forwards)
print(json.dumps({'min_in_msat': min_val}))
" "$result"
