#!/bin/bash
# lightning node-pay-complete-oldest   (FEAT-2199)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'error': 'no complete pays'}))
    sys.exit(0)
oldest = min(pays, key=lambda p: p.get('created_at', 0))
print(json.dumps({'payment_hash': oldest.get('payment_hash',''), 'created_at': oldest.get('created_at', 0), 'amount_msat': oldest.get('amount_msat', 0)}))
" "$result"
