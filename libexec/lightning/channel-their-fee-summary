#!/bin/bash
# lightning channel-their-fee-summary   (FEAT-2082)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
summary = []
for ch in channels:
    updates = ch.get('updates', {})
    remote = updates.get('remote', {})
    summary.append({
        'channel_id': ch.get('channel_id', ''),
        'their_base_fee_msat': remote.get('fee_base_msat', 0),
        'their_fee_per_millionth': remote.get('fee_proportional_millionths', 0),
    })
print(json.dumps({'their_fee_summary': summary}))
" "$result"
