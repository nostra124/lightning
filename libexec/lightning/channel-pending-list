#!/bin/bash
# lightning channel-pending-list   (FEAT-1062)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pending = [ch for ch in data.get('channels', []) if 'NORMAL' not in ch.get('state', '') and 'CLOSED' not in ch.get('state', '')]
out = [{'channel_id': ch.get('channel_id'), 'state': ch.get('state')} for ch in pending]
print(json.dumps({'count': len(out), 'channels': out}))
" "$result"
