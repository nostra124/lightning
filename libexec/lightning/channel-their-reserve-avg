#!/bin/bash
# lightning channel-their-reserve-avg   (FEAT-2580)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'their_reserve_avg_msat': 0}))
else:
    total = sum(c.get('their_reserve_msat', 0) for c in channels)
    avg = total // len(channels)
    print(json.dumps({'their_reserve_avg_msat': avg}))
" "$result"
