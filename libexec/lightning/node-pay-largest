#!/bin/bash
# lightning node-pay-largest   (FEAT-2049)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']

def to_msat(v):
    if isinstance(v, str) and v.endswith('msat'):
        return int(v[:-4])
    return int(v) if v else 0

if complete:
    largest = max(complete, key=lambda p: to_msat(p.get('amount_sent_msat', 0)))
    amt = to_msat(largest.get('amount_sent_msat', 0))
    print(json.dumps({'largest_pay_msat': amt, 'payment_hash': largest.get('payment_hash', ''), 'destination': largest.get('destination', '')}))
else:
    print(json.dumps({'largest_pay_msat': 0, 'payment_hash': '', 'destination': ''}))
" "$result"
