#!/bin/bash
# lightning wallet-export <wallet_name> <dest_path>   (FEAT-1043)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-export <wallet_name> <dest_path>"}'
    exit 0
fi
wname="$1"; dest="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
if cp "$db" "$dest" 2>/dev/null; then
    echo "{\"ok\":true,\"wallet\":\"$wname\",\"exported_to\":\"$dest\"}"
else
    echo '{"error":"export_failed"}'
fi
