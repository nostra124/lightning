#!/bin/bash
# lightning channel-rebalance-auto [--threshold N]   (FEAT-508)
threshold=20
while [ $# -gt 0 ]; do
    case "$1" in
        --threshold) threshold="$2"; shift 2 ;;
        *) shift ;;
    esac
done
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
threshold = int(sys.argv[2])
unbalanced = []
for c in channels:
    total = c.get('total_msat', 0)
    if total == 0:
        continue
    local_pct = c.get('to_us_msat', 0) * 100 // total
    if local_pct < threshold or local_pct > (100 - threshold):
        unbalanced.append({'channel_id': c.get('channel_id',''), 'local_pct': local_pct,
            'action': 'drain' if local_pct > 50 else 'fill'})
print(json.dumps({'candidates': len(unbalanced), 'threshold_pct': threshold,
    'channels': unbalanced}, separators=(',', ':')))
" "$result" "$threshold"
