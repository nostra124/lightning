#!/bin/bash
# lightning node-listpays-pending   (FEAT-871)
result=$(lightning-cli listpays status=pending 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'count': len(pays), 'pays': pays}))
" "$result"
