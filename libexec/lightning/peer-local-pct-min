#!/bin/bash
# lightning peer-local-pct-min   (FEAT-2498)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_pcts = {}
for c in channels:
    pid = c.get('peer_id', '')
    local = c.get('to_us_msat', c.get('local_msat', 0))
    total = c.get('total_msat', 0)
    if total and total > 0:
        pct = local / total * 100
        if pid not in peer_pcts or pct < peer_pcts[pid]:
            peer_pcts[pid] = pct
if peer_pcts:
    min_peer = min(peer_pcts, key=lambda k: peer_pcts[k])
    print(json.dumps({'peer_id': min_peer, 'local_pct_min': round(peer_pcts[min_peer], 4)}))
else:
    print(json.dumps({'peer_id': None, 'local_pct_min': None}))
" "$result"
