#!/bin/bash
# lightning api-account-invite-codes <address>   (FEAT-220)
#
# List the invite codes an account has minted (FEAT-218), for the PWA's
# "Invite a friend" screen.  Address-keyed, sudo-bridged from the
# accounts.py dispatcher.  If the account has no code yet, one is minted
# lazily so the invite screen always has something to show — the PWA
# fetches this rather than caching the code, so a CLI `invite-code
# revoke` takes effect on the next load.
#
#   {"invite_codes":[{"code":"...","uses":<int>,"created_at":<int>}]}

set -e
[ $# -ge 1 ] || exit 1
address="$1"

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
command -v jq >/dev/null || { echo '{"error":"jq not installed"}'; exit 127; }

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }
name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

now=$(date -u +%s)
sqlite3 "$db" "UPDATE accounts SET last_api_call_at = $now WHERE address = $(sql_quote "$address");" 2>/dev/null || true

# FEAT-222 PR-6 — invite whitelist.  When set, only listed accounts may
# MINT codes; the lazy-mint below is skipped for everyone else (listing
# any codes they already hold still works — we just don't create new
# ones).  Empty whitelist (default) = anyone may invite.
may_invite=1
access_file="$WALLETS_ROOT/$wname/access.recfile"
if [ -f "$access_file" ]; then
	whitelist=$(sed -n 's/^invite_whitelist:[[:space:]]*//p' "$access_file" | head -1)
	if [ -n "$(printf '%s' "$whitelist" | tr -d '[:space:]')" ]; then
		may_invite=0
		for w in $(printf '%s' "$whitelist" | tr ',' ' '); do
			if [ "$w" = "$name" ] || [ "$w" = "$address" ]; then may_invite=1; break; fi
		done
	fi
fi

count=$(sqlite3 "$db" "SELECT COUNT(*) FROM invite_codes WHERE account = $(sql_quote "$name");")
if [ "${count:-0}" -eq 0 ] && [ "$may_invite" = "1" ]; then
	# Lazy mint: 7 chars from [a-z0-9] (same alphabet as the CLI).
	code=$(head -c 8 /dev/urandom | base32 | tr 'A-Z' 'a-z' | tr -d '=\n' | head -c 7)
	sqlite3 "$db" "INSERT OR IGNORE INTO invite_codes(code, account, created_at) \
		VALUES($(sql_quote "$code"), $(sql_quote "$name"), $now);" 2>/dev/null || true
fi

sqlite3 -separator $'\t' "$db" \
	"SELECT code, COALESCE(uses,0), created_at FROM invite_codes \
	 WHERE account = $(sql_quote "$name") ORDER BY created_at DESC;" \
	| jq -R -n '[ inputs | split("\t")
		| {code:.[0], uses:(.[1]|tonumber), created_at:(.[2]|tonumber)} ]
		| {invite_codes: .}'
