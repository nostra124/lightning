#!/bin/bash
# lightning peer-our-reserve-max   (FEAT-2588)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
totals = {}
for c in channels:
    pid = c.get('peer_id', 'unknown')
    totals[pid] = totals.get(pid, 0) + int(c.get('our_reserve_msat', 0))
if not totals:
    print(json.dumps({'our_reserve_msat': None, 'peer_id': None}))
    sys.exit(0)
max_peer = max(totals, key=lambda p: totals[p])
print(json.dumps({'our_reserve_msat': totals[max_peer], 'peer_id': max_peer}))
" "$result"
