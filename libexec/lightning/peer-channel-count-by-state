#!/bin/bash
# lightning peer-channel-count-by-state   (FEAT-2006)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
by_peer = {}
for c in channels:
    peer = c.get('peer_id', 'unknown')
    state = c.get('state', 'unknown')
    if peer not in by_peer:
        by_peer[peer] = {}
    by_peer[peer][state] = by_peer[peer].get(state, 0) + 1
print(json.dumps({'peers': by_peer, 'peer_count': len(by_peer)}))
" "$result"
