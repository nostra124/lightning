#!/bin/bash
# lightning node-listforwards-fee-stddev   (FEAT-2561)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
fees = [f.get('fee_msat', 0) for f in forwards if 'fee_msat' in f]
if len(fees) < 2:
    stddev = 0
else:
    mean = sum(fees) / len(fees)
    variance = sum((x - mean) ** 2 for x in fees) / len(fees)
    stddev = math.sqrt(variance)
print(json.dumps({'fee_msat_stddev': stddev}))
" "$result"
