#!/bin/bash
# lightning node-invoice-paid-amount-stats   (FEAT-2187)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid']
amounts = []
for i in paid:
    amt = i.get('amount_received_msat', i.get('msatoshi_received', 0))
    if isinstance(amt, str): amt = int(amt.replace('msat',''))
    amounts.append(amt)
if amounts:
    result = {'paid_count': len(amounts), 'min_msat': min(amounts), 'max_msat': max(amounts), 'avg_msat': int(sum(amounts)/len(amounts))}
else:
    result = {'paid_count': 0, 'min_msat': None, 'max_msat': None, 'avg_msat': None}
print(json.dumps(result))
" "$result"
