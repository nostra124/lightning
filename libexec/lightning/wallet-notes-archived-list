#!/bin/bash
# lightning wallet-notes-archived-list <wallet>   (FEAT-1943)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-archived-list <wallet>"}'; exit 0; fi
wallet="$1"
db="$HOME/.lightning/wallets/$wallet/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet db not found"}'; exit 0; fi
result=$(sqlite3 "$db" "SELECT key, value FROM notes WHERE archived = 1 ORDER BY key" 2>/dev/null) || { echo '{"error":"sqlite3 query failed"}'; exit 0; }
python3 -c "
import sys, json
wallet = sys.argv[1]
raw = sys.argv[2]
notes = []
if raw.strip():
    for line in raw.strip().split('\n'):
        parts = line.split('|', 1)
        notes.append({'key': parts[0], 'value': parts[1] if len(parts) > 1 else ''})
print(json.dumps({'wallet': wallet, 'notes': notes, 'count': len(notes)}))
" "$wallet" "$result"
