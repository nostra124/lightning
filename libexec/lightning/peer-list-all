#!/bin/bash
# lightning peer-list-all   (FEAT-747)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = [{'id': p.get('id'), 'connected': p.get('connected'), 'channels': len(p.get('channels', []))} for p in data.get('peers', [])]
print(json.dumps(peers))
" "$result"
