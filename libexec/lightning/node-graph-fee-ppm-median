#!/bin/bash
# lightning node-graph-fee-ppm-median   (FEAT-2194)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'median_fee_ppm': 0, 'channel_count': 0}))
    sys.exit(0)
ppms = sorted(ch.get('fee_per_millionth', 0) for ch in channels)
n = len(ppms)
mid = n // 2
median = ppms[mid] if n % 2 else (ppms[mid-1] + ppms[mid]) / 2
print(json.dumps({'median_fee_ppm': median, 'channel_count': n}))
" "$result"
