#!/bin/bash
# lightning node-listforwards-count   (FEAT-1789)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
by_status = {}
for f in fwds:
    s = f.get('status', 'unknown')
    by_status[s] = by_status.get(s, 0) + 1
print(json.dumps({'total': len(fwds), 'by_status': by_status}))
" "$result"
