#!/bin/bash
# lightning node-listpays-grouped-status   (FEAT-2031)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
counts = {}
for p in pays:
    s = p.get('status', 'unknown')
    counts[s] = counts.get(s, 0) + 1
print(json.dumps({'status_counts': counts}))
" "$result"
