#!/bin/bash
# lightning wallet-created-list   (FEAT-638)
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root" ]; then
    echo '[]'
    exit 0
fi
python3 -c "
import sys, json, os, subprocess
root = sys.argv[1]
wallets = []
try:
    for name in sorted(os.listdir(root)):
        path = os.path.join(root, name)
        db = os.path.join(path, 'state.db')
        if os.path.isdir(path) and os.path.exists(db):
            mtime = int(os.path.getmtime(db))
            wallets.append({'name': name, 'created_mtime': mtime})
except Exception:
    pass
print(json.dumps(wallets))
" "$root"
