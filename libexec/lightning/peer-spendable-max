#!/bin/bash
# lightning peer-spendable-max   (FEAT-2558)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_totals = {}
for ch in channels:
    pid = ch.get('peer_id', '')
    peer_totals[pid] = peer_totals.get(pid, 0) + ch.get('spendable_msat', 0)
if not peer_totals:
    print(json.dumps({'error': 'no channels'}))
else:
    best_peer = max(peer_totals, key=lambda p: peer_totals[p])
    print(json.dumps({'peer_id': best_peer, 'spendable_msat': peer_totals[best_peer]}))
" "$result"
