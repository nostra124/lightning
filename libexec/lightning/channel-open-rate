#!/bin/bash
# lightning channel-open-rate   (FEAT-475)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json, time
channels = json.loads(sys.argv[1]).get('channels', [])
now = int(time.time())
week = 7 * 86400
recent = sum(1 for c in channels if now - c.get('opened_at', now) < week)
print(json.dumps({'total_channels': len(channels), 'opened_last_7d': recent}, separators=(',', ':')))
" "$result"
