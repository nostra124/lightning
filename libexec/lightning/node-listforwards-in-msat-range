#!/bin/bash
# lightning node-listforwards-in-msat-range   (FEAT-2789)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
vals = [f.get('in_msat', 0) for f in fwds if 'in_msat' in f]
if vals:
    in_msat_range = max(vals) - min(vals)
else:
    in_msat_range = None
print(json.dumps({'in_msat_range': in_msat_range, 'count': len(vals)}))
" "$result"
