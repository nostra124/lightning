#!/bin/bash
# lightning peer-channel-balance <peer_id>   (FEAT-1197)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-channel-balance <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
total_local = sum(c.get('to_us_msat', 0) for c in channels if isinstance(c.get('to_us_msat'), int))
print(json.dumps({'peer_id': pid, 'channel_count': len(channels), 'total_local_msat': total_local}))
" "$result" "$peer_id"
