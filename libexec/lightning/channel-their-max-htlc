#!/bin/bash
# lightning channel-their-max-htlc <channel_id>   (FEAT-1862)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-their-max-htlc <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        print(json.dumps({'channel_id': ch.get('channel_id'), 'their_max_htlc_msat': ch.get('their_max_htlc_value_in_flight_msat')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
