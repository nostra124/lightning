#!/bin/bash
# lightning node-feerate-normal   (FEAT-1774)
result=$(lightning-cli feerates normal 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fr = data.get('feerates', [{}])[0] if data.get('feerates') else data
print(json.dumps({'feerate': fr}))
" "$result"
