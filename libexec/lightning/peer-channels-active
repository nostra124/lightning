#!/bin/bash
# lightning peer-channels-active <peer_id>   (FEAT-857)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-channels-active <peer_id>"}'
    exit 0
fi
peer_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
active = [c for c in data.get('channels', []) if c.get('peer_id') == pid and c.get('peer_connected')]
print(json.dumps({'peer_id': pid, 'active_count': len(active)}))
" "$result" "$peer_id"
