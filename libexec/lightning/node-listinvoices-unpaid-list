#!/bin/bash
# lightning node-listinvoices-unpaid-list   (FEAT-2349)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
unpaid = [{'label': i.get('label', ''), 'amount_msat': i.get('amount_msat', 0)} for i in invoices if i.get('status') == 'unpaid']
print(json.dumps({'unpaid_invoices': unpaid}))
" "$result"
