#!/bin/bash
# lightning invoice-expiry-check <label>   (FEAT-865)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-expiry-check <label>"}'; exit 0; fi
label="$1"
if ! result=$(lightning-cli listinvoices "$label" 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1]); invs = data.get('invoices', [])
if invs:
    inv = invs[0]; exp = inv.get('expires_at', 0); now = int(time.time())
    print(json.dumps({'label': sys.argv[2], 'expired': exp < now, 'expires_at': exp}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result" "$label"
