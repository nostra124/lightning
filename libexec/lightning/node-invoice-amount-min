#!/bin/bash
# lightning node-invoice-amount-min   (FEAT-2314)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid' and 'amount_received_msat' in i]
if not paid:
    print(json.dumps({'min_amount_received_msat': None, 'count_paid': 0}))
else:
    min_val = min(i['amount_received_msat'] for i in paid)
    print(json.dumps({'min_amount_received_msat': min_val, 'count_paid': len(paid)}))
" "$result"
