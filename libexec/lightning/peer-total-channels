#!/bin/bash
# lightning peer-total-channels <node_id>   (FEAT-1946)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-total-channels <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nid = sys.argv[2]
for p in data.get('peers', []):
    if p.get('id') == nid:
        print(json.dumps({'node_id': nid, 'total_channels': len(p.get('channels', []))}))
        sys.exit(0)
print(json.dumps({'error': 'peer not found'}))
" "$result" "$node_id"
