#!/bin/bash
# lightning wallet-notes-rename <wallet_name> <old_key> <new_key>   (FEAT-1338)
if [ $# -lt 3 ]; then echo '{"error":"usage: wallet-notes-rename <wallet_name> <old_key> <new_key>"}'; exit 0; fi
wname="$1"; old_key="$2"; new_key="$3"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, sqlite3, json
db = sys.argv[1]; old_key = sys.argv[2]; new_key = sys.argv[3]; wname = sys.argv[4]
conn = sqlite3.connect(db)
row = conn.execute('SELECT value FROM notes WHERE key=?', (old_key,)).fetchone()
if not row:
    print(json.dumps({'error': 'key_not_found'}))
    conn.close(); exit()
conn.execute('INSERT OR REPLACE INTO notes (key, value) VALUES (?, ?)', (new_key, row[0]))
conn.execute('DELETE FROM notes WHERE key=?', (old_key,))
conn.commit(); conn.close()
print(json.dumps({'wallet': wname, 'old_key': old_key, 'new_key': new_key, 'ok': True}))
" "$db" "$old_key" "$new_key" "$wname" 2>/dev/null || echo '{"error":"db_error"}'
