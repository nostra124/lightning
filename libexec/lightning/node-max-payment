#!/bin/bash
# lightning node-max-payment   (FEAT-488)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
active = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
max_local = max((c.get('spendable_msat', 0) for c in active), default=0)
print(json.dumps({'max_sendable_msat': max_local, 'active_channels': len(active)}, separators=(',', ':')))
" "$result"
