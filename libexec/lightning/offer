#!/bin/bash
# lightning offer — create a BOLT-12 offer (reusable invoice).
#
# Implements: BOLT-12 per FEAT-173.
#   share/doc/lightning/standards/bolts/12-offer-encoding.md
#
# Usage:
#   lightning offer <sat>|any <description> [--qr]

set -e

[ $# -lt 2 ] && { echo "usage: lightning offer <sat>|any <description> [--qr]" >&2; exit 1; }

command -v lightning-cli >/dev/null || {
	echo "lightning: lightning-cli not found — install Core Lightning" >&2; exit 127; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

amount="$1"; desc="$2"; shift 2
want_qr=0

while [ $# -gt 0 ]; do
	case "$1" in
		--qr) want_qr=1; shift ;;
		*) echo "lightning offer: unknown flag '$1'" >&2; exit 1 ;;
	esac
done

# clightning's offer command takes amount in msat (or "any") + description.
if [ "$amount" = "any" ]; then
	amount_arg="any"
else
	amount_arg="$(( amount * 1000 ))msat"
fi

result=$(cli offer "$amount_arg" "$desc")
bolt12=$(jq -r .bolt12 <<<"$result")
offer_id=$(jq -r .offer_id <<<"$result")

echo "$bolt12"
echo "# offer_id: $offer_id" >&2

if [ "$want_qr" -eq 1 ] && [ -x "$SELF_LIBEXEC/lightning/qr" ]; then
	echo
	"$SELF_LIBEXEC/lightning/qr" "lightning:$bolt12"
fi
