#!/bin/bash
# lightning channel-total-balance   (FEAT-1676)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
local = sum(c.get('to_us_msat', 0) for c in channels)
total = sum(c.get('total_msat', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'local_msat': local, 'remote_msat': total - local, 'total_msat': total}))
" "$result"
