#!/bin/bash
# lightning node-graph-base-fee-avg   (FEAT-1629)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
fees = [c.get('base_fee_millisatoshi', 0) for c in channels]
if not fees:
    print(json.dumps({'count': 0, 'avg_base_fee_msat': None}))
    sys.exit(0)
print(json.dumps({'count': len(fees), 'avg_base_fee_msat': sum(fees) / len(fees)}))
" "$result"
