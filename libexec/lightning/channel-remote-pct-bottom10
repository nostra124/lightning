#!/bin/bash
# lightning channel-remote-pct-bottom10   (FEAT-2740)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
enriched = []
for c in channels:
    total = c.get('total_msat', 0)
    to_us = c.get('to_us_msat', 0)
    remote = total - to_us if total else 0
    pct = round(remote / total * 100, 2) if total else 0
    enriched.append({'short_channel_id': c.get('short_channel_id',''), 'peer_id': c.get('peer_id',''), 'remote_msat': remote, 'total_msat': total, 'remote_pct': pct})
bottom10 = sorted(enriched, key=lambda x: x['remote_pct'])[:10]
print(json.dumps({'bottom10_by_remote_pct': bottom10}))
" "$result"
