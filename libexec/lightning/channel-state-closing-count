#!/bin/bash
# lightning channel-state-closing-count   (FEAT-2195)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
closing_states = {'CHANNELD_SHUTTING_DOWN','CLOSINGD_SIGEXCHANGE','CLOSINGD_COMPLETE','AWAITING_UNILATERAL','FUNDING_SPEND_SEEN','ONCHAIN'}
count = sum(1 for ch in channels if ch.get('state','') in closing_states)
print(json.dumps({'closing_channel_count': count, 'total_channels': len(channels)}))
" "$result"
