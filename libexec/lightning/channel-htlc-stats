#!/bin/bash
# lightning channel-htlc-stats   (FEAT-2120)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
htlc_counts = [len(ch.get('htlcs', [])) for ch in channels]
total = sum(htlc_counts)
avg = int(total / len(htlc_counts)) if htlc_counts else 0
print(json.dumps({'total_htlcs': total, 'avg_htlcs_per_channel': avg, 'channel_count': len(channels)}))
" "$result"
