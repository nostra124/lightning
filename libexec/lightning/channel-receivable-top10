#!/bin/bash
# lightning channel-receivable-top10   (FEAT-2720)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
sorted_ch = sorted(channels, key=lambda c: c.get('receivable_msat', 0), reverse=True)[:10]
top10 = [{'short_channel_id': c.get('short_channel_id'), 'receivable_msat': c.get('receivable_msat', 0)} for c in sorted_ch]
print(json.dumps({'top10_by_receivable': top10}))
" "$result"
