#!/bin/bash
# lightning channel-force-close <channel_id>   (FEAT-469)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-force-close <channel_id>"}'
    exit 0
fi
channel_id="$1"
result=$(lightning-cli close "$channel_id" unilateraltimeout=1 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
