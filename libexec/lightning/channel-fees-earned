#!/bin/bash
# lightning channel-fees-earned <channel_id>   (FEAT-540)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-fees-earned <channel_id>"}'
    exit 0
fi
channel_id="$1"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
fwds = [f for f in data.get('forwards', []) if (f.get('in_channel') == cid or f.get('out_channel') == cid) and f.get('status') == 'settled']
total_fee = sum(f.get('fee_msat', 0) for f in fwds)
print(json.dumps({'channel_id': cid, 'forwards': len(fwds), 'fee_msat': total_fee, 'fee_sat': total_fee // 1000}))
" "$result" "$channel_id"
