#!/bin/bash
# lightning channel-fee-proportional-min   (FEAT-2782)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('fee_proportional_millionths') for c in channels if c.get('fee_proportional_millionths') is not None]
fee_min = min(vals) if vals else None
print(json.dumps({'fee_proportional_min': fee_min, 'count': len(vals)}))
" "$result"
