#!/bin/bash
# lightning peer-node-id <pubkey>   (FEAT-1926)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-node-id <pubkey>"}'; exit 0; fi
pubkey="$1"
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pubkey = sys.argv[2]
for p in data.get('peers', []):
    if p.get('id') == pubkey:
        print(json.dumps({'node_id': p.get('id'), 'connected': p.get('connected'), 'num_channels': len(p.get('channels', []))}))
        sys.exit(0)
print(json.dumps({'error': 'peer not found'}))
" "$result" "$pubkey"
