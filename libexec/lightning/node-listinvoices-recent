#!/bin/bash
# lightning node-listinvoices-recent   (FEAT-2249)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
recent = invoices[-5:] if len(invoices) >= 5 else invoices
out = [{'label': i.get('label'), 'status': i.get('status'), 'amount_msat': i.get('amount_msat')} for i in recent]
print(json.dumps({'recent_invoices': out}))
" "$result"
