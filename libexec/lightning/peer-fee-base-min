#!/bin/bash
# lightning peer-fee-base-min   (FEAT-2428)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'peer_id': None, 'fee_base_msat': None, 'channel_count': 0}))
else:
    best = min(channels, key=lambda c: c.get('fee_base_msat', float('inf')))
    print(json.dumps({'peer_id': best.get('peer_id'), 'fee_base_msat': best.get('fee_base_msat'), 'channel_count': len(channels)}))
" "$result"
