#!/bin/bash
# lightning peer-uptime-avg   (FEAT-2234)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
if not peers:
    print(json.dumps({'error': 'no peers'}))
    sys.exit(0)
connected = sum(1 for p in peers if p.get('connected'))
total = len(peers)
avg = connected / total if total else 0
print(json.dumps({'connected': connected, 'total': total, 'uptime_ratio': round(avg, 4)}))
" "$result"
