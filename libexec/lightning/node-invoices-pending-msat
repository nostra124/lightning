#!/bin/bash
# lightning node-invoices-pending-msat   (FEAT-991)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pending = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid']
total = sum(i.get('amount_msat', 0) for i in pending)
print(json.dumps({'pending_count': len(pending), 'total_msat': total}))
" "$result"
