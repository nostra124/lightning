#!/bin/bash
# lightning node-graph-channels-total   (FEAT-1254)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
active = sum(1 for c in channels if c.get('active'))
print(json.dumps({'total': len(channels), 'active': active}))
" "$result"
