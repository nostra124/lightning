#!/bin/bash
# lightning peer-disconnect <node_id>   (FEAT-679)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-disconnect <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli disconnect "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps(d))" "$result"
