#!/bin/bash
# lightning peer-disconnect <peer_id>   (FEAT-471)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-disconnect <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli disconnect "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
