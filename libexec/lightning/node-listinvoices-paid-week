#!/bin/bash
# lightning node-listinvoices-paid-week   (FEAT-2559)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
now = time.time()
week_ago = now - 7 * 86400
count = sum(
    1 for i in data.get('invoices', [])
    if i.get('status') == 'paid' and i.get('paid_at', 0) >= week_ago
)
print(json.dumps({'paid_week_count': count}))
" "$result"
