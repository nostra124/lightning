#!/bin/bash
# lightning peer-first-channel <peer_id>   (FEAT-1117)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-first-channel <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [ch for ch in data.get('channels', []) if ch.get('peer_id') == pid]
channels.sort(key=lambda c: c.get('opened_at', 0))
first = channels[0] if channels else None
print(json.dumps({'peer_id': pid, 'first_channel': first}))
" "$result" "$peer_id"
