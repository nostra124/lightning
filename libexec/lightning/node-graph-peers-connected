#!/bin/bash
# lightning node-graph-peers-connected   (FEAT-1894)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
connected = [p for p in peers if p.get('connected')]
print(json.dumps({'total': len(peers), 'connected': len(connected), 'disconnected': len(peers) - len(connected)}))
" "$result"
