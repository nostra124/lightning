#!/bin/bash
# lightning node-listforwards-min-fee   (FEAT-1869)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
fees = [f.get('fee_msat', 0) for f in fwds if f.get('fee_msat') is not None]
mn = min(fees) if fees else 0
print(json.dumps({'count': len(fwds), 'min_fee_msat': mn}))
" "$result"
