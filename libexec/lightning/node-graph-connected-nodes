#!/bin/bash
# lightning node-graph-connected-nodes   (FEAT-1714)
result=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
connected = [n for n in nodes if n.get('last_timestamp')]
print(json.dumps({'total': len(nodes), 'seen_recently': len(connected)}))
" "$result"
