#!/bin/bash
# lightning node-drain-check   (FEAT-527)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
drained = []
for ch in channels:
    local = ch.get('to_us_msat', 0)
    cap = ch.get('total_msat', 1)
    if cap > 0 and local / cap < 0.05:
        drained.append({'channel_id': ch.get('channel_id'), 'local_msat': local, 'total_msat': cap})
print(json.dumps({'drained_channels': drained, 'count': len(drained)}))
" "$result"
