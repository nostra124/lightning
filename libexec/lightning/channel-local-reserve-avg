#!/bin/bash
# lightning channel-local-reserve-avg   (FEAT-2430)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('our_reserve_msat', 0) for c in channels if 'our_reserve_msat' in c]
avg = int(sum(vals) / len(vals)) if vals else 0
print(json.dumps({'reserve_avg_msat': avg, 'channel_count': len(vals)}))
" "$result"
