#!/bin/bash
# lightning node-channel-open-avg-size   (FEAT-934)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
chs = data.get('channels', [])
if chs:
    avg = sum(c.get('total_msat', 0) for c in chs) / len(chs)
    print(json.dumps({'channel_count': len(chs), 'avg_size_msat': round(avg)}))
else:
    print(json.dumps({'channel_count': 0, 'avg_size_msat': 0}))
" "$result"
