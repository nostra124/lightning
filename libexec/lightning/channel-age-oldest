#!/bin/bash
# lightning channel-age-oldest   (FEAT-2148)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
with_time = [c for c in channels if c.get('opened_at') or c.get('funding_txid')]
if not with_time:
    print(json.dumps({'oldest': None}))
    sys.exit(0)
by_time = [c for c in channels if c.get('opened_at')]
if by_time:
    oldest = min(by_time, key=lambda c: c['opened_at'])
    print(json.dumps({'oldest': {'peer_id': oldest.get('peer_id',''), 'opened_at': oldest.get('opened_at'), 'short_channel_id': oldest.get('short_channel_id','')}}))
else:
    c = channels[0]
    print(json.dumps({'oldest': {'peer_id': c.get('peer_id',''), 'short_channel_id': c.get('short_channel_id','')}}))
" "$result"
