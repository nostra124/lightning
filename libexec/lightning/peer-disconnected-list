#!/bin/bash
# lightning peer-disconnected-list   (FEAT-2283)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
disconnected = [p['id'] for p in peers if not p.get('connected', True)]
print(json.dumps({'disconnected_peers': disconnected}))
" "$result"
