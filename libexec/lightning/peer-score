#!/bin/bash
# lightning peer-score <peer_id>   (FEAT-1107)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-score <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
channels = [ch for ch in data.get('channels', []) if ch.get('peer_id') == pid]
active = sum(1 for ch in channels if ch.get('state') == 'CHANNELD_NORMAL')
score = round(active / len(channels) * 100, 1) if channels else 0
print(json.dumps({'peer_id': pid, 'channel_count': len(channels), 'active_count': active, 'score': score}))
" "$result" "$peer_id"
