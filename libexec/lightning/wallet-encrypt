#!/bin/bash
# lightning wallet-encrypt <wallet_name> <passphrase>   (FEAT-768)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-encrypt <wallet_name> <passphrase>"}'; exit 0; fi
wname="$1"; pass="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
hash=$(echo -n "$pass" | sha256sum | cut -d' ' -f1)
if sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('enc_hash','$hash')" 2>/dev/null; then
    echo "{\"ok\":true,\"wallet\":\"$wname\",\"encrypted\":true}"
else
    echo '{"error":"encrypt failed"}'
fi
