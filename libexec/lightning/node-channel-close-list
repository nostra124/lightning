#!/bin/bash
# lightning node-channel-close-list   (FEAT-1049)
result=$(lightning-cli listclosedchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
closed = data.get('closedchannels', [])
out = [{'channel_id': ch.get('channel_id'), 'close_cause': ch.get('close_cause')} for ch in closed]
print(json.dumps({'count': len(out), 'channels': out}))
" "$result"
