#!/bin/bash
# lightning invoice-list-settled   (FEAT-1305)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = [i for i in data.get('invoices', []) if i.get('status') == 'paid']
print(json.dumps({'count': len(invs), 'invoices': invs}))
" "$result"
