#!/bin/bash
# lightning channel-max-receivable   (FEAT-1180)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
if not channels:
    print(json.dumps({'max_receivable_msat': 0}))
    sys.exit(0)
max_recv = max((c.get('receivable_msat', 0) for c in channels), default=0)
print(json.dumps({'max_receivable_msat': max_recv}))
" "$result"
