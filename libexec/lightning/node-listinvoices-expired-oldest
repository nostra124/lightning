#!/bin/bash
# lightning node-listinvoices-expired-oldest   (FEAT-2439)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
expired = [i for i in data.get('invoices', []) if i.get('status') == 'expired']
if expired:
    oldest = min(expired, key=lambda i: i.get('expires_at', 0))
    print(json.dumps({'label': oldest.get('label', ''), 'expires_at': oldest.get('expires_at', 0), 'amount_msat': oldest.get('amount_msat', 0)}))
else:
    print(json.dumps({'label': None, 'expires_at': None, 'amount_msat': None}))
" "$result"
