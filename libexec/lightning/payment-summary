#!/bin/bash
# lightning payment-summary   (FEAT-465)
if ! result=$(lightning-cli listpays 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
pays = json.loads(sys.argv[1]).get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
failed = [p for p in pays if p.get('status') == 'failed']
pending = [p for p in pays if p.get('status') == 'pending']
total_msat = sum(p.get('amount_sent_msat', 0) for p in complete)
print(json.dumps({'total': len(pays), 'complete': len(complete), 'failed': len(failed),
    'pending': len(pending), 'total_sent_msat': total_msat}, separators=(',', ':')))
" "$result"
