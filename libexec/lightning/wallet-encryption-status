#!/bin/bash
# lightning wallet-encryption-status <wallet_name>   (FEAT-908)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-encryption-status <wallet_name>"}'; exit 0; fi
wname="$1"; root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$wname" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
encrypted=false
[ -f "$root/$wname/.encrypted" ] && encrypted=true
echo "{\"wallet\":\"$wname\",\"encrypted\":$encrypted}"
