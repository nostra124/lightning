#!/bin/bash
# lightning node-plugin-list   (FEAT-314)
#
# Lists active CLN plugins.
# Returns [{name, active, dynamic}]

set -e
LD="--lightning-dir=${LIGHTNING_DIR:-$HOME/.lightning}"
NET="--network=${LIGHTNING_NETWORK:-bitcoin}"

command -v lightning-cli >/dev/null || { echo '[]'; exit 0; }

raw=$(lightning-cli $LD $NET plugin list 2>/dev/null) || { echo '[]'; exit 0; }

python3 -c "
import sys, json
d = json.loads(sys.argv[1])
plugins = d.get('plugins', [])
result = []
for p in plugins:
    result.append({
        'name': p.get('name', ''),
        'active': bool(p.get('active', True)),
        'dynamic': bool(p.get('dynamic', False)),
    })
print(json.dumps(result, separators=(',', ':')))
" "$raw"
