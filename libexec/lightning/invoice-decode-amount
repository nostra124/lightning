#!/bin/bash
# lightning invoice-decode-amount <bolt11>   (FEAT-595)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: invoice-decode-amount <bolt11>"}'
    exit 0
fi
bolt11="$1"
result=$(lightning-cli decodepay "$bolt11" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
if 'code' in data:
    print(json.dumps({'error': data.get('message', 'decode failed')}))
else:
    msat = data.get('amount_msat', 0)
    print(json.dumps({'amount_msat': msat, 'amount_sat': msat // 1000 if msat else 0, 'currency': data.get('currency')}))
" "$result"
