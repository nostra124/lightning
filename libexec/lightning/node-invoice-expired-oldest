#!/bin/bash
# lightning node-invoice-expired-oldest   (FEAT-2304)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
expired = [i for i in invoices if i.get('status') == 'expired']
if not expired:
    print(json.dumps({'oldest_expired_invoice': None}))
    sys.exit(0)
oldest = min(expired, key=lambda i: i.get('expires_at', 0))
print(json.dumps({'oldest_expired_invoice': oldest.get('label'), 'expires_at': oldest.get('expires_at')}))
" "$result"
