#!/bin/bash
# lightning peer-capacity-sum   (FEAT-2858)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peers = {}
for ch in channels:
    pid = ch.get('peer_id', 'unknown')
    cap = ch.get('total_msat', 0)
    peers[pid] = peers.get(pid, 0) + cap
print(json.dumps({'capacity_sum_peer_msat': peers}))
" "$result"
