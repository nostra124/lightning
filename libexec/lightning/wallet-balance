#!/bin/bash
# lightning wallet-balance <wallet_name>   (FEAT-558)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-balance <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
balance=$(sqlite3 "$db" "SELECT COALESCE(SUM(amount_msat),0) FROM transactions WHERE type='receive';" 2>/dev/null) || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"balance_msat\":$balance}"
