#!/bin/bash
# lightning node-invoice-avg-msat   (FEAT-1987)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
amounts = [i.get('amount_msat', 0) for i in invoices if i.get('amount_msat') is not None]
n = len(invoices)
avg = round(sum(amounts) / len(amounts), 2) if amounts else None
print(json.dumps({'total_invoices': n, 'avg_amount_msat': avg}))
" "$result"
