#!/bin/bash
# lightning node-listchannels-public   (FEAT-1184)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
public = [c for c in data.get('channels', []) if c.get('public')]
print(json.dumps({'count': len(public), 'channels': [c.get('short_channel_id') for c in public]}))
" "$result"
