#!/bin/bash
# lightning node-listchannels-public   (FEAT-1524)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
public = [c for c in channels if not c.get('private')]
print(json.dumps({'total': len(channels), 'public': len(public)}))
" "$result"
