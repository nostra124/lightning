#!/bin/bash
# lightning channel-our-fee-summary   (FEAT-2062)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
summary = []
for ch in channels:
    updates = ch.get('updates', {}).get('local', {})
    summary.append({
        'channel_id': ch.get('channel_id', ''),
        'base_fee_millisatoshi': updates.get('fee_base_msat', 0),
        'fee_per_millionth': updates.get('fee_proportional_millionths', 0),
    })
print(json.dumps({'fee_summary': summary}))
" "$result"
