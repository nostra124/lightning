#!/bin/bash
# lightning channel-private-list   (FEAT-842)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
priv = [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id')} for c in data.get('channels', []) if c.get('private')]
print(json.dumps({'count': len(priv), 'channels': priv}))
" "$result"
