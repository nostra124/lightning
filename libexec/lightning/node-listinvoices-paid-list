#!/bin/bash
# lightning node-listinvoices-paid-list   (FEAT-2279)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
paid = [
    {'payment_hash': i.get('payment_hash'), 'amount_msat': i.get('amount_received_msat', i.get('amount_msat'))}
    for i in data.get('invoices', [])
    if i.get('status') == 'paid'
]
print(json.dumps({'paid_invoices': paid}))
" "$result"
