#!/bin/bash
# lightning node-listinvoices-expired   (FEAT-2007)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
expired = [i for i in invoices if i.get('status') == 'expired']
print(json.dumps({'expired_invoices': expired, 'count': len(expired)}))
" "$result"
