#!/bin/bash
# lightning peer-connected-list   (FEAT-2273)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = [p['id'] for p in data.get('peers', []) if p.get('connected')]
print(json.dumps({'connected_peers': peers}))
" "$result"
