#!/bin/bash
# lightning node-graph-fee-base-stats   (FEAT-2154)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('base_fee_millisatoshi', 0) for c in channels if 'base_fee_millisatoshi' in c]
if not vals:
    print(json.dumps({'min': None, 'max': None, 'avg': None, 'count': 0}))
else:
    print(json.dumps({'min': min(vals), 'max': max(vals), 'avg': sum(vals)/len(vals), 'count': len(vals)}))
" "$result"
