#!/bin/bash
# lightning wallet-notes-all   (FEAT-1828)
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
rows=$(sqlite3 "$db" "SELECT key, value, tag FROM notes ORDER BY key;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
rows = [r.split('|') for r in sys.argv[1].splitlines() if r]
notes = [{'key': r[0], 'value': r[1] if len(r)>1 else '', 'tag': r[2] if len(r)>2 else ''} for r in rows]
print(json.dumps({'notes': notes, 'count': len(notes)}))
" "$rows"
