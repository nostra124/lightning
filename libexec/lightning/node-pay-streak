#!/bin/bash
# lightning node-pay-streak   (FEAT-2219)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
pays.sort(key=lambda x: x.get('completed_at', x.get('created_at', 0)), reverse=True)
streak = 0
for p in pays:
    if p.get('status') == 'complete':
        streak += 1
    else:
        break
print(json.dumps({'streak': streak, 'total_pays': len(pays)}))
" "$result"
