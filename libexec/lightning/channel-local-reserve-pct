#!/bin/bash
# lightning channel-local-reserve-pct   (FEAT-2038)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
results = []
for ch in channels:
    cid = ch.get('channel_id', ch.get('short_channel_id', ''))
    reserve = ch.get('our_reserve_msat', 0)
    to_us = ch.get('to_us_msat', 0)
    if to_us > 0:
        pct = round(100.0 * reserve / to_us, 2)
    else:
        pct = 0
    results.append({'channel_id': cid, 'local_reserve_pct': pct})
print(json.dumps({'channels': results}))
" "$result"
