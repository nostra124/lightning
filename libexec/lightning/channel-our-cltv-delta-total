#!/bin/bash
# lightning channel-our-cltv-delta-total   (FEAT-1632)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0; count = 0
for ch in channels:
    local = ch.get('updates', {}).get('local', {})
    delta = local.get('cltv_expiry_delta')
    if delta is not None:
        total += delta; count += 1
print(json.dumps({'channel_count': count, 'total_cltv_delta': total}))
" "$result"
