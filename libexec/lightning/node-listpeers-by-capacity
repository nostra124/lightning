#!/bin/bash
# lightning node-listpeers-by-capacity <min_sat>   (FEAT-1654)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-listpeers-by-capacity <min_sat>"}'; exit 0
fi
min_sat="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
min_sat = int(sys.argv[2])
peer_caps = {}
for ch in data.get('channels', []):
    pid = ch.get('peer_id')
    cap = ch.get('total_msat', 0) // 1000
    peer_caps[pid] = peer_caps.get(pid, 0) + cap
result = [{'peer_id': p, 'capacity_sat': c} for p, c in peer_caps.items() if c >= min_sat]
print(json.dumps({'count': len(result), 'peers': result}))
" "$result" "$min_sat"
