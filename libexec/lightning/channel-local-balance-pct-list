#!/bin/bash
# lightning channel-local-balance-pct-list   (FEAT-2208)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
entries = []
for c in channels:
    local = c.get('to_us_msat', 0)
    total = c.get('total_msat', 0)
    try:
        local = int(str(local).replace('msat',''))
        total = int(str(total).replace('msat',''))
    except Exception:
        continue
    pct = round(local / total * 100, 2) if total > 0 else 0.0
    entries.append({'channel_id': c.get('channel_id',''), 'local_pct': pct})
print(json.dumps({'channels': entries, 'count': len(entries)}))
" "$result"
