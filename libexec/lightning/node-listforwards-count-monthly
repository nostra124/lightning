#!/bin/bash
# lightning node-listforwards-count-monthly   (FEAT-2889)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
month_ago = time.time() - 30 * 86400
count = sum(1 for f in forwards if f.get('resolved_time', 0) >= month_ago)
print(json.dumps({'forwards_count_monthly': count}))
" "$result"
