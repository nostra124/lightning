#!/bin/bash
# lightning channel-close-count   (FEAT-1726)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
closed = [c for c in channels if c.get('state') in ('ONCHAIN', 'CLOSED')]
print(json.dumps({'total': len(channels), 'closed': len(closed)}))
" "$result"
