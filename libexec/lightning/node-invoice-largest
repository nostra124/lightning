#!/bin/bash
# lightning node-invoice-largest   (FEAT-2087)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [inv for inv in invoices if inv.get('status') == 'paid']
if paid:
    largest = max(paid, key=lambda x: x.get('amount_received_msat', 0))
    print(json.dumps({'largest_invoice': largest}))
else:
    print(json.dumps({'largest_invoice': None}))
" "$result"
