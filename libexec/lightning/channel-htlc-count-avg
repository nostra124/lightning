#!/bin/bash
# lightning channel-htlc-count-avg   (FEAT-2462)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'htlc_count_avg': 0, 'channel_count': 0}))
    sys.exit(0)
total_htlcs = sum(len(c.get('htlcs', [])) for c in channels)
avg = total_htlcs / len(channels)
print(json.dumps({'htlc_count_avg': avg, 'channel_count': len(channels)}))
" "$result"
