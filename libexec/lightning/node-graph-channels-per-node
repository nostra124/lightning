#!/bin/bash
# lightning node-graph-channels-per-node   (FEAT-1994)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
sources = [c.get('source') for c in channels if c.get('source')]
unique_nodes = len(set(sources))
total = len(channels)
avg = round(total / unique_nodes, 2) if unique_nodes else None
print(json.dumps({'unique_nodes': unique_nodes, 'total_channels': total, 'avg_channels_per_node': avg}))
" "$result"
