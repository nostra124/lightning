#!/bin/bash
# lightning channel-fee-ppm-bottom5   (FEAT-2690)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
enriched = [{'channel_id': c.get('channel_id',''), 'fee_proportional_millionths': c.get('fee_proportional_millionths', 0)} for c in channels]
bottom5 = sorted(enriched, key=lambda x: x['fee_proportional_millionths'])[:5]
print(json.dumps({'bottom5_by_fee_ppm': bottom5}))
" "$result"
