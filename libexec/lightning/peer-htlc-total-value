#!/bin/bash
# lightning peer-htlc-total-value   (FEAT-2383)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_msat = 0
for ch in channels:
    for h in ch.get('htlcs', []):
        amt = h.get('amount_msat', 0)
        if isinstance(amt, str) and amt.endswith('msat'):
            amt = int(amt[:-4])
        total_msat += int(amt)
print(json.dumps({'peer_htlc_total_value_msat': total_msat}))
" "$result"
