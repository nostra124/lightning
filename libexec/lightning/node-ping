#!/bin/bash
# lightning node-ping <peer_id>   (FEAT-335)
set -e
[ $# -ge 1 ] || { echo '{"error":"usage: node-ping <peer_id>"}'; exit 0; }
peer_id="$1"
result=$(lightning-cli ping "$peer_id" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
if 'totlen' in data:
    print(json.dumps({'ok': True, 'totlen': data['totlen']}, separators=(',', ':')))
else:
    print(json.dumps({'ok': False, 'detail': data}))
" "$result"
