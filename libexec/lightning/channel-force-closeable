#!/bin/bash
# lightning channel-force-closeable   (FEAT-1910)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
closeable = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'total': len(channels), 'force_closeable': len(closeable)}))
" "$result"
