#!/bin/bash
# lightning peer-our-reserve-total   (FEAT-2583)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
totals = {}
for c in channels:
    pid = c.get('peer_id', 'unknown')
    totals[pid] = totals.get(pid, 0) + int(c.get('our_reserve_msat', 0))
print(json.dumps({'peer_our_reserve_totals': totals}))
" "$result"
