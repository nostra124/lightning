#!/bin/bash
# lightning node-listchannels-by-node <node_id>   (FEAT-1664)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-listchannels-by-node <node_id>"}'; exit 0
fi
node_id="$1"
result=$(lightning-cli listchannels "source=$node_id" 2>/dev/null) || result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nid = sys.argv[2]
channels = [c for c in data.get('channels', []) if c.get('source') == nid or c.get('destination') == nid]
print(json.dumps({'node_id': nid, 'count': len(channels), 'channels': [c.get('short_channel_id') for c in channels]}))
" "$result" "$node_id"
