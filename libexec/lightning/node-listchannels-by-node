#!/bin/bash
# lightning node-listchannels-by-node <node_id>   (FEAT-1229)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listchannels-by-node <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listchannels "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
print(json.dumps({'node_id': sys.argv[2], 'count': len(channels), 'channels': [c.get('short_channel_id') for c in channels]}))
" "$result" "$node_id"
