#!/bin/bash
# lightning channel-htlc-value-total   (FEAT-2312)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
count = 0
for ch in channels:
    for htlc in ch.get('htlcs', []):
        total += htlc.get('amount_msat', 0)
        count += 1
print(json.dumps({'total_htlc_value_msat': total, 'htlc_count': count}))
" "$result"
