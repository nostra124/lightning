#!/bin/bash
# lightning wallet-notes-swap <wallet> <key1> <key2>   (FEAT-1643)
if [ $# -lt 3 ]; then
    echo '{"error":"usage: wallet-notes-swap <wallet> <key1> <key2>"}'; exit 0
fi
wname="$1"; key1="$2"; key2="$3"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
v1=$(sqlite3 "$db" "SELECT value FROM notes WHERE key='$key1';")
v2=$(sqlite3 "$db" "SELECT value FROM notes WHERE key='$key2';")
if [ -z "$v1" ] || [ -z "$v2" ]; then echo '{"error":"one or both keys not found"}'; exit 0; fi
sqlite3 "$db" "UPDATE notes SET value='$v2' WHERE key='$key1'; UPDATE notes SET value='$v1' WHERE key='$key2';" 2>/dev/null
echo "{\"wallet\":\"$wname\",\"swapped\":true,\"key1\":\"$key1\",\"key2\":\"$key2\"}"
