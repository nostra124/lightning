#!/bin/bash
# lightning peer-fee-ppm-min   (FEAT-2418)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
with_fee = [ch for ch in channels if 'fee_proportional_millionths' in ch]
if not with_fee:
    print(json.dumps({'peer_id': None, 'fee_ppm_min': None, 'channel_count': 0}))
    sys.exit(0)
best = min(with_fee, key=lambda ch: ch.get('fee_proportional_millionths', 0))
print(json.dumps({'peer_id': best.get('peer_id'), 'fee_ppm_min': best.get('fee_proportional_millionths'), 'channel_count': len(with_fee)}))
" "$result"
