#!/bin/bash
# lightning channel-close-type <channel_id>   (FEAT-1086)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: channel-close-type <channel_id>"}'
    exit 0
fi
channel_id="$1"
result=$(lightning-cli listclosedchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('closedchannels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        print(json.dumps({'channel_id': ch.get('channel_id'), 'close_cause': ch.get('close_cause'), 'closer': ch.get('closer')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
