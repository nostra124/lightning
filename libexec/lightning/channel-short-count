#!/bin/bash
# lightning channel-short-count   (FEAT-1906)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
with_scid = [c for c in channels if c.get('short_channel_id')]
print(json.dumps({'total': len(channels), 'with_scid': len(with_scid), 'without_scid': len(channels) - len(with_scid)}))
" "$result"
