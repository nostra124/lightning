#!/bin/bash
# lightning node-synced   (FEAT-639)
if ! result=$(lightning-cli getinfo 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'synced_to_chain': data.get('warning_bitcoind_sync') is None, 'synced_to_gossip': data.get('warning_lightningd_sync') is None, 'blockheight': data.get('blockheight')}))
" "$result"
