#!/bin/bash
# lightning node-htlc-max   (FEAT-681)
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
d = json.loads(sys.argv[1])
print(json.dumps({'max_payment_size_msat': d.get('max_payment_size_msat'), 'min_payment_size_msat': d.get('min_payment_size_msat')}))
" "$result"
