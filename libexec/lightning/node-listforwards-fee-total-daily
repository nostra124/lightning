#!/bin/bash
# lightning node-listforwards-fee-total-daily   (FEAT-2869)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
day_ago = time.time() - 86400
total = sum(f.get('fee_msat', 0) for f in forwards if f.get('received_time', 0) >= day_ago)
print(json.dumps({'fee_total_daily_msat': total}))
" "$result"
