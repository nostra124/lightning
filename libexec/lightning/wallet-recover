#!/bin/bash
# lightning wallet-recover <wallet_name> <backup_path>   (FEAT-713)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-recover <wallet_name> <backup_path>"}'; exit 0; fi
wname="$1"; backup="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
dest="$root/$wname"
if [ ! -f "$backup" ]; then echo '{"error":"backup file not found"}'; exit 0; fi
if [ -d "$dest" ]; then echo '{"error":"wallet already exists"}'; exit 0; fi
if mkdir -p "$dest" && cp "$backup" "$dest/state.db"; then
    echo "{\"ok\":true,\"wallet\":\"$wname\",\"path\":\"$dest\"}"
else
    echo '{"error":"recovery failed"}'
fi
