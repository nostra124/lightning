#!/bin/bash
# lightning wallet-recover <wallet_name>   (FEAT-503)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-recover <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
integrity=$(sqlite3 "$db" "PRAGMA integrity_check;" 2>/dev/null)
echo '{"wallet":"'"$wname"'","integrity":"'"$integrity"'"}'
