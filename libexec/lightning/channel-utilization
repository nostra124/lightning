#!/bin/bash
# lightning channel-utilization   (FEAT-1736)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL' and c.get('total_msat')]
utils = [{'channel_id': c.get('channel_id'), 'utilization_pct': round((1 - c.get('spendable_msat', 0) / c['total_msat']) * 100, 1)} for c in channels]
avg = sum(u['utilization_pct'] for u in utils) / len(utils) if utils else 0
print(json.dumps({'count': len(utils), 'avg_utilization_pct': round(avg, 1), 'channels': utils}))
" "$result"
