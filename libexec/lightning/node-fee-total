#!/bin/bash
# lightning node-fee-total   (FEAT-1189)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = [f for f in data.get('forwards', []) if f.get('status') == 'settled']
total_fee = sum(f.get('fee_msat', 0) for f in fwds if isinstance(f.get('fee_msat'), int))
print(json.dumps({'total_fee_msat': total_fee, 'settled_count': len(fwds)}))
" "$result"
