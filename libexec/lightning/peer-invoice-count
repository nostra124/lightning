#!/bin/bash
# lightning peer-invoice-count <node_id>   (FEAT-1976)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-invoice-count <node_id>"}'; exit 0; fi
arg="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
node_id = sys.argv[2]
invoices = data.get('invoices', [])
print(json.dumps({'node_id': node_id, 'total_invoices': len(invoices)}))
" "$result" "$arg"
