#!/bin/bash
# lightning peer-invoice-count <peer_id>   (FEAT-1177)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-invoice-count <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
matched = [i for i in data.get('invoices', []) if i.get('payer_note') == pid or str(i.get('pay_index','')) == pid]
print(json.dumps({'peer_id': pid, 'count': len(matched)}))
" "$result" "$peer_id"
