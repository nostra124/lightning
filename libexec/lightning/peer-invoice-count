#!/bin/bash
# lightning peer-invoice-count <peer_id>   (FEAT-1587)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-invoice-count <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = [i for i in data.get('invoices', []) if i.get('pay_index') is not None]
print(json.dumps({'peer_id': sys.argv[2], 'invoice_count': len(invs)}))
" "$result" "$peer_id"
