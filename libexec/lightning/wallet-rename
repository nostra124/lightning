#!/bin/bash
# lightning wallet-rename <old_name> <new_name>   (FEAT-748)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-rename <old_name> <new_name>"}'; exit 0; fi
old="$1"; new="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root/$old" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
if [ -d "$root/$new" ]; then echo '{"error":"target wallet already exists"}'; exit 0; fi
if mv "$root/$old" "$root/$new"; then
    echo "{\"ok\":true,\"old\":\"$old\",\"new\":\"$new\"}"
else
    echo '{"error":"rename failed"}'
fi
