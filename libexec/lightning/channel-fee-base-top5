#!/bin/bash
# lightning channel-fee-base-top5   (FEAT-2682)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
enriched = [{'channel_id': c.get('channel_id',''), 'fee_base_msat': c.get('fee_base_msat', 0)} for c in channels]
top5 = sorted(enriched, key=lambda x: x['fee_base_msat'], reverse=True)[:5]
print(json.dumps({'top5_by_fee_base': top5}))
" "$result"
