#!/bin/bash
# lightning channel-active-count   (FEAT-692)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
active = [c for c in data.get('channels', []) if c.get('peer_connected') and c.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'active': len(active), 'total': len(data.get('channels', []))}))
" "$result"
