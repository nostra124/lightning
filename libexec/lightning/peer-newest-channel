#!/bin/bash
# lightning peer-newest-channel   (FEAT-2343)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_block = -1
for ch in channels:
    scid = ch.get('short_channel_id', '')
    if scid:
        block = int(scid.split('x')[0])
        if block > best_block:
            best_block = block
            best = ch.get('peer_id', '')
print(json.dumps({'peer_id': best, 'block': best_block}))
" "\$result"
