#!/bin/bash
# lightning peer-remote-pct-avg   (FEAT-2778)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_totals = {}
peer_remote = {}
for ch in channels:
    pid = ch.get('peer_id', '')
    total = ch.get('total_msat', 0)
    to_them = ch.get('to_them_msat', 0)
    if isinstance(total, str): total = int(total.rstrip('msat'))
    if isinstance(to_them, str): to_them = int(to_them.rstrip('msat'))
    peer_totals[pid] = peer_totals.get(pid, 0) + total
    peer_remote[pid] = peer_remote.get(pid, 0) + to_them
pcts = []
for pid in peer_totals:
    if peer_totals[pid] > 0:
        pcts.append(peer_remote[pid] / peer_totals[pid] * 100)
if not pcts:
    print(json.dumps({'remote_pct_avg_peer': None}))
else:
    print(json.dumps({'remote_pct_avg_peer': round(sum(pcts) / len(pcts), 4)}))
" "$result"
