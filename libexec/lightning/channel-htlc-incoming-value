#!/bin/bash
# lightning channel-htlc-incoming-value   (FEAT-2322)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    for htlc in ch.get('htlcs', []):
        if htlc.get('direction') == 'in':
            total += htlc.get('amount_msat', 0)
print(json.dumps({'total_incoming_htlc_msat': total}))
" "$result"
