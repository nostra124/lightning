#!/bin/bash
# lightning node-channels-summary   (FEAT-671)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
by_state = {}
for c in channels:
    s = c.get('state', 'unknown')
    by_state[s] = by_state.get(s, 0) + 1
print(json.dumps({'total': len(channels), 'by_state': by_state}))
" "$result"
