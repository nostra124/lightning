#!/bin/bash
# lightning channel-peer-balance-total   (FEAT-2125)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = {}
for c in data.get('channels', []):
    pid = c.get('peer_id', 'unknown')
    local = c.get('to_us_msat', 0)
    total = c.get('total_msat', 0)
    remote = total - local
    if pid not in peers:
        peers[pid] = {'peer_id': pid, 'local_msat': 0, 'remote_msat': 0}
    peers[pid]['local_msat'] += local
    peers[pid]['remote_msat'] += remote
print(json.dumps({'peers': list(peers.values()), 'count': len(peers)}))
" "$result"
