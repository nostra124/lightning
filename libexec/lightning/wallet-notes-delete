#!/bin/bash
# lightning wallet-notes-delete <key>   (FEAT-1763)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-delete <key>"}'; exit 0; fi
key="$1"
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "DELETE FROM notes WHERE key='$key';" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"deleted\":true,\"key\":\"$key\"}"
