#!/bin/bash
# lightning wallet-notes-delete <wallet_name> <note_id>   (FEAT-1048)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-notes-delete <wallet_name> <note_id>"}'
    exit 0
fi
wname="$1"; nid="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
sqlite3 "$db" "DELETE FROM notes WHERE id='$nid';" 2>/dev/null
echo "{\"ok\":true,\"wallet\":\"$wname\",\"deleted\":\"$nid\"}"
