#!/bin/bash
# lightning api-account-history-note <address> <entry_id> <note>  (FEAT-254)
#
# Updates the note column for a ledger entry that belongs to the
# account.  Validates the row exists and belongs to the account before
# writing.  Returns {"ok":true} on success.

set -e
[ $# -eq 3 ] || exit 1
address="$1"; entry_id="$2"; note="$3"

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
case "$entry_id" in ''|*[!0-9]*) exit 2 ;; esac

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }

name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

rows=$(sqlite3 "$db" "SELECT COUNT(*) FROM ledger WHERE id = $entry_id AND account = $(sql_quote "$name");")
[ "${rows:-0}" -eq 1 ] || { echo '{"error":"entry_not_found"}'; exit 4; }

# Truncate note to 200 chars to mirror the pay verb limit.
note="${note:0:200}"
sqlite3 "$db" "UPDATE ledger SET note = $(sql_quote "$note") WHERE id = $entry_id AND account = $(sql_quote "$name");"

echo '{"ok":true}'
