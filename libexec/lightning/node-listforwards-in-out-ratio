#!/bin/bash
# lightning node-listforwards-in-out-ratio   (FEAT-2924)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total_in = 0
total_out = 0
for f in forwards:
    tin = f.get('in_msat', 0)
    tout = f.get('out_msat', 0)
    if isinstance(tin, str): tin = int(tin)
    if isinstance(tout, str): tout = int(tout)
    total_in += tin
    total_out += tout
ratio = round(total_in / total_out, 6) if total_out > 0 else 0
print(json.dumps({'in_out_ratio': ratio}))
" "$result"
