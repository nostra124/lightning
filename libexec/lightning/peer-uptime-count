#!/bin/bash
# lightning peer-uptime-count   (FEAT-2524)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
count = sum(1 for p in peers if p.get('connected', False))
print(json.dumps({'peer_uptime_count': count}))
" "$result"
