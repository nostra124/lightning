#!/bin/bash
# lightning channel-state-open-count   (FEAT-2175)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
count = sum(1 for ch in channels if ch.get('state') == 'CHANNELD_NORMAL')
print(json.dumps({'open_channel_count': count}))
" "$result"
