#!/bin/bash
# lightning node-pay-route-hop-max   (FEAT-2523)
result=$(lightning-cli listsendpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('payments', [])
max_hops = 0
for p in pays:
    hops = p.get('number_of_parts', 1)
    if hops > max_hops:
        max_hops = hops
print(json.dumps({'max_route_hops': max_hops}))
" "$result"
