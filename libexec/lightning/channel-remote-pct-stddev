#!/bin/bash
# lightning channel-remote-pct-stddev   (FEAT-2977)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pcts = []
for c in channels:
    total = c.get('total_msat', 0)
    remote = c.get('to_them_msat', 0)
    if total > 0:
        pcts.append(remote / total * 100)
if len(pcts) < 2:
    stddev = 0
else:
    mean = sum(pcts) / len(pcts)
    stddev = math.sqrt(sum((x - mean) ** 2 for x in pcts) / len(pcts))
print(json.dumps({'remote_pct_stddev_ch': round(stddev, 6)}))
" "$result"
