#!/bin/bash
# lightning node-pay-attempt-count   (FEAT-814)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'total_attempts': len(pays), 'complete': len([p for p in pays if p.get('status') == 'complete']), 'failed': len([p for p in pays if p.get('status') == 'failed'])}))
" "$result"
