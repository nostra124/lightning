#!/bin/bash
# lightning wallet-verify <wallet_name>   (FEAT-538)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-verify <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
check=$(sqlite3 "$db" "PRAGMA integrity_check;" 2>/dev/null) || { echo '{"error":"sqlite3 not found"}'; exit 0; }
if [ "$check" = "ok" ]; then
    echo "{\"wallet\":\"$wname\",\"integrity\":\"ok\"}"
else
    python3 -c "import sys,json; print(json.dumps({'wallet': sys.argv[1], 'integrity': 'fail', 'details': sys.argv[2]}))" "$wname" "$check"
fi
