#!/bin/bash
# lightning channel-remote-disabled   (FEAT-1406)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
disabled = [c.get('channel_id') for c in data.get('channels', []) if not c.get('peer_connected')]
print(json.dumps({'count': len(disabled), 'channel_ids': disabled}))
" "$result"
