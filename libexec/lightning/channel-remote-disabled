#!/bin/bash
# lightning channel-remote-disabled   (FEAT-1850)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
disabled = [c for c in channels if not c.get('peer_connected', True)]
print(json.dumps({'total': len(channels), 'remote_disconnected': len(disabled)}))
" "$result"
