#!/bin/bash
# lightning peer-oldest-channel-age <node_id>   (FEAT-1996)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-oldest-channel-age <node_id>"}'; exit 0; fi
arg="$1"
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
node_id = sys.argv[2]
peers = data.get('peers', [])
peer = next((p for p in peers if p.get('id') == node_id), None)
if not peer:
    print(json.dumps({'error': 'peer not found'}))
    sys.exit(0)
channels = peer.get('channels', [])
print(json.dumps({'node_id': node_id, 'channel_count': len(channels)}))
" "$result" "$arg"
