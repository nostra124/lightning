#!/bin/bash
# lightning channel-fee-base-max-channel   (FEAT-2375)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'channel_id': None, 'fee_base_msat': None}))
else:
    best = max(channels, key=lambda c: c.get('fee_base_msat', 0))
    print(json.dumps({'channel_id': best.get('short_channel_id') or best.get('channel_id'), 'peer_id': best.get('peer_id'), 'fee_base_msat': best.get('fee_base_msat')}))
" "$result"
