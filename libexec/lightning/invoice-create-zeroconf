#!/bin/bash
# lightning invoice-create-zeroconf <amount_msat> <label> [<desc>]   (FEAT-448)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: invoice-create-zeroconf <amount_msat> <label> [<desc>]"}'
    exit 0
fi
amount_msat="$1"; label="$2"; desc="${3:-zeroconf invoice}"
result=$(lightning-cli invoice "$amount_msat" "$label" "$desc" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
