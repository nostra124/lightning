#!/bin/bash
# lightning invoice-create-zeroamt <label> <description>   (FEAT-995)
if [ $# -lt 2 ]; then echo '{"error":"usage: invoice-create-zeroamt <label> <description>"}'; exit 0; fi
label="$1"; desc="$2"
if ! result=$(lightning-cli invoice any "$label" "$desc" 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
echo "$result"
