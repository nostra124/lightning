#!/bin/bash
# lightning channel-remote-pct-stats   (FEAT-2158)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pcts = []
for c in channels:
    local = c.get('to_us_msat', 0)
    total = c.get('total_msat', 0)
    if total and total > 0:
        remote = total - local
        pcts.append(remote / total * 100)
if not pcts:
    print(json.dumps({'min': None, 'max': None, 'avg': None, 'count': 0}))
else:
    print(json.dumps({'min': min(pcts), 'max': max(pcts), 'avg': sum(pcts)/len(pcts), 'count': len(pcts)}))
" "$result"
