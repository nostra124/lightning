#!/bin/bash
# lightning wallet-tag-set <wallet_name> <tag>   (FEAT-1073)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-tag-set <wallet_name> <tag>"}'
    exit 0
fi
wname="$1"; tag="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
echo "{\"ok\":true,\"wallet\":\"$wname\",\"tag\":\"$tag\"}"
