#!/bin/bash
# lightning invoice-list-by-index <index>   (FEAT-1585)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-list-by-index <index>"}'; exit 0; fi
index="$1"
result=$(lightning-cli listinvoices index=created start="$index" limit=1 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
print(json.dumps({'index': sys.argv[2], 'count': len(invs), 'invoices': invs}))
" "$result" "$index"
