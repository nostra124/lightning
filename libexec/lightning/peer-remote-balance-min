#!/bin/bash
# lightning peer-remote-balance-min   (FEAT-2398)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_remote = {}
for c in channels:
    pid = c.get('peer_id', '')
    peer_remote[pid] = peer_remote.get(pid, 0) + c.get('remote_msat', 0)
if not peer_remote:
    print(json.dumps({'peer_remote_balance_min': None}))
    sys.exit(0)
pid = min(peer_remote, key=lambda k: peer_remote[k])
print(json.dumps({'peer_remote_balance_min': {'peer_id': pid, 'total_remote_msat': peer_remote[pid]}}))
" "$result"
