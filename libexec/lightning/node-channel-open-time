#!/bin/bash
# lightning node-channel-open-time   (FEAT-1014)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
out = [{'channel_id': ch.get('channel_id'), 'opened_at': ch.get('opened_at')} for ch in channels if ch.get('opened_at')]
print(json.dumps({'count': len(out), 'channels': out}))
" "$result"
