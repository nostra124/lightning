#!/bin/bash
# lightning channel-local-balance-smallest   (FEAT-2198)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
def local(ch):
    v = ch.get('to_us_msat', 0)
    return int(str(v).rstrip('msat')) if v else 0
ch = min(channels, key=local)
print(json.dumps({'channel_id': ch.get('channel_id',''), 'peer_id': ch.get('peer_id',''), 'local_msat': local(ch)}))
" "$result"
