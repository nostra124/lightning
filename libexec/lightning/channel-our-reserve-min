#!/bin/bash
# lightning channel-our-reserve-min   (FEAT-2540)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best = None
best_val = None
for ch in channels:
    val = ch.get('our_reserve_msat', None)
    if val is None:
        continue
    if isinstance(val, str):
        val = int(val.rstrip('msat')) if val.endswith('msat') else int(val)
    if best_val is None or val < best_val:
        best_val = val
        best = ch.get('channel_id', '')
print(json.dumps({'our_reserve_msat': best_val, 'channel_id': best}))
" "$result"
