#!/bin/bash
# lightning node-pay-amount-total-weekly   (FEAT-2854)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
week_ago = time.time() - 7 * 86400
total = 0
for p in pays:
    created = p.get('created_at', 0)
    if created >= week_ago:
        total += p.get('amount_sent_msat', 0)
print(json.dumps({'amount_total_weekly_msat': total}))
" "$result"
