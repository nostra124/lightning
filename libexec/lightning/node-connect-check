#!/bin/bash
# lightning node-connect-check <node_id>   (FEAT-751)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-connect-check <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listpeers "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
if peers:
    print(json.dumps({'connected': peers[0].get('connected'), 'id': peers[0].get('id')}))
else:
    print(json.dumps({'connected': False, 'id': sys.argv[2]}))
" "$result" "$node_id"
