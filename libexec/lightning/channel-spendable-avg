#!/bin/bash
# lightning channel-spendable-avg   (FEAT-2412)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [ch.get('spendable_msat', 0) for ch in channels if 'spendable_msat' in ch]
avg = sum(vals) / len(vals) if vals else 0
print(json.dumps({'spendable_avg_msat': avg, 'channel_count': len(vals)}))
" "$result"
