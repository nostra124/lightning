#!/bin/bash
# lightning peer-remote-balance-avg   (FEAT-2433)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peers = {}
for ch in channels:
    pid = ch.get('peer_id', '')
    remote = ch.get('remote_msat', 0)
    if pid:
        peers.setdefault(pid, []).append(remote)
if peers:
    totals = [sum(v) for v in peers.values()]
    avg = sum(totals) / len(totals)
else:
    avg = 0
print(json.dumps({'remote_balance_avg_msat': int(avg), 'peer_count': len(peers)}))
" "$result"
