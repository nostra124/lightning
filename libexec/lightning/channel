# --- Balance entropy ---
cmd_balance_entropy() {
	cli listpeerchannels | python3 -c "
import sys, json, math
chs = json.load(sys.stdin).get('channels', [])
pcts = []
for c in chs:
    t = c.get('total_msat', 0); l = c.get('to_us_msat', 0)
    if t > 0: pcts.append(l/t)
n = len(pcts)
if n == 0: print(json.dumps({'error': 'no channels'})); sys.exit(0)
buckets = [0]*10
for p in pcts: buckets[min(int(p*10),9)] += 1
e = sum(-b/n*math.log2(b/n) for b in buckets if b > 0)
print(json.dumps({'balance_entropy_bits': round(e,4), 'channel_count': n}))
"
}

