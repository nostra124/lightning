# Consolidated channel-* micro-verbs (FEAT-203 consolidation)
#
# Three categories absorbed from origin/master:
#   stats          — one Python pass over listpeerchannels computing all
#                    statistical metrics (capacity, balance, fee, HTLC, age).
#   operational    — mutation / inspection subcommands with named case arms.
#   inspect        — full per-channel field dump for a single channel.
# ---------------------------------------------------------------------------

# cmd_stats [--field <name>] [--format tsv]
# One Python pass computes all statistical metrics and outputs JSON.
cmd_stats() {
	local field="" fmt="json"
	while [ $# -gt 0 ]; do
		case "$1" in
			--field)  field="$2"; shift 2 ;;
			--format) fmt="$2";   shift 2 ;;
			--help|-h)
				cat <<'EOF'
usage: lightning channel stats [--field <name>] [--format tsv]

Compute statistical metrics over all channels in one pass.
Output: JSON object with all fields, or a single value with --field.

Capacity fields:
  capacity_count, capacity_sum_msat, capacity_avg_msat,
  capacity_min_msat, capacity_max_msat, capacity_stddev_msat,
  capacity_skewness, capacity_kurtosis, capacity_gini,
  capacity_p10_msat, capacity_p25_msat, capacity_p50_msat,
  capacity_p75_msat, capacity_p90_msat,
  capacity_top10, capacity_bottom10

Balance-ratio fields (local/total per channel):
  balance_ratio_avg, balance_ratio_min, balance_ratio_max,
  balance_ratio_stddev, balance_ratio_gini, balance_ratio_variance,
  balance_entropy_bits, imbalanced_count,
  local_balance_sum_msat, remote_balance_sum_msat,
  local_balance_avg_msat, local_balance_stddev_msat

Fee fields:
  fee_base_avg_msat, fee_base_stddev_msat,
  fee_base_min_msat, fee_base_max_msat, fee_base_total_msat,
  fee_ppm_avg, fee_ppm_stddev, fee_ppm_min, fee_ppm_max

HTLC fields:
  htlc_count_total, htlc_count_avg, htlc_in_flight_total,
  htlc_max_avg_msat, htlc_min_avg_msat

State / misc:
  active_count, normal_count, pending_count, closing_count,
  peer_count, both_reserves_avg_msat
EOF
				return 0 ;;
			*) echo "channel stats: unknown flag '$1'" >&2; exit 1 ;;
		esac
	done

	local raw; raw=$(cli listpeerchannels 2>/dev/null) || {
		echo '{"error":"lightning-cli not found"}'; exit 0; }

	python3 - "$raw" "$field" "$fmt" <<'PYEOF'
import sys, json, math

raw   = sys.argv[1]
field = sys.argv[2]
fmt   = sys.argv[3]

def msat(v):
    if isinstance(v, str): return int(v.rstrip('msat')) if v.endswith('msat') else int(v)
    return int(v) if v else 0

def mean(xs): return sum(xs)/len(xs) if xs else 0.0
def variance(xs):
    if len(xs) < 2: return 0.0
    m = mean(xs); return sum((x-m)**2 for x in xs)/len(xs)
def stddev(xs): return math.sqrt(variance(xs))
def skewness(xs):
    if len(xs) < 3: return 0.0
    m = mean(xs); s = stddev(xs)
    if s == 0: return 0.0
    return sum((x-m)**3 for x in xs)/len(xs) / s**3
def kurtosis(xs):
    if len(xs) < 4: return 0.0
    m = mean(xs); v = variance(xs)
    if v == 0: return 0.0
    return sum((x-m)**4 for x in xs)/len(xs) / v**2 - 3
def gini(xs):
    if not xs: return 0.0
    xs = sorted(xs); n = len(xs); s = sum(xs)
    if s == 0: return 0.0
    return (2*sum((i+1)*x for i,x in enumerate(xs)))/(n*s) - (n+1)/n
def percentile(xs, p):
    if not xs: return 0
    xs = sorted(xs); idx = (len(xs)-1)*p/100
    lo, hi = int(idx), min(int(idx)+1, len(xs)-1)
    return xs[lo] + (xs[hi]-xs[lo])*(idx-lo)
def entropy_bits(pcts):
    n = len(pcts)
    if n == 0: return 0.0
    buckets = [0]*10
    for p in pcts:
        buckets[min(int(p*10),9)] += 1
    e = 0.0
    for b in buckets:
        if b > 0:
            prob = b/n; e -= prob*math.log2(prob)
    return round(e, 4)

data = json.loads(raw)
chs  = data.get('channels', [])

caps    = [msat(c.get('total_msat',0)) for c in chs]
locals_ = [msat(c.get('to_us_msat',0)) for c in chs]
ratios  = [l/t for l,t in zip(locals_, caps) if t > 0]
bases   = [msat(c.get('fee_base_msat',0)) for c in chs]
ppms    = [msat(c.get('fee_proportional_millionths',0)) for c in chs]
htlc_counts = [len(c.get('htlcs',[])) for c in chs]
htlc_maxs   = [msat(c.get('maximum_htlc_out_msat',0)) for c in chs]
htlc_mins   = [msat(c.get('minimum_htlc_out_msat',0)) for c in chs]
our_res  = [msat(c.get('our_reserve_msat',0)) for c in chs]
their_res = [msat(c.get('their_reserve_msat',0)) for c in chs]

def top_n(n, key_list, ch_list):
    paired = sorted(zip(key_list, ch_list), key=lambda x: -x[0])
    return [{'channel_id': c.get('channel_id'), 'short_channel_id': c.get('short_channel_id'), 'value_msat': k}
            for k,c in paired[:n]]
def bot_n(n, key_list, ch_list):
    paired = sorted(zip(key_list, ch_list), key=lambda x: x[0])
    return [{'channel_id': c.get('channel_id'), 'short_channel_id': c.get('short_channel_id'), 'value_msat': k}
            for k,c in paired[:n]]

state_counts = {}
for c in chs:
    s = c.get('state','unknown')
    state_counts[s] = state_counts.get(s, 0) + 1

peer_ids = set(c.get('peer_id','') for c in chs)

res = {
    # capacity
    'capacity_count':        len(chs),
    'capacity_sum_msat':     sum(caps),
    'capacity_avg_msat':     round(mean(caps), 2),
    'capacity_min_msat':     min(caps) if caps else 0,
    'capacity_max_msat':     max(caps) if caps else 0,
    'capacity_stddev_msat':  round(stddev(caps), 2),
    'capacity_skewness':     round(skewness(caps), 6),
    'capacity_kurtosis':     round(kurtosis(caps), 6),
    'capacity_gini':         round(gini(caps), 6),
    'capacity_p10_msat':     round(percentile(caps, 10), 2),
    'capacity_p25_msat':     round(percentile(caps, 25), 2),
    'capacity_p50_msat':     round(percentile(caps, 50), 2),
    'capacity_p75_msat':     round(percentile(caps, 75), 2),
    'capacity_p90_msat':     round(percentile(caps, 90), 2),
    'capacity_top10':        top_n(10, caps, chs),
    'capacity_bottom10':     bot_n(10, caps, chs),
    # balance ratios
    'balance_ratio_avg':        round(mean(ratios), 6),
    'balance_ratio_min':        round(min(ratios), 6) if ratios else 0,
    'balance_ratio_max':        round(max(ratios), 6) if ratios else 0,
    'balance_ratio_stddev':     round(stddev(ratios), 6),
    'balance_ratio_variance':   round(variance(ratios), 6),
    'balance_ratio_gini':       round(gini(ratios), 6),
    'balance_entropy_bits':     entropy_bits(ratios),
    'imbalanced_count':         sum(1 for r in ratios if r < 0.2 or r > 0.8),
    'local_balance_sum_msat':   sum(locals_),
    'remote_balance_sum_msat':  sum(caps) - sum(locals_),
    'local_balance_avg_msat':   round(mean(locals_), 2),
    'local_balance_stddev_msat':round(stddev(locals_), 2),
    # fees
    'fee_base_avg_msat':    round(mean(bases), 2),
    'fee_base_stddev_msat': round(stddev(bases), 2),
    'fee_base_min_msat':    min(bases) if bases else 0,
    'fee_base_max_msat':    max(bases) if bases else 0,
    'fee_base_total_msat':  sum(bases),
    'fee_ppm_avg':          round(mean(ppms), 2),
    'fee_ppm_stddev':       round(stddev(ppms), 2),
    'fee_ppm_min':          min(ppms) if ppms else 0,
    'fee_ppm_max':          max(ppms) if ppms else 0,
    # htlcs
    'htlc_count_total':     sum(htlc_counts),
    'htlc_count_avg':       round(mean(htlc_counts), 2),
    'htlc_in_flight_total': sum(htlc_counts),
    'htlc_max_avg_msat':    round(mean(htlc_maxs), 2),
    'htlc_min_avg_msat':    round(mean(htlc_mins), 2),
    # state
    'active_count':   state_counts.get('CHANNELD_NORMAL', 0),
    'normal_count':   state_counts.get('CHANNELD_NORMAL', 0),
    'pending_count':  sum(v for k,v in state_counts.items() if 'AWAITING' in k or 'OPENINGD' in k),
    'closing_count':  sum(v for k,v in state_counts.items() if 'CLOSING' in k or 'ONCHAIN' in k),
    'peer_count':     len(peer_ids),
    'both_reserves_avg_msat': round(mean([a+b for a,b in zip(our_res,their_res)]), 2) if our_res else 0,
}

if field:
    if field in res:
        v = res[field]
        print(json.dumps(v) if isinstance(v, (dict,list)) else str(v))
    else:
        print(f'{{"error":"unknown field: {field}"}}', file=sys.stderr); sys.exit(1)
elif fmt == 'tsv':
    for k,v in res.items():
        if not isinstance(v, (list,dict)):
            print(f'{k}\t{v}')
else:
    print(json.dumps(res, separators=(',', ':')))
PYEOF
}

# --- Per-channel inspect (returns full channel JSON + computed extras) ---
cmd_inspect() {
	[ $# -lt 1 ] && { echo "usage: lightning channel inspect <channel-id>" >&2; exit 1; }
	local id="$1"
	cli listpeerchannels | python3 -c "
import sys, json
data = json.load(sys.stdin)
cid = sys.argv[1]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        total = ch.get('total_msat', 0)
        local = ch.get('to_us_msat', 0)
        ch['_local_ratio'] = round(local/total, 6) if total else None
        ch['_healthy'] = ch.get('state') == 'CHANNELD_NORMAL' and bool(ch.get('peer_connected'))
        print(json.dumps(ch, indent=2))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}), file=sys.stderr); sys.exit(1)
" "$id"
}

