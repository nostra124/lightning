		local ch; ch=$(python3 -c "
import sys,json; d=json.loads(sys.argv[1])
print(json.dumps({'peer_id':sys.argv[2],'channel_id':d.get('channel_id',''),'ok':bool(d.get('channel_id',''))}))" \
			"$r" "$peer" 2>/dev/null) || ch="{\"peer_id\":\"$peer\",\"ok\":false}"
		results="${results}${sep}${ch}"; sep=","
	done
	echo "${results}]"
}

