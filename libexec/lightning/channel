#!/bin/bash
# lightning channel — channel management.
#
# Implements: BOLT-2 (peer protocol) + BOLT-5 (on-chain close) per
# FEAT-172, plus Static Channel Backup (SCB) per FEAT-185.
#   share/doc/lightning/standards/bolts/02-peer-protocol.md
#   share/doc/lightning/standards/bolts/05-onchain.md
#
# Subcommands:
#   list                                — TSV of channels
#   open  <node-uri> <sats> [--push <sats>]
#                                        — fund a new channel
#   close <channel-id>                   — cooperative close
#   force-close <channel-id> --confirm   — unilateral; loud warning
#   balance [<channel-id>]               — local / remote msat
#   info <channel-id>
#   pending                              — opening / closing
#   scb emit [--out <file>]              — static channel backup
#   scb restore <file>                   — restore from SCB

set -e

usage() {
	cat >&2 <<EOF
usage: lightning channel <subcommand> [args]

   Manage Lightning channels — the peer-to-peer payment funnels
   that move sats between nodes. Implements BOLT-2 (peer protocol)
   and BOLT-5 (on-chain close), plus Static Channel Backup for
   disaster recovery. Each sub-command also accepts --help.

subcommands:
   list                                 TSV of all channels
   open <node-uri> <sats> [--push <sats>]
                                        open a channel
   close <channel-id>                   cooperative close
   force-close <channel-id> --confirm   unilateral close (costly!)
   balance [<channel-id>]               local / remote msat
   info <channel-id>
   pending                              opening / closing channels
   scb emit [--out <file>]              static channel backup
   scb restore <file>                   restore from SCB
   autopilot run|status|suggest         combined fee + rebalance +
                                        suggest daemon (FEAT-205);
                                        opt-in sidecar via
                                        'daemon install --autopilot'
   paytarget-intel [--days N] [--top N] [--dry-run]
                                        suggest channels to the
                                        destinations users pay most
                                        (FEAT-217); fed by the autopilot
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }
require_cli() {
	command -v lightning-cli >/dev/null || {
		error "lightning-cli not found — install Core Lightning"; exit 127; }
}

cmd_list() {
	# Prefer the newer listpeerchannels (CLN 23.05+); fall back to listpeers.
	if json=$(cli listpeerchannels 2>/dev/null); then
		printf "id\tpeer\tcapacity\tlocal\tremote\tstate\n"
		jq -r '.channels[] | [
			(.short_channel_id // .channel_id // "-"),
			.peer_id,
			((.total_msat // 0) / 1000 | floor),
			((.to_us_msat  // 0) / 1000 | floor),
			(((.total_msat // 0) - (.to_us_msat // 0)) / 1000 | floor),
			.state
		] | @tsv' <<<"$json"
	else
		json=$(cli listpeers)
		printf "id\tpeer\tcapacity\tlocal\tremote\tstate\n"
		jq -r '.peers[] | . as $p | .channels[]? | [
			(.short_channel_id // .channel_id // "-"),
			$p.id,
			((.msatoshi_total // 0) / 1000 | floor),
			((.msatoshi_to_us // 0) / 1000 | floor),
			(((.msatoshi_total // 0) - (.msatoshi_to_us // 0)) / 1000 | floor),
			.state
		] | @tsv' <<<"$json"
	fi
}

cmd_open() {
	[ $# -lt 2 ] && { echo "usage: lightning channel open <node-uri> <sats> [--push <sats>]" >&2; exit 1; }
	local uri="$1" sats="$2"; shift 2
	local push_msat=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--push) push_msat="$(( $2 * 1000 ))msat"; shift 2 ;;
			*) error "channel open: unknown flag '$1'"; exit 1 ;;
		esac
	done

	# Connect first (idempotent on clightning).
	local pubkey="${uri%%@*}"
	cli connect "$uri" >/dev/null

	# Fund. fundchannel: id, amount, feerate, announce, minconf, utxos, push_msat
	if [ -n "$push_msat" ]; then
		result=$(cli fundchannel "$pubkey" "${sats}sat" null true null null "$push_msat")
	else
		result=$(cli fundchannel "$pubkey" "${sats}sat")
	fi

	local chan_id; chan_id=$(jq -r '.channel_id // .outnum' <<<"$result")
	local txid;    txid=$(jq -r .txid <<<"$result")
	echo "ok"
	echo "channel_id: $chan_id"
	echo "funding_txid: $txid"
}

cmd_close() {
	[ $# -lt 1 ] && { echo "usage: lightning channel close <channel-id>" >&2; exit 1; }
	local id="$1"
	result=$(cli close "$id")
	type=$(jq -r .type <<<"$result")
	echo "ok"
	echo "type: $type"
	echo "txid: $(jq -r '.txid // "-"' <<<"$result")"
}

cmd_force_close() {
	[ $# -lt 2 ] || [ "$2" != "--confirm" ] && {
		cat >&2 <<EOF
lightning channel force-close: REFUSING without --confirm.

A force close (unilateral close):
  - costs the to_self_delay (typically 144 blocks ≈ 1 day)
  - reveals the channel state to the on-chain layer
  - is the only option when the peer is unreachable

If that's what you want:
    lightning channel force-close <channel-id> --confirm
EOF
		exit 2
	}
	local id="$1"
	# clightning's `close` with unilateraltimeout=1 forces unilateral.
	result=$(cli close "$id" 1)
	echo "force-closed; on-chain timeout begins after first confirmation"
	jq . <<<"$result" >&2
}

cmd_balance() {
	local id="${1:-}"
	if [ -z "$id" ]; then
		cli listpeerchannels | jq -r '
			["channel_id","local_msat","remote_msat","state"], (
				.channels[] | [
					(.short_channel_id // .channel_id // "-"),
					(.to_us_msat // 0),
					(((.total_msat // 0) - (.to_us_msat // 0))),
					.state
				]
			) | @tsv'
	else
		cli listpeerchannels | jq -r --arg id "$id" '
			.channels[] | select(.short_channel_id == $id or .channel_id == $id) |
			["local_msat: " + (.to_us_msat|tostring),
			 "remote_msat: " + ((.total_msat - .to_us_msat)|tostring),
			 "state: " + .state] | .[]'
	fi
}

cmd_info() {
	[ $# -lt 1 ] && { echo "usage: lightning channel info <channel-id>" >&2; exit 1; }
	local id="$1"
	cli listpeerchannels | jq --arg id "$id" '.channels[] | select(.short_channel_id == $id or .channel_id == $id)'
}

cmd_pending() {
	cli listpeerchannels | jq -r '
		["channel_id","peer","state"], (
			.channels[] | select(.state | test("OPENINGD|CHANNELD_AWAITING_LOCKIN|CLOSINGD_SIGEXCHANGE|CLOSINGD_COMPLETE|AWAITING_UNILATERAL|FUNDING_SPEND_SEEN|ONCHAIN")) |
			[ (.short_channel_id // .channel_id // "-"), .peer_id, .state ]
		) | @tsv'
}

# FEAT-185: Static Channel Backup.

wallet_scb_dir() {
	local active; active=$(cat "${LIGHTNING_DIR}/wallet/.active" 2>/dev/null || echo "default")
	echo "${LIGHTNING_DIR}/wallet/$active/scb"
}

scb_emit() {
	local outfile=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--out) outfile="$2"; shift 2 ;;
			*) error "channel scb emit: unknown flag '$1'"; exit 1 ;;
		esac
	done

	scb_json=$(cli staticbackup 2>/dev/null || cli listpeerchannels 2>/dev/null | jq '{scb: .}' 2>/dev/null) || {
		error "failed to read SCB from daemon"; exit 4; }

	if [ -n "$outfile" ]; then
		echo "$scb_json" > "$outfile"
		echo "ok"
		echo "path: $outfile"
	else
		local scb_dir; scb_dir=$(wallet_scb_dir)
		mkdir -p "$scb_dir"
		local ts; ts=$(date -u +%Y%m%dT%H%M%SZ)
		local path="$scb_dir/scb-$ts.json"
		echo "$scb_json" > "$path"
		echo "ok"
		echo "path: $path"

		local wdir; wdir=$(dirname "$scb_dir")
		if [ -d "$wdir/.git" ]; then
			git -C "$wdir" add "$path" 2>/dev/null || true
			git -C "$wdir" commit -m "scb: snapshot $ts" --quiet 2>/dev/null || true
		fi
	fi
}

scb_restore() {
	[ $# -lt 1 ] && { echo "usage: lightning channel scb restore <file>" >&2; exit 1; }
	local file="$1"
	[ -f "$file" ] || { error "SCB file not found: $file"; exit 4; }

	result=$(cli staticbackup restore "$file" 2>/dev/null || cli emergency recover "$file" 2>/dev/null) || {
		error "SCB restore failed — daemon may need to be unlocked first"
		exit 4
	}

	echo "ok"
	warn "SCB restore initiated; force-closes expected within the next block"
	echo "$result" | jq . 2>/dev/null || echo "$result"
}

cmd_scb() {
	[ $# -lt 1 ] && {
		cat >&2 <<EOF
usage: lightning channel scb <subcommand> [args]

subcommands:
   emit [--out <file>]
   restore <file>
EOF
		exit 1
	}
	case "$1" in
		emit)    shift; scb_emit "$@" ;;
		restore) shift; scb_restore "$@" ;;
		*) error "channel scb: unknown subcommand '$1'"; exit 1 ;;
	esac
}

# ---------------------------------------------------------------------------
# FEAT-205 — channel autopilot
#
# Combines passive fee policy (delegated to `lightning fee policy`),
# active rebalancing (delegated to `lightning rebalance`), and
# informational channel-open/close suggestions into one periodic
# verb.  Designed to be invoked from a sidecar timer every 15
# minutes; safe to invoke manually at any time.
#
# Channel opens / closes are NEVER executed automatically — the verb
# only writes suggestions to a recfile for the operator to review.
# ---------------------------------------------------------------------------

AUTOPILOT_DIR="$LIGHTNING_DIR/autopilot"
AUTOPILOT_CONF="$LIGHTNING_DIR/autopilot.conf"
AUTOPILOT_STATE="$AUTOPILOT_DIR/state.recfile"
AUTOPILOT_SUGGESTIONS_TMPL="$AUTOPILOT_DIR/suggestions"
# FEAT-217 — pay-target open suggestions feed the autopilot suggest queue.
PAYTARGET_SUGGEST="$AUTOPILOT_DIR/paytarget.suggest.recfile"

# Default config values — used when autopilot.conf is missing or
# doesn't specify the key.  Matches the spec table.
autopilot_default_config() {
	cat <<'EOF'
enabled: true
fee_policy: balanced
rebalance_band_low: 10
rebalance_band_high: 90
rebalance_max_fee_ppm: 500
rebalance_daily_cap_sat: 5000
suggest_min_score: 8.0
suggest_stale_weeks: 6
EOF
}

# autopilot_config_get <key> [default]
# Reads $key from $AUTOPILOT_CONF if present, falling back to the
# default-config block, falling back to the second arg.
autopilot_config_get() {
	local key="$1" fallback="${2:-}"
	local v
	if [ -f "$AUTOPILOT_CONF" ]; then
		v=$(grep -E "^${key}:" "$AUTOPILOT_CONF" 2>/dev/null | head -1 | sed -E "s/^${key}: *//")
		[ -n "$v" ] && { echo "$v"; return; }
	fi
	v=$(autopilot_default_config | grep -E "^${key}:" | head -1 | sed -E "s/^${key}: *//")
	[ -n "$v" ] && { echo "$v"; return; }
	echo "$fallback"
}

cmd_autopilot() {
	local sub="${1:-}"; shift 2>/dev/null || true
	case "$sub" in
		run)     cmd_autopilot_run     "$@" ;;
		status)  cmd_autopilot_status  "$@" ;;
		suggest) cmd_autopilot_suggest "$@" ;;
		help|--help|-h|"")
			cat >&2 <<'EOF'
usage: lightning channel autopilot <subcommand>

   run [--dry-run]    one daemon iteration: apply fee policy,
                      rebalance unbalanced channels within budget,
                      write suggestions to a recfile.
   status             report last-run timestamp, recent actions,
                      remaining daily rebalance budget.
   suggest            run only the suggestions phase (no fee /
                      rebalance side effects); useful interactively.

Configuration: $LIGHTNING_DIR/autopilot.conf  (recfile, key: value)
State:         $LIGHTNING_DIR/autopilot/state.recfile
Suggestions:   $LIGHTNING_DIR/autopilot/suggestions-<timestamp>.recfile

Channel opens / closes are NEVER executed automatically — the verb
suggests, the operator decides.
EOF
			[ -z "$sub" ] && exit 1 || exit 0 ;;
		*) error "channel autopilot: unknown subcommand '$sub'"; exit 1 ;;
	esac
}

# Compute imbalance for each channel.  Output TSV:
#   channel_id  local_pct  total_sat  state
# Filters to CHANNELD_NORMAL channels only — pending / closing
# channels can't be rebalanced.
autopilot_imbalance_tsv() {
	cli listpeerchannels | jq -r '
		.channels[] |
		select(.state == "CHANNELD_NORMAL") |
		[
			(.short_channel_id // .channel_id // "-"),
			(if (.total_msat // 0) > 0
			 then ((.to_us_msat // 0) * 100 / .total_msat | floor)
			 else 0 end),
			((.total_msat // 0) / 1000 | floor),
			.state
		] | @tsv
	'
}

# Channels with zero forwards in the configured stale-weeks window
# are candidates for closure suggestions.  Uses listforwards which
# returns recent activity.
autopilot_stale_channels() {
	local stale_weeks
	stale_weeks=$(autopilot_config_get suggest_stale_weeks 6)
	# Build a set of channel-ids that HAVE recent forwards.
	local active_set
	active_set=$(cli listforwards 2>/dev/null | \
		jq -r '.forwards[] | (.in_channel, .out_channel)' 2>/dev/null | \
		sort -u)
	# For each open channel, if not in the active set, mark stale.
	autopilot_imbalance_tsv | while IFS=$'\t' read -r cid pct sat _state; do
		if ! grep -qxF "$cid" <<<"$active_set"; then
			printf '%s\t%s\t%d weeks\n' "$cid" "$sat" "$stale_weeks"
		fi
	done
}

cmd_autopilot_suggest() {
	mkdir -p "$AUTOPILOT_DIR"
	local ts; ts=$(date -u +%Y%m%dT%H%M%SZ)
	local out="${AUTOPILOT_SUGGESTIONS_TMPL}-$ts.recfile"
	{
		printf 'kind: stale-channels\n'
		printf 'generated_at: %s\n' "$ts"
		printf 'description: channels with no forwarding activity in the last %s weeks; consider closing\n' "$(autopilot_config_get suggest_stale_weeks 6)"
		printf '%%\n'
		autopilot_stale_channels | while IFS=$'\t' read -r cid sat win; do
			printf 'channel_id: %s\n' "$cid"
			printf 'capacity_sat: %s\n' "$sat"
			printf 'stale_for: %s\n' "$win"
			printf '%%\n'
		done
	} > "$out"
	echo "wrote $out"
	# Echo to stdout too so an operator running interactively sees results.
	cat "$out"
}

cmd_autopilot_run() {
	local dry_run=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--dry-run) dry_run=1; shift ;;
			--config) AUTOPILOT_CONF="$2"; shift 2 ;;
			*) error "channel autopilot run: unknown flag '$1'"; exit 1 ;;
		esac
	done

	# Bail early if the operator disabled it via config.
	if [ "$(autopilot_config_get enabled true)" != "true" ]; then
		echo "channel autopilot: disabled in $AUTOPILOT_CONF" >&2
		return 0
	fi

	mkdir -p "$AUTOPILOT_DIR"
	local started_at; started_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
	local today; today=$(date -u +%Y-%m-%d)
	local band_low band_high max_ppm daily_cap fee_policy
	band_low=$(autopilot_config_get rebalance_band_low 10)
	band_high=$(autopilot_config_get rebalance_band_high 90)
	max_ppm=$(autopilot_config_get rebalance_max_fee_ppm 500)
	daily_cap=$(autopilot_config_get rebalance_daily_cap_sat 5000)
	fee_policy=$(autopilot_config_get fee_policy balanced)

	# Reset daily rebalance budget if the day rolled over.
	local last_day budget_used
	last_day=$(grep "^budget_day:" "$AUTOPILOT_STATE" 2>/dev/null | tail -1 | awk '{print $2}')
	budget_used=$(grep "^budget_used_sat:" "$AUTOPILOT_STATE" 2>/dev/null | tail -1 | awk '{print $2}')
	if [ "$last_day" != "$today" ]; then
		budget_used=0
	fi
	budget_used="${budget_used:-0}"

	echo "channel autopilot: starting (dry-run=$dry_run)"
	echo "  band:        ${band_low}%..${band_high}%"
	echo "  max ppm:     $max_ppm"
	echo "  daily cap:   $daily_cap sat   (used today: $budget_used)"
	echo "  fee policy:  $fee_policy"

	# 1. Apply fee policy via the fee verb (passive layer).
	if [ "$dry_run" -eq 1 ]; then
		echo "would run: lightning fee policy $fee_policy"
	else
		"$SELF_LIBEXEC/lightning/fee" policy "$fee_policy" >/dev/null 2>&1 || {
			warn "channel autopilot: fee policy '$fee_policy' failed (continuing)"
		}
	fi

	# 2. Identify channels outside the band; rebalance within budget.
	local actions_log="" tsv
	tsv=$(autopilot_imbalance_tsv)
	while IFS=$'\t' read -r cid pct sat _state; do
		[ -n "$cid" ] || continue
		if [ "$pct" -lt "$band_low" ] || [ "$pct" -gt "$band_high" ]; then
			# Compute the rebalance amount to bring us back to ~50%.
			local target_pct=50 delta_pct delta_sat
			delta_pct=$(( target_pct - pct ))
			[ "$delta_pct" -lt 0 ] && delta_pct=$(( -delta_pct ))
			delta_sat=$(( sat * delta_pct / 100 ))
			# Check budget.
			local would_spend=$(( delta_sat * max_ppm / 1000000 ))
			[ "$would_spend" -lt 1 ] && would_spend=1
			if [ $(( budget_used + would_spend )) -gt "$daily_cap" ]; then
				echo "  skip $cid (pct=$pct%): daily budget would be exceeded"
				actions_log="${actions_log}skipped: $cid (budget)\n"
				continue
			fi
			if [ "$dry_run" -eq 1 ]; then
				echo "would rebalance $cid (pct=$pct%, target=50%, delta=$delta_sat sat, max_fee=$would_spend sat)"
				actions_log="${actions_log}would-rebalance: $cid pct=$pct%\n"
			else
				echo "rebalancing $cid (pct=$pct%, delta=$delta_sat sat)"
				if "$SELF_LIBEXEC/lightning/rebalance" "$delta_sat" --max-fee "$would_spend" >/dev/null 2>&1; then
					budget_used=$(( budget_used + would_spend ))
					actions_log="${actions_log}rebalanced: $cid pct=$pct% spent=$would_spend\n"
				else
					actions_log="${actions_log}rebalance-failed: $cid pct=$pct%\n"
				fi
			fi
		fi
	done <<<"$tsv"

	# 3. Suggestions phase (informational only).
	cmd_autopilot_suggest >/dev/null
	# FEAT-217 — pay-target intel feeds the suggest queue (best-effort;
	# a missing listpays / no history is a no-op).
	cmd_paytarget_intel >/dev/null 2>&1 || true

	# 4. Write state.
	{
		printf 'last_run: %s\n' "$started_at"
		printf 'budget_day: %s\n' "$today"
		printf 'budget_used_sat: %s\n' "$budget_used"
		printf 'budget_cap_sat: %s\n' "$daily_cap"
		printf 'dry_run: %s\n' "$dry_run"
		printf 'actions:\n'
		# shellcheck disable=SC2059
		printf "$actions_log"
	} > "$AUTOPILOT_STATE"

	echo "channel autopilot: done"
}

cmd_autopilot_status() {
	if [ ! -f "$AUTOPILOT_STATE" ]; then
		echo "channel autopilot: never run"
		echo "  enable via: lightning daemon install --autopilot"
		exit 0
	fi
	cat "$AUTOPILOT_STATE"
	# Latest suggestions file, if any.
	local last
	last=$(ls -t "$AUTOPILOT_DIR"/suggestions-*.recfile 2>/dev/null | head -1)
	if [ -n "$last" ]; then
		echo "---"
		echo "latest suggestions: $last"
	fi
}

# FEAT-217 — pay-target intelligence.  Aggregates the destinations our
# users actually pay (over the last N days) and writes the top targets
# we have NO direct channel to as autopilot open-suggestions.  A direct
# channel to a frequently-paid destination skips hops, saving routing
# fees + improving reliability.  Aggregate-only (no per-account / per-
# payment detail leaks into the autopilot logs).
cmd_paytarget_intel() {
	local days=30 top=10 dry=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--days)    days="$2"; shift 2 ;;
			--top)     top="$2"; shift 2 ;;
			--dry-run) dry=1; shift ;;
			*) error "channel paytarget-intel: unknown flag '$1'"; exit 1 ;;
		esac
	done
	case "$days" in ''|*[!0-9]*) error "channel paytarget-intel: --days must be a positive integer"; exit 1 ;; esac
	case "$top" in  ''|*[!0-9]*) error "channel paytarget-intel: --top must be a positive integer"; exit 1 ;; esac
	command -v jq >/dev/null || { error "channel paytarget-intel: jq not installed"; exit 127; }

	local cutoff; cutoff=$(( $(date -u +%s) - days * 86400 ))

	# Peers we already have a direct channel with (any state).
	local connected
	connected=$(cli listpeerchannels 2>/dev/null | jq -c '[.channels[]?.peer_id] | unique' 2>/dev/null)
	[ -n "$connected" ] || connected="[]"

	# Aggregate completed pays by destination, drop the ones we're
	# already connected to, keep the top N by sat volume.  amount_msat
	# normalises the legacy "Nmsat" string form.
	local agg
	agg=$(cli listpays 2>/dev/null | jq -c \
		--argjson cutoff "$cutoff" --argjson top "$top" --argjson connected "$connected" '
		[ .pays[]?
		  | select(.status == "complete")
		  | select((.created_at // 0) >= $cutoff)
		  | { dest: .destination,
		      msat: ( .amount_msat // 0
		              | if type == "string" then (sub("msat$"; "") | tonumber) else . end ) } ]
		| map(select(.dest != null))
		| group_by(.dest)
		| map({ dest: .[0].dest, count: length, msat: (map(.msat) | add) })
		| map(select(.dest as $d | ($connected | index($d)) == null))
		| sort_by(-.msat)
		| .[0:$top]' 2>/dev/null) || agg=""
	[ -n "$agg" ] || agg="[]"

	local n; n=$(jq 'length' <<<"$agg" 2>/dev/null); n="${n:-0}"
	if [ "$n" -eq 0 ]; then
		echo "channel paytarget-intel: no pay-target suggestions (no qualifying payment history)"
		return 0
	fi

	if [ "$dry" -eq 1 ]; then
		echo "channel paytarget-intel (dry-run): top $n pay-target(s) over ${days}d"
		jq -r '.[] | "  \(.dest)  \(.count) pays  \((.msat / 1000) | floor) sat"' <<<"$agg"
		return 0
	fi

	mkdir -p "$AUTOPILOT_DIR"
	local ts; ts=$(date -u +%Y%m%dT%H%M%SZ)
	{
		printf 'kind: pay-target-channels\n'
		printf 'generated_at: %s\n' "$ts"
		printf 'window_days: %s\n' "$days"
		printf 'description: destinations your users pay most that you have no direct channel to; consider opening\n'
		printf '%%\n'
		jq -r '.[] | "node_id: \(.dest)\npay_count: \(.count)\npay_volume_sat: \((.msat / 1000) | floor)\n%"' <<<"$agg"
	} > "$PAYTARGET_SUGGEST"
	echo "wrote $PAYTARGET_SUGGEST ($n pay-target suggestion(s))"
}

subhelp() {
	case "$1" in
		list)
			cat <<'EOF'
usage: lightning channel list

TSV of all channels. Columns:
   id<TAB>peer<TAB>capacity<TAB>local<TAB>remote<TAB>state
Amounts in sats. Falls back to listpeers for old CLN versions.
EOF
			;;
		open)
			cat <<'EOF'
usage: lightning channel open <node-uri> <sats> [--push <sats>]

Connect to <node-uri> (pubkey@host:port) and fund a new channel
with <sats> on-chain. --push gifts the peer that many sats at
open time (rarely a good idea). Implements BOLT-2 funding.
EOF
			;;
		close)
			cat <<'EOF'
usage: lightning channel close <channel-id>

Cooperative close: signs a mutual close transaction with the peer.
Funds return to the on-chain wallet within ~1 block. Prefer this
over force-close whenever the peer is reachable.
EOF
			;;
		force-close)
			cat <<'EOF'
usage: lightning channel force-close <channel-id> --confirm

Unilateral close. REFUSES without --confirm because it costs the
to_self_delay (typically 144 blocks ≈ 1 day) before funds are
spendable and reveals channel state on-chain. Use only when the
peer is unreachable.
EOF
			;;
		balance)
			cat <<'EOF'
usage: lightning channel balance [<channel-id>]

Without args: TSV header + one row per channel
   (channel_id, local_msat, remote_msat, state).
With <channel-id>: three lines local_msat / remote_msat / state.
EOF
			;;
		info)
			cat <<'EOF'
usage: lightning channel info <channel-id>

Full JSON for one channel (the matching entry from listpeerchannels).
Accepts either short_channel_id or channel_id.
EOF
			;;
		pending)
			cat <<'EOF'
usage: lightning channel pending

TSV of channels in non-NORMAL states: OPENINGD, AWAITING_LOCKIN,
CLOSINGD_*, AWAITING_UNILATERAL, FUNDING_SPEND_SEEN, ONCHAIN.
Use this to watch opens and closes confirm.
EOF
			;;
		scb)
			cat <<'EOF'
usage: lightning channel scb <emit|restore> [args]

Static Channel Backup (FEAT-185, BOLT-5 recovery aid):
   emit [--out <file>]   snapshot to wallet/scb/ or <file>
   restore <file>        request force-close of every channel in
                         the snapshot, surrendering remote balance
                         for recovery on a fresh daemon.
EOF
			;;
		autopilot)
			cat <<'EOF'
usage: lightning channel autopilot <subcommand>

   run [--dry-run]    one daemon iteration: apply fee policy,
                      rebalance unbalanced channels within budget,
                      write suggestions to a recfile.
   status             report last-run timestamp, recent actions,
                      remaining daily rebalance budget.
   suggest            run only the suggestions phase (no fee /
                      rebalance side effects); useful interactively.

Configuration lives at $LIGHTNING_DIR/autopilot.conf (recfile, key:
value).  Defaults: band 10%..90%, max ppm 500, daily cap 5000 sat,
fee policy "balanced".

State at $LIGHTNING_DIR/autopilot/state.recfile.  Suggestion
recfiles under $LIGHTNING_DIR/autopilot/suggestions-<timestamp>.

Channel opens / closes are NEVER executed automatically — the verb
suggests, the operator decides.  Opt in to a 15-min sidecar timer
via 'lightning daemon install --autopilot'.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="$1"; shift || true
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac
case "$SUB" in
	help) subhelp "${1:-}" || usage; exit ;;
esac

require_cli

case "$SUB" in
	list)        cmd_list "$@" ;;
	open)        cmd_open "$@" ;;
	close)       cmd_close "$@" ;;
	force-close) cmd_force_close "$@" ;;
	balance)     cmd_balance "$@" ;;
	info)        cmd_info "$@" ;;
	pending)     cmd_pending "$@" ;;
	scb)         cmd_scb "$@" ;;
	autopilot)   cmd_autopilot "$@" ;;
	paytarget-intel) cmd_paytarget_intel "$@" ;;
	*) usage; exit 1 ;;
esac
