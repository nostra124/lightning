# --- Peer summary ---
cmd_peer_summary() {
	cli listpeerchannels | python3 -c "
import sys, json
chs = json.load(sys.stdin).get('channels', [])
by_peer = {}
for c in chs:
    pid = c.get('peer_id', '')
    if pid not in by_peer:
        by_peer[pid] = {'peer_id': pid, 'channels': 0, 'total_msat': 0, 'local_msat': 0}
    by_peer[pid]['channels'] += 1
