# --- set-fee (--base / --ppm flags) ---
cmd_set_fee() {
	[ $# -lt 1 ] && { echo "usage: lightning channel set-fee <channel-id> --base <msat> --ppm <ppm>" >&2; exit 1; }
	local cid="$1"; shift; local base="" ppm=""
	while [ $# -gt 0 ]; do
		case "$1" in --base) base="$2"; shift 2 ;; --ppm) ppm="$2"; shift 2 ;; *) shift ;; esac
	done
	[ -n "$base" ] || { echo "channel set-fee: --base required" >&2; exit 1; }
	[ -n "$ppm"  ] || { echo "channel set-fee: --ppm required"  >&2; exit 1; }
	result=$(cli setchannel "$cid" "${base}msat" "$ppm")
	echo "{\"ok\":true,\"channel_id\":\"$cid\",\"base_msat\":$base,\"ppm\":$ppm}"
}

# --- set-private / set-public ---
cmd_set_private() {
	[ $# -lt 1 ] && { echo "usage: lightning channel set-private <channel-id>" >&2; exit 1; }
	cli setchannel "$1" announce false
}

cmd_set_public() {
	[ $# -lt 1 ] && { echo "usage: lightning channel set-public <channel-id>" >&2; exit 1; }
	cli setchannel "$1" announce true
}

# --- Stuck HTLC detection ---
cmd_stuck() {
	local minutes=30
	while [ $# -gt 0 ]; do
		case "$1" in --minutes) minutes="$2"; shift 2 ;; *) shift ;; esac
	done
	local cutoff; cutoff=$(( $(date +%s) - minutes * 60 ))
	local _ch_data; _ch_data=$(cli listpeerchannels)
	python3 - "$_ch_data" "$cutoff" "$minutes" <<'PYEOF'
import sys, json
chs = json.loads(sys.argv[1]).get('channels', [])
cutoff = int(sys.argv[2]); minutes = int(sys.argv[3])
stuck = []
for c in chs:
    old = [h for h in c.get('htlcs', []) if h.get('expiry', 0) and int(h.get('expiry',0)) < cutoff]
    if old:
        stuck.append({'channel_id': c.get('channel_id',''), 'peer_id': c.get('peer_id',''), 'stuck_htlc_count': len(old)})
print(json.dumps(stuck, separators=(',', ':')))
PYEOF
}

# --- Top earners ---
cmd_top_earners() {
	local limit=10
	while [ $# -gt 0 ]; do
		case "$1" in --limit) limit="$2"; shift 2 ;; *) shift ;; esac
	done
	local raw; raw=$(cli listforwards status=settled 2>/dev/null) || { echo '[]'; return; }
	python3 - "$raw" "$limit" <<'PYEOF'
import sys, json
fwds = json.loads(sys.argv[1]).get('forwards', [])
limit = int(sys.argv[2])
totals = {}
for f in fwds:
    ch = f.get('in_channel', ''); totals[ch] = totals.get(ch, 0) + f.get('fee_msat', 0)
top = sorted(totals.items(), key=lambda x: -x[1])[:limit]
print(json.dumps([{'channel_id': ch, 'total_fee_msat': fee} for ch, fee in top], separators=(',', ':')))
PYEOF
}

subhelp() {
	case "$1" in
		list)
			cat <<'EOF'
usage: lightning channel list

TSV of all channels. Columns:
   id<TAB>peer<TAB>capacity<TAB>local<TAB>remote<TAB>state
Amounts in sats. Falls back to listpeers for old CLN versions.
EOF
			;;
		open)
			cat <<'EOF'
usage: lightning channel open <node-uri> <sats> [--push <sats>]

Connect to <node-uri> (pubkey@host:port) and fund a new channel
with <sats> on-chain. --push gifts the peer that many sats at
open time (rarely a good idea). Implements BOLT-2 funding.
EOF
			;;
		close)
			cat <<'EOF'
usage: lightning channel close <channel-id>

Cooperative close: signs a mutual close transaction with the peer.
Funds return to the on-chain wallet within ~1 block. Prefer this
over force-close whenever the peer is reachable.
EOF
			;;
		force-close)
			cat <<'EOF'
usage: lightning channel force-close <channel-id> --confirm

Unilateral close. REFUSES without --confirm because it costs the
to_self_delay (typically 144 blocks ≈ 1 day) before funds are
spendable and reveals channel state on-chain. Use only when the
peer is unreachable.
EOF
			;;
		balance)
			cat <<'EOF'
usage: lightning channel balance [<channel-id>]

Without args: TSV header + one row per channel
   (channel_id, local_msat, remote_msat, state).
With <channel-id>: three lines local_msat / remote_msat / state.
EOF
			;;
		info)
			cat <<'EOF'
usage: lightning channel info <channel-id>

Full JSON for one channel (the matching entry from listpeerchannels).
Accepts either short_channel_id or channel_id.
EOF
			;;
		pending)
			cat <<'EOF'
usage: lightning channel pending

TSV of channels in non-NORMAL states: OPENINGD, AWAITING_LOCKIN,
CLOSINGD_*, AWAITING_UNILATERAL, FUNDING_SPEND_SEEN, ONCHAIN.
Use this to watch opens and closes confirm.
EOF
			;;
		scb)
			cat <<'EOF'
usage: lightning channel scb <emit|restore> [args]

Static Channel Backup (FEAT-185, BOLT-5 recovery aid):
   emit [--out <file>]   snapshot to wallet/scb/ or <file>
   restore <file>        request force-close of every channel in
                         the snapshot, surrendering remote balance
                         for recovery on a fresh daemon.
EOF
			;;
		autopilot)
			cat <<'EOF'
usage: lightning channel autopilot <subcommand>

   run [--dry-run]    one daemon iteration: apply fee policy,
                      rebalance unbalanced channels within budget,
                      write suggestions to a recfile.
   status             report last-run timestamp, recent actions,
                      remaining daily rebalance budget.
   suggest            run only the suggestions phase (no fee /
                      rebalance side effects); useful interactively.

Configuration lives at $LIGHTNING_DIR/autopilot.conf (recfile, key:
value).  Defaults: band 10%..90%, max ppm 500, daily cap 5000 sat,
fee policy "balanced".

State at $LIGHTNING_DIR/autopilot/state.recfile.  Suggestion
recfiles under $LIGHTNING_DIR/autopilot/suggestions-<timestamp>.

Channel opens / closes are NEVER executed automatically — the verb
suggests, the operator decides.  Opt in to a 15-min sidecar timer
via 'lightning daemon install --autopilot'.
EOF
			;;
		stats)
			cat <<'EOF'
usage: lightning channel stats [--field <name>] [--format tsv]

Compute statistical metrics over all channels in one Python pass.
Output: JSON with all fields; use --field to print one value.

Capacity: capacity_count, capacity_sum_msat, capacity_avg_msat,
  capacity_min_msat, capacity_max_msat, capacity_stddev_msat,
  capacity_skewness, capacity_kurtosis, capacity_gini,
  capacity_p10/p25/p50/p75/p90_msat, capacity_top10, capacity_bottom10

Balance ratio: balance_ratio_avg/min/max/stddev/variance/gini,
  balance_entropy_bits, imbalanced_count,
  local_balance_sum_msat, remote_balance_sum_msat

Fees: fee_base_avg/stddev/min/max/total_msat, fee_ppm_avg/stddev/min/max

HTLCs: htlc_count_total/avg, htlc_in_flight_total,
  htlc_max_avg_msat, htlc_min_avg_msat

State: active_count, normal_count, pending_count, closing_count,
  peer_count, both_reserves_avg_msat
EOF
			;;
		inspect)
			cat <<'EOF'
usage: lightning channel inspect <channel-id>

Full JSON for one channel (short_channel_id or channel_id), including
computed fields _local_ratio and _healthy.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="$1"; shift || true
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac
case "$SUB" in
	help) subhelp "${1:-}" || usage; exit ;;
