# --- Close all channels ---
cmd_close_all() {
	local force=0
	while [ $# -gt 0 ]; do
		case "$1" in --force) force=1; shift ;; *) shift ;; esac
	done
	local raw; raw=$(cli listpeerchannels)
	local count; count=$(jq '.channels | length' <<<"$raw")
	if [ "$force" -eq 0 ]; then
		echo "{\"error\":\"refusing to close $count channels without --force\"}" >&2; exit 1
	fi
	jq -r '.channels[].channel_id' <<<"$raw" | while read -r cid; do
		result=$(cli close "$cid" 2>/dev/null) || result='{"error":"failed"}'
		echo "$cid: $(jq -r '.type // .error // "?"' <<<"$result")"
	done
}

