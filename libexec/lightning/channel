# --- Rebalance suggestions ---
cmd_rebalance_suggestion() {
	cli listpeerchannels | python3 -c "
import sys, json
chs = json.load(sys.stdin).get('channels', [])
suggs = []
for c in chs:
    t = c.get('total_msat', 0); l = c.get('to_us_msat', 0)
    if t > 0:
        r = l/t
        if r > 0.8:   suggs.append({'channel_id': c.get('channel_id'), 'action': 'send',    'local_ratio': round(r,3)})
        elif r < 0.2: suggs.append({'channel_id': c.get('channel_id'), 'action': 'receive', 'local_ratio': round(r,3)})
print(json.dumps({'suggestions': suggs}))
"
}

cmd_rebalance_auto() {
	local threshold=20
	while [ $# -gt 0 ]; do
		case "$1" in --threshold) threshold="$2"; shift 2 ;; *) shift ;; esac
	done
	local _ch_data; _ch_data=$(cli listpeerchannels)
	python3 - "$_ch_data" "$threshold" <<'PYEOF'
import sys, json
chs = json.loads(sys.argv[1]).get('channels', [])
t = int(sys.argv[2])
unbal = []
for c in chs:
    total = c.get('total_msat', 0)
    if not total: continue
    pct = c.get('to_us_msat', 0) * 100 // total
    if pct < t or pct > (100-t):
        unbal.append({'channel_id': c.get('channel_id',''), 'local_pct': pct,
                      'action': 'drain' if pct > 50 else 'fill'})
print(json.dumps({'candidates': len(unbal), 'threshold_pct': t, 'channels': unbal}, separators=(',', ':')))
PYEOF
}

