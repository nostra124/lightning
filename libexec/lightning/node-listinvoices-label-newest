#!/bin/bash
# lightning node-listinvoices-label-newest   (FEAT-2599)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
if not invoices:
    print(json.dumps({'newest_label': None}))
else:
    newest = max(invoices, key=lambda i: int(i.get('created_index', 0)))
    print(json.dumps({'newest_label': newest.get('label', None)}))
" "$result"
