#!/bin/bash
# lightning address — Lightning Address support (FEAT-176).
#
# Usage:
#   lightning address resolve <addr>
#   lightning address pay <addr> <sat> [--comment <text>] [--account <name>]
#   lightning address create <addr> [--account <name>]
#   lightning address list
#   lightning address remove <addr>

set -e

usage() {
	cat >&2 <<EOF
usage: lightning address <subcommand> [args]

   Lightning Addresses (LUD-16): the user@domain form that
   resolves to LNURL-pay endpoints via
   https://<domain>/.well-known/lnurlp/<user>. Supports both
   consumption (resolve, pay) and self-hosting on Apache
   (create, list, remove). Each sub-command also accepts --help.
   See FEAT-176.

subcommands:
   resolve <addr>                          get LNURL-pay endpoint metadata
   pay <addr> <sat> [--comment <text>]     resolve + pay
         [--account <name>]
   create <addr> [--account <name>]        detect Apache, install handler
   list                                    owned addresses
   remove <addr>                           remove handler + record
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
SELF_LIBEXEC="${SELF_LIBEXEC:-$(cd "$(dirname "$0")" && pwd)}"

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

require_cli() {
	command -v lightning-cli >/dev/null || {
		error "lightning-cli not found — install Core Lightning"; exit 127; }
}

wallet_db() {
	local active; active=$(cat "$LIGHTNING_DIR/wallet/.active" 2>/dev/null || echo "default")
	echo "$LIGHTNING_DIR/wallet/$active/state.db"
}

# Parse "user@domain" → user + domain
parse_addr() {
	local addr="$1"
	[[ "$addr" == *@* ]] || { error "invalid address '$addr' — expected user@domain"; exit 2; }
	local user="${addr%%@*}"
	local domain="${addr#*@}"
	echo "$user $domain"
}

# Resolve LNURL-pay: return the JSON from the .well-known endpoint.
resolve_lnurlp() {
	local addr="$1"
	read -r user domain <<<"$(parse_addr "$addr")"

	# LUD-01: https://<domain>/.well-known/lnurlp/<user>
	local url="https://$domain/.well-known/lnurlp/$user"
	curl -sfL "$url" 2>/dev/null || {
		# Fallback: try http if https fails.
		url="http://$domain/.well-known/lnurlp/$user"
		curl -sfL "$url" 2>/dev/null || {
			error "failed to resolve $addr — is the remote running?"
			exit 4
		}
	}
	echo "$url"
}

cmd_resolve() {
	[ $# -lt 1 ] && { echo "usage: lightning address resolve <addr>" >&2; exit 1; }
	require_cli
	local addr="$1"; shift
	read -r user domain <<<"$(parse_addr "$addr")"

	local cb_url; cb_url=$(resolve_lnurlp "$addr")
	curl -sfL "$cb_url" | jq .
}

cmd_pay() {
	[ $# -lt 2 ] && { echo "usage: lightning address pay <addr> <sat> [--comment <text>] [--account <name>]" >&2; exit 1; }
	require_cli
	local addr="$1"; shift
	local sat="$1"; shift
	local comment=""
	local account=""

	while [ $# -gt 0 ]; do
		case "$1" in
			--comment) comment="$2"; shift 2 ;;
			--account) account="$2"; shift 2 ;;
			*) error "address pay: unknown flag '$1'"; exit 1 ;;
		esac
	done

	read -r user domain <<<"$(parse_addr "$addr")"

	# Resolve LNURL-pay endpoint.
	local lnurlp_url; lnurlp_url=$(resolve_lnurlp "$addr")
	local meta; meta=$(curl -sfL "$lnurlp_url") || {
		error "failed to fetch LNURL-pay metadata for $addr"; exit 4; }

	local callback; callback=$(jq -r '.callback' <<<"$meta")
	[ -z "$callback" ] && { error "no callback URL in LNURL-pay response"; exit 4; }
	[ "$callback" = "null" ] && { error "no callback URL in LNURL-pay response"; exit 4; }

	local comment_max; comment_max=$(jq -r '.commentAllowed // 0' <<<"$meta")
	local min_msat; min_msat=$(jq -r '.minSendable // 0' <<<"$meta")
	local max_msat; max_msat=$(jq -r '.maxSendable // 0' <<<"$meta")
	local msat=$(( sat * 1000 ))

	# Validate amount.
	if [ "$msat" -lt "$min_msat" ] 2>/dev/null; then
		error "$sat sat too small (min: $(( min_msat / 1000 )) sat)"; exit 3
	fi
	if [ "$msat" -gt "$max_msat" ] 2>/dev/null; then
		error "$sat sat too large (max: $(( max_msat / 1000 )) sat)"; exit 3
	fi

	# Truncate comment if needed.
	local trunc_comment="$comment"
	if [ -n "$comment" ] && [ "$comment_max" -gt 0 ] 2>/dev/null; then
		trunc_comment="${comment:0:$comment_max}"
	fi

	# Call callback to get invoice.
	local cb_result
	if [ -n "$trunc_comment" ]; then
		# URL-encode using xxd + tr (no python dependency).
		local enc; enc=$(printf '%s' "$trunc_comment" | xxd -p -c 256 | tr -d '\n' | sed 's/\(..\)/%\1/g')
		cb_result=$(curl -sfL "${callback}?amount=$msat&comment=$enc")
	else
		cb_result=$(curl -sfL "${callback}?amount=$msat")
	fi

	local bolt11; bolt11=$(jq -r '.pr // .invoice // ""' <<<"$cb_result")
	[ -z "$bolt11" ] && { error "no invoice in callback response"; exit 4; }

	# Pay the invoice.
	ARGS=()
	[ -n "$account" ] && ARGS+=(--account "$account")
	[ -n "$comment" ] && ARGS+=(--note "$comment")
	exec "$SELF_LIBEXEC/lightning/invoice" pay "$bolt11" "${ARGS[@]}"
}

cmd_create() {
	[ $# -lt 1 ] && { echo "usage: lightning address create <addr> [--account <name>]" >&2; exit 1; }
	local addr="$1"; shift
	local account=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--account) account="$2"; shift 2 ;;
			*) error "address create: unknown flag '$1'"; exit 1 ;;
		esac
	done

	read -r user domain <<<"$(parse_addr "$addr")"

	# Check Apache.
	local apache=""
	command -v apache2 >/dev/null && apache="apache2"
	command -v httpd >/dev/null && apache="httpd"
	if [ -z "$apache" ]; then
		error "Apache not found — install apache2 and try again"
		echo "  Debian/Ubuntu: sudo apt install apache2" >&2
		echo "  RHEL/Fedora:   sudo dnf install httpd" >&2
		exit 5
	fi

	# Insert into users table.
	DB=$(wallet_db)
	[ -f "$DB" ] || {
		error "no wallet database — run 'lightning wallet init' first"; exit 5; }

	local acct="${account:-$user}"
	sqlite3 "$DB" "INSERT OR REPLACE INTO users (user, account) VALUES ('$(echo "$user" | sed "s/'/''/g")', '$(echo "$acct" | sed "s/'/''/g")')" 2>/dev/null

	# Print BIP-353 TXT record hint.
	echo "ok"
	echo "address: $addr"
	echo "account: $acct"
	echo ""
	echo "BIP-353 DNS hint: publish this TXT record:" >&2
	echo "  _bitcoin-payment.$user.$domain. TXT \"bitcoin:$addr?amount=&label=\"" >&2
	echo ""
	echo "Apache wiring:" >&2
	echo "  Ensure CGI is enabled and the handler script is deployed." >&2
	echo "  See share/lightning/apache/lnurlp.conf for the config snippet." >&2
}

cmd_list() {
	DB=$(wallet_db)
	[ -f "$DB" ] || { error "no wallet — run 'lightning wallet init' first"; exit 5; }
	sqlite3 -readonly "$DB" -cmd ".mode tabs" "SELECT user, account, min_sat, max_sat FROM users ORDER BY user"
}

cmd_remove() {
	[ $# -lt 1 ] && { echo "usage: lightning address remove <addr>" >&2; exit 1; }
	local addr="$1"; shift
	read -r user domain <<<"$(parse_addr "$addr")"

	DB=$(wallet_db)
	[ -f "$DB" ] || { error "no wallet — run 'lightning wallet init' first"; exit 5; }
	sqlite3 "$DB" "DELETE FROM users WHERE user = '$(echo "$user" | sed "s/'/''/g")'"
	echo "ok"
	echo "address $addr removed"
}

subhelp() {
	case "$1" in
		resolve)
			cat <<'EOF'
usage: lightning address resolve <addr>

Fetch the LNURL-pay metadata for user@domain by GETting
https://<domain>/.well-known/lnurlp/<user> (LUD-16). Prints the
JSON: callback URL, minSendable / maxSendable, commentAllowed, etc.
EOF
			;;
		pay)
			cat <<'EOF'
usage: lightning address pay <addr> <sat>
            [--comment <text>] [--account <name>]

Resolve <addr> (LUD-16), fetch an invoice for <sat> sats from the
callback (LUD-06), and pay it. --comment is sent to the recipient
(truncated to their commentAllowed). --account tags the payment
in the ledger.
EOF
			;;
		create)
			cat <<'EOF'
usage: lightning address create <addr> [--account <name>]

Register <addr> (user@domain) as one of your Lightning Addresses.
Requires Apache (apache2 or httpd) on the host so the CGI
endpoints at .well-known/lnurlp/<user> can serve invoices.
Inserts into the wallet's users table; prints the BIP-353 TXT
record and a pointer to the Apache config snippet.
EOF
			;;
		list)
			cat <<'EOF'
usage: lightning address list

TSV of owned addresses (rows from the users table):
   user<TAB>account<TAB>min_sat<TAB>max_sat
EOF
			;;
		remove)
			cat <<'EOF'
usage: lightning address remove <addr>

Delete the user row for <addr>. Does NOT touch the Apache config
or remove existing payment history — only stops new invoices from
being issued via .well-known/lnurlp/<user>.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

SUB="$1"; shift || true
case "${1:-}" in
	--help|-h) subhelp "$SUB"; exit ;;
esac

case "$SUB" in
	resolve) cmd_resolve "$@" ;;
	pay)     cmd_pay "$@" ;;
	create)  cmd_create "$@" ;;
	list)    cmd_list "$@" ;;
	remove)  cmd_remove "$@" ;;
	help)    subhelp "${1:-}" || usage; exit ;;
	*) usage; exit 1 ;;
esac
