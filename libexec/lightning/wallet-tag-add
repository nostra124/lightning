#!/bin/bash
# lightning wallet-tag-add <wallet_name> <tag>   (FEAT-573)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-tag-add <wallet_name> <tag>"}'
    exit 0
fi
wname="$1"; tag="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
ts=$(date +%s)
sqlite3 "$db" "INSERT OR IGNORE INTO tags(tag,created_at) VALUES('$tag',$ts);" 2>/dev/null || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"ok\":true,\"wallet\":\"$wname\",\"tag\":\"$tag\"}"
