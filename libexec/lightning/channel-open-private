#!/bin/bash
# lightning channel-open-private <peer_id> <sat>   (FEAT-375)
set -e
if [ $# -lt 2 ]; then
    echo '{"error":"usage: channel-open-private <peer_id> <sat>"}'
    exit 0
fi
peer_id="$1"
sat="$2"
result=$(lightning-cli fundchannel "$peer_id" "${sat}sat" announce=false 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'channel_id': data.get('channel_id', ''), 'txid': data.get('txid', ''), 'private': True}, separators=(',', ':')))
" "$result"
