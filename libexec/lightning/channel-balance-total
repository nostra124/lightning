#!/bin/bash
# lightning channel-balance-total   (FEAT-670)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
local_total = sum(c.get('to_us_msat', 0) for c in channels if isinstance(c.get('to_us_msat', 0), int))
remote_total = sum((c.get('total_msat', 0) - c.get('to_us_msat', 0)) for c in channels if isinstance(c.get('total_msat', 0), int) and isinstance(c.get('to_us_msat', 0), int))
print(json.dumps({'local_msat': local_total, 'remote_msat': remote_total, 'total_channels': len(channels)}))
" "$result"
