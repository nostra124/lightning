#!/bin/bash
# lightning channel-balance-total   (FEAT-1176)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_local = sum(c.get('to_us_msat', 0) for c in channels if isinstance(c.get('to_us_msat'), int))
total_remote = sum(c.get('total_msat', 0) - c.get('to_us_msat', 0) for c in channels if isinstance(c.get('total_msat'), int) and isinstance(c.get('to_us_msat'), int))
print(json.dumps({'local_msat': total_local, 'remote_msat': total_remote, 'channels': len(channels)}))
" "$result"
