#!/bin/bash
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
uptimes = [p.get('total_uptime_seconds', 0) for p in peers if 'total_uptime_seconds' in p]
if len(uptimes) < 4:
    kurtosis = 0.0
else:
    n = len(uptimes)
    mean = sum(uptimes) / n
    variance = sum((x - mean) ** 2 for x in uptimes) / n
    if variance == 0:
        kurtosis = 0.0
    else:
        kurtosis = (sum((x - mean) ** 4 for x in uptimes) / n) / (variance ** 2) - 3
print(json.dumps({'uptime_kurtosis_peer': kurtosis}))
" "$result"
