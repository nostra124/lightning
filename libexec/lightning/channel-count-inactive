#!/bin/bash
# lightning channel-count-inactive   (FEAT-2877)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
count = sum(1 for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL' and not c.get('peer_connected', False))
print(json.dumps({'inactive_channel_count': count}))
" "$result"
