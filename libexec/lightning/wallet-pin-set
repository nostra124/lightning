#!/bin/bash
# lightning wallet-pin-set <wallet_name> <new_pin>   (FEAT-598)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-pin-set <wallet_name> <new_pin>"}'
    exit 0
fi
wname="$1"; pin="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
pin_hash=$(echo -n "$pin" | sha256sum | cut -d' ' -f1)
sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('pin_hash','$pin_hash');" 2>/dev/null || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"ok\":true,\"wallet\":\"$wname\",\"pin_set\":true}"
