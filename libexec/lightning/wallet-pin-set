#!/bin/bash
# lightning wallet-pin-set <wallet_name> <pin>   (FEAT-458)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-pin-set <wallet_name> <pin>"}'
    exit 0
fi
wname="$1"; pin="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
hash=$(printf '%s' "$pin" | openssl dgst -sha256 -hex 2>/dev/null | awk '{print $2}')
sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('pin_hash','$hash');" 2>/dev/null
echo '{"ok":true,"wallet":"'"$wname"'"}'
