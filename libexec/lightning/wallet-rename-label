#!/bin/bash
# lightning wallet-rename-label <wallet_name> <new_label>   (FEAT-623)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-rename-label <wallet_name> <new_label>"}'
    exit 0
fi
wname="$1"; new_label="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('label','$new_label');" 2>/dev/null || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"ok\":true,\"wallet\":\"$wname\",\"label\":\"$new_label\"}"
