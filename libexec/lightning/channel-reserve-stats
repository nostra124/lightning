#!/bin/bash
# lightning channel-reserve-stats   (FEAT-2162)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
our = [c.get('our_reserve_msat', 0) for c in channels if 'our_reserve_msat' in c]
their = [c.get('their_reserve_msat', 0) for c in channels if 'their_reserve_msat' in c]
def stats(vals):
    if not vals:
        return {}
    return {'min': min(vals), 'max': max(vals), 'avg': sum(vals) // len(vals), 'count': len(vals)}
print(json.dumps({'our_reserve_msat': stats(our), 'their_reserve_msat': stats(their)}))
" "$result"
