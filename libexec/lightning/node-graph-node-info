#!/bin/bash
# lightning node-graph-node-info <node_id>   (FEAT-1764)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-graph-node-info <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listnodes "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
if not nodes: print(json.dumps({'error': 'node not found'})); sys.exit(0)
n = nodes[0]
print(json.dumps({'nodeid': n.get('nodeid'), 'alias': n.get('alias'), 'color': n.get('color'), 'addresses': n.get('addresses')}))
" "$result"
