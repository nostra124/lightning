#!/bin/bash
# lightning node-listinvoices-paid-recent   (FEAT-2329)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = [inv for inv in data.get('invoices', []) if inv.get('status') == 'paid']
invoices.sort(key=lambda inv: inv.get('paid_at', 0), reverse=True)
recent = invoices[:10]
print(json.dumps({'recent_paid_invoices': recent}))
" "$result"
