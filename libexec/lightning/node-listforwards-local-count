#!/bin/bash
# lightning node-listforwards-local-count   (FEAT-2706)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
local_count = sum(1 for f in forwards if f.get('style') == 'local' or f.get('in_channel') is None)
print(json.dumps({'local_forward_count': local_count}))
" "$result"
