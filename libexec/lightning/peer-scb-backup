#!/bin/bash
# lightning peer-scb-backup   (FEAT-807)
result=$(lightning-cli staticbackup 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps({'peer_backup_count': len(d.get('peer_backup', []))}))" "$result"
