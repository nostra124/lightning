#!/bin/bash
# lightning peer-message-count <node_id>   (FEAT-837)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-message-count <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listpeers "$node_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
if peers:
    log = peers[0].get('log', [])
    print(json.dumps({'id': peers[0].get('id'), 'log_count': len(log)}))
else:
    print(json.dumps({'error': 'peer not found'}))
" "$result"
