#!/bin/bash
# lightning peer-age-stats   (FEAT-2126)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
now = int(time.time())
ages = []
for c in data.get('channels', []):
    opened = c.get('opened_at') or c.get('created_at')
    if opened:
        ages.append(now - int(opened))
if not ages:
    print(json.dumps({'min_age_s': None, 'max_age_s': None, 'avg_age_s': None, 'count': 0}))
else:
    print(json.dumps({'min_age_s': min(ages), 'max_age_s': max(ages), 'avg_age_s': sum(ages)//len(ages), 'count': len(ages)}))
" "$result"
