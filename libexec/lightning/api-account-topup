#!/bin/bash
# lightning api-account-topup <address> [<sat>]   (FEAT-212 PR-2)
#
# Returns the BIP-21 URI for the account's on-chain top-up address.
# The address IS the account ID (FEAT-212), so this is purely a
# format-conversion endpoint — no daemon call.  Optional <sat>
# parametrises the BIP-21 `amount=` query.
#
#   {"address":"bc1q...","uri":"bitcoin:bc1q...[?amount=N]","qr_text":"..."}

set -e
[ $# -ge 1 ] && [ $# -le 2 ] || exit 1
address="$1"; sat="${2:-}"

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
if [ -n "$sat" ]; then
	case "$sat" in ''|*[!0-9]*) exit 2 ;; esac
fi

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }
name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

# FEAT-243 — capability gate.
"$(cd "$(dirname "$0")" && pwd)/account" capability "$address" topup 2>/dev/null \
	|| { echo '{"error":"capability_disabled","capability":"topup"}'; exit 6; }

now=$(date -u +%s)
sqlite3 "$db" "UPDATE accounts SET last_api_call_at = $now WHERE address = $(sql_quote "$address");" 2>/dev/null || true

# BIP-21: amount is in BTC, not sat — convert if requested.
if [ -n "$sat" ]; then
	uri=$(printf 'bitcoin:%s?amount=%s.%08d' "$address" "$(( sat / 100000000 ))" "$(( sat % 100000000 ))")
else
	uri="bitcoin:$address"
fi

# QR text is just the URI; CGI client renders it.  Kept as a separate
# field so future renderings (e.g. SVG path) can land without breaking
# the contract.
jq -nc \
	--arg address "$address" \
	--arg uri "$uri" \
	'{address: $address, uri: $uri, qr_text: $uri}'
