#!/bin/bash
# lightning node-liquidity-ads   (FEAT-351)
set -e
result=$(lightning-cli listnodes 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
ads = [
    {'nodeid': n.get('nodeid', ''), 'alias': n.get('alias', ''), 'option_will_fund': n.get('option_will_fund', {})}
    for n in nodes
    if n.get('option_will_fund')
]
print(json.dumps(ads, separators=(',', ':')))
" "$result"
