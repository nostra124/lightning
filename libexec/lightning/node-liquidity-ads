#!/bin/bash
# lightning node-liquidity-ads   (FEAT-476)
if ! result=$(lightning-cli listconfigs 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
configs = json.loads(sys.argv[1])
cfg = configs.get('configs', configs)
lease = cfg.get('lease-fee-base-msat', {})
feebase = lease.get('value_msat', 0) if isinstance(lease, dict) else 0
print(json.dumps({'liquidity_ads_enabled': bool(feebase), 'lease_fee_base_msat': feebase}, separators=(',', ':')))
" "$result"
