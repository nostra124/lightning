#!/bin/bash
# lightning wallet-stats <wallet_name>   (FEAT-728)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-stats <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
tx_count=$(sqlite3 "$db" "SELECT COUNT(*) FROM transactions" 2>/dev/null) || tx_count=0
echo "{\"wallet\":\"$wname\",\"transactions\":$tx_count}"
