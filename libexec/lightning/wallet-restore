#!/bin/bash
# lightning wallet-restore <wallet_name> <backup_path>   (FEAT-1023)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-restore <wallet_name> <backup_path>"}'
    exit 0
fi
wname="$1"; src="$2"
if [ ! -f "$src" ]; then
    echo '{"error":"backup_not_found"}'
    exit 0
fi
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
mkdir -p "$root/$wname"
if cp "$src" "$root/$wname/state.db" 2>/dev/null; then
    echo "{\"ok\":true,\"wallet\":\"$wname\",\"restored_from\":\"$src\"}"
else
    echo '{"error":"restore_failed"}'
fi
