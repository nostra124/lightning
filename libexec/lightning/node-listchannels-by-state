#!/bin/bash
# lightning node-listchannels-by-state <state>   (FEAT-1089)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-listchannels-by-state <state>"}'
    exit 0
fi
state="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
st = sys.argv[2]
channels = [{'channel_id': ch.get('channel_id'), 'peer_id': ch.get('peer_id')} for ch in data.get('channels', []) if ch.get('state') == st]
print(json.dumps({'state': st, 'count': len(channels), 'channels': channels}))
" "$result" "$state"
