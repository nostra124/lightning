#!/bin/bash
# lightning invoice-created-index <label>   (FEAT-1435)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-created-index <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
if invs:
    i = invs[0]
    print(json.dumps({'label': i.get('label'), 'created_index': i.get('created_index')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
