#!/bin/bash
# lightning node-listpays-latest   (FEAT-1281)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = sorted(data.get('pays', []), key=lambda p: p.get('created_at', 0), reverse=True)[:5]
print(json.dumps({'count': len(pays), 'latest': pays}))
" "$result"
