#!/bin/bash
# lightning channel-htlc-pending-value   (FEAT-2332)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    for h in ch.get('htlcs', []):
        total += h.get('amount_msat', 0)
print(json.dumps({'pending_htlc_value_msat': total}))
" "$result"
