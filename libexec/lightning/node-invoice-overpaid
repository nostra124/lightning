#!/bin/bash
# lightning node-invoice-overpaid   (FEAT-984)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
overpaid = [i for i in data.get('invoices', []) if i.get('status') == 'paid' and i.get('amount_received_msat', 0) > i.get('amount_msat', 0)]
print(json.dumps({'count': len(overpaid), 'invoices': [i.get('label') for i in overpaid]}))
" "$result"
