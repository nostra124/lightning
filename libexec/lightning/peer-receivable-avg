#!/bin/bash
# lightning peer-receivable-avg   (FEAT-2618)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peers = {}
for ch in channels:
    pid = ch.get('peer_id', '')
    receivable = ch.get('receivable_msat', 0) or 0
    peers.setdefault(pid, []).append(receivable)
result = {}
for pid, vals in peers.items():
    result[pid] = sum(vals) / len(vals) if vals else 0
print(json.dumps({'receivable_avg_msat': result}))
" "$result"
