#!/bin/bash
# lightning node-invoice-paid-count-year   (FEAT-2796)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
now = time.time()
year_start = now - 365 * 24 * 3600
count = sum(1 for i in invoices if i.get('status') == 'paid' and i.get('paid_at', 0) >= year_start)
print(json.dumps({'paid_count_year': count}))
" "$result"
