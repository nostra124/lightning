#!/bin/bash
# lightning peer-capacity-stddev   (FEAT-2768)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_totals = {}
for c in channels:
    pid = c.get('peer_id', '')
    peer_totals[pid] = peer_totals.get(pid, 0) + c.get('total_msat', 0)
vals = list(peer_totals.values())
if len(vals) < 2:
    stddev = 0.0
else:
    mean = sum(vals) / len(vals)
    stddev = math.sqrt(sum((v - mean) ** 2 for v in vals) / len(vals))
print(json.dumps({'peer_capacity_stddev_msat': stddev}))
" "$result"
