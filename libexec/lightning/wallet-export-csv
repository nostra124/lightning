#!/bin/bash
# lightning wallet-export-csv <wallet_name>   (FEAT-773)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-export-csv <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
rows=$(sqlite3 -csv "$db" "SELECT * FROM transactions ORDER BY created_at DESC LIMIT 100" 2>/dev/null) || rows=""
echo "{\"wallet\":\"$wname\",\"csv\":$(python3 -c "import sys,json; print(json.dumps(sys.argv[1]))" "$rows")}"
