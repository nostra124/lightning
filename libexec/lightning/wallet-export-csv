#!/bin/bash
# lightning wallet-export-csv <wallet_name>   (FEAT-478)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-export-csv <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
sqlite3 -csv "$db" "SELECT id,ts,account,direction,amount_sat,tag,description FROM ledger ORDER BY ts;" 2>/dev/null \
    || echo '{"error":"export_failed"}'
