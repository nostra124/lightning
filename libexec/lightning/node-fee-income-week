#!/bin/bash
# lightning node-fee-income-week   (FEAT-1937)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
cutoff = time.time() - 604800
recent = [f for f in forwards if f.get('resolved_time', 0) >= cutoff]
fee_sum = sum(f.get('fee_msat', 0) for f in recent)
print(json.dumps({'count': len(recent), 'fee_msat_7d': fee_sum}))
" "$result"
