#!/bin/bash
# lightning node-listforwards-fee-variance   (FEAT-2799)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
vals = [f.get('fee_msat', 0) for f in forwards if 'fee_msat' in f]
if len(vals) >= 2:
    mean = sum(vals) / len(vals)
    variance = sum((v - mean) ** 2 for v in vals) / len(vals)
else:
    variance = 0.0
print(json.dumps({'fee_variance_msat': round(variance, 6), 'count': len(vals)}))
" "$result"
