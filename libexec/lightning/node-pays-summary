#!/bin/bash
# lightning node-pays-summary   (FEAT-764)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']
failed = [p for p in pays if p.get('status') == 'failed']
total_sent = sum(p.get('amount_sent_msat', 0) for p in complete if isinstance(p.get('amount_sent_msat', 0), int))
print(json.dumps({'total': len(pays), 'complete': len(complete), 'failed': len(failed), 'total_sent_msat': total_sent}))
" "$result"
