#!/bin/bash
# lightning peer-has-channels <peer_id>   (FEAT-1727)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-has-channels <peer_id>"}'; exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
print(json.dumps({'peer_id': sys.argv[2], 'has_channels': len(channels) > 0, 'count': len(channels)}))
" "$result" "$peer_id"
