#!/bin/bash
# lightning channel-remote-balance-bottom5   (FEAT-2617)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
entries = []
for ch in channels:
    total = ch.get('total_msat', 0) or 0
    to_us = ch.get('to_us_msat', 0) or 0
    remote = total - to_us
    entries.append({
        'channel_id': ch.get('short_channel_id') or ch.get('channel_id'),
        'peer_id': ch.get('peer_id'),
        'remote_msat': remote
    })
entries.sort(key=lambda x: x['remote_msat'])
print(json.dumps({'bottom5_channels_by_remote': entries[:5]}))
" "$result"
