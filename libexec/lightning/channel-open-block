#!/bin/bash
# lightning channel-open-block <channel_id>   (FEAT-1196)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-open-block <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        scid = ch.get('short_channel_id', '')
        block = int(scid.split('x')[0]) if scid and 'x' in scid else None
        print(json.dumps({'channel_id': ch.get('channel_id'), 'open_block': block}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
