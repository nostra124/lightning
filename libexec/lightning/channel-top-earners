#!/bin/bash
# lightning channel-top-earners [--limit N]   (FEAT-383)
set -e
limit=10
while [ $# -gt 0 ]; do
    case "$1" in
        --limit) limit="$2"; shift 2 ;;
        *) shift ;;
    esac
done
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
limit = int(sys.argv[2])
fwds = data.get('forwards', [])
totals = {}
for f in fwds:
    ch = f.get('in_channel', '')
    totals[ch] = totals.get(ch, 0) + f.get('fee_msat', 0)
top = sorted(totals.items(), key=lambda x: x[1], reverse=True)[:limit]
print(json.dumps([{'channel_id': ch, 'total_fee_msat': fee} for ch, fee in top], separators=(',', ':')))
" "$result" "$limit"
