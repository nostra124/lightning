#!/bin/bash
# lightning wallet-meta-delete-all <wallet_name>   (FEAT-1418)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-meta-delete-all <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
python3 -c "
import sys, sqlite3, json
db = sys.argv[1]; wname = sys.argv[2]
conn = sqlite3.connect(db)
cur = conn.execute('DELETE FROM meta')
count = cur.rowcount; conn.commit(); conn.close()
print(json.dumps({'wallet': wname, 'deleted': count}))
" "$db" "$wname" 2>/dev/null || echo '{"error":"db_error"}'
