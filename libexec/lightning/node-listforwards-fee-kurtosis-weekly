#!/bin/bash
# lightning node-listforwards-fee-kurtosis-weekly   (FEAT-2832)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time, math
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
week_ago = time.time() - 7 * 86400
vals = [f['fee_msat'] for f in forwards if 'fee_msat' in f and f.get('resolved_time', 0) >= week_ago]
if len(vals) < 4:
    print(json.dumps({'fee_kurtosis_weekly': None, 'sample_count': len(vals)}))
    sys.exit(0)
n = len(vals)
mean = sum(vals) / n
m2 = sum((x - mean) ** 2 for x in vals) / n
m4 = sum((x - mean) ** 4 for x in vals) / n
kurtosis = (m4 / (m2 ** 2)) - 3 if m2 != 0 else None
print(json.dumps({'fee_kurtosis_weekly': round(kurtosis, 4) if kurtosis is not None else None, 'sample_count': n}))
" "$result"
