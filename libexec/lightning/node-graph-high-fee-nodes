#!/bin/bash
# lightning node-graph-high-fee-nodes <min_ppm>   (FEAT-1709)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-graph-high-fee-nodes <min_ppm>"}'; exit 0
fi
min_ppm="$1"
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
min_ppm = int(sys.argv[2])
nodes = set()
for c in data.get('channels', []):
    if c.get('fee_per_millionth', 0) >= min_ppm:
        nodes.add(c.get('source'))
print(json.dumps({'min_ppm': min_ppm, 'node_count': len(nodes)}))
" "$result" "$min_ppm"
