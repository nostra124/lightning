#!/bin/bash
# lightning api-account-invoice-get <address> <payment_hash>   (FEAT-225)
#
# Look up a commercial invoice by payment_hash and recompute its
# *effective* amount from the stored terms + elapsed time since issue:
#
#   * paid within the Skonto window (elapsed <= skonto.within_days)
#       -> face * (100 - discount_pct) / 100   (early-pay discount)
#   * past the grace period (elapsed > due_days + late_fee.after_days)
#       -> face * (100 + late_fee.pct) / 100   (late fee)
#   * otherwise                                 -> face
#
# Settlement status is read live from `lightning-cli listinvoices`
# (by payment_hash); a settled invoice flips commerce_invoices.state
# to 'paid' so the POS reconciles the order.  Output:
#   {"bolt11":"...","payment_hash":"...","face_sat":<int>,
#    "effective_sat":<int>,"reference":{...},"terms":{...},
#    "issued_at":<int>,"elapsed_days":<int>,"state":"issued|paid",
#    "paid":true|false}

set -e
[ $# -eq 2 ] || exit 1
address="$1"; payment_hash="$2"

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
case "$payment_hash" in ''|*[!0-9a-fA-F]*) exit 2 ;; esac

command -v jq >/dev/null || { echo '{"error":"jq not installed"}'; exit 127; }

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }
name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

now=$(date -u +%s)
sqlite3 "$db" "UPDATE accounts SET last_api_call_at = $now WHERE address = $(sql_quote "$address");" 2>/dev/null || true

# Fetch the commercial invoice, scoped to THIS account so one account
# can't read another's order references.  The four NOT-NULL columns are
# read tab-separated; the two nullable JSON columns are pulled as
# separate scalar queries so an empty `reference` can't collapse the
# field-split and shift `terms` into the wrong variable.
row=$(sqlite3 -separator $'\t' "$db" "
	SELECT bolt11, face_sat, issued_at, state
	FROM commerce_invoices
	WHERE payment_hash = $(sql_quote "$payment_hash") AND account = $(sql_quote "$name");")
[ -n "$row" ] || { echo '{"error":"unknown invoice"}'; exit 4; }
IFS=$'\t' read -r bolt11 face_sat issued_at state <<<"$row"
ref_json=$(sqlite3 "$db" "SELECT reference FROM commerce_invoices WHERE payment_hash = $(sql_quote "$payment_hash") AND account = $(sql_quote "$name");")
terms_json=$(sqlite3 "$db" "SELECT terms FROM commerce_invoices WHERE payment_hash = $(sql_quote "$payment_hash") AND account = $(sql_quote "$name");")

# Settlement status from the backend (by payment_hash).  A missing
# plugin / RPC failure is non-fatal: we fall back to the stored state.
paid=false
if command -v lightning-cli >/dev/null; then
	inv_json=$(lightning-cli \
		--lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
		--network="${LIGHTNING_NETWORK:-bitcoin}" \
		listinvoices -k payment_hash="$payment_hash" 2>/dev/null) || inv_json='{"invoices":[]}'
	if jq -e '[.invoices[]? | select(.status=="paid")] | length > 0' >/dev/null 2>&1 <<<"$inv_json"; then
		paid=true
	fi
fi
if [ "$paid" = true ] && [ "$state" != "paid" ]; then
	sqlite3 "$db" "UPDATE commerce_invoices SET state='paid' WHERE payment_hash = $(sql_quote "$payment_hash");" 2>/dev/null || true
	state="paid"
fi

# Effective amount from terms + elapsed days.  Mirror the issue-time
# logic in api-account-invoice (which quotes at elapsed = 0).
elapsed_days=$(( (now - issued_at) / 86400 ))
[ "$elapsed_days" -ge 0 ] || elapsed_days=0
effective_sat="$face_sat"
if [ -n "$terms_json" ]; then
	read -r due_days sk_within sk_pct lf_after lf_pct < <(
		jq -r '[(.due_days // -1), (.skonto.within_days // -1), (.skonto.discount_pct // 0),
		        (.late_fee.after_days // -1), (.late_fee.pct // 0)] | @tsv' <<<"$terms_json")
	if [ "${sk_within:--1}" != "-1" ] && [ "$elapsed_days" -le "${sk_within:-0}" ] 2>/dev/null; then
		effective_sat=$(awk -v f="$face_sat" -v p="${sk_pct:-0}" 'BEGIN { printf "%d", f * (100 - p) / 100 }')
	elif [ "${lf_after:--1}" != "-1" ] && [ "${due_days:--1}" != "-1" ] \
	     && [ "$elapsed_days" -gt "$(( due_days + lf_after ))" ] 2>/dev/null; then
		effective_sat=$(awk -v f="$face_sat" -v p="${lf_pct:-0}" 'BEGIN { printf "%d", f * (100 + p) / 100 }')
	fi
fi

jq -nc \
	--arg b11 "$bolt11" \
	--arg hash "$payment_hash" \
	--argjson face "$face_sat" \
	--argjson eff "$effective_sat" \
	--argjson issued "$issued_at" \
	--argjson elapsed "$elapsed_days" \
	--arg state "$state" \
	--argjson paid "$paid" \
	--argjson ref "${ref_json:-null}" \
	--argjson terms "${terms_json:-null}" \
	'{bolt11: $b11, payment_hash: $hash, face_sat: $face, effective_sat: $eff,
	  reference: $ref, terms: $terms,
	  issued_at: $issued, elapsed_days: $elapsed, state: $state, paid: $paid}'
