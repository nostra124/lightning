#!/bin/bash
# lightning wallet — your Lightning identity.
#
# A single object covering the clightning node (FEAT-171, FEAT-184,
# FEAT-185) and the git-backed state repo (FEAT-174, FEAT-187). There
# is exactly one active wallet per machine; the on-disk layout lives at
# $LIGHTNING_DIR/wallet/default/.
#
# Subcommands — node-side (lightning-cli):
#   info                    summary of `lightning-cli getinfo`
#   id                      this node's pubkey
#   peers                   connected peers (TSV)
#   balance [--on-chain]    on-chain + LN balance / receive addr
#   unlock [--stored|rotate|forget]
#                           HSM unlock + secret-store integration
#   seed export [--out <f>] export the seed phrase
#   seed import             import a seed phrase
#   seed verify             prompt-verify the stored seed
#
# Subcommands — storage-side (git + sqlite):
#   init                    create the local state repo
#   push [remote]           git push
#   pull [remote]           git pull (rebuild state.db)
#   sync [remote]           pull + push
#   backup [--seed]         emit SCB + git push (FEAT-187)
#   backup verify           sanity-check the wallet backup
#   restore <remote>        clone wallet remote + rebuild state.db

set -e

usage() {
	cat >&2 <<EOF
usage: lightning wallet <subcommand> [args]

   Your Lightning identity: the clightning node (seed, channels,
   funds) plus the git-backed state repo that records everything
   you've done. Exactly one wallet per machine; the on-disk
   layout lives at \$LIGHTNING_DIR/wallet/default/. Sub-commands
   split into node (lightning-cli wrappers) and storage (git +
   sqlite). Each sub-command also accepts --help.

node:
   info                     summary of \`lightning-cli getinfo\`
   id                       this node's pubkey
   peers                    connected peers (TSV)
   balance [--on-chain]     on-chain + LN balance (TSV) / receive addr
   unlock [--stored|rotate|forget]
                            HSM unlock + secret-store integration
   seed export [--out <f>]  export the seed phrase
   seed import              import a seed phrase
   seed verify              prompt-verify the stored seed

storage:
   init                     create the local state repo
   push [remote]            git push
   pull [remote]            git pull (rebuild state.db)
   sync [remote]            pull + push
   backup [--seed]          emit SCB + git push
   backup verify            sanity-check the wallet backup
   restore <remote>         clone wallet remote + rebuild state.db
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
WALLET_ROOT="$LIGHTNING_DIR/wallet"
WALLET_NAME="default"

require_cli() {
	command -v lightning-cli >/dev/null || {
		error "lightning-cli not found — install Core Lightning (lightningd) and ensure lightning-cli is on PATH"
		exit 127
	}
}

require_secret() {
	command -v secret >/dev/null || {
		error "the \`secret\` package is required (https://github.com/nostra124/secret)"
		exit 127
	}
}

require_sqlite() {
	command -v sqlite3 >/dev/null || {
		error "sqlite3 not found — install sqlite3"; exit 127; }
}

cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

wallet_dir() { echo "$WALLET_ROOT/$WALLET_NAME"; }
wallet_db()  { echo "$(wallet_dir)/state.db"; }

hsm_secret_path() {
	local p="$LIGHTNING_DIR/$LIGHTNING_NETWORK/hsm_secret"
	[ -f "$p" ] || p="$LIGHTNING_DIR/hsm_secret"
	echo "$p"
}

is_encrypted() {
	local p; p=$(hsm_secret_path)
	[ -f "$p" ] || return 1
	local n; n=$(stat -c%s "$p" 2>/dev/null || stat -f%z "$p")
	[ "$n" -gt 32 ]
}

# -----------------------------------------------------------------------------
# node-side: info / id / peers / balance (FEAT-171)
# -----------------------------------------------------------------------------

cmd_info() {
	require_cli
	local json; json=$(cli getinfo) || {
		error "lightning-cli getinfo failed (is the daemon running? try \`lightning daemon status\`)"
		exit 2
	}

	if command -v jq >/dev/null; then
		j() { jq -r "$1" <<<"$json"; }
		printf "id:          %s\n" "$(j .id)"
		printf "alias:       %s\n" "$(j .alias)"
		printf "color:       %s\n" "$(j .color)"
		printf "network:     %s\n" "$(j .network)"
		printf "version:     %s\n" "$(j .version)"
		printf "blockheight: %s\n" "$(j .blockheight)"
		printf "channels:    active=%s pending=%s inactive=%s\n" \
			"$(j .num_active_channels)" "$(j .num_pending_channels)" "$(j .num_inactive_channels)"
		printf "peers:       %s\n" "$(j .num_peers)"
	else
		echo "$json"
	fi
}

cmd_id() {
	require_cli
	cli getinfo | jq -r .id
}

cmd_peers() {
	require_cli
	printf "pubkey\tconnected\tfeatures\taddr\n"
	cli listpeers \
		| jq -r '.peers[] | [.id, (.connected|tostring), (.features // "-"), ((.netaddr // [])[0] // "-")] | @tsv'
}

cmd_balance() {
	require_cli
	if [ "${1:-}" = "--on-chain" ]; then
		cli newaddr | jq -r '.bech32 // .p2tr // .p2wkh'
		return
	fi
	local json; json=$(cli listfunds)
	printf "onchain_confirmed_sat\tonchain_unconfirmed_sat\tchannels_sat\n"
	jq -r '[
		([.outputs[]? | select(.status == "confirmed") | (.amount_msat // (.value*1000)) ] | add // 0 | . / 1000 | floor),
		([.outputs[]? | select(.status == "unconfirmed") | (.amount_msat // (.value*1000)) ] | add // 0 | . / 1000 | floor),
		([.channels[]? | (.our_amount_msat // (.channel_sat*1000)) ] | add // 0 | . / 1000 | floor)
	] | @tsv' <<<"$json"
}

# -----------------------------------------------------------------------------
# node-side: unlock (FEAT-184)
# -----------------------------------------------------------------------------

unlock_interactive() {
	require_cli; require_secret

	if ! is_encrypted; then
		info "hsm_secret is not encrypted (32 bytes); nothing to unlock"
		exit 0
	fi

	echo -n "lightning: HSM password for $WALLET_NAME: " >&2
	local pw; read -rs pw; echo >&2

	if ! echo "$pw" | cli hsmtool decrypt "$(hsm_secret_path)" >/dev/null 2>&1; then
		if ! cli unlock "$pw" >/dev/null 2>&1; then
			error "unlock failed (wrong password?)"
			exit 3
		fi
	fi

	echo "$pw" | secret put "lightning.$WALLET_NAME.unlock" >/dev/null
	info "unlocked and stored under secret/lightning.$WALLET_NAME.unlock"
}

unlock_stored() {
	require_cli; require_secret

	if ! is_encrypted; then exit 0; fi

	local pw
	pw=$(secret get "lightning.$WALLET_NAME.unlock" 2>/dev/null) || {
		error "no stored unlock secret at lightning.$WALLET_NAME.unlock"
		exit 4
	}

	if ! echo "$pw" | cli hsmtool decrypt "$(hsm_secret_path)" >/dev/null 2>&1; then
		cli unlock "$pw" >/dev/null 2>&1 || {
			error "stored secret rejected (was the password rotated outside this tool?)"
			exit 3
		}
	fi
}

unlock_rotate() {
	require_cli; require_secret

	echo -n "lightning: current HSM password: " >&2; read -rs old; echo >&2
	echo -n "lightning: new HSM password:     " >&2; read -rs new1; echo >&2
	echo -n "lightning: confirm new password: " >&2; read -rs new2; echo >&2

	if [ "$new1" != "$new2" ]; then
		error "new passwords don't match"
		exit 5
	fi

	if ! printf '%s\n%s\n' "$old" "$new1" | cli hsmtool generatehsm "$(hsm_secret_path)" 2>/dev/null; then
		warn "rotate via hsmtool failed; trying RPC \`changepw\`"
		cli changepw "$old" "$new1" >/dev/null || {
			error "rotate failed"
			exit 3
		}
	fi

	echo "$new1" | secret put "lightning.$WALLET_NAME.unlock" >/dev/null
	info "password rotated; secret store updated"
}

unlock_forget() {
	require_secret
	secret rm "lightning.$WALLET_NAME.unlock" 2>/dev/null || true
	info "stored unlock secret removed; future restarts will prompt"
}

cmd_unlock() {
	while [ $# -gt 0 ]; do
		case "$1" in
			--stored) shift; unlock_stored "$@"; return ;;
			rotate)   shift; unlock_rotate "$@"; return ;;
			forget)   shift; unlock_forget "$@"; return ;;
			--help|-h) usage; return ;;
			*) error "wallet unlock: unknown arg '$1'"; exit 1 ;;
		esac
	done
	unlock_interactive
}

# -----------------------------------------------------------------------------
# node-side: seed (FEAT-185)
# -----------------------------------------------------------------------------

seed_export() {
	require_cli
	local outfile=""
	while [ $# -gt 0 ]; do
		case "$1" in
			--out) outfile="$2"; shift 2 ;;
			*) error "wallet seed export: unknown flag '$1'"; exit 1 ;;
		esac
	done

	local hs; hs=$(hsm_secret_path)
	[ -f "$hs" ] || { error "no hsm_secret found at $hs"; exit 4; }

	local mnemonic
	mnemonic=$(cli hsmtool gethsmsecret "$hs" 2>/dev/null | tr -d '"\n' || true)
	if [ -z "$mnemonic" ]; then
		mnemonic=$(xxd -p "$hs" 2>/dev/null | tr -d '\n')
	fi

	if [ -n "$outfile" ]; then
		echo "$mnemonic" > "$outfile"
		chmod 600 "$outfile"
		warn "seed written to $outfile (keep this safe!)"
	else
		cat >&2 <<'BANNER'
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                    WARNING                            !
!    This seed controls ALL your Lightning funds.       !
!    Anyone with this phrase can steal your money.      !
!    Read it once, then store it OFFLINE.               !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
BANNER
		echo >&2
		echo "$mnemonic"
	fi
}

seed_import() {
	require_cli
	echo -n "lightning: paste your seed phrase (12/24 words) and press Enter: " >&2
	read -r phrase

	local hs; hs=$(hsm_secret_path)
	if [ -f "$hs" ] && [ ! -s "$hs" ]; then
		rm -f "$hs"
	fi
	[ -f "$hs" ] && {
		error "hsm_secret already exists; refusing to overwrite"
		exit 3
	}

	if ! cli hsmtool generatehsm "$hs" 2>/dev/null <<<"$phrase"; then
		error "seed import failed (wrong phrase length?)"
		exit 4
	fi
	echo "ok"
	warn "seed imported; daemon ready for unlock"
}

seed_verify() {
	require_cli
	local hs; hs=$(hsm_secret_path)
	[ -f "$hs" ] || { error "no hsm_secret found"; exit 4; }

	local mnemonic
	mnemonic=$(cli hsmtool gethsmsecret "$hs" 2>/dev/null | tr -d '"\n' || true)
	[ -z "$mnemonic" ] && {
		error "could not read seed from daemon"
		exit 4
	}

	IFS=' ' read -ra words <<<"$mnemonic"
	local n=${#words[@]}
	[ "$n" -lt 12 ] && { error "seed phrase too short ($n words)"; exit 4; }

	local i1 i2
	i1=$(( ($(od -An -N2 -i /dev/random) % n) ))
	i2=$(( ($(od -An -N2 -i /dev/random 2>/dev/null || echo 42) % n) ))
	while [ "$i2" = "$i1" ]; do
		i2=$(( (i2 + 1) % n ))
	done

	echo -n "lightning: verify seed — word $((i1+1)): " >&2
	read -r w1
	echo -n "lightning: verify seed — word $((i2+1)): " >&2
	read -r w2

	if [ "${words[$i1]}" = "$w1" ] && [ "${words[$i2]}" = "$w2" ]; then
		echo "ok"
		warn "seed verified"
	else
		error "seed verification FAILED — phrases do not match"
		exit 2
	fi
}

cmd_seed() {
	[ $# -lt 1 ] && {
		cat >&2 <<EOF
usage: lightning wallet seed <subcommand> [args]

subcommands:
   export [--out <file>]
   import
   verify
EOF
		exit 1
	}
	case "$1" in
		export) shift; seed_export "$@" ;;
		import) shift; seed_import "$@" ;;
		verify) shift; seed_verify "$@" ;;
		*) error "wallet seed: unknown subcommand '$1'"; exit 1 ;;
	esac
}

# -----------------------------------------------------------------------------
# storage-side: init / push / pull / sync (FEAT-174)
# -----------------------------------------------------------------------------

init_db() {
	local db="$1"
	sqlite3 "$db" <<'EOSQL'
CREATE TABLE IF NOT EXISTS accounts (
    name        TEXT    PRIMARY KEY,
    description TEXT    NOT NULL DEFAULT '',
    limit_sat   INTEGER,
    overdraft   TEXT    NOT NULL DEFAULT 'deny'
);
CREATE TABLE IF NOT EXISTS ledger (
    id           INTEGER PRIMARY KEY,
    ts           TEXT    NOT NULL,
    account      TEXT    NOT NULL DEFAULT '-',
    direction    TEXT    NOT NULL,
    amount_msat  INTEGER NOT NULL,
    peer         TEXT    NOT NULL DEFAULT '-',
    payment_hash TEXT    NOT NULL DEFAULT '-',
    message      TEXT    NOT NULL DEFAULT '',
    note         TEXT    NOT NULL DEFAULT ''
);
CREATE TABLE IF NOT EXISTS invoices (
    bolt11       TEXT    PRIMARY KEY,
    payment_hash TEXT    NOT NULL,
    account      TEXT    NOT NULL DEFAULT '-',
    amount_msat  INTEGER NOT NULL,
    expiry       TEXT    NOT NULL,
    message      TEXT    NOT NULL DEFAULT '',
    state        TEXT    NOT NULL DEFAULT 'pending'
);
CREATE TABLE IF NOT EXISTS channel_notes (
    channel_id TEXT PRIMARY KEY,
    note       TEXT NOT NULL
);
CREATE TABLE IF NOT EXISTS users (
    user        TEXT    PRIMARY KEY,
    account     TEXT    NOT NULL,
    min_sat     INTEGER NOT NULL DEFAULT 1,
    max_sat     INTEGER NOT NULL DEFAULT 100000000,
    comment_max INTEGER NOT NULL DEFAULT 256
);
EOSQL
}

init_gitignore() {
	local dir="$1"
	cat > "$dir/.gitignore" <<'EOF'
state.db
*.db
EOF
}

cmd_init() {
	require_sqlite
	local wdir; wdir=$(wallet_dir)

	if [ -d "$wdir" ]; then
		error "wallet already exists at $wdir"
		exit 3
	fi

	mkdir -p "$wdir"
	init_db "$wdir/state.db"
	init_gitignore "$wdir"
	echo "$LIGHTNING_DIR" > "$wdir/lightning-dir"

	git -C "$wdir" init --quiet

	# Install the pre-commit hook BEFORE the first commit so it can
	# auto-dump state.db to state.sql and stage it during this commit.
	mkdir -p "$wdir/.git/hooks"
	cat > "$wdir/.git/hooks/pre-commit" <<'EOF'
#!/bin/bash
# Auto-regenerate state.sql from state.db on commit.
cd "$(git rev-parse --git-dir)/.."
if [ -f state.db ]; then
	sqlite3 state.db .dump > state.sql.tmp
	mv state.sql.tmp state.sql
	git add state.sql
fi
EOF
	chmod +x "$wdir/.git/hooks/pre-commit"

	# git commit prints a "nothing to commit" hint on STDOUT (not
	# stderr) when staging is empty; redirect both. --quiet only
	# suppresses success output.
	git -C "$wdir" add .gitignore lightning-dir >/dev/null 2>&1
	git -C "$wdir" commit -m "wallet: init" --quiet >/dev/null 2>&1 || \
		warn "initial commit failed — wallet created but unversioned (check 'git config user.email')"

	echo "ok"
	echo "wallet: $wdir"
}

cmd_push() {
	require_sqlite
	local remote="${1:-origin}"
	local wdir; wdir=$(wallet_dir)
	[ -d "$wdir/.git" ] || {
		error "wallet not initialized at $wdir — run \`lightning wallet init\`"
		exit 5
	}

	if [ -f "$wdir/state.db" ]; then
		sqlite3 "$wdir/state.db" .dump > "$wdir/state.sql.tmp"
		mv "$wdir/state.sql.tmp" "$wdir/state.sql"
	fi
	git -C "$wdir" add -A >/dev/null 2>&1
	git -C "$wdir" commit --allow-empty -m "wallet: auto-sync $(date -u +%Y-%m-%dT%H:%M:%SZ)" --quiet >/dev/null 2>&1 || true
	git -C "$wdir" push "$remote" >/dev/null 2>&1 || \
		warn "push failed — set remote with 'git -C $wdir remote add $remote <url>'"
	echo "ok"
}

cmd_pull() {
	require_sqlite
	local remote="${1:-origin}"
	local wdir; wdir=$(wallet_dir)
	[ -d "$wdir/.git" ] || {
		error "wallet not initialized at $wdir — run \`lightning wallet init\`"
		exit 5
	}

	git -C "$wdir" pull "$remote" 2>&1 || warn "pull failed"

	if [ -f "$wdir/state.sql" ] && [ ! -f "$wdir/state.db" ]; then
		sqlite3 "$wdir/state.db" < "$wdir/state.sql"
	elif [ -f "$wdir/state.sql" ]; then
		sqlite3 "$wdir/state.db.tmp" < "$wdir/state.sql" 2>/dev/null && \
			mv "$wdir/state.db.tmp" "$wdir/state.db" || true
	fi
	echo "ok"
}

cmd_sync() {
	cmd_pull "$@"
	cmd_push "$@"
}

# -----------------------------------------------------------------------------
# storage-side: backup / restore (FEAT-187)
# -----------------------------------------------------------------------------

_sibling() {
	local lib="${SELF_LIBEXEC:+$SELF_LIBEXEC/lightning}"
	lib="${lib:-$(cd "$(dirname "$0")" && pwd)}"
	echo "$lib/$1"
}

backup_emit() {
	local include_seed=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--seed) include_seed=1; shift ;;
			*) error "wallet backup: unknown flag '$1'"; exit 1 ;;
		esac
	done

	"$(_sibling channel)" scb emit

	if [ "$include_seed" -eq 1 ]; then
		cat >&2 <<'BANNER'
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!   WARNING: storing your seed in the wallet repo       !
!   makes it available to anyone who can read the git   !
!   history. Only use --seed if you understand this.    !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
BANNER
		local seed_path; seed_path="$(wallet_dir)/seed.enc"
		seed_export --out "$seed_path"
		warn "seed exported to $seed_path"

		local wdir; wdir=$(wallet_dir)
		if [ -d "$wdir/.git" ]; then
			git -C "$wdir" add "$seed_path" 2>/dev/null || true
			git -C "$wdir" commit -m "backup: seed export" --quiet 2>/dev/null || true
		fi
	fi

	cmd_push

	warn "backup complete"
}

backup_verify() {
	local wdir; wdir=$(wallet_dir)
	local scb_count; scb_count=$(ls "$wdir/scb/"*.json 2>/dev/null | wc -l)

	[ "$scb_count" -gt 0 ] || {
		warn "WARNING — no SCB snapshots found in wallet"
	}

	local remote
	remote=$(git -C "$wdir" remote get-url origin 2>/dev/null) || remote="(none)"
	echo "wallet:      $WALLET_NAME"
	echo "remote:      $remote"
	echo "scb_count:   $scb_count"

	if [ -f "$wdir/seed.enc" ]; then
		echo "seed:        present at $wdir/seed.enc"
	else
		echo "seed:        not stored in wallet (expected — use --seed at backup time)"
	fi
	warn "backup structure looks intact"
}

cmd_backup() {
	if [ "${1:-}" = "verify" ]; then
		shift; backup_verify "$@"
	else
		backup_emit "$@"
	fi
}

cmd_restore() {
	[ $# -lt 1 ] && { echo "usage: lightning wallet restore <remote>" >&2; exit 1; }
	require_sqlite
	local remote="$1"
	local wdir; wdir=$(wallet_dir)

	[ -d "$wdir" ] && {
		error "wallet already exists at $wdir — move it aside before restoring"
		exit 3
	}

	mkdir -p "$WALLET_ROOT"
	git clone "$remote" "$wdir" 2>/dev/null || {
		error "failed to clone $remote"; exit 4; }

	if [ -f "$wdir/state.sql" ] && ! [ -f "$wdir/state.db" ]; then
		sqlite3 "$wdir/state.db" < "$wdir/state.sql"
	fi

	local latest_scb; latest_scb=$(ls -t "$wdir/scb/"*.json 2>/dev/null | head -1)

	warn "wallet restored from $remote"
	warn "now run 'lightning wallet seed import' to restore your seed,"
	echo "          then 'lightning wallet unlock' to unlock the daemon." >&2

	if [ -n "$latest_scb" ]; then
		warn "latest SCB: $latest_scb"
		echo "          run 'lightning channel scb restore $latest_scb' after unlock" >&2
	fi
}

subhelp() {
	case "$1" in
		info)
			cat <<'EOF'
usage: lightning wallet info

Summary of `lightning-cli getinfo`: id, alias, color, network,
version, blockheight, channel counts (active/pending/inactive),
peer count. Requires the daemon to be running and unlocked.
EOF
			;;
		id)
			cat <<'EOF'
usage: lightning wallet id

Print this node's public key (the `.id` field of getinfo). The
pubkey is your stable identity on the Lightning network.
EOF
			;;
		peers)
			cat <<'EOF'
usage: lightning wallet peers

TSV of connected peers. Columns:
   pubkey<TAB>connected<TAB>features<TAB>addr
EOF
			;;
		balance)
			cat <<'EOF'
usage: lightning wallet balance [--on-chain]

Without flags: TSV row of on-chain and channel balance in sats:
   onchain_confirmed_sat<TAB>onchain_unconfirmed_sat<TAB>channels_sat
With --on-chain: print a fresh receive address for funding the node.
EOF
			;;
		unlock)
			cat <<'EOF'
usage: lightning wallet unlock [--stored | rotate | forget]
       lightning wallet unlock [--wallet <name>]

Release the clightning HSM. With no flags, prompts for the password
interactively and stores it under `secret/lightning.<wallet>.unlock`
for future auto-unlock. --stored reads the stored secret instead.
rotate changes the password (daemon + secret store atomically).
forget drops the stored secret.
EOF
			;;
		seed)
			cat <<'EOF'
usage: lightning wallet seed <export|import|verify> [args]

Manage the 12/24-word BIP-39 seed phrase that controls all funds.
   export [--out <file>]  print or write the seed (DANGEROUS)
   import                 paste a phrase to create a new hsm_secret
   verify                 prompt-verify two random words

The seed is the ONLY thing that survives a full disk loss. Treat
the export like the keys to your bank vault.
EOF
			;;
		init)
			cat <<'EOF'
usage: lightning wallet init

Create the local state repo at $LIGHTNING_DIR/wallet/default/.
Initialises a SQLite store (state.db) and a git repo with a
pre-commit hook that auto-dumps state.db to state.sql. Idempotent:
refuses to overwrite an existing wallet.
EOF
			;;
		push)
			cat <<'EOF'
usage: lightning wallet push [<remote>]

Regenerate state.sql from state.db, commit any changes, then
`git push <remote>` (default: origin). Configure the remote with
`git -C $LIGHTNING_DIR/wallet/default remote add origin <url>`.
EOF
			;;
		pull)
			cat <<'EOF'
usage: lightning wallet pull [<remote>]

`git pull <remote>` (default: origin) then rebuild state.db by
replaying state.sql. Use after restoring on a fresh machine or
when another device has pushed new state.
EOF
			;;
		sync)
			cat <<'EOF'
usage: lightning wallet sync [<remote>]

Shortcut for `wallet pull` followed by `wallet push`. Run this on
each device that shares the wallet repo to keep them in step.
EOF
			;;
		backup)
			cat <<'EOF'
usage: lightning wallet backup [--seed]
       lightning wallet backup verify

Emit a fresh Static Channel Backup snapshot (via `channel scb emit`),
then `wallet push`. With --seed, also exports the seed phrase into
the repo as seed.enc (WARNING: anyone with git access can read it).
`verify` does a read-only sanity check of the backup structure.
EOF
			;;
		restore)
			cat <<'EOF'
usage: lightning wallet restore <wallet-remote>

Clone <wallet-remote> into $LIGHTNING_DIR/wallet/default/ and
rebuild state.db from state.sql. Refuses if a wallet already
exists at the target. After restore, run `wallet seed import`,
`wallet unlock`, and `channel scb restore <latest.json>` to
recover channel state.
EOF
			;;
		*)
			usage
			return 1
			;;
	esac
}

# --help / -h interception: print sub-command help and exit.
SUB="$1"; shift || true
case "${1:-}" in
	--help|-h)
		subhelp "$SUB"
		exit
		;;
esac

case "$SUB" in
	info)    cmd_info "$@" ;;
	id)      cmd_id "$@" ;;
	peers)   cmd_peers "$@" ;;
	balance) cmd_balance "$@" ;;
	unlock)  cmd_unlock "$@" ;;
	seed)    cmd_seed "$@" ;;
	init)    cmd_init "$@" ;;
	push)    cmd_push "$@" ;;
	pull)    cmd_pull "$@" ;;
	sync)    cmd_sync "$@" ;;
	backup)  cmd_backup "$@" ;;
	restore) cmd_restore "$@" ;;
	help)    subhelp "${1:-}" || usage; exit ;;
