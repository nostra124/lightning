#!/bin/bash
# lightning node-invoice-count-by-day   (FEAT-2284)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from datetime import datetime, timezone
data = json.loads(sys.argv[1])
invoices = [i for i in data.get('invoices', []) if i.get('status') == 'paid' and 'paid_at' in i]
counts = {}
for inv in invoices:
    day = datetime.fromtimestamp(inv['paid_at'], tz=timezone.utc).strftime('%Y-%m-%d')
    counts[day] = counts.get(day, 0) + 1
print(json.dumps({'invoices_by_day': counts}))
" "$result"
