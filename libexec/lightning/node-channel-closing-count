#!/bin/bash
# lightning node-channel-closing-count   (FEAT-1299)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
closing_states = {'CLOSINGD_SIGEXCHANGE', 'CLOSINGD_COMPLETE', 'AWAITING_UNILATERAL', 'FUNDING_SPEND_SEEN', 'ONCHAIN'}
closing = [c for c in data.get('channels', []) if c.get('state') in closing_states]
print(json.dumps({'closing_count': len(closing)}))
" "$result"
