#!/bin/bash
# lightning invoice-label-list   (FEAT-785)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
labels = [i.get('label') for i in data.get('invoices', []) if i.get('label')]
print(json.dumps(labels))
" "$result"
