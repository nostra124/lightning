#!/bin/bash
# lightning channel-capacity-stats   (FEAT-2122)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
caps = [c.get('total_msat', 0) for c in data.get('channels', []) if 'total_msat' in c]
if not caps:
    print(json.dumps({'min': None, 'max': None, 'avg': None, 'total': 0, 'count': 0}))
else:
    print(json.dumps({'min': min(caps), 'max': max(caps), 'avg': sum(caps)//len(caps), 'total': sum(caps), 'count': len(caps)}))
" "$result"
