#!/bin/bash
# lightning wallet-pin-hash <wallet_name>   (FEAT-1113)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-pin-hash <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
hash=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='pin_hash';" 2>/dev/null || echo "")
echo "{\"wallet\":\"$wname\",\"pin_hash\":\"$hash\"}"
