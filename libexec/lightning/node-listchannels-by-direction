#!/bin/bash
# lightning node-listchannels-by-direction <direction>   (FEAT-1704)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-listchannels-by-direction <direction>"}'; exit 0
fi
direction="$1"
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
d = int(sys.argv[2]) if sys.argv[2].isdigit() else -1
channels = [c for c in data.get('channels', []) if c.get('direction') == d]
print(json.dumps({'direction': d, 'count': len(channels)}))
" "$result" "$direction"
