#!/bin/bash
# lightning channel-inflight-htlc-total   (FEAT-1796)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(len(c.get('htlcs', [])) for c in data.get('channels', []))
print(json.dumps({'total_inflight_htlcs': total}))
" "$result"
