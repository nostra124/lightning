#!/bin/bash
# lightning channel-min-to-them <channel_id>   (FEAT-1226)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-min-to-them <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        total = ch.get('total_msat', 0)
        local = ch.get('to_us_msat', 0)
        print(json.dumps({'channel_id': ch.get('channel_id'), 'to_them_msat': total - local if isinstance(total, int) and isinstance(local, int) else None}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
