#!/bin/bash
# lightning node-listpays-amount-range   (FEAT-2041)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
args = sys.argv[2:]
pays = data.get('pays', [])
complete = [p for p in pays if p.get('status') == 'complete']

def to_msat(v):
    if isinstance(v, str) and v.endswith('msat'):
        return int(v[:-4])
    return int(v)

amounts = [to_msat(p.get('amount_sent_msat', 0)) for p in complete]

if len(args) >= 2:
    mn, mx = int(args[0]), int(args[1])
    filtered = [a for a in amounts if mn <= a <= mx]
    print(json.dumps({'count': len(filtered), 'min_msat': mn, 'max_msat': mx}))
elif len(amounts) > 0:
    print(json.dumps({'count': len(amounts), 'min_msat': min(amounts), 'max_msat': max(amounts)}))
else:
    print(json.dumps({'count': 0, 'min_msat': 0, 'max_msat': 0}))
" "$result" "$@"
