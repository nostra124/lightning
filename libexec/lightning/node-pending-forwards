#!/bin/bash
# lightning node-pending-forwards   (FEAT-759)
result=$(lightning-cli listforwards status=offered 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
print(json.dumps({'pending': len(fwds), 'forwards': fwds[:20]}))
" "$result"
