#!/bin/bash
# lightning peer-list-by-capacity   (FEAT-1417)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from collections import defaultdict
data = json.loads(sys.argv[1])
caps = defaultdict(int)
for ch in data.get('channels', []):
    caps[ch.get('peer_id', '')] += ch.get('total_msat', 0)
peers = sorted([{'peer_id': k, 'total_capacity_msat': v} for k, v in caps.items()], key=lambda x: x['total_capacity_msat'], reverse=True)
print(json.dumps({'count': len(peers), 'peers': peers}))
" "$result"
