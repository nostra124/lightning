#!/bin/bash
# lightning wallet-network   (FEAT-613)
if ! result=$(lightning-cli getinfo 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'network': data.get('network'), 'chain': data.get('id')}))
" "$result"
