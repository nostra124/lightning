#!/bin/bash
# lightning node-pay-volume-daily   (FEAT-2229)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from datetime import datetime, timezone, timedelta
data = json.loads(sys.argv[1])
now = datetime.now(timezone.utc)
cutoff = now - timedelta(days=7)
daily = {}
for p in data.get('pays', []):
    if p.get('status') != 'complete': continue
    ts = p.get('created_at', 0)
    dt = datetime.fromtimestamp(ts, tz=timezone.utc)
    if dt < cutoff: continue
    day = dt.strftime('%Y-%m-%d')
    amt = int(str(p.get('amount_sent_msat', 0) or 0).replace('msat',''))
    daily[day] = daily.get(day, 0) + amt
print(json.dumps({'daily_volume_msat': daily}))
" "\$result"
