#!/bin/bash
# lightning node-listforwards-newest   (FEAT-2281)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = [f for f in data.get('forwards', []) if f.get('status') == 'settled']
if not forwards:
    print(json.dumps({'newest_forward': None}))
    sys.exit(0)
newest = max(forwards, key=lambda f: f.get('received_time', 0))
print(json.dumps({'newest_forward': newest}))
" "$result"
