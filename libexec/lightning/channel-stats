#!/bin/bash
# lightning channel-stats <channel_id>   (FEAT-746)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-stats <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
for ch in data.get('channels', []):
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        print(json.dumps({'channel_id': ch.get('channel_id'), 'in_fulfilled_msat': ch.get('in_fulfilled_msat'), 'out_fulfilled_msat': ch.get('out_fulfilled_msat'), 'in_offered_msat': ch.get('in_offered_msat'), 'out_offered_msat': ch.get('out_offered_msat')}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$channel_id"
