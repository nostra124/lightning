#!/bin/bash
# lightning peer-capacity-min   (FEAT-2463)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
peer_cap = {}
for c in channels:
    pid = c.get('peer_id', '')
    cap = c.get('local_msat', 0) + c.get('remote_msat', 0)
    peer_cap[pid] = peer_cap.get(pid, 0) + cap
if not peer_cap:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
best = min(peer_cap, key=lambda p: peer_cap[p])
print(json.dumps({'peer_id': best, 'capacity_msat': peer_cap[best]}))
" "$result"
