#!/bin/bash
# lightning node-channel-normal-count   (FEAT-1239)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
normal = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'normal_count': len(normal)}))
" "$result"
