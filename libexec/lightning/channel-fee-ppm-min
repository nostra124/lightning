#!/bin/bash
# lightning channel-fee-ppm-min   (FEAT-2385)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
active = [ch for ch in channels if 'fee_proportional_millionths' in ch]
if not active:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
best = min(active, key=lambda c: c['fee_proportional_millionths'])
print(json.dumps({'peer_id': best.get('peer_id', ''), 'fee_proportional_millionths': best['fee_proportional_millionths']}))
" "$result"
