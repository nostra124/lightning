#!/bin/bash
# lightning node-channel-stats   (FEAT-445)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
by_state = {}
for c in channels:
    s = c.get('state', 'unknown')
    by_state[s] = by_state.get(s, 0) + 1
total_cap = sum(c.get('total_msat', 0) for c in channels if c.get('state') == 'CHANNELD_NORMAL')
print(json.dumps({'total_channels': len(channels), 'by_state': by_state,
    'total_active_capacity_msat': total_cap}, separators=(',', ':')))
" "$result"
