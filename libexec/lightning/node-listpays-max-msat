#!/bin/bash
# lightning node-listpays-max-msat   (FEAT-2071)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete']
if not pays:
    print(json.dumps({'max_amount_sent_msat': 0}))
else:
    max_msat = max(int(str(p.get('amount_sent_msat', 0)).replace('msat','')) for p in pays)
    print(json.dumps({'max_amount_sent_msat': max_msat}))
" "$result"
