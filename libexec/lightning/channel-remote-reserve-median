#!/bin/bash
# lightning channel-remote-reserve-median   (FEAT-2645)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = sorted([c['remote_reserve_msat'] for c in channels if 'remote_reserve_msat' in c])
if vals:
    n = len(vals)
    median = vals[n // 2] if n % 2 == 1 else (vals[n // 2 - 1] + vals[n // 2]) / 2
else:
    median = None
print(json.dumps({'median_remote_reserve_msat': median}))
" "$result"
