#!/bin/bash
# lightning node-invoice-amount-avg   (FEAT-2057)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [i for i in invoices if i.get('status') == 'paid']
if paid:
    amounts = [int(i.get('amount_received_msat', i.get('amount_msat', 0))) for i in paid]
    avg = sum(amounts) // len(amounts)
else:
    avg = 0
print(json.dumps({'avg_amount_msat': avg, 'paid_invoice_count': len(paid)}))
" "$result"
