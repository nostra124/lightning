#!/bin/bash
# lightning node-listpays-memo <payment_hash>   (FEAT-1851)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listpays-memo <payment_hash>"}'; exit 0; fi
phash="$1"
result=$(lightning-cli listpays "$phash" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
if not pays: print(json.dumps({'error': 'pay not found'})); sys.exit(0)
p = pays[0]
print(json.dumps({'payment_hash': p.get('payment_hash'), 'description': p.get('description'), 'label': p.get('label')}))
" "$result"
