#!/bin/bash
# lightning peer-oldest-connected   (FEAT-2388)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
connected = [p for p in peers if p.get('connected') is True]
if not connected:
    print(json.dumps({'error': 'no connected peers'}))
    sys.exit(0)
# Return first connected peer (CLN returns in connection order; oldest first)
oldest = connected[0]
print(json.dumps({'peer_id': oldest.get('id', ''), 'connected': True}))
" "$result"
