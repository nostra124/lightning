#!/bin/bash
# lightning invoice-list [--limit N] [--status pending|paid|expired]   (FEAT-263)
#
# Lists invoices from lightning-cli listinvoices.
# Returns [{label, bolt11, amount_msat, status, paid_at, description}].

set -e
limit=50; status_filter=""
while [ $# -gt 0 ]; do
    case "$1" in
        --limit)  limit="$2";  shift 2 ;;
        --status) status_filter="$2"; shift 2 ;;
        *) exit 2 ;;
    esac
done
case "$limit" in ''|*[!0-9]*) limit=50 ;; esac
[ "$limit" -gt 500 ] && limit=500

command -v lightning-cli >/dev/null || { echo '[]'; exit 0; }

raw=$(lightning-cli \
    --lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
    --network="${LIGHTNING_NETWORK:-bitcoin}" \
    listinvoices 2>/dev/null) || { echo '[]'; exit 0; }

python3 - "$raw" "$limit" "$status_filter" <<'EOF'
import sys, json

raw = sys.argv[1]
limit = int(sys.argv[2])
status_filter = sys.argv[3].lower()

try:
    data = json.loads(raw)
except Exception:
    print("[]"); sys.exit(0)

invoices = data.get("invoices", [])
out = []
for inv in invoices:
    status = inv.get("status", "")
    if status_filter and status != status_filter:
        continue
    amount_msat = inv.get("amount_msat", 0)
    if isinstance(amount_msat, str):
        amount_msat = int(amount_msat.rstrip("msat") or 0)
    out.append({
        "label":        inv.get("label", ""),
        "bolt11":       inv.get("bolt11", ""),
        "amount_msat":  amount_msat,
        "amount_sat":   amount_msat // 1000,
        "status":       status,
        "description":  inv.get("description", ""),
        "paid_at":      inv.get("paid_at"),
        "expires_at":   inv.get("expires_at"),
    })
    if len(out) >= limit:
        break

print(json.dumps(out))
EOF
