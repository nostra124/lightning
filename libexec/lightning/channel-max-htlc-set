#!/bin/bash
# lightning channel-max-htlc-set <channel_id> <max_msat>   (FEAT-377)
set -e
if [ $# -lt 2 ]; then
    echo '{"error":"usage: channel-max-htlc-set <channel_id> <max_msat>"}'
    exit 0
fi
channel_id="$1"
max_msat="$2"
result=$(lightning-cli setchannel "$channel_id" htlcmax="${max_msat}msat" 2>/dev/null) || {
    echo '{"error":"lightning-cli not found"}'
    exit 0
}
echo '{"ok":true}'
