#!/bin/bash
# lightning node-pay-failed-count-7d   (FEAT-2634)
result=$(lightning-cli listpays status=failed 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
cutoff = time.time() - 7 * 86400
count = 0
for p in pays:
    ct = p.get('created_at', 0)
    if ct >= cutoff:
        count += 1
print(json.dumps({'failed_pay_count_7d': count}))
" "$result"
