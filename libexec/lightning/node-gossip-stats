#!/bin/bash
# lightning node-gossip-stats   (FEAT-744)
result=$(lightning-cli listnodes 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
result2=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
nodes = json.loads(sys.argv[1]).get('nodes', [])
channels = json.loads(sys.argv[2]).get('channels', [])
print(json.dumps({'node_count': len(nodes), 'channel_count': len(channels)}))
" "$result" "$result2"
