#!/bin/bash
# lightning node-gossip-stats   (FEAT-451)
if ! result=$(lightning-cli listchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
active = sum(1 for c in channels if c.get('active', False))
print(json.dumps({'total_channels': len(channels), 'active': active,
    'inactive': len(channels) - active}, separators=(',', ':')))
" "$result"
