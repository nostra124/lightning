#!/bin/bash
# lightning wallet-backup-path <wallet_name>   (FEAT-1148)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-backup-path <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
echo "{\"wallet\":\"$wname\",\"db_path\":\"$db\"}"
