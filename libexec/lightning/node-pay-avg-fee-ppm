#!/bin/bash
# lightning node-pay-avg-fee-ppm   (FEAT-1589)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete' and p.get('amount_msat') and p.get('amount_sent_msat')]
if not pays:
    print(json.dumps({'count': 0, 'avg_fee_ppm': 0}))
    sys.exit(0)
fees = [(p['amount_sent_msat'] - p['amount_msat']) * 1000000 / p['amount_msat'] for p in pays]
print(json.dumps({'count': len(pays), 'avg_fee_ppm': round(sum(fees) / len(fees), 2)}))
" "$result"
