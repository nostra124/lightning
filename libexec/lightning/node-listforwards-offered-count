#!/bin/bash
# lightning node-listforwards-offered-count   (FEAT-2721)
result=$(lightning-cli listforwards status=offered 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
print(json.dumps({'offered_forward_count': len(forwards)}))
" "$result"
