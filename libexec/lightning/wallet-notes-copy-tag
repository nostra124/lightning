#!/bin/bash
# lightning wallet-notes-copy-tag <wallet> <src_tag> <dst_tag>   (FEAT-1623)
if [ $# -lt 3 ]; then
    echo '{"error":"usage: wallet-notes-copy-tag <wallet> <src_tag> <dst_tag>"}'; exit 0
fi
wname="$1"; src_tag="$2"; dst_tag="$3"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE tag='$src_tag';" 2>/dev/null)
sqlite3 "$db" "UPDATE notes SET tag='$dst_tag' WHERE tag='$src_tag';" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"src_tag\":\"$src_tag\",\"dst_tag\":\"$dst_tag\",\"updated\":$count}"
