#!/bin/bash
# lightning node-routing-score   (FEAT-386)
set -e
result_channels=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
result_fwds=$(lightning-cli listforwards status=settled 2>/dev/null) || result_fwds='{"forwards":[]}'
python3 -c "
import sys, json
channels = json.loads(sys.argv[1]).get('channels', [])
fwds = json.loads(sys.argv[2]).get('forwards', [])
normal = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
total_cap = sum(c.get('total_msat', 0) for c in normal)
avg_ratio = (sum(c.get('to_us_msat', 0) for c in normal) / total_cap) if total_cap else 0
fee_total = sum(f.get('fee_msat', 0) for f in fwds)
peer_count = len(normal)
# Simple composite score 0-100
balance_score = 100 - int(abs(avg_ratio - 0.5) * 200)
capacity_score = min(100, peer_count * 10)
revenue_score = min(100, fee_total // 1000)
overall = (balance_score * 0.5 + capacity_score * 0.3 + revenue_score * 0.2)
print(json.dumps({
    'overall_score': round(overall, 1),
    'balance_score': balance_score,
    'capacity_score': capacity_score,
    'revenue_score': revenue_score,
    'active_channels': peer_count,
}, separators=(',', ':')))
" "$result_channels" "$result_fwds"
