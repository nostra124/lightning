#!/bin/bash
# lightning node-invoice-bolt12-count   (FEAT-2344)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
count = sum(1 for i in invoices if i.get('local_offer_id'))
print(json.dumps({'bolt12_invoice_count': count}))
" "$result"
