#!/bin/bash
# lightning wallet-address-latest <wallet_name>   (FEAT-1008)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-address-latest <wallet_name>"}'
    exit 0
fi
wname="$1"
if ! result=$(lightning-cli newaddr 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
addr = data.get('bech32') or data.get('p2sh-segwit') or data.get('address', '')
print(json.dumps({'wallet': sys.argv[2], 'address': addr}))
" "$result" "$wname"
