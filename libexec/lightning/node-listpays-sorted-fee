#!/bin/bash
# lightning node-listpays-sorted-fee   (FEAT-1711)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('status') == 'complete' and p.get('amount_sent_msat') and p.get('amount_msat')]
pays = sorted(pays, key=lambda p: p['amount_sent_msat'] - p['amount_msat'], reverse=True)
top = [{'payment_hash': p.get('payment_hash'), 'fee_msat': p['amount_sent_msat'] - p['amount_msat']} for p in pays[:10]]
print(json.dumps({'count': len(pays), 'top_by_fee': top}))
" "$result"
