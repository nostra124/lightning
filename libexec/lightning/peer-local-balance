#!/bin/bash
# lightning peer-local-balance <peer_id>   (FEAT-1617)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-local-balance <peer_id>"}'; exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('to_us_msat', 0) for c in channels if c.get('state') == 'CHANNELD_NORMAL')
print(json.dumps({'peer_id': sys.argv[2], 'local_balance_msat': total}))
" "$result" "$peer_id"
