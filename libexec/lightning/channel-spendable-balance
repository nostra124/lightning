#!/bin/bash
# lightning channel-spendable-balance   (FEAT-1486)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(ch.get('spendable_msat', 0) for ch in data.get('channels', []) if ch.get('state') == 'CHANNELD_NORMAL')
print(json.dumps({'total_spendable_msat': total}))
" "$result"
