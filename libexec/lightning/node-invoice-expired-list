#!/bin/bash
# lightning node-invoice-expired-list   (FEAT-1684)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
expired = [i for i in data.get('invoices', []) if i.get('status') == 'expired']
print(json.dumps({'count': len(expired), 'invoices': [i.get('label') for i in expired]}))
" "$result"
