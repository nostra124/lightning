#!/bin/bash
# lightning peer-local-pct-max   (FEAT-2508)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
best_pct = None
best_peer = None
for c in channels:
    local = c.get('to_us_msat') or c.get('local_msat') or 0
    total = c.get('total_msat') or 0
    if total > 0:
        pct = round(local / total * 100, 2)
        if best_pct is None or pct > best_pct:
            best_pct = pct
            best_peer = c.get('peer_id')
print(json.dumps({'peer_id': best_peer, 'local_pct_max': best_pct}))
" "$result"
