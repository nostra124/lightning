#!/bin/bash
# lightning peer-total-forwarded <peer_id>   (FEAT-1527)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-total-forwarded <peer_id>"}'; exit 0; fi
peer_id="$1"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peer = sys.argv[2]
fwds = [f for f in data.get('forwards', []) if f.get('in_channel', '').startswith(peer) or f.get('out_channel', '').startswith(peer)]
total = sum(f.get('out_msat', 0) for f in fwds)
print(json.dumps({'peer_id': peer, 'forward_count': len(fwds), 'total_forwarded_msat': total}))
" "$result" "$peer_id"
