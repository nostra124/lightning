#!/bin/bash
# lightning channel-max-accepted-htlcs-total   (FEAT-1962)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('max_accepted_htlcs', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_max_accepted_htlcs': total}))
" "$result"
