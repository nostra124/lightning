#!/bin/bash
# lightning channel-funding-age   (FEAT-2050)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
now = int(time.time())
ages = []
for ch in channels:
    opened = ch.get('funding_txid', None)
    # Use opened_at timestamp if available
    ts = ch.get('opened_at', ch.get('created_at', None))
    if ts:
        ages.append({'channel_id': ch.get('channel_id', ch.get('short_channel_id', '')), 'funding_age_seconds': now - int(ts)})
    else:
        ages.append({'channel_id': ch.get('channel_id', ch.get('short_channel_id', '')), 'funding_age_seconds': None})
print(json.dumps({'channels': ages, 'count': len(ages)}))
" "$result"
