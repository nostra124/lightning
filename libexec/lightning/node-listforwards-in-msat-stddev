#!/bin/bash
# lightning node-listforwards-in-msat-stddev   (FEAT-2781)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
vals = [f.get('in_msat', 0) for f in fwds if 'in_msat' in f]
if len(vals) < 2:
    stddev = 0.0
else:
    mean = sum(vals) / len(vals)
    stddev = math.sqrt(sum((v - mean) ** 2 for v in vals) / len(vals))
print(json.dumps({'in_msat_stddev': stddev, 'count': len(vals)}))
" "$result"
