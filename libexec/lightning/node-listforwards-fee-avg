#!/bin/bash
# lightning node-listforwards-fee-avg   (FEAT-2291)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
settled = [f for f in forwards if f.get('status') == 'settled']
if settled:
    avg = sum(f.get('fee_msat', 0) for f in settled) / len(settled)
else:
    avg = 0
print(json.dumps({'fee_msat_avg': avg, 'settled_count': len(settled)}))
" "$result"
