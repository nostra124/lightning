#!/bin/bash
# lightning wallet-notes-bulk-remove-tag <wallet> <tag>   (FEAT-1703)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-notes-bulk-remove-tag <wallet> <tag>"}'; exit 0
fi
wname="$1"; tag="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE tag='$tag';" 2>/dev/null)
sqlite3 "$db" "UPDATE notes SET tag=NULL WHERE tag='$tag';" 2>/dev/null
echo "{\"wallet\":\"$wname\",\"tag\":\"$tag\",\"updated\":$count}"
