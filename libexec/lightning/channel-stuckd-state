#!/bin/bash
# lightning channel-stuckd-state   (FEAT-1716)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
stuck_states = {'CHANNELD_AWAITING_LOCKIN', 'DUALOPEND_AWAITING_LOCKIN'}
channels = [c for c in data.get('channels', []) if c.get('state') in stuck_states]
print(json.dumps({'count': len(channels), 'channels': [c.get('channel_id') for c in channels]}))
" "$result"
