#!/bin/bash
# lightning channel-htlc-value-stddev   (FEAT-3209)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
totals = []
for ch in channels:
    htlcs = ch.get('htlcs', [])
    total = sum(h.get('amount_msat', 0) for h in htlcs)
    totals.append(total)
if len(totals) < 2:
    print(json.dumps({'htlc_value_stddev_channel': 0}))
else:
    avg = sum(totals) / len(totals)
    stddev = math.sqrt(sum((v - avg) ** 2 for v in totals) / len(totals))
    print(json.dumps({'htlc_value_stddev_channel': stddev}))
" "$result"
