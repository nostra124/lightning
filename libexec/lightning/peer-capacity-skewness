#!/bin/bash
# lightning peer-capacity-skewness   (FEAT-2828)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c['total_msat'] for c in channels if 'total_msat' in c]
n = len(vals)
if n < 3:
    print(json.dumps({'capacity_skewness_peer': None, 'n': n}))
    sys.exit(0)
mean = sum(vals) / n
var = sum((v - mean)**2 for v in vals) / n
std = math.sqrt(var)
if std == 0:
    skew = 0.0
else:
    skew = (sum((v - mean)**3 for v in vals) / n) / (std**3)
print(json.dumps({'capacity_skewness_peer': skew, 'n': n}))
" "$result"
