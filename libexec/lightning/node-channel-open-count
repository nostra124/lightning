#!/bin/bash
# lightning node-channel-open-count   (FEAT-685)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
normal = [c for c in channels if c.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'total': len(channels), 'normal': len(normal)}))
" "$result"
