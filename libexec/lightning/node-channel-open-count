#!/bin/bash
# lightning node-channel-open-count   (FEAT-1309)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [ch for ch in data.get('channels', []) if ch.get('state') in ('CHANNELD_NORMAL', 'CHANNELD_AWAITING_LOCKIN')]
print(json.dumps({'count': len(channels)}))
" "$result"
