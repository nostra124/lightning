#!/bin/bash
# lightning invoice-max-amount   (FEAT-625)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = [c for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
max_recv = sum(c.get('receivable_msat', 0) for c in channels)
print(json.dumps({'max_receivable_msat': max_recv, 'max_receivable_sat': max_recv // 1000}))
" "$result"
