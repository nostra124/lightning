#!/bin/bash
# lightning node-listpays-by-bolt11 <bolt11>   (FEAT-1671)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: node-listpays-by-bolt11 <bolt11>"}'; exit 0
fi
bolt11="$1"
result=$(lightning-cli listpays "$bolt11" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'count': len(pays), 'pays': pays}))
" "$result"
