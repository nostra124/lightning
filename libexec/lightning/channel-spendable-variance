#!/bin/bash
# lightning channel-spendable-variance   (FEAT-2939)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = []
for ch in channels:
    v = ch.get('spendable_msat')
    if v is not None:
        try:
            vals.append(int(str(v).replace('msat','').strip()))
        except (ValueError, AttributeError):
            pass
if vals:
    mean = sum(vals) / len(vals)
    variance = sum((x - mean) ** 2 for x in vals) / len(vals)
else:
    variance = 0
print(json.dumps({'spendable_variance_msat': variance}))
" "\$result"
