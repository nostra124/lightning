#!/bin/bash
# lightning wallet-backup-create <wallet_name>   (FEAT-1258)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-backup-create <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
ts=$(date +%Y%m%d_%H%M%S)
dest="$root/$wname/backup_${ts}.db"
if cp "$db" "$dest" 2>/dev/null; then
    echo "{\"ok\":true,\"wallet\":\"$wname\",\"backup\":\"$dest\"}"
else
    echo '{"error":"backup failed"}'
fi
