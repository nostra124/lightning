#!/bin/bash
# lightning node-listchannels-normal   (FEAT-1414)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
normal = [{'channel_id': c.get('channel_id'), 'peer_id': c.get('peer_id')} for c in data.get('channels', []) if c.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'count': len(normal), 'channels': normal}))
" "$result"
