#!/bin/bash
# lightning channel-fee-earned-avg   (FEAT-2405)
fwd=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
ch=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
fwd_data = json.loads(sys.argv[1])
ch_data = json.loads(sys.argv[2])
forwards = fwd_data.get('forwards', [])
channels = ch_data.get('channels', [])
channel_count = len(channels)
total_fee = sum(f.get('fee_msat', 0) for f in forwards if f.get('status') == 'settled')
avg = total_fee / channel_count if channel_count else 0
print(json.dumps({'fee_earned_avg_msat': avg, 'channel_count': channel_count, 'total_fee_msat': total_fee}))
" "$fwd" "$ch"
