#!/bin/bash
# lightning node-listforwards-in-msat   (FEAT-1809)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
total_in = sum(f.get('in_msat', 0) for f in fwds)
print(json.dumps({'count': len(fwds), 'total_in_msat': total_in}))
" "$result"
