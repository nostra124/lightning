#!/bin/bash
# lightning channel-fee-base-max   (FEAT-2233)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
best = max(channels, key=lambda c: c.get('fee_base_msat', 0) if isinstance(c.get('fee_base_msat'), int) else 0)
print(json.dumps({'short_channel_id': best.get('short_channel_id', ''), 'fee_base_msat': best.get('fee_base_msat', 0)}))
" "$result"
