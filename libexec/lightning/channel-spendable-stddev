#!/bin/bash
# lightning channel-spendable-stddev   (FEAT-2830)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c['spendable_msat'] for c in channels if 'spendable_msat' in c]
n = len(vals)
if n < 2:
    print(json.dumps({'spendable_stddev_msat': None, 'n': n}))
    sys.exit(0)
mean = sum(vals) / n
stddev = math.sqrt(sum((v - mean)**2 for v in vals) / n)
print(json.dumps({'spendable_stddev_msat': stddev, 'n': n}))
" "$result"
