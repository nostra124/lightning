#!/bin/bash
# lightning node-listpays-by-destination <destination>   (FEAT-1361)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listpays-by-destination <destination>"}'; exit 0; fi
dest="$1"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = [p for p in data.get('pays', []) if p.get('destination') == sys.argv[2]]
print(json.dumps({'destination': sys.argv[2], 'count': len(pays), 'pays': pays}))
" "$result" "$dest"
