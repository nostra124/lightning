#!/bin/bash
# lightning node-listpays-by-destination <destination>   (FEAT-1947)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-listpays-by-destination <destination>"}'; exit 0; fi
destination="$1"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
dest = sys.argv[2]
pays = [p for p in data.get('pays', []) if p.get('destination') == dest]
print(json.dumps({'destination': dest, 'count': len(pays), 'pays': pays}))
" "$result" "$destination"
