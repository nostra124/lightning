#!/bin/bash
# lightning node-listforwards-failed   (FEAT-861)
result=$(lightning-cli listforwards status=failed 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
fwds = data.get('forwards', [])
print(json.dumps({'count': len(fwds), 'forwards': fwds}))
" "$result"
