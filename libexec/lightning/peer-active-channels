#!/bin/bash
# lightning peer-active-channels <peer_id>   (FEAT-1137)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-active-channels <peer_id>"}'
    exit 0
fi
peer_id="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pid = sys.argv[2]
active = [{'channel_id': ch.get('channel_id'), 'state': ch.get('state')} for ch in data.get('channels', []) if ch.get('peer_id') == pid and ch.get('state') == 'CHANNELD_NORMAL']
print(json.dumps({'peer_id': pid, 'active_count': len(active), 'channels': active}))
" "$result" "$peer_id"
