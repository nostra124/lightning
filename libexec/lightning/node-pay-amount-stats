#!/bin/bash
# lightning node-pay-amount-stats   (FEAT-2129)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
amounts = [p.get('amount_sent_msat', 0) for p in data.get('pays', []) if p.get('status') == 'complete' and 'amount_sent_msat' in p]
if not amounts:
    print(json.dumps({'min': None, 'max': None, 'avg': None, 'total': 0, 'count': 0}))
else:
    print(json.dumps({'min': min(amounts), 'max': max(amounts), 'avg': sum(amounts)//len(amounts), 'total': sum(amounts), 'count': len(amounts)}))
" "$result"
