#!/bin/bash
# lightning node-onchain-conf   (FEAT-1389)
result=$(lightning-cli listfunds 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
outputs = [o for o in data.get('outputs', []) if o.get('status') == 'confirmed']
total = sum(o.get('amount_msat', 0) for o in outputs)
print(json.dumps({'count': len(outputs), 'total_msat': total}))
" "$result"
