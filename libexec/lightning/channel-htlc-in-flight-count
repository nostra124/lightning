#!/bin/bash
# lightning channel-htlc-in-flight-count   (FEAT-2170)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
per_channel = []
for c in channels:
    htlcs = c.get('htlcs', [])
    count = len(htlcs)
    total += count
    if count > 0:
        per_channel.append({
            'peer_id': c.get('peer_id', ''),
            'channel_id': c.get('channel_id', ''),
            'in_flight': count,
        })
print(json.dumps({'total_in_flight': total, 'channels_with_htlcs': len(per_channel), 'details': per_channel}))
" "$result"
