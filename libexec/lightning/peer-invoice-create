#!/bin/bash
# lightning peer-invoice-create <amount_msat> <label>   (FEAT-887)
if [ $# -lt 2 ]; then echo '{"error":"usage: peer-invoice-create <amount_msat> <label>"}'; exit 0; fi
amount_msat="$1"; label="$2"
if ! result=$(lightning-cli invoice "$amount_msat" "$label" "peer-invoice" 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
echo "$result"
