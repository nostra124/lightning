#!/bin/bash
# lightning node-listforwards-fee-total-48h   (FEAT-2441)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
cutoff = time.time() - 48 * 3600
total = sum(
    f.get('fee_msat', 0)
    for f in data.get('forwards', [])
    if f.get('status') == 'settled' and f.get('received_time', 0) >= cutoff
)
print(json.dumps({'fee_total_msat_48h': total}))
" "$result"
