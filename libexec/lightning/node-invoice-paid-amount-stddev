#!/bin/bash
# lightning node-invoice-paid-amount-stddev   (FEAT-2806)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
vals = [i.get('amount_received_msat', 0) for i in invoices if i.get('status') == 'paid' and 'amount_received_msat' in i]
n = len(vals)
if n >= 2:
    mean = sum(vals) / n
    stddev = math.sqrt(sum((v - mean)**2 for v in vals) / n)
else:
    stddev = 0.0
print(json.dumps({'paid_amount_stddev_msat': round(stddev, 6), 'count': n}))
" "$result"
