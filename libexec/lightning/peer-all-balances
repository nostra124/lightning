#!/bin/bash
# lightning peer-all-balances   (FEAT-1897)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total_us = sum(c.get('to_us_msat', 0) for c in channels)
total = sum(c.get('total_msat', 0) for c in channels)
total_spendable = sum(c.get('spendable_msat', 0) for c in channels)
total_receivable = sum(c.get('receivable_msat', 0) for c in channels)
print(json.dumps({'channel_count': len(channels), 'total_local_msat': total_us, 'total_msat': total, 'total_spendable_msat': total_spendable, 'total_receivable_msat': total_receivable}))
" "$result"
