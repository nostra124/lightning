#!/bin/bash
# lightning peer-oldest-channel   (FEAT-2243)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
def block_height(scid):
    try:
        return int(scid.split('x')[0])
    except Exception:
        return 999999999
candidates = [c for c in channels if c.get('short_channel_id')]
if candidates:
    oldest = min(candidates, key=lambda c: block_height(c['short_channel_id']))
    print(json.dumps({'peer_id': oldest.get('peer_id'), 'short_channel_id': oldest.get('short_channel_id')}))
else:
    print(json.dumps({'peer_id': None, 'short_channel_id': None}))
" "$result"
