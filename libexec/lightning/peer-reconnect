#!/bin/bash
# lightning peer-reconnect <peer_id>   (FEAT-567)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: peer-reconnect <peer_id>"}'
    exit 0
fi
peer_id="$1"
lightning-cli disconnect "$peer_id" 2>/dev/null || true
result=$(lightning-cli connect "$peer_id" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
echo "$result"
