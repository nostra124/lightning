#!/bin/bash
# lightning node-graph-avg-capacity   (FEAT-1639)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
caps = [c.get('satoshis', 0) for c in channels]
if not caps:
    print(json.dumps({'count': 0, 'avg_capacity_sat': None}))
    sys.exit(0)
print(json.dumps({'count': len(caps), 'avg_capacity_sat': sum(caps) / len(caps)}))
" "$result"
