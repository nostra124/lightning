#!/bin/bash
# lightning wallet-seed-check <wallet_name>   (FEAT-1093)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-seed-check <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"wallet_not_found"}'
    exit 0
fi
has_seed=$(sqlite3 "$db" "SELECT COUNT(*) FROM meta WHERE key='seed';" 2>/dev/null || echo 0)
echo "{\"wallet\":\"$wname\",\"has_seed\":$([ \"$has_seed\" -gt 0 ] && echo true || echo false)}"
