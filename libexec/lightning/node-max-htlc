#!/bin/bash
# lightning node-max-htlc   (FEAT-701)
result=$(lightning-cli listconfigs 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
d = json.loads(sys.argv[1])
configs = d.get('configs', d)
print(json.dumps({'max-concurrent-htlcs': configs.get('max-concurrent-htlcs', {}).get('value_int') if isinstance(configs.get('max-concurrent-htlcs'), dict) else configs.get('max-concurrent-htlcs')}))
" "$result"
