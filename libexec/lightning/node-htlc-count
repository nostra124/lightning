#!/bin/bash
# lightning node-htlc-count   (FEAT-1059)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
total = sum(len(ch.get('htlcs', [])) for ch in data.get('channels', []))
print(json.dumps({'total_htlcs': total}))
" "$result"
