#!/bin/bash
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
balances = [c.get('spendable_msat', 0) for c in channels if 'spendable_msat' in c]
if len(balances) < 2:
    variance = 0.0
else:
    mean = sum(balances) / len(balances)
    variance = sum((x - mean) ** 2 for x in balances) / len(balances)
print(json.dumps({'spendable_balance_variance_msat': variance}))
" "$result"
