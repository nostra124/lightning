#!/bin/bash
# lightning node-listforwards-fee-ppm-avg   (FEAT-2361)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
settled = [f for f in forwards if f.get('status') == 'settled' and f.get('fee_msat') is not None and f.get('in_msat') is not None and f.get('in_msat', 0) > 0]
if not settled:
    print(json.dumps({'fee_ppm_avg': 0, 'settled_count': 0}))
    sys.exit(0)
ppms = [f['fee_msat'] * 1000000 / f['in_msat'] for f in settled]
avg = sum(ppms) / len(ppms)
print(json.dumps({'fee_ppm_avg': round(avg, 2), 'settled_count': len(settled)}))
" "$result"
