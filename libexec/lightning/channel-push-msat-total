#!/bin/bash
# lightning channel-push-msat-total   (FEAT-1702)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('push_msat', 0) for c in channels if c.get('push_msat'))
print(json.dumps({'channel_count': len(channels), 'total_push_msat': total}))
" "$result"
