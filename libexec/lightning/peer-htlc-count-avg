#!/bin/bash
# lightning peer-htlc-count-avg   (FEAT-2206)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
from collections import defaultdict
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels:
    print(json.dumps({'error': 'no channels'}))
    sys.exit(0)
peer_htlcs = defaultdict(int)
for c in channels:
    peer = c.get('peer_id', '')
    htlcs = c.get('htlcs', [])
    peer_htlcs[peer] += len(htlcs)
if not peer_htlcs:
    print(json.dumps({'error': 'no peers found'}))
    sys.exit(0)
avg = sum(peer_htlcs.values()) / len(peer_htlcs)
print(json.dumps({'avg_htlcs_per_peer': round(avg, 4), 'peer_count': len(peer_htlcs)}))
" "$result"
