#!/bin/bash
# lightning wallet-notes-flip <key1> <key2>   (FEAT-1873)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-flip <key1> <key2>"}'; exit 0; fi
key1="$1"
key2="$2"
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "
BEGIN;
UPDATE notes SET key='__tmp__' WHERE key='$key1';
UPDATE notes SET key='$key1' WHERE key='$key2';
UPDATE notes SET key='$key2' WHERE key='__tmp__';
COMMIT;" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"flipped\":true,\"key1\":\"$key1\",\"key2\":\"$key2\"}"
