#!/bin/bash
# lightning channel-opener-count   (FEAT-1852)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
local = sum(1 for c in channels if c.get('opener') == 'local')
remote = sum(1 for c in channels if c.get('opener') == 'remote')
print(json.dumps({'total': len(channels), 'local_opened': local, 'remote_opened': remote}))
" "$result"
