#!/bin/bash
# lightning channel-inflight-htlcs <channel_id>   (FEAT-1978)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-inflight-htlcs <channel_id>"}'; exit 0; fi
arg="$1"
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
cid = sys.argv[2]
channels = data.get('channels', [])
for ch in channels:
    if ch.get('channel_id') == cid or ch.get('short_channel_id') == cid:
        htlcs = ch.get('htlcs', [])
        print(json.dumps({'channel_id': cid, 'htlcs_count': len(htlcs), 'htlcs': htlcs}))
        sys.exit(0)
print(json.dumps({'error': 'channel not found'}))
" "$result" "$arg"
