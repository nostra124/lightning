#!/bin/bash
# lightning channel-spendable-rank   (FEAT-2088)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ranked = []
for ch in channels:
    spendable = ch.get('spendable_msat', 0)
    if isinstance(spendable, str):
        spendable = int(spendable.replace('msat',''))
    ranked.append({'channel_id': ch.get('channel_id',''), 'spendable_msat': spendable})
ranked.sort(key=lambda x: x['spendable_msat'], reverse=True)
for i, ch in enumerate(ranked):
    ch['rank'] = i + 1
print(json.dumps({'channels': ranked}))
" "$result"
