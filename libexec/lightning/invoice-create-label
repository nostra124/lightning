#!/bin/bash
# lightning invoice-create-label <label> <msat> <desc>   (FEAT-1075)
if [ $# -lt 3 ]; then
    echo '{"error":"usage: invoice-create-label <label> <msat> <desc>"}'
    exit 0
fi
label="$1"; msat="$2"; desc="$3"
result=$(lightning-cli invoice "$msat" "$label" "$desc" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'label': sys.argv[2], 'bolt11': data.get('bolt11'), 'payment_hash': data.get('payment_hash')}))
" "$result" "$label"
