#!/bin/bash
# lightning invoice-description-set <amount_msat> <label> <description>   (FEAT-537)
if [ $# -lt 3 ]; then
    echo '{"error":"usage: invoice-description-set <amount_msat> <label> <description>"}'
    exit 0
fi
amount_msat="$1"; label="$2"; description="$3"
if ! result=$(lightning-cli invoice "$amount_msat" "$label" "$description" 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
echo "$result"
