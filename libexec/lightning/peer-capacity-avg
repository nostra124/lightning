#!/bin/bash
# lightning peer-capacity-avg   (FEAT-1867)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels: print(json.dumps({'avg_capacity_msat': 0, 'count': 0})); sys.exit(0)
total = sum(c.get('total_msat', 0) for c in channels)
avg = total // len(channels)
print(json.dumps({'avg_capacity_msat': avg, 'count': len(channels)}))
" "$result"
