#!/bin/bash
# lightning peer-fee-earned-avg   (FEAT-2753)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
by_peer = {}
for c in channels:
    pid = c.get('peer_id', '')
    fee = c.get('fee_earned_msat', 0)
    by_peer.setdefault(pid, []).append(fee)
if by_peer:
    peer_totals = [sum(v) for v in by_peer.values()]
    avg = sum(peer_totals) / len(peer_totals)
else:
    avg = 0
print(json.dumps({'fee_earned_avg_msat': avg}))
" "$result"
