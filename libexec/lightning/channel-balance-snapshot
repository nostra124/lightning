#!/bin/bash
# lightning channel-balance-snapshot   (FEAT-940)
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
chs = data.get('channels', [])
snapshot = [{'channel_id': c.get('channel_id'), 'to_us_msat': c.get('to_us_msat'), 'total_msat': c.get('total_msat')} for c in chs]
print(json.dumps({'timestamp': int(time.time()), 'channels': snapshot}))
" "$result"
