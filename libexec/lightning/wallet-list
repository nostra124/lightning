#!/bin/bash
# lightning wallet-list   (FEAT-507)
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
if [ ! -d "$root" ]; then
    echo '[]'
    exit 0
fi
python3 -c "
import os, json, sys
root = sys.argv[1]
wallets = [d for d in os.listdir(root) if os.path.isdir(os.path.join(root, d))]
print(json.dumps(wallets, separators=(',', ':')))
" "$root"
