#!/bin/bash
# lightning wallet-import-seed <wallet_name> <seed>   (FEAT-803)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-import-seed <wallet_name> <seed>"}'; exit 0; fi
wname="$1"; seed="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
hash=$(echo -n "$seed" | sha256sum | cut -d' ' -f1)
if sqlite3 "$db" "INSERT OR REPLACE INTO meta(key,value) VALUES('seed_hash','$hash')" 2>/dev/null; then
    echo "{\"ok\":true,\"wallet\":\"$wname\"}"
else
    echo '{"error":"import seed failed"}'
fi
