#!/bin/bash
# lightning node-listchannels-htlc-max   (FEAT-1824)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
if not channels: print(json.dumps({'count': 0, 'max_htlc_msat': 0})); sys.exit(0)
maxes = [c.get('htlc_maximum_msat', 0) for c in channels if c.get('htlc_maximum_msat')]
print(json.dumps({'count': len(channels), 'max_htlc_msat': max(maxes) if maxes else 0}))
" "$result"
