#!/bin/bash
# lightning wallet-notes-has-value <value>   (FEAT-1823)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-has-value <value>"}'; exit 0; fi
value="$1"
wname="${LIGHTNING_WALLET:-default}"
db="$HOME/.lightning/wallets/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE value='$value';" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"has_value\":$([ "$count" -gt 0 ] && echo true || echo false),\"count\":$count}"
