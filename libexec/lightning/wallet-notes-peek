#!/bin/bash
# lightning wallet-notes-peek <wallet> <key>   (FEAT-1688)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-notes-peek <wallet> <key>"}'; exit 0
fi
wname="$1"; key="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
row=$(sqlite3 "$db" "SELECT value,tag,pinned FROM notes WHERE key='$key';" 2>/dev/null)
if [ -z "$row" ]; then echo '{"error":"key not found"}'; exit 0; fi
value=$(echo "$row" | cut -d'|' -f1)
tag=$(echo "$row" | cut -d'|' -f2)
pinned=$(echo "$row" | cut -d'|' -f3)
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"value\":\"$value\",\"tag\":\"$tag\",\"pinned\":$pinned}"
