#!/bin/bash
# lightning node-listpays-created-range <start> <end>   (FEAT-1861)
if [ $# -lt 2 ]; then echo '{"error":"usage: node-listpays-created-range <start> <end>"}'; exit 0; fi
start="$1"
end="$2"
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
s, e = int(sys.argv[2]), int(sys.argv[3])
pays = [p for p in data.get('pays', []) if s <= p.get('created_at', 0) <= e]
print(json.dumps({'count': len(pays), 'pays': pays}))
" "$result" "$start" "$end"
