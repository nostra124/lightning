#!/bin/bash
# lightning channel-fees-total   (FEAT-686)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
by_chan = {}
for f in data.get('forwards', []):
    if f.get('status') == 'settled':
        cid = f.get('in_channel', 'unknown')
        by_chan[cid] = by_chan.get(cid, 0) + f.get('fee_msat', 0)
print(json.dumps({'by_channel': by_chan}))
" "$result"
