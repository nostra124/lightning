#!/bin/bash
# lightning node-invoice-pending-count   (FEAT-1581)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pending = [i for i in data.get('invoices', []) if i.get('status') == 'unpaid']
print(json.dumps({'count': len(pending)}))
" "$result"
