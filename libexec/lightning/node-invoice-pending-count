#!/bin/bash
# lightning node-invoice-pending-count   (FEAT-811)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
pending = [i for i in invoices if i.get('status') == 'unpaid']
print(json.dumps({'pending': len(pending), 'total': len(invoices)}))
" "$result"
