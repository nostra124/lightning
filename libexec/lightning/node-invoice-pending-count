#!/bin/bash
# lightning node-invoice-pending-count   (FEAT-457)
if ! result=$(lightning-cli listinvoices 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
invs = json.loads(sys.argv[1]).get('invoices', [])
unpaid = [i for i in invs if i.get('status') == 'unpaid']
paid = [i for i in invs if i.get('status') == 'paid']
print(json.dumps({'total': len(invs), 'unpaid': len(unpaid), 'paid': len(paid)}, separators=(',', ':')))
" "$result"
