#!/bin/bash
# lightning node-splice-count   (FEAT-779)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
splicing = [c for c in channels if c.get('state') in ['CHANNELD_AWAITING_SPLICE', 'SPLICE']]
print(json.dumps({'splicing': len(splicing), 'total': len(channels)}))
" "$result"
