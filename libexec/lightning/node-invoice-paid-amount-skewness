#!/bin/bash
# lightning node-invoice-paid-amount-skewness   (FEAT-2816)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
vals = [i['amount_received_msat'] for i in invoices if i.get('status') == 'paid' and 'amount_received_msat' in i]
if len(vals) < 3:
    print(json.dumps({'paid_amount_skewness': None, 'count': len(vals)}))
    sys.exit(0)
n = len(vals)
mean = sum(vals) / n
var = sum((x - mean)**2 for x in vals) / n
std = var**0.5
if std == 0:
    print(json.dumps({'paid_amount_skewness': None, 'count': n}))
    sys.exit(0)
skew = (sum(((x - mean)/std)**3 for x in vals) / n)
print(json.dumps({'paid_amount_skewness': skew, 'count': n}))
" "$result"
