#!/bin/bash
# lightning channel-close-unilateral <channel_id>   (FEAT-690)
if [ $# -lt 1 ]; then echo '{"error":"usage: channel-close-unilateral <channel_id>"}'; exit 0; fi
channel_id="$1"
result=$(lightning-cli close "$channel_id" unilateraltimeout=1 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "import sys, json; d=json.loads(sys.argv[1]); print(json.dumps(d))" "$result"
