#!/bin/bash
# lightning node-listforwards-in-msat-sum   (FEAT-2621)
result=$(lightning-cli listforwards status=settled 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total = sum(f.get('in_msat', 0) for f in forwards)
print(json.dumps({'in_msat_sum': total}))
" "$result"
