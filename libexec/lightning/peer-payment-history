#!/bin/bash
# lightning peer-payment-history <node_id>   (FEAT-717)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-payment-history <node_id>"}'; exit 0; fi
node_id="$1"
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nid = sys.argv[2]
related = [f for f in data.get('forwards', []) if f.get('in_channel', '').startswith(nid[:10]) or f.get('out_channel', '').startswith(nid[:10])]
print(json.dumps({'node_id': nid, 'forwards': related[:50]}))
" "$result" "$node_id"
