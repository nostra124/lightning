#!/bin/bash
# lightning wallet-notes-has-tag <wallet> <tag>   (FEAT-1503)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-has-tag <wallet> <tag>"}'; exit 0; fi
wname="$1"; tag="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
count=$(sqlite3 "$db" "SELECT COUNT(*) FROM notes WHERE tag='$tag';" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"tag\":\"$tag\",\"exists\":$([ "$count" -gt 0 ] && echo true || echo false)}"
