#!/bin/bash
# lightning channel-receivable-pct   (FEAT-2085)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
out = []
for ch in channels:
    cap = ch.get('total_msat', 0)
    if isinstance(cap, str):
        cap = int(cap.replace('msat',''))
    recv = ch.get('receivable_msat', 0)
    if isinstance(recv, str):
        recv = int(recv.replace('msat',''))
    pct = round(recv / cap * 100, 2) if cap > 0 else 0
    out.append({'channel_id': ch.get('channel_id',''), 'receivable_pct': pct})
print(json.dumps({'channels': out}))
" "$result"
