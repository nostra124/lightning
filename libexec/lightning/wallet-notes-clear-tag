#!/bin/bash
# lightning wallet-notes-clear-tag <wallet> <tag>   (FEAT-1498)
if [ $# -lt 2 ]; then echo '{"error":"usage: wallet-notes-clear-tag <wallet> <tag>"}'; exit 0; fi
wname="$1"; tag="$2"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "UPDATE notes SET tag=NULL WHERE tag='$tag';" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"tag\":\"$tag\",\"cleared\":true}"
