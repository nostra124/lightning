#!/bin/bash
# lightning node-graph-active-channels   (FEAT-1514)
result=$(lightning-cli listchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
active = [c for c in channels if c.get('active')]
print(json.dumps({'active_count': len(active), 'total': len(channels)}))
" "$result"
