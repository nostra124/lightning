#!/bin/bash
# lightning node-graph-peer-aliases   (FEAT-1834)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = data.get('peers', [])
aliases = [{'id': p.get('id'), 'alias': None} for p in peers]
print(json.dumps({'count': len(aliases), 'peers': aliases}))
" "$result"
