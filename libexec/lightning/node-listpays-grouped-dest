#!/bin/bash
# lightning node-listpays-grouped-dest   (FEAT-1891)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
grouped = {}
for p in pays:
    d = p.get('destination', 'unknown')
    grouped[d] = grouped.get(d, 0) + 1
print(json.dumps({'destinations': len(grouped), 'total_pays': len(pays)}))
" "$result"
