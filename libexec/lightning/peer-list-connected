#!/bin/bash
# lightning peer-list-connected   (FEAT-607)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
connected = [{'id': p.get('id'), 'connected': p.get('connected')} for p in data.get('peers', []) if p.get('connected')]
print(json.dumps(connected))
" "$result"
