#!/bin/bash
# lightning peer-list-connected   (FEAT-1337)
result=$(lightning-cli listpeers 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
peers = [{'id': p.get('id')} for p in data.get('peers', []) if p.get('connected')]
print(json.dumps({'count': len(peers), 'peers': peers}))
" "$result"
