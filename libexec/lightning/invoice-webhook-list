#!/bin/bash
# lightning invoice-webhook-list   (FEAT-560)
if ! result=$(lightning-cli listinvoices 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
paid = [{'label': i.get('label'), 'payment_hash': i.get('payment_hash'), 'paid_at': i.get('paid_at')} for i in invoices if i.get('status') == 'paid']
print(json.dumps({'paid_invoices': paid, 'count': len(paid)}))
" "$result"
