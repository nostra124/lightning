#!/bin/bash
# lightning peer-remote-reserve-total   (FEAT-2503)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = sum(c.get('their_reserve_msat', 0) for c in channels if c.get('their_reserve_msat') is not None)
print(json.dumps({'remote_reserve_total_msat': total}))
" "$result"
