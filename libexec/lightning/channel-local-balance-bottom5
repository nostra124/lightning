#!/bin/bash
# lightning channel-local-balance-bottom5   (FEAT-2615)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
entries = []
for ch in channels:
    to_us = ch.get('to_us_msat', 0) or 0
    entries.append({
        'channel_id': ch.get('short_channel_id') or ch.get('channel_id'),
        'peer_id': ch.get('peer_id'),
        'to_us_msat': to_us
    })
entries.sort(key=lambda x: x['to_us_msat'])
print(json.dumps({'bottom5_channels_by_local': entries[:5]}))
" "$result"
