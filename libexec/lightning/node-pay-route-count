#!/bin/bash
# lightning node-pay-route-count   (FEAT-1441)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
count = sum(1 for p in pays if p.get('number_of_parts') is not None)
print(json.dumps({'pays_with_route_count': count, 'total_pays': len(pays)}))
" "$result"
