#!/bin/bash
# lightning node-pay-route-count   (FEAT-1201)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'total_pays': len(pays), 'complete': sum(1 for p in pays if p.get('status') == 'complete')}))
" "$result"
