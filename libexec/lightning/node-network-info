#!/bin/bash
# lightning node-network-info   (FEAT-470)
if ! result=$(lightning-cli getinfo 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
info = json.loads(sys.argv[1])
print(json.dumps({'network': info.get('network', ''), 'version': info.get('version', ''),
    'blockheight': info.get('blockheight', 0), 'id': info.get('id', ''),
    'num_peers': info.get('num_peers', 0)}, separators=(',', ':')))
" "$result"
