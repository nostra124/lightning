#!/bin/bash
# lightning channel-remote-reserve-total   (FEAT-2247)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
def to_msat(v):
    if isinstance(v, int):
        return v
    if isinstance(v, str) and v.endswith('msat'):
        return int(v[:-4])
    return 0
total = sum(to_msat(c.get('their_reserve_msat', 0)) for c in channels)
print(json.dumps({'remote_reserve_total_msat': total}))
" "$result"
