#!/bin/bash
# lightning node-gossip-map   (FEAT-569)
if ! result=$(lightning-cli listnodes 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
nodes = data.get('nodes', [])
summary = [{'nodeid': n.get('nodeid'), 'alias': n.get('alias', '')} for n in nodes[:50]]
print(json.dumps({'node_count': len(nodes), 'sample': summary}))
" "$result"
