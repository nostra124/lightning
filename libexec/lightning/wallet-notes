#!/bin/bash
# lightning wallet-notes <wallet_name>   (FEAT-528)
if [ $# -lt 1 ]; then
    echo '{"error":"usage: wallet-notes <wallet_name>"}'
    exit 0
fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
notes_file="$root/$wname/notes.txt"
if [ -f "$notes_file" ]; then
    notes=$(cat "$notes_file")
    python3 -c "import sys, json; print(json.dumps({'wallet': sys.argv[1], 'notes': sys.argv[2]}))" "$wname" "$notes"
else
    echo "{\"wallet\":\"$wname\",\"notes\":null}"
fi
