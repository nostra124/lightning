#!/bin/bash
# lightning node-pay-volume-weekly   (FEAT-2306)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
now = time.time()
week = 7 * 86400
buckets = {0: 0, 1: 0, 2: 0, 3: 0}
for p in pays:
    if p.get('status') != 'complete':
        continue
    age = now - p.get('created_at', 0)
    idx = int(age // week)
    if idx in buckets:
        buckets[idx] += p.get('amount_sent_msat', 0)
weeks = [{'week_ago': k, 'volume_msat': v} for k, v in sorted(buckets.items())]
print(json.dumps({'weekly_pay_volume': weeks}))
" "$result"
