#!/bin/bash
# lightning channel-local-pct-avg   (FEAT-2285)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
ratios = []
for c in channels:
    local = c.get('local_msat', 0)
    remote = c.get('remote_msat', 0)
    total = local + remote
    if total > 0:
        ratios.append(local / total)
avg = sum(ratios) / len(ratios) if ratios else None
print(json.dumps({'local_pct_avg': round(avg * 100, 4) if avg is not None else None}))
" "$result"
