#!/bin/bash
# lightning wallet-notes-set-tag <wallet> <key> <tag>   (FEAT-1563)
if [ $# -lt 3 ]; then echo '{"error":"usage: wallet-notes-set-tag <wallet> <key> <tag>"}'; exit 0; fi
wname="$1"; key="$2"; tag="$3"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
sqlite3 "$db" "UPDATE notes SET tag='$tag' WHERE key='$key';" 2>/dev/null || { echo '{"error":"db error"}'; exit 0; }
echo "{\"wallet\":\"$wname\",\"key\":\"$key\",\"tag\":\"$tag\"}"
