#!/bin/bash
# lightning node-invoice-list-by-time <since_ts>   (FEAT-974)
if [ $# -lt 1 ]; then echo '{"error":"usage: node-invoice-list-by-time <since_ts>"}'; exit 0; fi
since_ts="$1"
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '[]'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); ts = int(sys.argv[2])
filtered = [i for i in data.get('invoices', []) if i.get('expires_at', 0) >= ts]
print(json.dumps(filtered))
" "$result" "$since_ts"
