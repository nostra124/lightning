#!/bin/bash
# lightning peer-fee-ppm-max   (FEAT-2248)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
candidates = [c for c in channels if 'fee_proportional_millionths' in c]
if candidates:
    best = max(candidates, key=lambda c: c['fee_proportional_millionths'])
    print(json.dumps({'peer_id': best.get('peer_id'), 'fee_ppm': best.get('fee_proportional_millionths')}))
else:
    print(json.dumps({'peer_id': None, 'fee_ppm': None}))
" "$result"
