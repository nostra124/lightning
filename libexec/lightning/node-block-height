#!/bin/bash
# lightning node-block-height   (FEAT-323)
set -e
result=$(lightning-cli getinfo 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
print(json.dumps({'blockheight': data.get('blockheight', 0)}, separators=(',', ':')))
" "$result"
