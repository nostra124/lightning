#!/bin/bash
# lightning node-invoice-unpaid-count-today   (FEAT-2614)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
now = time.time()
start_of_day = now - (now % 86400)
count = sum(
    1 for inv in invoices
    if inv.get('status') == 'unpaid'
    and (inv.get('created_at') or inv.get('pay_index') or 0) >= start_of_day
)
print(json.dumps({'unpaid_today_count': count}))
" "$result"
