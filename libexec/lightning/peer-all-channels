#!/bin/bash
# lightning peer-all-channels <peer_id>   (FEAT-947)
if [ $# -lt 1 ]; then echo '{"error":"usage: peer-all-channels <peer_id>"}'; exit 0; fi
peer_id="$1"
if ! result=$(lightning-cli listpeerchannels 2>/dev/null); then echo '{"error":"lightning-cli not found"}'; exit 0; fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1]); pid = sys.argv[2]
chs = [c for c in data.get('channels', []) if c.get('peer_id') == pid]
print(json.dumps({'peer_id': pid, 'count': len(chs), 'channels': chs}))
" "$result" "$peer_id"
