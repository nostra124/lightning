#!/bin/bash
# lightning api-account-invoice <address> <sat> [--ref <json>] [--terms <json>]
#                                                            (FEAT-225)
#
# Mint a commercial invoice: a fixed-amount BOLT-11 that carries a
# structured order/shipment reference + optional payment terms.  The
# reference is embedded recoverably in the BOLT-11 description (a
# `[ref:<base64url-json>]` tail) AND stored in commerce_invoices, so
# a webshop reconciles a settled payment back to the order by
# payment_hash.
#
# Reference (any subset): {order_id, delivery_note, shipment_id, memo}
# Terms (optional): {due_days, skonto:{within_days,discount_pct},
#                    late_fee:{after_days,pct}} — drive the *effective*
#                    amount computed at GET time (api-account-invoice-get).
#
#   {"bolt11":"...","payment_hash":"...","face_sat":<int>,
#    "effective_sat":<int>,"reference":{...},"terms":{...}}

set -e
[ $# -ge 2 ] || exit 1
address="$1"; sat="$2"; shift 2
ref_json=""; terms_json=""
while [ $# -gt 0 ]; do
	case "$1" in
		--ref)   ref_json="$2"; shift 2 ;;
		--terms) terms_json="$2"; shift 2 ;;
		*) exit 2 ;;
	esac
done

case "$address" in bc1*|tb1*|bcrt1*) ;; *) exit 2 ;; esac
case "$sat" in ''|*[!0-9]*) exit 2 ;; esac
[ "$sat" -gt 0 ] || { echo '{"error":"amount_must_be_positive"}'; exit 2; }

command -v jq >/dev/null || { echo '{"error":"jq not installed"}'; exit 127; }

# Validate JSON inputs early (empty = absent).
if [ -n "$ref_json" ]; then
	jq -e . >/dev/null 2>&1 <<<"$ref_json" || { echo '{"error":"ref_not_json"}'; exit 2; }
fi
if [ -n "$terms_json" ]; then
	jq -e . >/dev/null 2>&1 <<<"$terms_json" || { echo '{"error":"terms_not_json"}'; exit 2; }
fi

WALLETS_ROOT="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning/wallet}"
ACTIVE_LINK="${LIGHTNING_WALLETS_ROOT:-$HOME/.lightning}/active"
wname="default"; [ -f "$ACTIVE_LINK" ] && wname=$(cat "$ACTIVE_LINK")
db="$WALLETS_ROOT/$wname/state.db"
[ -f "$db" ] || { echo '{"error":"no active wallet"}'; exit 3; }

sql_quote() { printf "'%s'" "${1//\'/\'\'}"; }
name=$(sqlite3 "$db" "SELECT name FROM accounts WHERE address = $(sql_quote "$address");")
[ -n "$name" ] || { echo '{"error":"unknown account"}'; exit 4; }

now=$(date -u +%s)
sqlite3 "$db" "UPDATE accounts SET last_api_call_at = $now WHERE address = $(sql_quote "$address");" 2>/dev/null || true

# Build the BOLT-11 description: a human memo + the recoverable
# reference tail `[ref:<base64url-json>]`.  Convention documented in
# the FEAT-225 spec + the inline docs (FEAT-209).
memo="commercial invoice"
[ -n "$ref_json" ] && memo=$(jq -r '.memo // "commercial invoice"' <<<"$ref_json")
description="$memo"
if [ -n "$ref_json" ]; then
	ref_b64=$(jq -c . <<<"$ref_json" | base64 | tr '+/' '-_' | tr -d '=\n')
	description="$memo [ref:$ref_b64]"
fi

command -v lightning-cli >/dev/null || { echo '{"error":"lightning-cli not installed"}'; exit 127; }
label="comm-${address:0:12}-$(date +%s%N)"
inv_json=$(lightning-cli \
	--lightning-dir="${LIGHTNING_DIR:-$HOME/.lightning}" \
	--network="${LIGHTNING_NETWORK:-bitcoin}" \
	invoice "$(( sat * 1000 ))msat" "$label" "$description" 2>/dev/null) || {
		echo '{"error":"invoice_failed"}'; exit 5; }

bolt11=$(jq -r '.bolt11 // empty' <<<"$inv_json")
payment_hash=$(jq -r '.payment_hash // empty' <<<"$inv_json")
[ -n "$bolt11" ] && [ -n "$payment_hash" ] || { echo '{"error":"invoice_incomplete"}'; exit 5; }

# Persist the commercial invoice (reference + terms + issued_at).
sqlite3 "$db" "INSERT OR REPLACE INTO commerce_invoices(payment_hash, account, bolt11, face_sat, reference, terms, issued_at, state) \
	VALUES($(sql_quote "$payment_hash"), $(sql_quote "$name"), $(sql_quote "$bolt11"), $sat, \
	       $([ -n "$ref_json" ] && sql_quote "$ref_json" || echo NULL), \
	       $([ -n "$terms_json" ] && sql_quote "$terms_json" || echo NULL), \
	       $now, 'issued');" 2>/dev/null || true

# Also mirror into the FEAT-193 invoices table for ledger reconciliation.
sqlite3 "$db" "INSERT OR IGNORE INTO invoices(bolt11, payment_hash, account, amount_msat, expiry, message) \
	VALUES($(sql_quote "$bolt11"), $(sql_quote "$payment_hash"), $(sql_quote "$name"), $(( sat * 1000 )), '', $(sql_quote "$memo"));" 2>/dev/null || true

# Effective amount at issue time (elapsed = 0): the Skonto window
# applies immediately, so a terms-bearing invoice quotes the
# discounted price for "pay now".  Same helper logic as
# api-account-invoice-get.
effective_sat="$sat"
if [ -n "$terms_json" ]; then
	read -r sk_within sk_pct < <(jq -r '[(.skonto.within_days // -1), (.skonto.discount_pct // 0)] | @tsv' <<<"$terms_json")
	if [ "${sk_within:-(-1)}" != "-1" ] && [ "${sk_within:-0}" -ge 0 ] 2>/dev/null; then
		# elapsed 0 days <= within_days → discount applies.
		effective_sat=$(awk -v f="$sat" -v p="${sk_pct:-0}" 'BEGIN { printf "%d", f * (100 - p) / 100 }')
	fi
fi

jq -nc \
	--arg b11 "$bolt11" \
	--arg hash "$payment_hash" \
	--argjson face "$sat" \
	--argjson eff "$effective_sat" \
	--argjson ref "${ref_json:-null}" \
	--argjson terms "${terms_json:-null}" \
	'{bolt11: $b11, payment_hash: $hash, face_sat: $face,
	  effective_sat: $eff, reference: $ref, terms: $terms}'
