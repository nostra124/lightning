#!/bin/bash
# lightning node-peer-channel-count   (FEAT-801)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
peer_counts = {}
for c in channels:
    pid = c.get('peer_id', 'unknown')
    peer_counts[pid] = peer_counts.get(pid, 0) + 1
print(json.dumps({'peer_channel_counts': peer_counts, 'total_peers': len(peer_counts)}))
" "$result"
