#!/bin/bash
# lightning channel-receivable-variance   (FEAT-2941)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
vals = [c.get('receivable_msat', 0) for c in channels if 'receivable_msat' in c]
if len(vals) < 2:
    variance = 0
else:
    mean = sum(vals) / len(vals)
    variance = sum((v - mean) ** 2 for v in vals) / len(vals)
print(json.dumps({'receivable_variance_msat': variance, 'channel_count': len(vals)}))
" "$result"
