#!/bin/bash
# lightning node-invoice-paid-last-30d   (FEAT-2404)
result=$(lightning-cli listinvoices 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, time
data = json.loads(sys.argv[1])
invoices = data.get('invoices', [])
cutoff = time.time() - 30 * 86400
paid = [i for i in invoices if i.get('status') == 'paid' and i.get('paid_at', 0) >= cutoff]
print(json.dumps({'invoice_paid_last_30d': len(paid)}))
" "$result"
