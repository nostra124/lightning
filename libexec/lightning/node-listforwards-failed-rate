#!/bin/bash
# lightning node-listforwards-failed-rate   (FEAT-2381)
result=$(lightning-cli listforwards 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
forwards = data.get('forwards', [])
total = len(forwards)
failed = sum(1 for f in forwards if f.get('status') in ('failed', 'local_failed'))
rate = round(failed / total, 6) if total > 0 else 0.0
print(json.dumps({'total_forwards': total, 'failed_forwards': failed, 'failed_rate': rate}))
" "$result"
