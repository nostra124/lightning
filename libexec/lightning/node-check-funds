#!/bin/bash
# lightning node-check-funds   (FEAT-491)
if ! result=$(lightning-cli listfunds 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
funds = json.loads(sys.argv[1])
outputs = funds.get('outputs', [])
channels = funds.get('channels', [])
onchain = sum(o.get('amount_msat', 0) for o in outputs if o.get('status') == 'confirmed')
offchain = sum(c.get('our_amount_msat', 0) for c in channels)
print(json.dumps({'onchain_msat': onchain, 'offchain_msat': offchain,
    'total_msat': onchain + offchain}, separators=(',', ':')))
" "$result"
