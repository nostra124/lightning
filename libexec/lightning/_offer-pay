#!/bin/bash
# lightning offer-pay — fetch + pay a BOLT-12 offer.
#
# Implements: BOLT-12 fetchinvoice + pay per FEAT-173.
#   share/doc/lightning/standards/bolts/12-offer-encoding.md
#
# Usage:
#   lightning offer-pay <bolt12-offer> [<sat>] [--message <text>]

set -e

[ $# -lt 1 ] && { echo "usage: lightning offer-pay <bolt12-offer> [<sat>] [--message <text>]" >&2; exit 1; }

command -v lightning-cli >/dev/null || {
	echo "lightning: lightning-cli not found — install Core Lightning" >&2; exit 127; }

LIGHTNING_DIR="${LIGHTNING_DIR:-$HOME/.lightning}"
LIGHTNING_NETWORK="${LIGHTNING_NETWORK:-bitcoin}"
cli() { lightning-cli --lightning-dir="$LIGHTNING_DIR" --network="$LIGHTNING_NETWORK" "$@"; }

offer="$1"; shift
amount_arg="null"
message=""

while [ $# -gt 0 ]; do
	case "$1" in
		--message) message="$2"; shift 2 ;;
		[0-9]*)    amount_arg="$(( $1 * 1000 ))msat"; shift ;;
		*) echo "lightning offer-pay: unknown arg '$1'" >&2; exit 1 ;;
	esac
done

# fetchinvoice: BOLT-12 spec calls this the "invoice request" round.
# Args: offer [amount_msat] [quantity] [recurrence_*] [timeout] [payer_note]
if [ -n "$message" ]; then
	fetched=$(cli fetchinvoice "$offer" "$amount_arg" null null null null null "$message")
else
	fetched=$(cli fetchinvoice "$offer" "$amount_arg")
fi

bolt12_invoice=$(jq -r .invoice <<<"$fetched")
result=$(cli pay "$bolt12_invoice")
status=$(jq -r .status <<<"$result")
hash=$(jq -r .payment_hash <<<"$result")

if [ "$status" = "complete" ]; then
	echo "ok"
	echo "payment_hash: $hash"
	exit 0
else
	echo "failed: $status" >&2
	exit 4
fi
