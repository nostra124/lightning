#!/bin/bash
# lightning wallet-notes-tag-list <wallet_name>   (FEAT-1223)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-tag-list <wallet_name>"}'; exit 0; fi
wname="$1"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet_not_found"}'; exit 0; fi
sqlite3 "$db" "SELECT DISTINCT tag FROM notes WHERE tag IS NOT NULL;" 2>/dev/null | python3 -c "
import sys, json
tags = [line.rstrip('\n') for line in sys.stdin if line.strip()]
print(json.dumps({'tags': tags, 'count': len(tags)}))
"
