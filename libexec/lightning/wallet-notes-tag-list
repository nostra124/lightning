#!/bin/bash
# lightning wallet-notes-tag-list <wallet>   (FEAT-1448)
if [ $# -lt 1 ]; then echo '{"error":"usage: wallet-notes-tag-list <wallet>"}'; exit 0; fi
wname="$1"
db="${WALLETS_ROOT:-$HOME/.wallets}/$wname/state.db"
if [ ! -f "$db" ]; then echo '{"error":"wallet not found"}'; exit 0; fi
tags=$(sqlite3 "$db" "SELECT DISTINCT tag FROM notes WHERE tag IS NOT NULL ORDER BY tag;" 2>/dev/null) || { echo '{"error":"db error"}'; exit 0; }
python3 -c "
import sys, json
tags = [t for t in sys.argv[1].split('\n') if t]
print(json.dumps({'wallet': sys.argv[2], 'tags': tags}))
" "$tags" "$wname"
