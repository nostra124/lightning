#!/bin/bash
# lightning node-balance-remote   (FEAT-1957)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
total = 0
for ch in channels:
    val = ch.get('to_them_msat', 0)
    if isinstance(val, str): val = int(val.replace('msat',''))
    total += val
print(json.dumps({'total_remote_msat': total, 'channel_count': len(channels)}))
" "$result"
