#!/bin/bash
# lightning node-pay-fee-kurtosis   (FEAT-2834)
result=$(lightning-cli listpays status=complete 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json, math
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
vals = []
for p in pays:
    sent = p.get('amount_sent_msat', 0)
    amt = p.get('amount_msat', 0)
    if sent and amt:
        vals.append(sent - amt)
if len(vals) < 4:
    print(json.dumps({'fee_kurtosis_pay': None, 'sample_count': len(vals)}))
    sys.exit(0)
n = len(vals)
mean = sum(vals) / n
m2 = sum((x - mean) ** 2 for x in vals) / n
m4 = sum((x - mean) ** 4 for x in vals) / n
kurtosis = (m4 / (m2 ** 2)) - 3 if m2 != 0 else None
print(json.dumps({'fee_kurtosis_pay': round(kurtosis, 4) if kurtosis is not None else None, 'sample_count': n}))
" "$result"
