#!/bin/bash
# lightning node-min-final-cltv   (FEAT-619)
if ! result=$(lightning-cli listconfigs 2>/dev/null); then
    echo '{"error":"lightning-cli not found"}'
    exit 0
fi
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
configs = data.get('configs', {})
min_final = configs.get('cltv-final', {}).get('value_int', None)
print(json.dumps({'min_final_cltv_expiry': min_final}))
" "$result"
