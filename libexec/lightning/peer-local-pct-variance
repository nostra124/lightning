#!/bin/bash
# lightning peer-local-pct-variance   (FEAT-2984)
result=$(lightning-cli listpeerchannels 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
channels = data.get('channels', [])
pcts = []
for ch in channels:
    total = ch.get('total_msat', 0)
    local = ch.get('to_us_msat', 0)
    if isinstance(total, str): total = int(total.replace('msat',''))
    if isinstance(local, str): local = int(local.replace('msat',''))
    if total > 0:
        pcts.append(local / total * 100)
if len(pcts) < 2:
    variance = 0.0
else:
    mean = sum(pcts) / len(pcts)
    variance = sum((p - mean) ** 2 for p in pcts) / len(pcts)
print(json.dumps({'local_pct_variance_peer': round(variance, 4), 'sample_size': len(pcts)}))
" "$result"
