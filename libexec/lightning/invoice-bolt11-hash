#!/bin/bash
# lightning invoice-bolt11-hash <label>   (FEAT-1355)
if [ $# -lt 1 ]; then echo '{"error":"usage: invoice-bolt11-hash <label>"}'; exit 0; fi
label="$1"
result=$(lightning-cli listinvoices "$label" 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
invs = data.get('invoices', [])
if invs:
    i = invs[0]
    print(json.dumps({'label': i.get('label'), 'payment_hash': i.get('payment_hash')}))
else:
    print(json.dumps({'error': 'invoice not found'}))
" "$result"
