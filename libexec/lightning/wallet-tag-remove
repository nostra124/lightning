#!/bin/bash
# lightning wallet-tag-remove <wallet_name> <tag>   (FEAT-578)
if [ $# -lt 2 ]; then
    echo '{"error":"usage: wallet-tag-remove <wallet_name> <tag>"}'
    exit 0
fi
wname="$1"; tag="$2"
root="${WALLETS_ROOT:-$HOME/.lightning/wallets}"
db="$root/$wname/state.db"
if [ ! -f "$db" ]; then
    echo '{"error":"database_not_found"}'
    exit 0
fi
sqlite3 "$db" "DELETE FROM tags WHERE tag='$tag';" 2>/dev/null || { echo '{"error":"sqlite3 not found"}'; exit 0; }
echo "{\"ok\":true,\"wallet\":\"$wname\",\"removed_tag\":\"$tag\"}"
