#!/bin/bash
# lightning node-pay-count-total   (FEAT-2149)
result=$(lightning-cli listpays 2>/dev/null) || { echo '{"error":"lightning-cli not found"}'; exit 0; }
python3 -c "
import sys, json
data = json.loads(sys.argv[1])
pays = data.get('pays', [])
print(json.dumps({'total': len(pays)}))
" "$result"
