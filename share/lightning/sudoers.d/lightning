    /usr/local/bin/lightning api-account-mandate-pull  tb1* *, \
    /usr/local/bin/lightning api-account-mandate-pull  bcrt1* *, \
    /usr/local/bin/lightning api-account-charge        bc1* *, \
    /usr/local/bin/lightning api-account-charge        tb1* *, \
    /usr/local/bin/lightning api-account-charge        bcrt1* *, \
    /usr/local/bin/lightning export tax-data           bc1* *, \
