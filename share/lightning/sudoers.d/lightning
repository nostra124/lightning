    /usr/local/bin/lightning api-account-invoice-get   tb1* *, \
    /usr/local/bin/lightning api-account-invoice-get   bcrt1* *, \
    /usr/local/bin/lightning api-account-standing-order bc1* *, \
    /usr/local/bin/lightning api-account-standing-order tb1* *, \
