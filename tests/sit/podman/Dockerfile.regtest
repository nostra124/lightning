# bitcoind regtest base image (FEAT-182).
#
# Used as the FROM base for Dockerfile.clightning. Stays
# minimal so the layer cache holds: bitcoind + a regtest
# config + an entrypoint that starts the daemon and exposes
# port 18443.
#
# NOTE: Debian no longer ships a `bitcoind` apt package, so we install the
# official Bitcoin Core release binaries (multi-arch: amd64 + arm64).

FROM debian:bookworm-slim

ARG BITCOIN_VERSION=27.0
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl bash \
    && rm -rf /var/lib/apt/lists/* \
    && set -eux; \
       arch="$(uname -m)"; \
       case "$arch" in \
         x86_64)        barch="x86_64-linux-gnu" ;; \
         aarch64|arm64) barch="aarch64-linux-gnu" ;; \
         *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
       esac; \
       curl -fsSL "https://bitcoincore.org/bin/bitcoin-core-${BITCOIN_VERSION}/bitcoin-${BITCOIN_VERSION}-${barch}.tar.gz" \
         -o /tmp/bitcoin.tar.gz; \
       tar -xzf /tmp/bitcoin.tar.gz -C /opt; \
       ln -s "/opt/bitcoin-${BITCOIN_VERSION}/bin/"* /usr/local/bin/; \
       rm /tmp/bitcoin.tar.gz; \
       bitcoind --version | head -1

RUN useradd --create-home --shell /bin/bash bitcoin
USER bitcoin
WORKDIR /home/bitcoin

RUN mkdir -p .bitcoin && cat > .bitcoin/bitcoin.conf <<EOF
regtest=1
server=1
txindex=1
rpcuser=test
rpcpassword=test
rpcallowip=127.0.0.1
fallbackfee=0.0001
[regtest]
rpcport=18443
EOF

EXPOSE 18443

CMD ["bitcoind", "-regtest"]
