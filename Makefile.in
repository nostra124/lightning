# Makefile template for per-script repos (FEAT-191 autoconf umbrella).
#
# Substituted at `./configure` time:
#   @PREFIX@        install prefix (default $HOME/.local non-root,
#                   /usr/local root)
#   @BINDIR@        $PREFIX/bin
#   @LIBEXECDIR@    $PREFIX/libexec
#   @SYSCONFDIR@    $PREFIX/etc
#   @DATADIR@       $PREFIX/share
#   @MANDIR@        $PREFIX/share/man
#   @PACKAGE@       the package name (account / cluster / dht / …)

SHELL = /bin/bash

PACKAGE   = @PACKAGE@
PREFIX    = @PREFIX@
BINDIR    = @BINDIR@
LIBEXECDIR = @LIBEXECDIR@
SYSCONFDIR = @SYSCONFDIR@
DATADIR   = @DATADIR@
MANDIR    = @MANDIR@

# Staging root for packaged/staged installs (GNU-standard `DESTDIR`).
# Empty for a normal install straight into $(PREFIX); rpk sets it to build
# into a staging tree it then versions. The Makefile itself NEVER calls
# stow (CLAUDE.md §7) — rpk owns the stow-based versioning layer.
DESTDIR ?=

# Scratch build dir (kcov coverage output lands under it).
BUILD_DIR = build/$(PACKAGE)

.PHONY: all install uninstall check check-unit check-vectors \
        check-sit check-thunderd-sit check-all lint test help package clean \
        install-skills-user uninstall-skills-user \
        thunderd thunderd-check thunderd-guard

all: install

help:
	@echo "Targets: install, uninstall, check, lint, check-sit, check-all,"
	@echo "         install-skills-user, uninstall-skills-user, package, clean"

# Install directly into $(DESTDIR)$(PREFIX). Per CLAUDE.md §7 the Makefile
# installs straight into $PREFIX and NEVER calls stow itself — rpk owns
# the stow-based versioning layer (it points $(PREFIX)/DESTDIR at its
# per-version tree). DESTDIR is honoured the GNU-standard way for staged
# / packaged installs.
install:
	@mkdir -p $(DESTDIR)$(BINDIR) $(DESTDIR)$(LIBEXECDIR)/$(PACKAGE) \
	          $(DESTDIR)$(SYSCONFDIR)/bash_completion.d \
	          $(DESTDIR)$(MANDIR)/man1 \
	          $(DESTDIR)$(DATADIR)/doc/$(PACKAGE) \
	          $(DESTDIR)$(DATADIR)/$(PACKAGE)
	@cp -a bin/* $(DESTDIR)$(BINDIR)/
	@ln -sf $(PACKAGE) $(DESTDIR)$(BINDIR)/$(PACKAGE).sh
	@if [ -d libexec/$(PACKAGE) ]; then \
		cp -a libexec/$(PACKAGE)/* $(DESTDIR)$(LIBEXECDIR)/$(PACKAGE)/; \
	fi
	@if [ -d etc/bash_completion.d ]; then \
		cp -a etc/bash_completion.d/* \
		      $(DESTDIR)$(SYSCONFDIR)/bash_completion.d/; \
	fi
	@if [ -d share/man/man1 ]; then \
		cp -a share/man/man1/* $(DESTDIR)$(MANDIR)/man1/; \
	fi
	@if [ -d share/doc/$(PACKAGE) ]; then \
		cp -a share/doc/$(PACKAGE)/* \
		      $(DESTDIR)$(DATADIR)/doc/$(PACKAGE)/; \
	fi
	# Per-package share/ payload (schema, git hooks, etc.).
	@if [ -d share/$(PACKAGE) ]; then \
		cp -a share/$(PACKAGE)/* $(DESTDIR)$(DATADIR)/$(PACKAGE)/; \
	fi
	# Agent skills — each skills/$(PACKAGE)-<name>/ ships its SKILL.md
	# to share/claude/skills/<name>/ and share/raven/skills/<name>/,
	# and its opencode.md to share/opencode/commands/<name>.md.
	# install-skills-user symlinks these into the user's per-agent dirs.
	@if ls -d skills/$(PACKAGE)-* >/dev/null 2>&1; then \
		for skill in skills/$(PACKAGE)-*; do \
			name=$$(basename $$skill); \
			if [ -f "$$skill/SKILL.md" ]; then \
				mkdir -p $(DESTDIR)$(DATADIR)/claude/skills/$$name; \
				install -m 644 "$$skill/SKILL.md" \
				    $(DESTDIR)$(DATADIR)/claude/skills/$$name/SKILL.md; \
				mkdir -p $(DESTDIR)$(DATADIR)/raven/skills/$$name; \
				install -m 644 "$$skill/SKILL.md" \
				    $(DESTDIR)$(DATADIR)/raven/skills/$$name/SKILL.md; \
			fi; \
			if [ -f "$$skill/opencode.md" ]; then \
				mkdir -p $(DESTDIR)$(DATADIR)/opencode/commands; \
				install -m 644 "$$skill/opencode.md" \
				    $(DESTDIR)$(DATADIR)/opencode/commands/$$name.md; \
			fi; \
		done; \
	fi
	# VERSION → $DATADIR/<pkg>/version : the runtime version string
	# the binary reads (FEAT-194). Falls back to ./VERSION in dev trees.
	@if [ -f VERSION ]; then \
		install -m 644 VERSION $(DESTDIR)$(DATADIR)/$(PACKAGE)/version; \
	fi
	# Normalise perms: a dev tree may carry restrictive owner/group-only
	# modes that `cp -a` would propagate. A system install must be
	# world-readable (and bin/libexec world-executable) for the three-user
	# model — clightning daemon / operator / www-data (CLAUDE.md §4).
	# a+rX = add read for all; add execute on directories and files that
	# are already executable (the scripts), never on plain data.
	@for p in $(DESTDIR)$(BINDIR)/$(PACKAGE) $(DESTDIR)$(BINDIR)/$(PACKAGE).sh \
	          $(DESTDIR)$(LIBEXECDIR)/$(PACKAGE) \
	          $(DESTDIR)$(DATADIR)/$(PACKAGE) \
	          $(DESTDIR)$(DATADIR)/doc/$(PACKAGE); do \
		[ -e "$$p" ] && chmod -R a+rX "$$p" || true; \
	done
	@if [ -d etc/bash_completion.d ]; then \
		for f in etc/bash_completion.d/*; do \
			chmod a+r "$(DESTDIR)$(SYSCONFDIR)/bash_completion.d/$$(basename $$f)" 2>/dev/null || true; \
		done; \
	fi
	@if [ -d share/man/man1 ]; then \
		for m in share/man/man1/*; do \
			chmod a+r "$(DESTDIR)$(MANDIR)/man1/$$(basename $$m)" 2>/dev/null || true; \
		done; \
	fi
	@echo "installed $(PACKAGE) into $(DESTDIR)$(PREFIX)"

# Symmetric removal of exactly what `install` placed (no stow).
uninstall:
	@for f in bin/*; do rm -f $(DESTDIR)$(BINDIR)/$$(basename $$f); done
	@rm -f $(DESTDIR)$(BINDIR)/$(PACKAGE).sh
	@rm -rf $(DESTDIR)$(LIBEXECDIR)/$(PACKAGE)
	@if [ -d etc/bash_completion.d ]; then \
		for f in etc/bash_completion.d/*; do \
			rm -f $(DESTDIR)$(SYSCONFDIR)/bash_completion.d/$$(basename $$f); \
		done; \
	fi
	@if [ -d share/man/man1 ]; then \
		for m in share/man/man1/*; do \
			rm -f $(DESTDIR)$(MANDIR)/man1/$$(basename $$m); \
		done; \
	fi
	@rm -rf $(DESTDIR)$(DATADIR)/doc/$(PACKAGE)
	@rm -rf $(DESTDIR)$(DATADIR)/$(PACKAGE)
	@if ls -d skills/$(PACKAGE)-* >/dev/null 2>&1; then \
		for skill in skills/$(PACKAGE)-*; do \
			name=$$(basename $$skill); \
			rm -rf $(DESTDIR)$(DATADIR)/claude/skills/$$name \
			       $(DESTDIR)$(DATADIR)/raven/skills/$$name; \
			rm -f $(DESTDIR)$(DATADIR)/opencode/commands/$$name.md; \
		done; \
	fi
	@echo "uninstalled $(PACKAGE) from $(DESTDIR)$(PREFIX)"

# Tests
check: check-unit check-vectors

check-unit:
	@if command -v bats >/dev/null 2>&1; then \
		bats tests/unit/*.bats; \
	else echo "bats not installed; skipping"; fi

# kcov coverage report. Wraps the bats suite in kcov to produce
# line coverage for bin/lightning + libexec/lightning/*. HTML
# lands at $(BUILD_DIR)/coverage/.
COVERAGE_DIR = $(BUILD_DIR)/coverage
coverage:
	@if ! command -v kcov >/dev/null 2>&1; then \
		echo "kcov not installed; build from source via:"; \
		echo "    git clone https://github.com/SimonKagstrom/kcov"; \
		echo "    cd kcov && mkdir build && cd build && cmake .. && make && sudo make install"; \
		exit 127; \
	fi
	@if ! command -v bats >/dev/null 2>&1; then \
		echo "bats not installed; sudo apt install bats"; exit 127; \
	fi
	@rm -rf $(COVERAGE_DIR)
	@mkdir -p $(COVERAGE_DIR)
	@kcov \
		--include-path=$(PWD)/bin/lightning,$(PWD)/libexec/lightning \
		--exclude-path=$(PWD)/tests \
		$(COVERAGE_DIR) \
		bats tests/unit/lightning.bats >/dev/null
	@echo "==> coverage report at $(COVERAGE_DIR)/index.html"
	@if command -v jq >/dev/null; then \
		jq -r '.percent_covered' $(COVERAGE_DIR)/bats/coverage.json \
			| awk '{ printf "==> line coverage: %.1f%%\n", $$1 }'; \
	fi

check-vectors:
	@if [ -d tests/vectors ] && command -v prove >/dev/null 2>&1; then \
		prove tests/vectors/*.t; \
	else echo "prove or tests/vectors/ not present; skipping"; fi

check-sit:
	@if ! command -v podman >/dev/null 2>&1; then \
		echo "podman not installed; soft-skipping SIT"; \
		exit 0; \
	fi
	@echo "==> building lightning-regtest"
	@podman build -t lightning-regtest -f tests/sit/podman/Dockerfile.regtest tests/sit
	@echo "==> building lightning-clightning (with the local working tree)"
	@podman build -t lightning-clightning -f tests/sit/podman/Dockerfile.clightning .
	@echo "==> running bats /suites/*.bats inside the container"
	@podman run --rm \
		-v $(PWD)/tests/sit/suites:/suites:ro \
		lightning-clightning \
		/bin/bash -lc 'bats /suites/*.bats'

# thunderd live-node integration: drives the Rust daemon end-to-end
# against a real regtest lightningd (health/getinfo, BOLT-11 recv,
# BOLT-12 offer, auth contract, and a channel payment). Soft-skips when
# podman is absent. This is the shadow-run prerequisite for the 2.0
# cutover (FEAT-326). See tests/sit/thunderd-live.sh.
check-thunderd-sit:
	@tests/sit/thunderd-live.sh

check-all: check check-sit check-thunderd-sit

lint:
	@if command -v shellcheck >/dev/null 2>&1; then \
		shellcheck -S warning bin/* $$(find libexec/$(PACKAGE) -type f 2>/dev/null); \
	else echo "shellcheck not installed; skipping"; fi

test: check

# thunderd — the Rust companion daemon (FEAT-300+). The `thunder/`
# workspace is deliberately standalone (no coupling to this bash
# package), so it builds/tests on its own. Kept out of the default
# `install` until the FEAT-301 binary-install wiring lands; build
# it explicitly with `make thunderd`.
thunderd:
	@cd thunder && cargo build --release

thunderd-check:
	@cd thunder && cargo fmt --check \
		&& cargo clippy --all-targets -- -D warnings \
		&& cargo test

# FEAT-302 — one-way carve-out boundary check.
thunderd-guard:
	@thunder/scripts/carve-out-guard.sh

# Skills installation (FEAT-192).
#
# Opt-in symlinks into the user's per-agent dirs, iff each dir
# already exists. Three agents, two layouts (per the rpk skill
# convention):
#   - Claude  : dir  ~/.claude/skills/<name>          -> share/claude/skills/<name>
#   - Raven   : dir  ~/.raven/workspace/skills/<name> -> share/raven/skills/<name>
#   - opencode: file ~/.config/opencode/commands/<name>.md
#                                                     -> share/opencode/commands/<name>.md
# Claude and Raven point at the SKILL.md dir; opencode points at
# the single .md command file. `ln -sf` makes this idempotent.
install-skills-user:
	@for skill in skills/$(PACKAGE)-*; do \
		[ -d "$$skill" ] || continue; \
		name=$$(basename $$skill); \
		if [ -d "$$HOME/.claude/skills" ] && [ -f "$$skill/SKILL.md" ]; then \
			ln -sf $(PREFIX)/share/claude/skills/$$name \
			    "$$HOME/.claude/skills/$$name"; \
		fi; \
		if [ -d "$$HOME/.raven/workspace/skills" ] && [ -f "$$skill/SKILL.md" ]; then \
			ln -sf $(PREFIX)/share/raven/skills/$$name \
			    "$$HOME/.raven/workspace/skills/$$name"; \
		fi; \
		if [ -d "$$HOME/.config/opencode/commands" ] && [ -f "$$skill/opencode.md" ]; then \
			ln -sf $(PREFIX)/share/opencode/commands/$$name.md \
			    "$$HOME/.config/opencode/commands/$$name.md"; \
		fi; \
	done

uninstall-skills-user:
	@for skill in skills/$(PACKAGE)-*; do \
		[ -d "$$skill" ] || continue; \
		name=$$(basename $$skill); \
		find $$HOME/.claude/skills $$HOME/.raven/workspace/skills \
		  -maxdepth 1 -name "$$name" -type l -delete 2>/dev/null || true; \
		find $$HOME/.config/opencode/commands \
		  -maxdepth 1 -name "$$name.md" -type l -delete 2>/dev/null || true; \
	done

# FEAT-196: drop the sudoers fragment that lets Apache (www-data) cross
# into the operator's account for the narrow `lightning api-*` verbs.
# Operator is read from $$LIGHTNING_OPERATOR (default $$USER). This target
# requires root and is explicitly NOT run by `make install`.
LIGHTNING_OPERATOR ?= $(USER)
install-apache-bridge:
	@if [ "$$(id -u)" != "0" ]; then \
		echo "install-apache-bridge: must be run as root"; exit 1; \
	fi
	@sed "s/alice/$(LIGHTNING_OPERATOR)/g" share/lightning/sudoers.d/lightning \
		> /etc/sudoers.d/lightning.tmp
	@visudo -c -f /etc/sudoers.d/lightning.tmp >/dev/null
	@chmod 0440 /etc/sudoers.d/lightning.tmp
	@mv /etc/sudoers.d/lightning.tmp /etc/sudoers.d/lightning
	@echo "install-apache-bridge: dropped /etc/sudoers.d/lightning"
	@echo "install-apache-bridge: add the Apache snippet to your vhost:"
	@echo "    cat /usr/share/lightning/apache/lnurlp.conf"

uninstall-apache-bridge:
	@if [ "$$(id -u)" != "0" ]; then \
		echo "uninstall-apache-bridge: must be run as root"; exit 1; \
	fi
	@rm -f /etc/sudoers.d/lightning
	@echo "uninstall-apache-bridge: removed /etc/sudoers.d/lightning"

# Versioning (FEAT-194)
#
# VERSION (project root) is the source of truth read by bin/lightning
# and installed to $DATADIR/<pkg>/version. .rpk/versions is the
# per-release SHA ledger appended below. To bump, see
# skills/version.md.
package:
	@if [ -z "$(VERSION)" ]; then \
		echo "Usage: make package VERSION=x.y.z"; exit 1; \
	fi
	@grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$$' <<< "$(VERSION)" || { \
		echo "Invalid semver: $(VERSION)"; exit 1; }
	@printf '%s\t%s\n' "$(VERSION)" "$$(git rev-parse HEAD)" \
		>> .rpk/versions
	@echo "$(VERSION)" > VERSION
	@git add VERSION .rpk/versions
	@git commit -m "package $(VERSION)"
	@git tag "v$(VERSION)"

# Per FEAT-191's invariant: clean never touches installed files.
clean:
	@rm -rf build/
