#!/bin/bash

has_binary() {
	command -v "$1" >/dev/null 2>&1 && return 0
	[ -x "/opt/homebrew/bin/$1" ] && return 0
	[ -x "/usr/local/bin/$1" ] && return 0
	[ -x "/opt/local/bin/$1" ] && return 0
	return 1
}

BIN="bash"
has_binary "$BIN" && exit 0

case "$(rpk platform)" in
	alpine)
		rpk action sudo apk add bash
		;;
	debian|ubuntu|pureos|linuxmint)
		rpk action sudo apt-get --yes install bash
		;;
	fedora|rhel|centos|rocky|almalinux)
		rpk action sudo dnf install -y bash
		;;
	arch|manjaro|endeavouros)
		rpk action sudo pacman -S --noconfirm bash
		;;
	opensuse|opensuse-leap|opensuse-tumbleweed|sles)
		rpk action sudo zypper install -y bash
		;;
	freebsd)
		rpk action sudo pkg install -y bash
		;;
	macos-ports)
		rpk action sudo /opt/local/bin/port install bash >/dev/null
		;;
	macos-brew)
		rpk action /opt/homebrew/bin/brew install bash >/dev/null
		;;
	*)
		rpk fatal "no packager for platform '$(rpk platform)' — install $BIN manually"
		;;
esac
